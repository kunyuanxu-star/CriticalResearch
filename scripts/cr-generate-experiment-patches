#!/usr/bin/env bash
# cr-generate-experiment-patches — Emit agent instructions for generating
# experiment obligations from claim-level paper patches.
# Prompt scaffolding, not a deterministic generator.
#
# Usage: cr-generate-experiment-patches <round_dir> <project_dir>

set -euo pipefail

ROUND_DIR="${1:-}"
PROJECT_DIR="${2:-}"

if [ -z "$ROUND_DIR" ] || [ -z "$PROJECT_DIR" ]; then
    echo "Usage: cr-generate-experiment-patches <round_dir> <project_dir>" >&2
    exit 2
fi

ROUND_NAME=$(basename "$ROUND_DIR")
PATCHES_DIR="$ROUND_DIR/patches"

echo "## Experiment Obligation Generation Task"
echo ""
echo "Generate experiment obligations for claim-level paper patches in round $ROUND_NAME."
echo ""
echo "### Claim-Level Patches"
echo ""

if [ -d "$PATCHES_DIR" ]; then
    for pf in "$PATCHES_DIR"/PP-*.yaml; do
        [ ! -f "$pf" ] && continue
        PP_ID=$(basename "$pf" .yaml)
        PATCH_TYPES=$(grep -A 20 '^patch_type:' "$pf" 2>/dev/null | grep -E '^\s+-' | sed 's/^\s*-\s*//' || echo "")

        # Check if this patch changes a claim.
        if echo "$PATCH_TYPES" | grep -qE 'weaken_claim|strengthen_claim|reframe_contribution|add_evaluation' 2>/dev/null; then
            HAS_EXP=$(grep -E '^\s+-\s+EXP-[0-9]{3}' "$pf" 2>/dev/null || echo "")
            echo "- **$PP_ID** (types: $(echo $PATCH_TYPES | tr '\n' ' '))"
            [ -n "$HAS_EXP" ] && echo "  Has experiment obligations: $HAS_EXP"
            [ -z "$HAS_EXP" ] && echo "  **Missing experiment obligation — needs generation**"
        fi
    done
fi

echo ""
echo "### Instructions"
echo ""
echo "For each claim-level patch without experiment obligations:"
echo ""
echo "1. Identify the claim being changed (linked_claim in patch)"
echo "2. Determine claim type: performance, isolation_semantics, fault_isolation, expressiveness, resource_control, compatibility"
echo "3. Create \`EXP-XXX.yaml\` in \`$ROUND_DIR/experiments/\` with:"
echo "   - target_claim: the claim this experiment validates"
echo "   - linked_patch_id: the patch that triggered this obligation"
echo "   - baseline: the strongest baseline system/approach"
echo "   - test_cases: specific test scenarios (include negative tests for isolation claims)"
echo "   - metric: primary evaluation metric"
echo "   - support_condition: what result supports the claim"
echo "   - refute_condition: what result refutes the claim"
echo "4. Add the EXP ID to the patch's experiment_obligations field"
echo ""
echo "### Schema"
echo "See \`schemas/experiment_obligation.schema.json\` for the full specification."
echo ""
echo "### Validation"
echo "After generation, run: \`cr-validate-experiments $ROUND_DIR\`"
