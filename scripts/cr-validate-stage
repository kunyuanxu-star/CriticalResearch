#!/usr/bin/env bash
# cr-validate-stage — Validate that a specific stage's required outputs exist and pass schema checks.
# Usage: cr-validate-stage <project_dir> <round_dir> <stage_name>
# Returns 0 if stage is complete, 2 if requirements not met.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

PROJECT_DIR="${1:-}"
ROUND_DIR="${2:-}"
STAGE="${3:-}"

if [ -z "$PROJECT_DIR" ] || [ -z "$ROUND_DIR" ] || [ -z "$STAGE" ]; then
    echo "Usage: cr-validate-stage <project_dir> <round_dir> <stage>" >&2
    exit 2
fi

STATE_FILE="$ROUND_DIR/workflow-state.yaml"
if [ ! -f "$STATE_FILE" ]; then
    fail "workflow-state.yaml not found in $ROUND_DIR"
    cr_exit_summary
fi

    # Check stage exists in workflow-state.yaml.
STAGE_STATUS=$(yq -r ".stages.$STAGE.status // \"unknown\"" "$STATE_FILE" 2>/dev/null || echo "unknown")
if [ "$STAGE_STATUS" = "unknown" ]; then
    fail "Stage '$STAGE' not found in workflow-state.yaml"
    cr_exit_summary
fi

# Check depends_on stages are complete.
echo "Stage: $STAGE (status: $STAGE_STATUS)"
DEPS=$(yq -r ".stages.$STAGE.depends_on // [] | .[]" "$STATE_FILE" 2>/dev/null || echo "")
for dep in $DEPS; do
    [ -z "$dep" ] && continue
    DEP_STATUS=$(yq -r ".stages.$dep.status // \"unknown\"" "$STATE_FILE" 2>/dev/null || echo "unknown")
    if [ "$DEP_STATUS" != "complete" ]; then
        fail "Dependency '$dep' is not complete (status: $DEP_STATUS)"
    else
        pass "Dependency '$dep' is complete"
    fi
done

ALL_PRESENT=true

# Check required inputs exist.
PM=$(yq -r '.mode // "deep"' "$ROUND_DIR/contract.yaml" 2>/dev/null || echo "deep")
INPUTS=$(yq -r ".stages.$STAGE.required_inputs // [] | .[]" "$STATE_FILE" 2>/dev/null || echo "")
for input in $INPUTS; do
    [ -z "$input" ] && continue
    case "$input" in
        writing/*|state/*|documents/*)
            if [ -f "$PROJECT_DIR/$input" ]; then
                pass "Input '$input' exists"
            elif [ "$PM" != "triage" ]; then
                fail "Input '$input' not found"
                ALL_PRESENT=false
            else
                warn "Input '$input' not found"
            fi
            ;;
        *)
            if [ -f "$ROUND_DIR/$input" ]; then
                pass "Input '$input' exists"
            elif [ -d "$ROUND_DIR/$input" ]; then
                pass "Input '$input/' exists"
            elif [ "$PM" != "triage" ]; then
                fail "Input '$input' not found"
                ALL_PRESENT=false
            else
                warn "Input '$input' not found"
            fi
            ;;
    esac
done

# Check required outputs exist.
REQ=$(yq -r ".stages.$STAGE.required_outputs // [] | .[]" "$STATE_FILE" 2>/dev/null || echo "")
for output in $REQ; do
    [ -z "$output" ] && continue
    case "$output" in
        *.yaml|*.md|*.json)
            if [ -f "$ROUND_DIR/$output" ]; then
                pass "Output '$output' exists"
            elif [ -f "$PROJECT_DIR/$output" ]; then
                pass "Output '$output' exists (project-level)"
            else
                fail "Output '$output' is missing"
                ALL_PRESENT=false
            fi
            ;;
        raw-sources)
            if [ -d "$ROUND_DIR/raw-sources" ] && [ -n "$(ls -A "$ROUND_DIR/raw-sources" 2>/dev/null)" ]; then
                pass "Output 'raw-sources/' exists and is non-empty"
            else
                fail "Output 'raw-sources/' is missing or empty"
                ALL_PRESENT=false
            fi
            ;;
        patches)
            if [ -d "$ROUND_DIR/patches" ]; then
                pass "Output 'patches/' exists"
            else
                fail "Output 'patches/' is missing"
                ALL_PRESENT=false
            fi
            ;;
        experiments)
            if [ -d "$ROUND_DIR/experiments" ]; then
                pass "Output 'experiments/' exists"
            else
                fail "Output 'experiments/' is missing"
                ALL_PRESENT=false
            fi
            ;;
        *)
            warn "Unknown output type '$output' — skipping"
            ;;
    esac
done

# Stage-specific semantic validators.
check_field_substantive() {
    local file="$1" field_path="$2" label="${3:-$field_path}"
    local val
    val=$(yq -r "$field_path // \"\"" "$file" 2>/dev/null || echo "")
    if [ -z "$val" ] || [ "$val" = "null" ] || [ "$val" = "TBD" ] || [ "$val" = "TODO" ] || [ "$val" = "test" ] || [ "$val" = "Test" ]; then
        fail "$label is empty or placeholder in $file"
        ALL_PRESENT=false
    else
        pass "$label: ${val:0:80}"
    fi
}

check_array_content() {
    local file="$1" query="$2" min="${3:-1}" label="${4:-items}"
    [ ! -f "$file" ] && { fail "$file not found"; ALL_PRESENT=false; return; }
    local count
    count=$(yq -r "$query | length // 0" "$file" 2>/dev/null || echo "0")
    if [ "${count:-0}" -lt "$min" ]; then
        fail "$label: $count found, need >= $min"
        ALL_PRESENT=false
    else
        pass "$label: $count"
    fi
}
# ── Generic output-content validation ────────────────────────────
# Check content quality of any known output files present in the round.
# Stage-agnostic: validates whatever files exist regardless of workflow.

# Determine document type from state.
DOCUMENT_TYPE=$(yq -r '.document_type // "paper"' "$STATE_FILE" 2>/dev/null || echo "paper")

CONTRACT="$ROUND_DIR/contract.yaml"
if [ -f "$CONTRACT" ]; then
    check_field_substantive "$CONTRACT" '.objective // ""' "Round objective"
fi

EVIDENCE="$ROUND_DIR/evidence-ledger.yaml"
if [ -f "$EVIDENCE" ]; then
    check_array_content "$EVIDENCE" '.evidence' 1 "Evidence items"
    WEAKENING=$(yq -r '[.evidence[] | select(.evidence_category == "weakening")] | length' "$EVIDENCE" 2>/dev/null || echo "0")
    if [ "$WEAKENING" -ge 1 ]; then
        pass "Weakening evidence items: $WEAKENING"
    else
        fail "At least one weakening evidence item required"
        ALL_PRESENT=false
    fi
fi

# ── Evidence proof enforcement (standard/deep modes) ────────────

# 1. Search-log.yaml — verify at least one query executed.
SEARCH_LOG="$ROUND_DIR/search-log.yaml"
if [ -f "$SEARCH_LOG" ]; then
    QUERY_COUNT=$(yq -r '.queries | length // 0' "$SEARCH_LOG" 2>/dev/null || echo "0")
    if [ "${QUERY_COUNT:-0}" -ge 1 ]; then
        pass "Search log: $QUERY_COUNT queries executed"
    else
        fail "Search log has no executed queries"
        ALL_PRESENT=false
    fi
fi

# 2. Raw-sources/ — verify non-empty and each source has metadata.
RAW_SOURCES="$ROUND_DIR/raw-sources"
if [ -d "$RAW_SOURCES" ] && [ -n "$(ls -A "$RAW_SOURCES" 2>/dev/null)" ]; then
    SOURCE_COUNT=0
    SOURCE_ISSUES=0
    for src_file in "$RAW_SOURCES"/*; do
        [ -f "$src_file" ] || continue
        SOURCE_COUNT=$((SOURCE_COUNT + 1))
        src_url=$(yq -r '.url // ""' "$src_file" 2>/dev/null || echo "")
        src_retrieved=$(yq -r '.retrieved_at // ""' "$src_file" 2>/dev/null || echo "")
        src_type=$(yq -r '.source_type // ""' "$src_file" 2>/dev/null || echo "")
        src_id=$(yq -r '.source_id // ""' "$src_file" 2>/dev/null || echo "")
        if [ -z "$src_url" ]; then
            fail "Source '$(basename "$src_file")' missing url"
            SOURCE_ISSUES=$((SOURCE_ISSUES + 1))
        fi
        if [ -z "$src_retrieved" ]; then
            fail "Source '$(basename "$src_file")' missing retrieved_at"
            SOURCE_ISSUES=$((SOURCE_ISSUES + 1))
        fi
        if [ -z "$src_type" ]; then
            fail "Source '$(basename "$src_file")' missing source_type"
            SOURCE_ISSUES=$((SOURCE_ISSUES + 1))
        fi
    done
    if [ "$SOURCE_ISSUES" -gt 0 ]; then
        ALL_PRESENT=false
    else
        pass "Raw sources: $SOURCE_COUNT files, all valid"
    fi
fi

# 3. Evidence ledger items must reference source IDs present in raw-sources/.
if [ -f "$EVIDENCE" ] && [ -d "$RAW_SOURCES" ]; then
    # Collect all source_ids from raw-sources.
    KNOWN_IDS=""
    for src_file in "$RAW_SOURCES"/*; do
        [ -f "$src_file" ] || continue
        sid=$(yq -r '.source_id // ""' "$src_file" 2>/dev/null || echo "")
        [ -n "$sid" ] && KNOWN_IDS="${KNOWN_IDS} ${sid}"
    done
    # Check evidence items reference known sources.
    EVID_COUNT=$(yq -r '.evidence | length // 0' "$EVIDENCE" 2>/dev/null || echo "0")
    if [ "${EVID_COUNT:-0}" -gt 0 ] && [ -n "$KNOWN_IDS" ]; then
        for i in $(seq 0 $((EVID_COUNT - 1))); do
            refs=$(yq -r ".evidence[$i].source_refs // [] | .[]" "$EVIDENCE" 2>/dev/null || echo "")
            for ref in $refs; do
                [ -z "$ref" ] && continue
                if ! echo " $KNOWN_IDS " | grep -q " $ref "; then
                    fail "Evidence item $i references unknown source '$ref'"
                    ALL_PRESENT=false
                fi
            done
        done
    fi
fi
CRITIQUE="$ROUND_DIR/critique-ledger.yaml"
if [ -f "$CRITIQUE" ]; then
    check_array_content "$CRITIQUE" '.critiques' 1 "Critiques"
    CRITIQUE_COUNT=$(yq -r '.critiques | length // 0' "$CRITIQUE" 2>/dev/null || echo "0")
    for i in $(seq 0 $((CRITIQUE_COUNT - 1))); do
        severity=$(yq -r ".critiques[$i].severity // \"\"" "$CRITIQUE" 2>/dev/null || echo "")
        evidence_refs=$(yq -r ".critiques[$i].evidence_refs | length // 0" "$CRITIQUE" 2>/dev/null || echo "0")
        if [ "$severity" = "medium" ] || [ "$severity" = "high" ] || [ "$severity" = "fatal" ]; then
            if [ "$evidence_refs" -eq 0 ]; then
                fail "Medium+ critique $i missing evidence_refs"
                ALL_PRESENT=false
            fi
        fi
    done
fi

REVISION="$ROUND_DIR/revision-plan.yaml"
if [ -f "$REVISION" ]; then
    check_array_content "$REVISION" '.revisions' 1 "Revisions"
fi

WRITING="$ROUND_DIR/writing-plan.yaml"
if [ -f "$WRITING" ]; then
    check_array_content "$WRITING" '.high_level.argument_order' 1 "Argument order"
fi

WRITING_DIFF="$ROUND_DIR/writing-diff.yaml"
if [ -f "$WRITING_DIFF" ]; then
    CHANGES=$(yq -r '.changes | length // 0' "$WRITING_DIFF" 2>/dev/null || echo "0")
    pass "Writing diff changes: $CHANGES"
fi

KNOWLEDGE="$ROUND_DIR/knowledge-delta.yaml"
if [ -f "$KNOWLEDGE" ]; then
    check_array_content "$KNOWLEDGE" '.updates' 1 "Knowledge updates"
fi

NEXT_TARGETS="$ROUND_DIR/next-round-targets.yaml"
if [ -f "$NEXT_TARGETS" ]; then
    check_array_content "$NEXT_TARGETS" '.candidates' 1 "Next-round candidates"
fi

PATCH="$ROUND_DIR/patch-trace.yaml"
if [ -f "$PATCH" ]; then
    check_array_content "$PATCH" '.patches' 1 "Patch entries"
fi

DIFF="$ROUND_DIR/document-diff.yaml"
if [ -f "$DIFF" ]; then
    check_array_content "$DIFF" '.diffs' 1 "Document diffs"
fi

    # ── Stage-specific workflow validators ─────────────────────────
    SKILL_HOME="${CR_SKILL_HOME:-$(cd "$SCRIPT_DIR/.." && pwd)}"
    CONTRACT="$ROUND_DIR/contract.yaml"
    if [ -f "$CONTRACT" ]; then
        WF_ID=$(grep -E '^\s+id:' "$CONTRACT" 2>/dev/null | head -1 | sed 's/.*id: *//' | tr -d '"' || echo "")
        if [ -n "$WF_ID" ] && [ -f "$SKILL_HOME/workflows/$WF_ID/workflow.yaml" ]; then
            STAGE_VALIDATORS=$(yq -r ".stage_contracts.\"$STAGE\".validators[] // \"\"" "$SKILL_HOME/workflows/$WF_ID/workflow.yaml" 2>/dev/null || echo "")
            for v in $STAGE_VALIDATORS; do
                [ -z "$v" ] && continue
                WF_VAL="$SKILL_HOME/workflows/$WF_ID/validators/$v"
                echo "── Running stage validator: $v ──"
                if [ -x "$WF_VAL" ]; then
                    if ! "$WF_VAL" "$ROUND_DIR"; then
                        fail "Stage validator '$v' failed"
                        ALL_PRESENT=false
                    else
                        pass "Stage validator '$v' passed"
                    fi
                else
                    warn "Stage validator '$v' not found at $WF_VAL"
                fi
            done
        fi
    fi

if [ "$ALL_PRESENT" = true ]; then
    pass "Stage '$STAGE' validation passed"
    cr_exit_summary
else
    fail "Stage '$STAGE' validation failed"
    cr_exit_summary
fi
