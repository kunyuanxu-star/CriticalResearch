#!/usr/bin/env bash
# cr-validate-stop — Stop gate validation (Inv7).
# Delegates to cr-stop-gate for consistency.
#
# Called by the Stop hook. Returns JSON for hook decision.
#
# Usage: cr-validate-stop <project_dir> [--force]
#   --force: user explicitly requested stop (override incomplete round)
#
# Output (on stdout): JSON for hook decision
#   {"decision":"approve"} or {"decision":"block","reason":"..."}
#
# Exit codes:
#   0 — allow stop
#   1 — block stop

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

PROJECT_DIR="${1:-}"
FORCE_FLAG="${2:-}"

STOP_GATE="$SCRIPT_DIR/cr-stop-gate"
if [ -x "$STOP_GATE" ]; then
    "$STOP_GATE" "$PROJECT_DIR" "$FORCE_FLAG"
    exit $?
fi

# Fallback if cr-stop-gate is missing.
if [ -z "$PROJECT_DIR" ] || [ ! -d "$PROJECT_DIR" ]; then
    echo '{"decision":"approve"}'
    exit 0
fi

STATE_FILE="$PROJECT_DIR/state/project-state.json"
if [ ! -f "$STATE_FILE" ]; then
    echo '{"decision":"approve"}'
    exit 0
fi

ACTIVE_ROUND=$(jq -r '.active_round // empty' "$STATE_FILE" 2>/dev/null || echo "")
if [ -z "$ACTIVE_ROUND" ] || [ "$ACTIVE_ROUND" = "null" ]; then
    echo '{"decision":"approve"}'
    exit 0
fi

echo '{"decision":"block","reason":"cr-stop-gate missing and round is active"}'
exit 1
