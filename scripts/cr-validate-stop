#!/usr/bin/env bash
# cr-validate-stop — v2 stop gate for active CriticalResearch rounds.
# Blocks session stop if a round is active and incomplete.
# This is a gate only — it does NOT close the round.
# The round must be closed via: cr round close <project>
#
# Usage: cr-validate-stop <project_dir> [allow_reason]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

PROJECT_DIR="${1:-}"
ALLOW_REASON="${2:-}"

approve() {
  echo '{"decision":"approve"}'
  exit 0
}

block() {
  local reason="$1"
  jq -n --arg reason "$reason" '{
    decision: "block",
    reason: $reason
  }'
  exit 1
}

# No project dir → nothing to gate.
[ -z "$PROJECT_DIR" ] && approve
[ ! -d "$PROJECT_DIR" ] && approve

STATE_FILE="$PROJECT_DIR/state/project-state.json"
[ ! -f "$STATE_FILE" ] && approve

ACTIVE_ROUND="$(jq -r '.active_round // "null"' "$STATE_FILE" 2>/dev/null || echo "null")"
if [ "$ACTIVE_ROUND" = "null" ] || [ -z "$ACTIVE_ROUND" ]; then
  approve
fi

ROUND_DIR="$PROJECT_DIR/rounds/round-$(printf "%03d" "$ACTIVE_ROUND")"
WF_STATE="$ROUND_DIR/workflow-state.yaml"

if [ ! -f "$WF_STATE" ]; then
  block "Active round $ACTIVE_ROUND exists, but workflow-state.yaml is missing. Repair the round state before stopping.

Run: cr round status $(basename "$PROJECT_DIR")"
fi

INCOMPLETE="$(yq -r '[.stages | to_entries[] | select(.value.status != "complete")] | length' "$WF_STATE" 2>/dev/null || echo "1")"
CURRENT_STAGE="$(yq -r '.current_stage // ""' "$WF_STATE" 2>/dev/null || echo "")"

if [ "${INCOMPLETE:-1}" -gt 0 ]; then
  block "CriticalResearch round is incomplete. Current stage: ${CURRENT_STAGE:-unknown}.

Complete the current stage before stopping.
Run: cr stage status $(basename "$PROJECT_DIR")
Then: cr stage advance $(basename "$PROJECT_DIR")"
fi

# All stages complete, but round still active.
block "All stages are complete but the round is still active.

Close the round before stopping:
  cr round close $(basename "$PROJECT_DIR")"
