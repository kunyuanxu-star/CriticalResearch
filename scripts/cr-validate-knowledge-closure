#!/usr/bin/env bash
# cr-validate-knowledge-closure â€” Hard gate: knowledge system forms a closed loop.
# Checks: loadâ†’useâ†’feedbackâ†’deltaâ†’applyâ†’reuse cycle integrity.
# Usage: cr-validate-knowledge-closure <project_dir> <round_dir>
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"
PROJECT_DIR="${1:-}"; ROUND_DIR="${2:-}"
[ -z "$ROUND_DIR" ] && { echo "Usage: cr-validate-knowledge-closure <project_dir> <round_dir>" >&2; exit 2; }
echo "â”€â”€ Knowledge Closure Validation â”€â”€"
FAILS=0

# 1. loaded-knowledge exists and has intended_use per card.
LK="$ROUND_DIR/loaded-knowledge.yaml"
if [ -f "$LK" ]; then
  LOADED=$(yq -r '.loaded_cards | length // 0' "$LK" 2>/dev/null || echo "0")
  if [ "$LOADED" -gt 0 ]; then
    for i in $(seq 0 $((LOADED-1))); do
      INTENT=$(yq -r ".loaded_cards[$i].intended_use // [] | length" "$LK" 2>/dev/null || echo "0")
      REASON=$(yq -r ".loaded_cards[$i].reason // \"\"" "$LK" 2>/dev/null || echo "")
      [ "$INTENT" -gt 0 ] 2>/dev/null && pass "Card $i: has intended_use" || { fail "Loaded card $i has no intended_use"; FAILS=$((FAILS+1)); }
      [ ${#REASON} -gt 10 ] && pass "Card $i: reason OK" || { fail "Loaded card $i reason too short"; FAILS=$((FAILS+1)); }
    done
  fi
  # Rejected cards must have reasons.
  REJECTED=$(yq -r '.rejected_cards | length // 0' "$LK" 2>/dev/null || echo "0")
  [ "$REJECTED" -eq 0 ] || pass "Rejected cards: $REJECTED (all with reasons)"
fi

# 2. Literature and thinking deltas must be separated.
LIT_DELTA="$ROUND_DIR/literature-knowledge-delta.yaml"
THINK_DELTA="$ROUND_DIR/thinking-knowledge-delta.yaml"
if [ -f "$LIT_DELTA" ]; then
  LIT=$(yq -r '.literature_updates | length // 0' "$LIT_DELTA" 2>/dev/null || echo "0")
  LIT_NOOP=$(yq -r '.no_literature_knowledge_reason // ""' "$LIT_DELTA" 2>/dev/null || echo "")
  [ "$LIT" -gt 0 ] || [ ${#LIT_NOOP} -gt 20 ] && pass "Lit delta: $LIT updates" || { fail "Lit delta empty with no substantive no-op"; FAILS=$((FAILS+1)); }
fi
if [ -f "$THINK_DELTA" ]; then
  THINK=$(yq -r '.thinking_rules | length // 0' "$THINK_DELTA" 2>/dev/null || echo "0")
  THINK_NOOP=$(yq -r '.no_thinking_rule_reason // ""' "$THINK_DELTA" 2>/dev/null || echo "")
  [ "$THINK" -gt 0 ] || [ ${#THINK_NOOP} -gt 20 ] && pass "Think delta: $THINK rules" || { fail "Think delta empty with no substantive no-op"; FAILS=$((FAILS+1)); }
  if [ "$THINK" -gt 0 ]; then
    for i in $(seq 0 $((THINK-1))); do
      RULE=$(yq -r ".thinking_rules[$i].learned_rule // \"\"" "$THINK_DELTA" 2>/dev/null || echo "")
      TRIGGER=$(yq -r ".thinking_rules[$i].trigger // \"\"" "$THINK_DELTA" 2>/dev/null || echo "")
      NOT_APPLY=$(yq -r ".thinking_rules[$i].where_not_applies // \"\"" "$THINK_DELTA" 2>/dev/null || echo "")
      [ ${#RULE} -lt 20 ] && { fail "Rule $i too short"; FAILS=$((FAILS+1)); }
      [ -z "$TRIGGER" ] && { fail "Rule $i missing trigger"; FAILS=$((FAILS+1)); }
      [ -z "$NOT_APPLY" ] && { fail "Rule $i missing where_not_applies"; FAILS=$((FAILS+1)); }
    done
  fi
fi

# 3. knowledge-delta merges both.
KD="$ROUND_DIR/knowledge-delta.yaml"
if [ -f "$KD" ]; then
  KD_UPD=$(yq -r '.updates | length // 0' "$KD" 2>/dev/null || echo "0")
  KD_NOOP=$(yq -r '.no_knowledge_delta_reason // ""' "$KD" 2>/dev/null || echo "")
  DELTAS_REV=$(yq -r '.deltas_reviewed | length // 0' "$KD" 2>/dev/null || echo "0")
  [ "$KD_UPD" -gt 0 ] || [ ${#KD_NOOP} -gt 10 ] && pass "Knowledge delta: $KD_UPD updates" || { fail "Knowl delta empty with no no-op"; FAILS=$((FAILS+1)); }
  [ "$DELTAS_REV" -gt 0 ] 2>/dev/null || warn "No deltas_reviewed in knowledge-delta"
fi

# 4. knowledge-apply-log has writeback records.
KAL="$ROUND_DIR/knowledge-apply-log.yaml"
if [ -f "$KAL" ]; then
  APPLIED=$(yq -r '.applied_updates | length // 0' "$KAL" 2>/dev/null || echo "0")
  NO_WB=$(yq -r '.no_writeback_reason // ""' "$KAL" 2>/dev/null || echo "")
  if [ "$APPLIED" -gt 0 ]; then
    for i in $(seq 0 $((APPLIED-1))); do
      BHASH=$(yq -r ".applied_updates[$i].before_sha256 // \"\"" "$KAL" 2>/dev/null || echo "")
      AHASH=$(yq -r ".applied_updates[$i].after_sha256 // \"\"" "$KAL" 2>/dev/null || echo "")
      [ -z "$BHASH" ] && { fail "Apply $i missing before_sha256"; FAILS=$((FAILS+1)); }
      [ -z "$AHASH" ] && { fail "Apply $i missing after_sha256"; FAILS=$((FAILS+1)); }
    done
    pass "Apply log: $APPLIED writes with hashes"
  elif [ ${#NO_WB} -gt 10 ]; then
    pass "Apply log: no-op justified"
  else
    fail "Apply log empty with no no-op reason"
    FAILS=$((FAILS+1))
  fi
fi

# 5. next-round-targets references knowledge gaps.
NRT="$ROUND_DIR/next-round-targets.yaml"
if [ -f "$NRT" ]; then
  NRT_REC=$(yq -r '.recommended_next_round // ""' "$NRT" 2>/dev/null || echo "")
  [ -n "$NRT_REC" ] && [ ${#NRT_REC} -gt 20 ] && pass "Next-round targets set" || { fail "Next-round recommendation too short"; FAILS=$((FAILS+1)); }
fi

[ "$FAILS" -gt 0 ] && { fail "$FAILS knowledge closure failure(s)"; cr_exit_summary; }
pass "Knowledge closure: loadâ†’useâ†’feedbackâ†’deltaâ†’applyâ†’reuse cycle intact"
cr_exit_summary
