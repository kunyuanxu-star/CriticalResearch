#!/usr/bin/env bash
# cr-run-validator-pipeline — Execute the validator pipeline from artifact-registry.json.
# Reads the registry's validator_pipeline.validators[] and runs them in order,
# respecting hard/soft gate classification.
#
# Usage: cr-run-validator-pipeline <project_dir> <round_dir>
#
# Exit codes:
#   0 — all hard gates passed
#   2 — one or more hard gates failed

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

PROJECT_DIR="${1:-}"
ROUND_DIR="${2:-}"

if [ -z "$PROJECT_DIR" ] || [ -z "$ROUND_DIR" ]; then
    echo "Usage: cr-run-validator-pipeline <project_dir> <round_dir>" >&2
    exit 2
fi

REGISTRY_PATH=$(cr_artifact_registry_path)
if [ -z "$REGISTRY_PATH" ] || [ ! -f "$REGISTRY_PATH" ]; then
    echo "Error: artifact registry not found" >&2
    exit 2
fi

echo ""
echo "══ Validator Pipeline ══"
echo "  Project: $(basename "$PROJECT_DIR")"
echo "  Round:   $(basename "$ROUND_DIR")"
echo ""

HARD_FAILURES=0
SOFT_WARNINGS=0

# Read validators from registry and execute in order.
VALIDATOR_COUNT=$(jq -r '.validator_pipeline.validators | length' "$REGISTRY_PATH" 2>/dev/null || echo 0)

if [ "$VALIDATOR_COUNT" -eq 0 ]; then
    warn "No validators defined in artifact registry"
    cr_exit_summary
fi

for i in $(seq 0 $((VALIDATOR_COUNT - 1))); do
    NAME=$(jq -r ".validator_pipeline.validators[$i].name" "$REGISTRY_PATH" 2>/dev/null)
    GATE=$(jq -r ".validator_pipeline.validators[$i].gate" "$REGISTRY_PATH" 2>/dev/null)
    CHECKS=$(jq -r ".validator_pipeline.validators[$i].checks" "$REGISTRY_PATH" 2>/dev/null)

    VALIDATOR_SCRIPT="$SCRIPT_DIR/${NAME}"
    if [ ! -x "$VALIDATOR_SCRIPT" ]; then
        if [ "$GATE" = "hard" ]; then
            fail "Validator not found: $NAME (hard gate)"
            HARD_FAILURES=$((HARD_FAILURES + 1))
        else
            warn "Validator not found: $NAME (soft gate — skipping)"
            SOFT_WARNINGS=$((SOFT_WARNINGS + 1))
        fi
        continue
    fi

    echo "── [$((i + 1))/$VALIDATOR_COUNT] $NAME ($GATE) ──"

    # Helper: increment the right counter on validator failure.
    gate_fail() {
        if [ "$GATE" = "hard" ]; then
            HARD_FAILURES=$((HARD_FAILURES + 1))
        else
            SOFT_WARNINGS=$((SOFT_WARNINGS + 1))
        fi
    }

    # Run validator. Arguments match each validator's documented signature.
    case "$NAME" in
        cr-validate-schema|cr-validate-ids)
            "$VALIDATOR_SCRIPT" "$ROUND_DIR" "$PROJECT_DIR" || gate_fail
            ;;
        cr-validate-all-phases)
            "$VALIDATOR_SCRIPT" "$PROJECT_DIR" "$ROUND_DIR" || gate_fail
            ;;
        cr-validate-references)
            "$VALIDATOR_SCRIPT" "$ROUND_DIR" "$PROJECT_DIR" || gate_fail
            ;;
        cr-validate-artifacts|cr-validate-paper-patches|cr-validate-experiments|cr-validate-knowledge|cr-validate-critique)
            "$VALIDATOR_SCRIPT" "$ROUND_DIR" || gate_fail
            ;;
        cr-validate-research)
            "$VALIDATOR_SCRIPT" "$PROJECT_DIR" "$ROUND_DIR" || gate_fail
            ;;
        cr-validate-source-integrity)
            "$VALIDATOR_SCRIPT" "$ROUND_DIR" || gate_fail
            ;;
        cr-validate-evidence-claim-links|cr-validate-anchors|cr-validate-human-gates)
            "$VALIDATOR_SCRIPT" "$ROUND_DIR" "$PROJECT_DIR" || gate_fail
            ;;
        cr-validate-patch-application)
            "$VALIDATOR_SCRIPT" "$PROJECT_DIR" "$ROUND_DIR" || gate_fail
            ;;
        cr-validate-paper-completeness)
            "$VALIDATOR_SCRIPT" "$PROJECT_DIR" || gate_fail
            ;;
        cr-validate-prompts|cr-validate-source-notes|cr-validate-claim-evidence-matrix|cr-validate-argument-flow|cr-validate-claim-paper-alignment|cr-validate-reviewer-readiness|cr-validate-transaction-chain)
            "$VALIDATOR_SCRIPT" "$PROJECT_DIR" "$ROUND_DIR" || gate_fail
            ;;
        *)
            if [ "$GATE" = "hard" ]; then
                fail "Unknown hard validator: $NAME"
                HARD_FAILURES=$((HARD_FAILURES + 1))
            else
                warn "Unknown soft validator: $NAME -- skipping"
                SOFT_WARNINGS=$((SOFT_WARNINGS + 1))
            fi
            ;;
    esac
done

echo ""
echo "══ Pipeline Complete: $HARD_FAILURES hard failure(s), $SOFT_WARNINGS soft warning(s) ══"

[ "$HARD_FAILURES" -gt 0 ] && exit 2
exit 0
