#!/usr/bin/env bash
# cr-validate-human-gates — Human judgment gate validation.
# Checks that thesis-level patches have resolved human decisions before
# round closure. Blocks if pending decisions remain.
#
# Usage: cr-validate-human-gates <round_dir> <project_dir>
#
# Exit codes:
#   0 — all human gates resolved
#   2 — pending decisions block round close (hard gate)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

ROUND_DIR="${1:-}"
PROJECT_DIR="${2:-}"

if [ -z "$ROUND_DIR" ] || [ -z "$PROJECT_DIR" ]; then
    echo "Usage: cr-validate-human-gates <round_dir> <project_dir>" >&2
    exit 2
fi

ROUND_NAME="$(basename "$ROUND_DIR")"
echo ""
echo "══ Human Gate Validation: $ROUND_NAME ══"

PENDING_COUNT=0

# Check patches for unresolved human decisions.
PATCHES_DIR="$ROUND_DIR/patches"
if [ -d "$PATCHES_DIR" ]; then
    for patch_file in "$PATCHES_DIR"/PP-*.yaml; do
        [ ! -f "$patch_file" ] && continue
        PP_ID=$(basename "$patch_file" .yaml)
        NEEDS_HUMAN=$(grep -E '^needs_human_decision:' "$patch_file" 2>/dev/null | sed 's/^needs_human_decision:\s*//' | xargs || echo "false")
        LIFECYCLE=$(grep -E '^lifecycle_status:' "$patch_file" 2>/dev/null | sed 's/^lifecycle_status:\s*//' | xargs || echo "")

        if [ "$NEEDS_HUMAN" = "true" ]; then
            case "$LIFECYCLE" in
                approved|applied|rejected|superseded)
                    pass "$PP_ID: human decision resolved (lifecycle=$LIFECYCLE)"
                    ;;
                *)
                    fail "$PP_ID: needs human decision but lifecycle=$LIFECYCLE (pending)"
                    PENDING_COUNT=$((PENDING_COUNT + 1))
                    ;;
            esac
        fi
    done
fi

# Check human-review-queue.yaml.
HUMAN_QUEUE="$PROJECT_DIR/state/human-review-queue.yaml"
if [ -f "$HUMAN_QUEUE" ]; then
    TOTAL=$(grep -cE '^\s+decision_id:' "$HUMAN_QUEUE" 2>/dev/null || echo 0)
    RESOLVED=$(grep -cE '^\s+decision:\s+(accepted|accepted_with_modifications|rejected|deferred)' "$HUMAN_QUEUE" 2>/dev/null || echo 0)
    UNRESOLVED=$((TOTAL - RESOLVED))

    if [ "$UNRESOLVED" -gt 0 ]; then
        fail "$UNRESOLVED unresolved human decisions in human-review-queue.yaml"
        PENDING_COUNT=$((PENDING_COUNT + UNRESOLVED))
    elif [ "$TOTAL" -gt 0 ]; then
        pass "All $TOTAL human decisions resolved"
    fi
fi

if [ "$PENDING_COUNT" -gt 0 ]; then
    fail "$PENDING_COUNT pending human decision(s) — must be resolved before round close (hard gate)"
elif [ -d "$PATCHES_DIR" ] || [ -f "$HUMAN_QUEUE" ]; then
    pass "No pending human decisions"
fi

cr_exit_summary
