#!/usr/bin/env bash
# cr-validate-phase-transition — Enforce allowed state transitions.
# Blocks forbidden transitions like blocked→complete, open→complete without
# running. Used by cr-complete-phase and cr-step set-phase.
#
# Allowed transitions:
#   blocked  -> open
#   open     -> running
#   running  -> repair_required
#   running  -> waiting_human
#   running  -> complete
#   repair_required -> running
#   waiting_human   -> running
#
# Forbidden transitions (will be blocked):
#   blocked  -> complete (skip phase)
#   open     -> complete (allowed, with validation)
#   repair_required -> complete (no revalidation)
#   waiting_human   -> complete (no decision artifact)
#   any      -> skipped (not a valid status)
#
# Usage: cr-validate-phase-transition <state_yaml> <phase> <from_status> <to_status>
# Exit: 0 = allowed, 1 = blocked

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

STATE_FILE="${1:-}"
PHASE="${2:-}"
FROM_STATUS="${3:-}"
TO_STATUS="${4:-}"

if [ -z "$STATE_FILE" ] || [ -z "$PHASE" ] || [ -z "$FROM_STATUS" ] || [ -z "$TO_STATUS" ]; then
    echo "Usage: cr-validate-phase-transition <state_yaml> <phase> <from> <to>" >&2
    exit 2
fi

# ── Forbidden transitions ──────────────────────────────────────────

block_transition() {
    local reason="$1"
    echo "BLOCKED: Phase '$PHASE' cannot transition $FROM_STATUS -> $TO_STATUS"
    echo "  Reason: $reason"
    exit 1
}

# Skip is never a valid status.
if [ "$TO_STATUS" = "skipped" ]; then
    block_transition "Skipping phases is forbidden. Produce a schema-valid no-op artifact instead."
fi

# blocked → complete (cannot skip running + validation)
if [ "$FROM_STATUS" = "blocked" ] && [ "$TO_STATUS" = "complete" ]; then
    block_transition "Cannot jump from blocked to complete. Phase must be opened, run, and validated."
fi

# blocked → running (must go through open first)
if [ "$FROM_STATUS" = "blocked" ] && [ "$TO_STATUS" = "running" ]; then
    block_transition "Cannot jump from blocked to running. Phase must be opened first (dependencies must be complete)."
fi

# blocked → waiting_human
if [ "$FROM_STATUS" = "blocked" ] && [ "$TO_STATUS" = "waiting_human" ]; then
    block_transition "Cannot jump from blocked to waiting_human. Phase must be opened first."
fi

# blocked → repair_required
if [ "$FROM_STATUS" = "blocked" ] && [ "$TO_STATUS" = "repair_required" ]; then
    block_transition "Cannot jump from blocked to repair_required. Phase must be opened and run first."
fi

# open → complete — allowed. Phase is open (dependencies met); completion runs validation.
# The key block is blocked→complete (skip dependency chain).

# open → waiting_human (cannot need human input before running)
if [ "$FROM_STATUS" = "open" ] && [ "$TO_STATUS" = "waiting_human" ]; then
    block_transition "Cannot jump from open to waiting_human. Phase must be running first."
fi

# open → repair_required (cannot need repair before running)
if [ "$FROM_STATUS" = "open" ] && [ "$TO_STATUS" = "repair_required" ]; then
    block_transition "Cannot jump from open to repair_required. Phase must be run first."
fi

# repair_required → complete (must re-run and validate after repair)
if [ "$FROM_STATUS" = "repair_required" ] && [ "$TO_STATUS" = "complete" ]; then
    block_transition "Cannot complete from repair_required without re-running. Set to running first, re-validate, then complete."
fi

# waiting_human → complete (must document decision)
if [ "$FROM_STATUS" = "waiting_human" ] && [ "$TO_STATUS" = "complete" ]; then
    block_transition "Cannot complete from waiting_human without decision artifact. Set to running first, resolve decision, then complete."
fi

# complete → anything (immutable once complete, unless repair mode)
if [ "$FROM_STATUS" = "complete" ] && [ "$TO_STATUS" != "complete" ]; then
    if [ "${CR_REPAIR_MODE:-0}" != "1" ]; then
        block_transition "Completed phases are immutable. Set CR_REPAIR_MODE=1 to revert and repair."
    fi
    echo "WARNING: Repairing completed phase '$PHASE'. Record in repair-log.yaml."
fi

# ── Allowed transitions ────────────────────────────────────────────

allowed_transition() {
    echo "ALLOWED: $PHASE $FROM_STATUS -> $TO_STATUS"
    exit 0
}

case "$FROM_STATUS->$TO_STATUS" in
    "blocked->open")          allowed_transition ;;
    "open->running")          allowed_transition ;;
    "open->complete")         allowed_transition ;; # open (deps met) -> complete (validated)
    "open->blocked")          allowed_transition ;; # re-block if dependency becomes incomplete
    "running->complete")      allowed_transition ;;
    "running->repair_required") allowed_transition ;;
    "running->waiting_human") allowed_transition ;;
    "running->running")       allowed_transition ;; # idempotent re-run
    "repair_required->running") allowed_transition ;;
    "waiting_human->running") allowed_transition ;;
    "complete->complete")     allowed_transition ;; # idempotent
    "complete->repair_required")
        if [ "${CR_REPAIR_MODE:-0}" = "1" ]; then
            allowed_transition
        else
            block_transition "Set CR_REPAIR_MODE=1 to repair a completed phase."
        fi
        ;;
    *)
        block_transition "Unknown or unsupported transition."
        ;;
esac
