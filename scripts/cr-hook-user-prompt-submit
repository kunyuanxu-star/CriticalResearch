#!/usr/bin/env bash
# cr-hook-user-prompt-submit — UserPromptSubmit hook: inject scope + stage mandate (v2).
# Runs before each user prompt. Injects:
# 1. Session scope context (write boundaries)
# 2. Mandatory stage execution instruction (when an active round exists)
#
# This ensures the agent CANNOT forget which stage it must execute.
# Every user message is a reminder to execute the current stage.
#
# Exit: 0 always (non-blocking, context injection only)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

WORKSPACE_ROOT="$(cr_workspace_root)"
SCOPE_CLI="$SCRIPT_DIR/cr-scope"

# Quick check: is there a workspace?
if [ ! -d "$WORKSPACE_ROOT/_cr" ]; then
    exit 0
fi

# ── Part 1: Scope context ──────────────────────────────────────

SCOPE_CTX=$("$SCOPE_CLI" resolve --for-session 2>/dev/null || echo "")

# ── Part 2: Stage execution mandate ────────────────────────────
# Generated when there is an active round and stages are incomplete.

STAGE_CTX=""
PROJECT_DIR=""
STAGE_TOTAL=0

# Resolve project directory (priority: session scope > direct project > active-project).
SESSIONS_DIR="$WORKSPACE_ROOT/_cr/sessions"
if [ -d "$SESSIONS_DIR" ] && [ -n "$(ls -A "$SESSIONS_DIR" 2>/dev/null)" ]; then
    SESSION_FILE="$SESSIONS_DIR/$(cr_session_id).yaml"
    if [ -f "$SESSION_FILE" ]; then
        SCOPED_PROJECT=$(yq -r '.project_id // ""' "$SESSION_FILE" 2>/dev/null || echo "")
        SCOPE_TYPE=$(yq -r '.scope_type // ""' "$SESSION_FILE" 2>/dev/null || echo "")
        if [ -n "$SCOPED_PROJECT" ] && [ "$SCOPE_TYPE" = "single_project_write" ]; then
            PROJECT_DIR="$WORKSPACE_ROOT/$SCOPED_PROJECT"
            [ -d "$PROJECT_DIR" ] || PROJECT_DIR=""
        fi
    fi
fi

# Fallback: _cr/active-project
if [ -z "$PROJECT_DIR" ]; then
    ACTIVE_PROJECT_FILE="$WORKSPACE_ROOT/_cr/active-project"
    if [ -f "$ACTIVE_PROJECT_FILE" ]; then
        ACTIVE_PROJECT=$(cat "$ACTIVE_PROJECT_FILE")
        PROJECT_DIR="$WORKSPACE_ROOT/$ACTIVE_PROJECT"
        [ -d "$PROJECT_DIR" ] || PROJECT_DIR=""
    fi
fi

# Try direct project directory.
if [ -z "$PROJECT_DIR" ]; then
    if [ -f "$WORKSPACE_ROOT/state/project-state.json" ]; then
        PROJECT_DIR="$WORKSPACE_ROOT"
    fi
fi

# Generate stage execution mandate if we have an active round.
if [ -n "$PROJECT_DIR" ]; then
    STATE_FILE="$PROJECT_DIR/state/project-state.json"
    if [ -f "$STATE_FILE" ]; then
        ACTIVE_ROUND=$(jq -r '.active_round // empty' "$STATE_FILE" 2>/dev/null || echo "")
        if [ -n "$ACTIVE_ROUND" ] && [ "$ACTIVE_ROUND" != "null" ]; then
            ROUND_NUM=$(printf "%03d" "$ACTIVE_ROUND")
            ROUND_DIR="$PROJECT_DIR/rounds/round-$ROUND_NUM"
            WF_STATE="$ROUND_DIR/workflow-state.yaml"

            if [ -f "$WF_STATE" ]; then
                # Check if round is still running (not closed).
                ROUND_STATUS=$(yq -r '.status // "running"' "$WF_STATE" 2>/dev/null || echo "running")
                if [ "$ROUND_STATUS" = "closed" ]; then
                    exit 0
                fi

                CURRENT_STAGE=$(yq -r '.current_stage // "unknown"' "$WF_STATE" 2>/dev/null || echo "unknown")
                STAGE_STATUS=$(yq -r ".stages.\"$CURRENT_STAGE\".status // \"unknown\"" "$WF_STATE" 2>/dev/null || echo "unknown")
                STAGE_TOTAL=$(yq -r '.stage_order | length' "$WF_STATE" 2>/dev/null || echo "0")
                STAGE_COMPLETE=$(yq -r '[.stages | to_entries[] | select(.value.status=="complete")] | length' "$WF_STATE" 2>/dev/null || echo "0")
                PROJ_NAME=$(basename "$PROJECT_DIR")
                WF_ID=$(yq -r '.workflow_id // "paper"' "$WF_STATE" 2>/dev/null || echo "paper")

                # Get required outputs and check which are missing.
                REQ=$(yq -r ".stages.\"$CURRENT_STAGE\".required_outputs // [] | .[]" "$WF_STATE" 2>/dev/null || echo "")
                MISSING_LINES=""
                MISSING_COUNT=0
                for output in $REQ; do
                    [ -z "$output" ] && continue
                    case "$output" in
                        *.yaml|*.md|*.json)
                            if [ -f "$ROUND_DIR/$output" ] || [ -f "$PROJECT_DIR/$output" ]; then
                                continue
                            fi
                            ;;
                        raw-sources|source-notes|patches|experiments)
                            if [ -d "$ROUND_DIR/$output" ] && [ -n "$(ls -A "$ROUND_DIR/$output" 2>/dev/null)" ]; then
                                continue
                            fi
                            ;;
                    esac
                    if [ "$MISSING_COUNT" -eq 0 ]; then
                        MISSING_LINES="   [MISSING] ${output}"
                    else
                        MISSING_LINES="${MISSING_LINES}"$'\n'"   [MISSING] ${output}"
                    fi
                    MISSING_COUNT=$((MISSING_COUNT + 1))
                done

                # Get required inputs.
                INPUTS=$(yq -r ".stages.\"$CURRENT_STAGE\".required_inputs // [] | .[]" "$WF_STATE" 2>/dev/null || echo "")
                INPUT_LINES=""
                INPUT_COUNT=0
                for input in $INPUTS; do
                    [ -z "$input" ] && continue
                    if [ "$INPUT_COUNT" -eq 0 ]; then
                        INPUT_LINES="   ${input}"
                    else
                        INPUT_LINES="${INPUT_LINES}"$'\n'"   ${input}"
                    fi
                    INPUT_COUNT=$((INPUT_COUNT + 1))
                done

                # Get allowed write scopes (compact).
                ALLOWED=$(yq -r ".stages.\"$CURRENT_STAGE\".allowed_write_scopes // [] | .[]" "$WF_STATE" 2>/dev/null || echo "")
                ALLOWED_STR=""
                for a in $ALLOWED; do
                    [ -z "$a" ] && continue
                    ALLOWED_STR="${ALLOWED_STR} ${a}"
                done
                ALLOWED_STR=$(echo "$ALLOWED_STR" | xargs)

                # Get forbidden actions (compact).
                FORBIDDEN=$(yq -r ".stages.\"$CURRENT_STAGE\".forbidden_actions // [] | .[]" "$WF_STATE" 2>/dev/null || echo "")
                FORBIDDEN_STR=""
                for f in $FORBIDDEN; do
                    [ -z "$f" ] && continue
                    FORBIDDEN_STR="${FORBIDDEN_STR} ${f}"
                done
                FORBIDDEN_STR=$(echo "$FORBIDDEN_STR" | xargs)

                # Determine required action text.
                ACTION_TEXT=""
                case "$STAGE_STATUS" in
                    open)
                        ACTION_TEXT="1. Read the stage prompt if provided above
2. Read all required inputs
3. Create ALL required outputs listed as [MISSING]
4. Run: cr stage advance ${PROJ_NAME}"
                        ;;
                    running)
                        if [ "$MISSING_COUNT" -gt 0 ]; then
                            ACTION_TEXT="1. Complete creating all [MISSING] outputs above
2. Run: cr stage advance ${PROJ_NAME}"
                        else
                            ACTION_TEXT="1. All outputs present. Run: cr stage advance ${PROJ_NAME}"
                        fi
                        ;;
                    complete)
                        ACTION_TEXT="1. ADVANCE NOW: cr stage advance ${PROJ_NAME}"
                        ;;
                    blocked)
                        ACTION_TEXT="1. Stage is blocked. Check dependencies.
2. Run: cr stage status ${PROJ_NAME}"
                        ;;
                    *)
                        ACTION_TEXT="1. Check stage status and resolve blockers
2. Run: cr stage status ${PROJ_NAME}"
                        ;;
                esac

                # Build the stage mandate block.
                STAGE_CTX=$(printf "+==============================================================+
| CRITICAL: Stage Execution Required                           |
+==============================================================+
| Project: %-50s |
| Active Round: %-45s |
| Workflow: %-47s |
|                                                              |
| Execution Policy:                                            |
|   full_round_required: true                                  |
|   required_stage_count: %-36s |
|   round_close_required: true                                 |
|                                                              |
| Current Stage: %-43s |
| Stage Status: %-45s |
| Progress: %s/%s stages complete" \
                    "$PROJ_NAME" \
                    "$ACTIVE_ROUND" \
                    "$WF_ID" \
                    "$STAGE_TOTAL" \
                    "$CURRENT_STAGE" \
                    "$STAGE_STATUS" \
                    "$STAGE_COMPLETE" "$STAGE_TOTAL")

                # Append missing outputs section.
                if [ "$MISSING_COUNT" -gt 0 ]; then
                    MISSING_SECTION=$(printf '|                                                              |
| Required Outputs (%s missing):                               |
%s' "$MISSING_COUNT" "$MISSING_LINES")
                    STAGE_CTX="${STAGE_CTX}"$'\n'"${MISSING_SECTION}"
                fi

                # Append required inputs section.
                if [ -n "$INPUT_LINES" ]; then
                    INPUT_SECTION=$(printf '|                                                              |
| Required Inputs:                                             |
%s' "$INPUT_LINES")
                    STAGE_CTX="${STAGE_CTX}"$'\n'"${INPUT_SECTION}"
                fi

                # Append allowed scopes.
                if [ -n "$ALLOWED_STR" ]; then
                    STAGE_CTX="${STAGE_CTX}"$'\n'"|                                                              |
| Allowed: ${ALLOWED_STR}"
                fi

                # Append forbidden actions.
                if [ -n "$FORBIDDEN_STR" ]; then
                    STAGE_CTX="${STAGE_CTX}"$'\n'"|                                                              |
| FORBIDDEN: ${FORBIDDEN_STR}"
                fi

                # Append required actions.
                STAGE_CTX="${STAGE_CTX}"$'\n'"|                                                              |
| REQUIRED ACTIONS:                                            |
| ${ACTION_TEXT}"

                # Append footer.
                STAGE_CTX="${STAGE_CTX}"$'\n'"|                                                              |
| !! You CANNOT stop until all ${STAGE_TOTAL} stages complete.        |
| !! The Stop hook will BLOCK session end.                     |
| !! EXECUTE THIS STAGE NOW. Do anything else = violation.     |
+==============================================================+"
            fi
        fi
    fi
fi

# ── Output ─────────────────────────────────────────────────────

if [ -z "$SCOPE_CTX" ] && [ -z "$STAGE_CTX" ]; then
    exit 0
fi

COMBINED=""
[ -n "$SCOPE_CTX" ] && COMBINED="$SCOPE_CTX"
[ -n "$STAGE_CTX" ] && COMBINED="${COMBINED}"$'\n'"${STAGE_CTX}"

FOOTER=""
if [ -n "$STAGE_CTX" ]; then
    FOOTER="You MUST execute the current stage before doing anything else. The full-round execution policy requires all ${STAGE_TOTAL} stages to complete. You cannot stop until the round is closed. Create the required outputs, then run: cr stage advance <project>"
elif [ -n "$SCOPE_CTX" ]; then
    FOOTER="You must respect the write boundary above. Before any write, verify the target belongs to the scoped project. Do not edit _cr metadata, protected state files, or other projects directly. Use cr commands for state mutations."
fi

jq -n --arg ctx "$COMBINED" --arg footer "$FOOTER" '{
    hookSpecificOutput: {
        hookEventName: "UserPromptSubmit",
        additionalContext: ("\n" + $ctx + "\n\n" + $footer + "\n")
    }
}'
