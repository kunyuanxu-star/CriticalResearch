#!/usr/bin/env bash
# cr-validate-evidence-claim-links — Verify that every evidence item links to a valid source
# and that evidence-to-source and evidence-to-claim chains are unbroken.
# Usage: cr-validate-evidence-claim-links <round_dir> <project_dir>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

ROUND_DIR="${1:-}"
PROJECT_DIR="${2:-}"

if [ -z "$ROUND_DIR" ] || [ -z "$PROJECT_DIR" ]; then
    echo "Usage: cr-validate-evidence-claim-links <round_dir> <project_dir>" >&2
    exit 2
fi

echo "── Evidence-Claim Links ──"

EVID_FILE="$ROUND_DIR/evidence-ledger.yaml"
SRC_INDEX="$ROUND_DIR/source-index.yaml"
CLAIM_LEDGER="$PROJECT_DIR/state/claim-ledger.yaml"
CLAIM_GRAPH="$PROJECT_DIR/state/claim-graph.md"

ALL_PASSED=true

if [ ! -f "$EVID_FILE" ]; then
    fail "evidence-ledger.yaml not found"
    cr_exit_summary
fi

# Collect known source IDs.
KNOWN_SRC=""
if [ -f "$SRC_INDEX" ]; then
    KNOWN_SRC=$(yq -r '.sources[].source_id // ""' "$SRC_INDEX" 2>/dev/null | sort -u | tr '\n' ' ')
fi

# # Collect known claim IDs from claim-ledger.yaml (L0 authoritative), fallback to claim-graph.md.
KNOWN_CLM=""
if [ -f "$CLAIM_LEDGER" ]; then
    KNOWN_CLM=$(yq -r '.claims[]?.claim_id // ""' "$CLAIM_LEDGER" 2>/dev/null | sort -u | tr '
' ' ')
fi
if [ -z "$KNOWN_CLM" ] && [ -f "$CLAIM_GRAPH" ]; then
    KNOWN_CLM=$(grep -oE 'CLM-[0-9]{3}' "$CLAIM_GRAPH" 2>/dev/null | sort -u | tr '
' ' ')
fi

EVID_COUNT=$(yq -r '.evidence | length // 0' "$EVID_FILE" 2>/dev/null || echo "0")

if [ "${EVID_COUNT:-0}" -eq 0 ]; then
    fail "No evidence entries in evidence-ledger.yaml"
    cr_exit_summary
fi

DANGLING_SRC=0
DANGLING_CLM=0
for i in $(seq 0 $((EVID_COUNT - 1))); do
    EID=$(yq -r ".evidence[$i].evidence_id // \"\"" "$EVID_FILE" 2>/dev/null || echo "")
    SID=$(yq -r ".evidence[$i].source_id // \"\"" "$EVID_FILE" 2>/dev/null || echo "")

    # Check source link.
    if [ -n "$KNOWN_SRC" ]; then
        if echo "$KNOWN_SRC" | grep -qw "$SID"; then
            pass "$EID -> $SID: valid source link"
        else
            fail "$EID -> $SID: source not found in source-index.yaml"
            DANGLING_SRC=$((DANGLING_SRC + 1))
            ALL_PASSED=false
        fi
    else
        warn "$EID -> $SID: cannot verify (no source index)"
    fi

    # Check claim links.
    CLMS=$(yq -r ".evidence[$i].related_claims[] // \"\"" "$EVID_FILE" 2>/dev/null || echo "")
    for clm in $CLMS; do
        [ -z "$clm" ] && continue
        if [ -n "$KNOWN_CLM" ]; then
            if echo "$KNOWN_CLM" | grep -qw "$clm"; then
                pass "  $clm: valid claim link"
            else
                fail "  $clm: claim not found in claim-ledger.yaml or claim-graph.md"
                ALL_PASSED=false
                DANGLING_CLM=$((DANGLING_CLM + 1))
            fi
        else
            pass "  $clm: claim link present"
        fi
    done
done

if [ "$DANGLING_SRC" -gt 0 ]; then
    fail "$DANGLING_SRC evidence item(s) with dangling source references"
fi

if [ "$ALL_PASSED" = false ]; then
    cr_exit_summary
fi

pass "Evidence-chain validation: all links checked"
cr_exit_summary
