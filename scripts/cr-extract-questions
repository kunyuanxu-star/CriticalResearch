#!/usr/bin/env bash
# cr-extract-questions — Extract human judgment questions from paper patches.
# Scans patches with needs_human_decision=true and emits structured question
# cards for the user to answer.
#
# Usage: cr-extract-questions <round_dir>
#
# Output: question cards on stdout (markdown format).

set -euo pipefail

ROUND_DIR="${1:-}"

if [ -z "$ROUND_DIR" ] || [ ! -d "$ROUND_DIR" ]; then
    echo "Usage: cr-extract-questions <round_dir>" >&2
    exit 2
fi

ROUND_NAME=$(basename "$ROUND_DIR")
PATCHES_DIR="$ROUND_DIR/patches"

if [ ! -d "$PATCHES_DIR" ]; then
    echo "No patches/ directory — no questions to extract."
    exit 0
fi

echo "# Human Judgment Questions — $ROUND_NAME"
echo ""

QUESTION_NUM=0

for patch_file in "$PATCHES_DIR"/PP-*.yaml; do
    [ ! -f "$patch_file" ] && continue

    PP_ID=$(basename "$patch_file" .yaml)
    NEEDS_HUMAN=$(grep -E '^needs_human_decision:' "$patch_file" 2>/dev/null | sed 's/^needs_human_decision:\s*//' | xargs || echo "false")
    LIFECYCLE=$(grep -E '^lifecycle_status:' "$patch_file" 2>/dev/null | sed 's/^lifecycle_status:\s*//' | xargs || echo "")

    # Skip patches that don't need human input or are already resolved.
    [ "$NEEDS_HUMAN" != "true" ] && continue
    case "$LIFECYCLE" in
        approved|applied|rejected|superseded) continue ;;
        *) ;;
    esac

    QUESTION_NUM=$((QUESTION_NUM + 1))

    LINKED_CRT=$(grep -E '^linked_critique:' "$patch_file" 2>/dev/null | sed 's/^linked_critique:\s*//' | xargs || echo "")
    RATIONALE=$(grep -E '^human_decision_rationale:' "$patch_file" 2>/dev/null | sed 's/^human_decision_rationale:\s*//' | xargs || echo "")
    SEVERITY=$(grep -E '^severity:' "$patch_file" 2>/dev/null | sed 's/^severity:\s*//' | xargs || echo "")

    # Extract before/after.
    BEFORE=$(sed -n '/^proposed_change:/,/^[a-z]/p' "$patch_file" 2>/dev/null | grep -A 10 'before:' | grep -v 'before:' | sed 's/^\s*//' | head -5 || echo "see patch file")
    AFTER=$(sed -n '/^proposed_change:/,/^[a-z]/p' "$patch_file" 2>/dev/null | grep -A 10 'after:' | grep -v 'after:' | sed 's/^\s*//' | head -5 || echo "see patch file")

    # Extract options.
    echo "## Q$QUESTION_NUM: $PP_ID"
    echo ""
    echo "**Trigger**: $LINKED_CRT (severity: $SEVERITY)"
    echo ""
    echo "**Why this needs your decision**: $RATIONALE"
    echo ""
    echo "**Proposed change**:"
    echo ""
    echo "- Before: $BEFORE"
    echo "- After: $AFTER"
    echo ""
    echo "**Options**:"
    echo ""

    # Extract options from the patch.
    OPT_COUNT=$(grep -cE '^\s+- label:' "$patch_file" 2>/dev/null || echo 0)
    if [ "$OPT_COUNT" -gt 0 ]; then
        local i=0
        while IFS= read -r line; do
            [ -z "$line" ] && continue
            i=$((i + 1))
            label=$(echo "$line" | sed 's/.*label:\s*//' | tr -d '"' | xargs)
            echo "  $i. $label"
        done < <(grep -E '^\s+- label:' "$patch_file" 2>/dev/null)
    else
        echo "  1. Accept the proposed change"
        echo "  2. Reject the proposed change"
        echo "  3. Request modifications"
    fi

    echo ""

    # Agent recommendation.
    AGENT_CHOICE=$(grep -E '^\s+choice:' "$patch_file" 2>/dev/null | head -1 | sed 's/.*choice:\s*//' | tr -d '"' | xargs || echo "")
    AGENT_REASON=$(grep -E '^\s+reason:' "$patch_file" 2>/dev/null | head -1 | sed 's/.*reason:\s*//' | tr -d '"' | xargs || echo "")
    if [ -n "$AGENT_CHOICE" ]; then
        echo "**Agent recommendation**: $AGENT_CHOICE"
        [ -n "$AGENT_REASON" ] && echo "  Reason: $AGENT_REASON"
        echo ""
    fi

    echo "---"
    echo ""
done

if [ "$QUESTION_NUM" -eq 0 ]; then
    echo "No pending human judgment questions."
fi
