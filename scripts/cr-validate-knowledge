#!/usr/bin/env bash
# cr-validate-knowledge — Knowledge distillation validation.
# Authoritative source: knowledge-delta.yaml + knowledge-apply-log.yaml.
# knowledge-delta.md is a human-readable report (L2, not validated).
#
# Usage: cr-validate-knowledge <round_dir>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

ROUND_DIR="${1:-}"

if [ -z "$ROUND_DIR" ]; then
    echo "Usage: cr-validate-knowledge <round_dir>" >&2
    exit 2
fi

ROUND_NAME="$(basename "$ROUND_DIR")"
echo ""
echo "══ Knowledge Validation: $ROUND_NAME ══"

ALL_PASSED=true

# ── knowledge-delta.yaml (L1 authoritative) ──────────────────────

DELTA_FILE="$ROUND_DIR/knowledge-delta.yaml"
if [ -f "$DELTA_FILE" ]; then
    pass "knowledge-delta.yaml exists"

    # Schema validation.
    SCHEMA_FILE=$(cr_schema_path "knowledge-delta.schema.json")
    if [ -n "$SCHEMA_FILE" ] && [ -f "$SCHEMA_FILE" ]; then
        if cr_validate_schema "$DELTA_FILE" "$SCHEMA_FILE" "yaml" 2>/dev/null; then
            pass "  Schema valid"
        else
            fail "  Schema validation failed"
            ALL_PASSED=false
        fi
    fi

    UPDATE_COUNT=$(yq -r '.updates | length // 0' "$DELTA_FILE" 2>/dev/null || echo "0")
    NO_JUST=$(yq -r '.no_update_justification // ""' "$DELTA_FILE" 2>/dev/null || echo "")

    if [ "${UPDATE_COUNT:-0}" -eq 0 ]; then
        if [ -z "$NO_JUST" ] || [ "$NO_JUST" = "null" ]; then
            fail "knowledge-delta.yaml has no updates and no no_update_justification"
            ALL_PASSED=false
        else
            pass "  No updates with justification: ${NO_JUST:0:80}..."
        fi
    else
        pass "  $UPDATE_COUNT knowledge update(s)"

        # Validate each update.
        for i in $(seq 0 $((UPDATE_COUNT - 1))); do
            UID_VAL=$(yq -r ".updates[$i].update_id // \"\"" "$DELTA_FILE" 2>/dev/null || echo "")
            UTYPE=$(yq -r ".updates[$i].update_type // \"\"" "$DELTA_FILE" 2>/dev/null || echo "")
            UOP=$(yq -r ".updates[$i].operation // \"\"" "$DELTA_FILE" 2>/dev/null || echo "")
            USCOPE=$(yq -r ".updates[$i].scope // \"\"" "$DELTA_FILE" 2>/dev/null || echo "")
            TARGET=$(yq -r ".updates[$i].target_path // \"\"" "$DELTA_FILE" 2>/dev/null || echo "")
            HAS_PATCHES=$(yq -r ".updates[$i].generated_from.patches // [] | length" "$DELTA_FILE" 2>/dev/null || echo "0")
            HAS_CRITS=$(yq -r ".updates[$i].generated_from.critiques // [] | length" "$DELTA_FILE" 2>/dev/null || echo "0")
            HAS_EVIDENCE=$(yq -r ".updates[$i].generated_from.evidence // [] | length" "$DELTA_FILE" 2>/dev/null || echo "0")

            if [ -z "$UTYPE" ] || [ "$UTYPE" = "null" ]; then
                fail "  $UID_VAL: missing update_type"
                ALL_PASSED=false
            fi
            if [ -z "$UOP" ] || [ "$UOP" = "null" ]; then
                fail "  $UID_VAL: missing operation"
                ALL_PASSED=false
            fi

            # Non-noop updates (scope != project_local) need target_path.
            if [ "$USCOPE" != "project_local" ]; then
                if [ -z "$TARGET" ] || [ "$TARGET" = "null" ]; then
                    fail "  $UID_VAL (scope=$USCOPE): missing target_path"
                    ALL_PASSED=false
                fi
            fi

            # Each non-project-local update must be traceable to a patch, critique, or evidence.
            if [ "$USCOPE" != "project_local" ]; then
                if [ "${HAS_PATCHES:-0}" -eq 0 ] && [ "${HAS_CRITS:-0}" -eq 0 ] && [ "${HAS_EVIDENCE:-0}" -eq 0 ]; then
                    fail "  $UID_VAL (scope=$USCOPE): not linked to any patch, critique, or evidence"
                    ALL_PASSED=false
                fi
                # Must be covered by apply-log.
                HIT=$(yq -r "[.applied_updates[]? | select(.update_id == "$UID_VAL")] | length" "$APPLY_FILE" 2>/dev/null || echo "0")
                if [ "${HIT:-0}" -eq 0 ]; then
                    fail "  $UID_VAL (scope=$USCOPE): missing from knowledge-apply-log.yaml"
                    ALL_PASSED=false
                fi
            fi

            pass "  $UID_VAL: type=$UTYPE op=$UOP scope=$USCOPE"
        done
    fi
else
    fail "knowledge-delta.yaml not found — L1 knowledge transaction required"
    ALL_PASSED=false
fi

# ── knowledge-apply-log.yaml (L1 authoritative) ──────────────────

APPLY_FILE="$ROUND_DIR/knowledge-apply-log.yaml"
if [ -f "$APPLY_FILE" ]; then
    APPLY_COUNT=$(yq -r '.applied_updates | length // 0' "$APPLY_FILE" 2>/dev/null || echo "0")
    IDX_COUNT=$(yq -r '.index_updates | length // 0' "$APPLY_FILE" 2>/dev/null || echo "0")

    if [ "${APPLY_COUNT:-0}" -gt 0 ] || [ "${IDX_COUNT:-0}" -gt 0 ]; then
        pass "knowledge-apply-log.yaml: $APPLY_COUNT applied, $IDX_COUNT index updates"

        # Check each applied update has a target_path that exists.
        for i in $(seq 0 $((APPLY_COUNT - 1))); do
            AUID=$(yq -r ".applied_updates[$i].update_id // \"\"" "$APPLY_FILE" 2>/dev/null || echo "")
            ATARGET=$(yq -r ".applied_updates[$i].target_path // \"\"" "$APPLY_FILE" 2>/dev/null || echo "")
            if [ -n "$ATARGET" ] && [ "$ATARGET" != "null" ]; then
                WORKSPACE_ROOT="$(cr_workspace_root)"
                if [ -f "$WORKSPACE_ROOT/$ATARGET" ] || [ -f "$ATARGET" ]; then
                    pass "  $AUID: target exists ($ATARGET)"
                else
                    fail "  $AUID: target not found ($ATARGET)"
                    ALL_PASSED=false
                fi
            fi
        done
    else
        # Empty apply log is OK if knowledge-delta also has no bank_updates.
        if [ "${UPDATE_COUNT:-0}" -gt 0 ]; then
            BANK_UPDATES=$(yq -r '[.updates[] | select(.scope == "bank_update")] | length' "$DELTA_FILE" 2>/dev/null || echo "0")
            if [ "${BANK_UPDATES:-0}" -gt 0 ]; then
                fail "knowledge-delta.yaml has bank_update entries but knowledge-apply-log.yaml is empty"
                ALL_PASSED=false
            else
                pass "knowledge-apply-log.yaml: empty (no bank updates to apply)"
            fi
        else
            pass "knowledge-apply-log.yaml: empty"
        fi
    fi
else
    warn "knowledge-apply-log.yaml not found"
fi

# ── Knowledge Implication on patches (unchanged from before) ─────

PATCHES_DIR="$ROUND_DIR/patches"
if [ -d "$PATCHES_DIR" ]; then
    PATCH_FILES=$(find "$PATCHES_DIR" -name 'PP-*.yaml' -type f 2>/dev/null || echo "")
    if [ -n "$PATCH_FILES" ]; then
        for patch_file in $PATCH_FILES; do
            PATCH_ID=$(basename "$patch_file" .yaml)
            HAS_KNOWLEDGE_IMPL=$(grep -cE '^knowledge_implication:' "$patch_file" 2>/dev/null || echo 0)
            if [ "$HAS_KNOWLEDGE_IMPL" -ge 1 ]; then
                pass "$PATCH_ID: knowledge_implication present"
            else
                fail "$PATCH_ID: missing knowledge_implication field"
                ALL_PASSED=false
            fi
        done
    fi
fi

if [ "$ALL_PASSED" = false ]; then
    cr_exit_summary
fi

pass "Knowledge validation passed"
cr_exit_summary
