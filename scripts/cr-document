#!/usr/bin/env bash
# cr-document — Document management for CriticalResearch v2.
# Subcommands: add, list, status.
#
# Usage:
#   cr document add <project> <doc-id> --type <type> --path <path>
#   cr document list <project>
#   cr document status <project> <doc-id>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

usage() {
    echo "Usage: cr document <add|list|status> [args...]"
    echo ""
    echo "  add <project> <doc-id> --type <type> --path <path>"
    echo "      Register a new document in the project."
    echo ""
    echo "  list <project>"
    echo "      List all documents in the project."
    echo ""
    echo "  status <project> <doc-id>"
    echo "      Show document details and unit count."
    exit 2
}

SUBCOMMAND="${1:-}"
shift 2>/dev/null || true

if [ -z "$SUBCOMMAND" ]; then
    usage
fi

WORKSPACE_ROOT="$(cr_workspace_root)"

# ── Validate project exists ───────────────────────────────────────

validate_project() {
    local proj="$1"
    local proj_dir="$WORKSPACE_ROOT/$proj"
    if [ ! -d "$proj_dir" ] || [ ! -f "$proj_dir/project.yaml" ]; then
        echo "Error: project '$proj' not found at $proj_dir" >&2
        exit 1
    fi
    echo "$proj_dir"
}

# ── Valid document types ──────────────────────────────────────────

VALID_TYPES="survey design-doc paper proposal experiment-plan"

is_valid_type() {
    local t="$1"
    for vt in $VALID_TYPES; do
        [ "$t" = "$vt" ] && return 0
    done
    return 1
}

# ── Document add ──────────────────────────────────────────────────

cmd_add() {
    local project="${1:-}"
    local doc_id="${2:-}"
    shift 2 2>/dev/null || true

    if [ -z "$project" ] || [ -z "$doc_id" ]; then
        echo "Usage: cr document add <project> <doc-id> --type <type> --path <path>" >&2
        exit 2
    fi

    local doc_type=""
    local doc_path=""

    # Parse --type and --path flags.
    while [ $# -gt 0 ]; do
        case "$1" in
            --type)
                doc_type="${2:-}"
                shift 2
                ;;
            --path)
                doc_path="${2:-}"
                shift 2
                ;;
            *)
                echo "Error: unknown flag '$1'" >&2
                exit 2
                ;;
        esac
    done
    # Validate project exists before any other checks.
    local proj_dir
    proj_dir=$(validate_project "$project")

    # Infer type from doc-id if not explicitly given.
    if [ -z "$doc_type" ]; then
        if is_valid_type "$doc_id"; then
            doc_type="$doc_id"
        else
            echo "Error: unknown document type. Must be one of: $VALID_TYPES" >&2
            echo "  Use --type <type> to specify the document type explicitly." >&2
            exit 2
        fi
    else
        if ! is_valid_type "$doc_type"; then
            echo "Error: unknown document type '$doc_type'. Must be one of: $VALID_TYPES" >&2
            exit 2
        fi
    fi

    # Infer path from doc-id if not explicitly given.
    if [ -z "$doc_path" ]; then
        doc_path="documents/${doc_id}.md"
    fi

    # Validate path is inside documents/.
    case "$doc_path" in
        documents/*.md) ;;
        *)
            echo "Error: path must be under documents/ and end with .md: $doc_path" >&2
            exit 2
            ;;
    esac

    local registry_file="$proj_dir/documents/registry.yaml"
    local units_dir="$proj_dir/units"

    # Ensure documents/ and units/ directories exist.
    mkdir -p "$proj_dir/documents" "$units_dir"

    # Check if doc-id already registered.
    if [ -f "$registry_file" ]; then
        if grep -q "^  - id: \"$doc_id\"\$" "$registry_file" 2>/dev/null; then
            echo "Error: document '$doc_id' already exists in registry" >&2
            exit 1
        fi
    fi

    # Check if document file already exists.
    local doc_file="$proj_dir/$doc_path"
    if [ -f "$doc_file" ]; then
        echo "Error: document file already exists: $doc_path" >&2
        exit 1
    fi

    # Create document directory if needed.
    mkdir -p "$(dirname "$doc_file")"

    # Create minimal template header.
    local now
    now="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
    local title=""
    case "$doc_type" in
        survey)       title="Literature Survey" ;;
        design-doc)   title="Design Document" ;;
        paper)        title="Research Paper" ;;
        proposal)     title="Research Proposal" ;;
        experiment-plan) title="Experiment Plan" ;;
    esac

    cat > "$doc_file" << DOC
# $title

**Document ID:** $doc_id
**Type:** $doc_type
**Created:** $now
**Status:** active

---

DOC

    # Append to registry.
    if [ ! -f "$registry_file" ]; then
        # Create new registry.
        cat > "$registry_file" << REG
documents:
REG
    fi

    cat >> "$registry_file" << ENTRY
  - id: "$doc_id"
    type: "$doc_type"
    path: "$doc_path"
    status: active
    created_at: "$now"
ENTRY

    # Update project.yaml documents array.
    local project_yaml="$proj_dir/project.yaml"
    if [ -f "$project_yaml" ]; then
        # Check if documents key exists in project.yaml.
        if grep -q '^documents:' "$project_yaml" 2>/dev/null; then
            # Append to existing documents array.
            cat >> "$project_yaml" << PDOC
  - id: "$doc_id"
    type: "$doc_type"
    path: "$doc_path"
    status: active
PDOC
        else
            # Add documents section.
            cat >> "$project_yaml" << PDOC
documents:
  - id: "$doc_id"
    type: "$doc_type"
    path: "$doc_path"
    status: active
PDOC
        fi
    fi

    # Create units file with empty units list.
    local units_file="$units_dir/${doc_id}.units.yaml"
    cat > "$units_file" << UNITS
units: []
UNITS

    echo "Document '$doc_id' registered (type: $doc_type, path: $doc_path)"
}

# ── Document list ─────────────────────────────────────────────────

cmd_list() {
    local project="${1:-}"

    if [ -z "$project" ]; then
        echo "Usage: cr document list <project>" >&2
        exit 2
    fi

    local proj_dir
    proj_dir=$(validate_project "$project")

    local registry_file="$proj_dir/documents/registry.yaml"

    if [ ! -f "$registry_file" ]; then
        echo "No documents registered in project '$project'."
        exit 0
    fi

    echo "Documents in project '$project':"
    echo ""

    # Parse and display registry entries.
    local count=0
    while IFS= read -r line; do
        if echo "$line" | grep -q '^  - id:'; then
            local eid
            eid=$(echo "$line" | sed 's/^  - id: *"\(.*\)"$/\1/')
            count=$((count + 1))
            # Read ahead for type, path, status.
            local etype="" epath="" estatus=""
            if IFS= read -r l2; then
                etype=$(echo "$l2" | sed -n 's/^    type: *"\(.*\)"$/\1/p')
            fi
            if IFS= read -r l3; then
                epath=$(echo "$l3" | sed -n 's/^    path: *"\(.*\)"$/\1/p')
            fi
            if IFS= read -r l4; then
                estatus=$(echo "$l4" | sed -n 's/^    status: *"\(.*\)"$/\1/p')
            fi
            printf "  %-20s type: %-16s path: %-30s status: %s\n" \
                "$eid" "$etype" "$epath" "${estatus:-active}"
        fi
    done < "$registry_file"

    if [ "$count" -eq 0 ]; then
        echo "  (no documents)"
    fi
}

# ── Document status ───────────────────────────────────────────────

cmd_status() {
    local project="${1:-}"
    local doc_id="${2:-}"

    if [ -z "$project" ] || [ -z "$doc_id" ]; then
        echo "Usage: cr document status <project> <doc-id>" >&2
        exit 2
    fi

    local proj_dir
    proj_dir=$(validate_project "$project")

    local registry_file="$proj_dir/documents/registry.yaml"

    if [ ! -f "$registry_file" ]; then
        echo "Error: no document registry found for project '$project'" >&2
        exit 1
    fi

    # Find the document entry.
    local found=false
    local eid etype epath estatus ecreated
    while IFS= read -r line; do
        if echo "$line" | grep -q "^  - id: \"$doc_id\"\$"; then
            found=true
            eid="$doc_id"
            if IFS= read -r l2; then
                etype=$(echo "$l2" | sed -n 's/^    type: *"\(.*\)"$/\1/p')
            fi
            if IFS= read -r l3; then
                epath=$(echo "$l3" | sed -n 's/^    path: *"\(.*\)"$/\1/p')
            fi
            if IFS= read -r l4; then
                estatus=$(echo "$l4" | sed -n 's/^    status: *"\(.*\)"$/\1/p')
            fi
            if IFS= read -r l5; then
                ecreated=$(echo "$l5" | sed -n 's/^    created_at: *"\(.*\)"$/\1/p')
            fi
            break
        fi
    done < "$registry_file"

    if [ "$found" != true ]; then
        echo "Error: document '$doc_id' not found in project '$project'" >&2
        exit 1
    fi

    echo "Document: $doc_id"
    echo "  Type:       ${etype:-unknown}"
    echo "  Path:       ${epath:-unknown}"
    echo "  Status:     ${estatus:-active}"
    echo "  Created:    ${ecreated:-unknown}"

    # Show unit count.
    local units_file="$proj_dir/units/${doc_id}.units.yaml"
    local unit_count=0
    if [ -f "$units_file" ]; then
        unit_count=$(grep -c '^  - id:' "$units_file" 2>/dev/null || true)
    fi
    echo "  Units:      $unit_count"

    # Show if document file exists.
    if [ -n "${epath:-}" ] && [ -f "$proj_dir/$epath" ]; then
        echo "  File:       exists"
    else
        echo "  File:       missing"
    fi
}

# ── Dispatch ──────────────────────────────────────────────────────

case "$SUBCOMMAND" in
    add)
        cmd_add "$@"
        ;;
    list)
        cmd_list "$@"
        ;;
    status)
        cmd_status "$@"
        ;;
    *)
        echo "Error: unknown subcommand '$SUBCOMMAND'" >&2
        usage
        ;;
esac
