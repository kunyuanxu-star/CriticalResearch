#!/usr/bin/env bash
# cr-new-round — Create a new research round (Inv2).
# Creates the round directory with all required file templates.
#
# Usage: cr-new-round <project_dir> [round_type] [--mode paper|triage|standard|deep]
#   round_type: discovery (default), validation, re_search, rebuttal, writing, repair, finalization

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

PROJECT_DIR="${1:-}"
ROUND_TYPE="${2:-discovery}"
WORKFLOW_MODE=""

# Parse --mode flag from remaining args.
shift 2 2>/dev/null || true
while [ $# -gt 0 ]; do
    case "$1" in
        --mode) WORKFLOW_MODE="${2:-}"; shift 2 ;;
        *) shift ;;
    esac
done

if [ -z "$PROJECT_DIR" ]; then
    echo "Usage: cr-new-round <project_dir> [round_type] [--mode paper|triage|standard|deep]" >&2
    echo "  round_type: discovery, validation, re_search, rebuttal, writing, repair, finalization, setup" >&2
    exit 2
fi

if [ ! -d "$PROJECT_DIR" ]; then
    echo "Error: project directory not found: $PROJECT_DIR" >&2
    exit 2
fi

# If no mode specified, detect from project state.
if [ -z "$WORKFLOW_MODE" ]; then
    if [ -f "$PROJECT_DIR/state/project-state.json" ]; then
        WORKFLOW_MODE=$(jq -r '.workflow_mode // "deep"' "$PROJECT_DIR/state/project-state.json" 2>/dev/null || echo "deep")
    fi
    # Also check previous round's mode.
    if [ "$WORKFLOW_MODE" = "deep" ] || [ -z "$WORKFLOW_MODE" ]; then
        last_round=$(find "$PROJECT_DIR/rounds" -name 'round.yaml' -type f 2>/dev/null | sort -r | head -1)
        if [ -n "$last_round" ]; then
            WORKFLOW_MODE=$(grep -E '^workflow_mode:' "$last_round" 2>/dev/null | sed 's/^workflow_mode:\s*//' | xargs || echo "deep")
        fi
    fi
    [ -z "$WORKFLOW_MODE" ] && WORKFLOW_MODE="deep"
fi

# Validate round type.
VALID_TYPES="discovery validation re_search rebuttal writing repair finalization setup"
if ! echo "$VALID_TYPES" | grep -qw "$ROUND_TYPE"; then
    echo "Error: invalid round_type '$ROUND_TYPE'. Valid: $VALID_TYPES" >&2
    exit 2
fi

# Determine next round number.
ROUNDS_DIR="$PROJECT_DIR/rounds"
mkdir -p "$ROUNDS_DIR"

NEXT_ROUND=1
if [ -d "$ROUNDS_DIR" ]; then
    EXISTING=$(find "$ROUNDS_DIR" -maxdepth 1 -type d -name 'round-*' 2>/dev/null | wc -l | tr -d ' ')
    NEXT_ROUND=$((EXISTING + 1))
fi

ROUND_NUM=$(printf "%03d" "$NEXT_ROUND")
ROUND_DIR="$ROUNDS_DIR/round-$ROUND_NUM"

mkdir -p "$ROUND_DIR"

# Extract project_id from project.yaml if available.
PROJECT_ID=""
if [ -f "$PROJECT_DIR/project.yaml" ]; then
    PROJECT_ID=$(grep -E '^project_id:' "$PROJECT_DIR/project.yaml" 2>/dev/null | sed 's/^project_id:\s*//' | tr -d '"' | xargs || echo "unknown")
fi
[ -z "$PROJECT_ID" ] && PROJECT_ID="$(basename "$PROJECT_DIR")"

# Generate required output keys for the given round type.
# Outputs one key per line (no leading spaces — indentation is in the template).
gen_required_outputs() {
    case "$1" in
        setup)        echo "report" ;;
        repair)       printf 'report\nknowledge_delta\n' ;;
        writing)      echo "writing_diff" ;;
        finalization) printf 'report\nwriting_diff\nknowledge_delta\n' ;;
        *)            printf 'report\nevidence_ledger\ncritique_ledger\nwriting_diff_yaml\nknowledge_delta\nknowledge_apply_log\n' ;;
    esac
    if [ "$WORKFLOW_MODE" = "paper" ]; then
        printf 'paper_patch\nexperiment_obligation\n'
    fi
}

NOW=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

# Write round.yaml with proper YAML list under required_outputs.
{
    echo "round_id: $NEXT_ROUND"
    echo "project_id: $PROJECT_ID"
    echo "round_type: $ROUND_TYPE"
    echo "status: open"
    echo "started_at: $NOW"
    echo "completed_at: null"
    echo "target_gap: null"
    echo "workflow_mode: $WORKFLOW_MODE"
    echo "required_outputs:"
    gen_required_outputs "$ROUND_TYPE" | sed 's/^/  - /'
    echo 'notes: ""'
    echo 'schema_version: "1.0.0"'
} > "$ROUND_DIR/round.yaml"

# Paper mode: scaffold paper-mode directories and files.
if [ "$WORKFLOW_MODE" = "paper" ]; then
    mkdir -p "$ROUND_DIR/patches"
    mkdir -p "$ROUND_DIR/experiments"
    mkdir -p "$ROUND_DIR/raw-sources"

    # Create dispositions.yaml template.
    cat > "$ROUND_DIR/dispositions.yaml" << YAML
# Critique Disposition Records
# Each entry links a critique to a patch or decision.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
dispositions: []
# no_disposition_reason: ""
# validated_critiques: []
YAML

    # Create questions.md template.
    cat > "$ROUND_DIR/questions.md" << MD
# Round $NEXT_ROUND — Human Judgment Questions

<!-- Blocking questions that need human decisions before round close. -->

MD

    # Create paper-patches.md summary.
    cat > "$ROUND_DIR/paper-patches.md" << MD
# Round $NEXT_ROUND — Paper Patches

| Patch ID | Critique | Patch Type | Affected Sections | Lifecycle | Human Decision |
|----------|----------|------------|-------------------|-----------|----------------|
|          |          |            |                   |           |                |

MD

    # Create experiment-patches.md summary.
    cat > "$ROUND_DIR/experiment-patches.md" << MD
# Round $NEXT_ROUND — Experiment Obligations

| Obligation ID | Target Claim | Baseline | Metric | Status |
|---------------|-------------|----------|--------|--------|
|               |             |          |        |        |

MD

    cat > "$ROUND_DIR/experiment-obligations.yaml" << YAML
# Experiment Obligations
# Records experiment obligations. If empty, no_obligation_reason is required.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
phase: generate_experiment_obligations
obligations: []
# Fill no_obligation_reason if obligations is empty:
no_obligation_reason: ""
# validated_patches must cover all PP-*.yaml if obligations is empty:
validated_patches: []
YAML

    # ── L1 authoritative YAML templates (paper mode) ──────────────

    # Create search-queue.yaml template.
    cat > "$ROUND_DIR/search-queue.yaml" << YAML
# Research Search Queue
# Queries to execute during the execute_retrieval phase.
queries: []
YAML

    cat > "$ROUND_DIR/loaded-knowledge.yaml" << YAML
# Loaded Knowledge
# Global knowledge cards loaded for this round.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
loaded_cards: []
usage_contract:
  must_reference_loaded_cards_in: []
YAML

    cat > "$ROUND_DIR/paper-state.yaml" << YAML
# Paper State
# Snapshot of the current paper's claims, baselines, assumptions, and risks.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
paper_snapshot:
  draft_path: writing/paper-draft.md
  draft_sha256: ""
research_object:
  type: ""
  one_sentence: ""
problem_setting:
  domain: ""
target_properties: []
core_claims: []
main_risks: []
round_recommendation:
  priority: ""
  reason: ""
YAML

    cat > "$ROUND_DIR/round-objective.yaml" << YAML
# Round Objective
# User-specified primary focus for this round. The objective is a weighting lens,
# NOT a scope limiter. Every phase must cover the full paper.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
raw_user_request: ""
normalized_objective: ""
objective_role: primary_focus
scope_policy:
  type: full_paper_required
  objective_may_limit_scope: false
  objective_may_change_priority: true
  objective_may_change_critique_weight: true
  objective_may_change_patch_priority: true
coverage_required:
  entire_paper: true
  all_sections: true
  all_core_claims: true
  all_assumptions: true
  all_baselines: true
  all_evaluation_obligations: true
  all_open_critiques: true
primary_focus:
  type: ""
  description: ""
success_criteria: []
YAML

    cat > "$ROUND_DIR/full-paper-coverage-plan.yaml" << YAML
# Full-Paper Coverage Plan
# Complete inventory of every element that every phase must check.
# No section, claim, assumption, baseline, or evaluation may be excluded.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
paper_inventory:
  sections: []
  claims: []
  assumptions: []
  baselines: []
  evaluation_items: []
coverage_policy:
  all_sections_required: true
  all_claims_required: true
  all_assumptions_required: true
  all_baselines_required: true
  all_evaluation_items_required: true
objective_focus:
  objective_id: current
  focus_type: ""
  priority_weight: high
non_focus_policy:
  if_issue_found: record_as_secondary_finding
  if_severe: create_patch_or_human_decision
YAML

    cat > "$ROUND_DIR/research-questions.yaml" << YAML
# Research Questions
# Structured research questions derived from round risk.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
questions: []
YAML

    cat > "$ROUND_DIR/search-plan.yaml" << YAML
# Search Plan
# Search strategy with query classes and expected evidence types.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
queries: []
required_query_classes:
  - core_problem
  - strongest_baseline
  - recent_top_conference
  - production_or_real_world_case
  - counterexample_or_failure
success_criteria:
  min_queries: 5
  min_sources: 5
  min_s_or_a_sources: 2
  must_find_or_record_failure_for_each_query_class: true
YAML

    cat > "$ROUND_DIR/search-log.yaml" << YAML
# Search Log
# Records every search query executed and which sources were selected.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
searches: []
YAML

    cat > "$ROUND_DIR/source-index.yaml" << YAML
# Source Index
# Index of all raw source snapshots with sha256 hashes.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
sources: []
YAML

    cat > "$ROUND_DIR/evidence-ledger.yaml" << YAML
# Evidence Ledger
# Authoritative structured evidence. Each item links a source and at least one claim.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
evidence: []
YAML

    cat > "$ROUND_DIR/critique-ledger.yaml" << YAML
# Critique Ledger
# Structured critique entries attacking claims, baselines, or assumptions.
# If no medium+ critiques were found, fill no_medium_plus_critique instead.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
critiques: []
# no_medium_plus_critique:
#   reason: ""
#   checked_claims: []
#   reviewer_lenses: []
YAML

    cat > "$ROUND_DIR/literature-knowledge-delta.yaml" << YAML
# Literature Knowledge Delta
# Literature card updates from source notes.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
updates: []
YAML

    cat > "$ROUND_DIR/thinking-knowledge-delta.yaml" << YAML
# Thinking Knowledge Delta
# Thinking rules derived from critique failures and reviewer patterns.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
updates: []
YAML

    cat > "$ROUND_DIR/source-triage.yaml" << YAML
# Source Triage
# Include/exclude/maybe decisions per source.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
triage: []
YAML

    mkdir -p "$ROUND_DIR/source-notes"

    cat > "$ROUND_DIR/related-work-map.yaml" << YAML
# Related Work Map
# Baseline families, closest work, positioning risks.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
baseline_families: []
closest_work: []
dangerous_prior_work: []
positioning_risks: []
YAML

    cat > "$ROUND_DIR/claim-evidence-matrix.yaml" << YAML
# Claim-Evidence Matrix
# Per-claim evidence summary with support levels.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
claim_rows: []
YAML

    cat > "$ROUND_DIR/baseline-positioning.yaml" << YAML
# Baseline Positioning
# Strongest baseline, novelty threat, required changes.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
strongest_baseline: {}
novelty_threat: ""
required_positioning_change: ""
YAML

    cat > "$ROUND_DIR/evaluation-gap-map.yaml" << YAML
# Evaluation Gap Map
# Per-claim evaluation contract and gap assessment.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
gap_map: []
YAML

    cat > "$ROUND_DIR/critique-claim-precision.yaml" << YAML
# Critique: Claim Precision
# Falsifiability, scope clarity, term definitions per claim.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
assessments: []
YAML

    cat > "$ROUND_DIR/critique-novelty-baseline.yaml" << YAML
# Critique: Novelty & Baselines
# Novelty and baseline coverage assessment.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
baseline_assessments: []
YAML

    cat > "$ROUND_DIR/critique-evidence.yaml" << YAML
# Critique: Evidence
# Evidence sufficiency judgments per claim.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
evidence_judgments: []
YAML

    cat > "$ROUND_DIR/critique-evaluation.yaml" << YAML
# Critique: Evaluation
# Evaluation contract critique.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
evaluation_assessments: []
YAML

    cat > "$ROUND_DIR/critique-writing.yaml" << YAML
# Critique: Writing Argument
# Argument chain review with section anchors.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
argument_checks: []
YAML

    cat > "$ROUND_DIR/human-decisions.yaml" << YAML
# Human Decisions
# Resolved human decisions from this round.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
decisions: []
YAML

    cat > "$ROUND_DIR/writing-plan.yaml" << YAML
# Writing Plan
# Ordered plan for applying patches to draft sections.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
target_sections: []
patch_order: []
do_not_touch_sections: []
YAML

    cat > "$ROUND_DIR/patch-application-report.yaml" << YAML
# Patch Application Report
# Post-apply verification report for patches.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
verification: []
YAML

    cat > "$ROUND_DIR/argument-flow-report.yaml" << YAML
# Argument Flow Report
# Global argument chain consistency check.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
flow_checks:
  introduction_chain: ""
  motivation_to_problem: ""
  design_to_evaluation: ""
  conclusion_to_claims: ""
YAML

    cat > "$ROUND_DIR/claim-paper-matrix.yaml" << YAML
# Claim-Paper Alignment Matrix
# Cross-reference: paper claims vs claim-ledger vs evidence level.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
mapping: []
YAML

    cat > "$ROUND_DIR/reviewer-readiness.yaml" << YAML
# Reviewer Readiness
# Pre-submission check: remaining objections and known weaknesses.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
remaining_objections: []
likely_reviewer_questions: []
known_weaknesses: []
YAML

    cat > "$ROUND_DIR/next-round-targets.yaml" << YAML
# Next Round Targets
# Candidate risks and priorities for next round.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
candidate_risks: []
priority: []
blocked_items: []
YAML

    cat > "$ROUND_DIR/writing-diff.yaml" << YAML
# Writing Diff
# Structured record of draft changes applied this round.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
draft_before_sha256: ""
draft_after_sha256: ""
changes: []
YAML

    cat > "$ROUND_DIR/knowledge-delta.yaml" << YAML
# Knowledge Delta
# Reusable knowledge generated this round. Authoritative; knowledge-delta.md is a report.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
updates: []
YAML

    cat > "$ROUND_DIR/knowledge-apply-log.yaml" << YAML
# Knowledge Apply Log
# Records that knowledge updates were actually written back to the global bank.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
applied_updates: []
index_updates: []
YAML

    cat > "$ROUND_DIR/closure-report.yaml" << YAML
# Closure Report
# Generated by cr close-round when all validators pass. Do not edit manually.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
closed_at: null
validator_results: {}
YAML

    # Generate state.yaml from template.
    STATE_TEMPLATE="$(cr_skill_home)/templates/round-state.yaml"
    if [ -f "$STATE_TEMPLATE" ]; then
        cp "$STATE_TEMPLATE" "$ROUND_DIR/state.yaml"
        if command -v yq >/dev/null 2>&1; then
            yq -i '.project_id = "'"$PROJECT_ID"'" | .round_id = '"$NEXT_ROUND" "$ROUND_DIR/state.yaml"
        else
            sed -i '' "s/^project_id:.*/project_id: $PROJECT_ID/" "$ROUND_DIR/state.yaml" 2>/dev/null || \
                sed -i "s/^project_id:.*/project_id: $PROJECT_ID/" "$ROUND_DIR/state.yaml"
            sed -i '' "s/^round_id:.*/round_id: $NEXT_ROUND/" "$ROUND_DIR/state.yaml" 2>/dev/null || \
                sed -i "s/^round_id:.*/round_id: $NEXT_ROUND/" "$ROUND_DIR/state.yaml"
        fi
    else
        echo "  Warning: round-state.yaml template not found -- skipping state.yaml"
    fi

    cat > "$ROUND_DIR/patches/.no-patch.yaml" << YAML
# Patch No-Op Record
# Fill this if no paper patches were generated this round.
schema_version: "1.0.0"
round_id: $NEXT_ROUND
no_patch_reason: ""
validated_dispositions: []
YAML

    echo "  Paper mode: patches/, experiments/, raw-sources/, state.yaml, dispositions.yaml, questions.md"
fi

# Write empty report template.
cat > "$ROUND_DIR/report.md" << MD
# Round $NEXT_ROUND Report

## Objective



## Key Findings



## Decisions Made



## Next Steps


MD

# Write empty sources template.
cat > "$ROUND_DIR/sources.md" << MD
# Round $NEXT_ROUND — Sources

<!-- Each source entry must include: title, source_type, why_relevant, supports, weakens, does_not_support, understanding_delta -->

MD

# Write empty critique template.
cat > "$ROUND_DIR/critique.md" << MD
# Round $NEXT_ROUND — Critique

<!-- Each critique entry must include: critique_id, target_claim, severity, attack_type, attack_statement, why_damaging, required_action, status -->

MD

# Write empty writing diff template.
cat > "$ROUND_DIR/writing-diff.md" << MD
# Round $NEXT_ROUND — Writing Diff

## Added


## Deleted


## Weakened


## Reframed


## Still Unstable


MD

# Write empty knowledge delta template.
cat > "$ROUND_DIR/knowledge-delta.md" << MD
# Round $NEXT_ROUND — Knowledge Delta

## Literature Knowledge Updated
<!-- Yes / No -->


## Thinking Knowledge Updated
<!-- Yes / No -->


## Candidate Rules Generated
<!-- List candidate reusable rules, or "None" -->


## Project-Local Insights Only
<!-- Yes / No -->


## If No Updates
<!-- Explain why no reusable knowledge was generated this round -->


MD

# Update project state.
if [ -f "$PROJECT_DIR/state/project-state.json" ]; then
    STATE_DIR="$PROJECT_DIR/state"
    TMP_STATE="$STATE_DIR/project-state.json.tmp"
    jq --arg round "$NEXT_ROUND" --arg now "$NOW" \
        '.active_round = ($round | tonumber) | .total_rounds = ($round | tonumber) | .last_updated = $now' \
        "$PROJECT_DIR/state/project-state.json" > "$TMP_STATE" 2>/dev/null && \
        mv "$TMP_STATE" "$PROJECT_DIR/state/project-state.json" || true
fi

echo "Round $ROUND_NUM created: $ROUND_DIR"
echo "  Type: $ROUND_TYPE"
echo "  Mode: $WORKFLOW_MODE"
echo "  Required outputs: see $ROUND_DIR/round.yaml"
