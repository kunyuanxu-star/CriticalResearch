#!/usr/bin/env bash
# CriticalResearch Stop hook. Gates only active non-terminal or invalid runs.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CR="$SCRIPT_DIR/cr"

workspace_root() {
    local dir="${1:-$(pwd)}"
    while [ "$dir" != "/" ]; do
        if [ -f "$dir/_cr/workspace.yaml" ]; then
            echo "$dir"
            return 0
        fi
        dir="$(dirname "$dir")"
    done
    pwd
}

ROOT="$(workspace_root "${1:-$(pwd)}")"
ACTIVE="$ROOT/_cr/active-project"

if [ ! -f "$ACTIVE" ]; then
    echo '{"decision":"approve"}'
    exit 0
fi

PROJECT="$(tr -d '\n' < "$ACTIVE")"
if [ -z "$PROJECT" ] || [ ! -f "$ROOT/$PROJECT/project.yaml" ]; then
    echo '{"decision":"approve"}'
    exit 0
fi

STATUS="$(CR_WORKSPACE_ROOT="$ROOT" "$CR" status "$PROJECT" --field status 2>/dev/null || echo invalid)"

case "$STATUS" in
    complete|blocked|gated|budget_exhausted)
        set +e
        CR_WORKSPACE_ROOT="$ROOT" "$CR" validate "$PROJECT" >/dev/null 2>&1
        RC=$?
        set -e
        if [ "$RC" -ne 2 ]; then
            echo '{"decision":"approve"}'
            exit 0
        fi
        VALIDATION="$(CR_WORKSPACE_ROOT="$ROOT" "$CR" validate "$PROJECT" 2>&1 || true)"
        jq -n --arg reason "CriticalResearch terminal run failed validation.\n\n$VALIDATION" '{
          decision: "block",
          reason: $reason
        }'
        exit 1
        ;;
    invalid|draft|forming|reviewing|repairing|*)
        jq -n --arg status "$STATUS" '{
          decision: "block",
          reason: ("CriticalResearch run is not terminal (status=" + $status + "). Set status to complete, blocked, gated, or budget_exhausted and run cr validate.")
        }'
        exit 1
        ;;
esac
