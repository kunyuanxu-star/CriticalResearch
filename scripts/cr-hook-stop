#!/usr/bin/env bash
# cr-hook-stop — Stop hook wrapper. Resolves the active project from
# the workspace root and delegates to cr-validate-stop.
#
# Called by .claude/settings.json Stop hook with workspace root as arg.
# This handles the case where CLAUDE_PROJECT_DIR is the workspace root
# (e.g., ~/Research) rather than a specific project directory.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

WORKSPACE_ROOT="${1:-$(cr_workspace_root)}"

# Check if we're directly in a project directory.
if [ -f "$WORKSPACE_ROOT/state/project-state.json" ]; then
    exec "$SCRIPT_DIR/cr-validate-stop" "$WORKSPACE_ROOT" "${2:-}"
fi

# Otherwise, look for active project in workspace.
ACTIVE_PROJECT_FILE="$WORKSPACE_ROOT/_cr/active-project"
if [ -f "$ACTIVE_PROJECT_FILE" ]; then
    ACTIVE_PROJECT=$(cat "$ACTIVE_PROJECT_FILE")
    PROJECT_DIR="$WORKSPACE_ROOT/$ACTIVE_PROJECT"
    if [ -d "$PROJECT_DIR" ]; then
        exec "$SCRIPT_DIR/cr-validate-stop" "$PROJECT_DIR" "${2:-}"
    fi
fi

# No project found — allow stop.
echo '{"decision":"allow"}'
exit 0
