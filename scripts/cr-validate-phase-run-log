#!/usr/bin/env bash
# cr-validate-phase-run-log — Hard gate: every completed phase must have execution proof.
# Validates the phase-run-log.yaml against the state.yaml and actual artifacts.
#
# Usage: cr-validate-phase-run-log <project_dir> <round_dir>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

PROJECT_DIR="${1:-}"
ROUND_DIR="${2:-}"

if [ -z "$PROJECT_DIR" ] || [ -z "$ROUND_DIR" ]; then
    echo "Usage: cr-validate-phase-run-log <project_dir> <round_dir>" >&2
    exit 2
fi

echo "── Phase Run Log Validation ──"

RUN_LOG="$ROUND_DIR/phase-run-log.yaml"
STATE_FILE="$ROUND_DIR/state.yaml"

if [ ! -f "$RUN_LOG" ]; then
    fail "phase-run-log.yaml not found"
    cr_exit_summary
fi

if [ ! -f "$STATE_FILE" ]; then
    fail "state.yaml not found"
    cr_exit_summary
fi

# ── 1. Schema check ──────────────────────────────────────────────

SCHEMA_VERSION=$(yq -r '.schema_version // ""' "$RUN_LOG" 2>/dev/null || echo "")
if [ "$SCHEMA_VERSION" != "1.0.0" ]; then
    fail "phase-run-log schema_version='$SCHEMA_VERSION' (expected 1.0.0)"
fi

EVENTS_COUNT=$(yq -r '.events | length // 0' "$RUN_LOG" 2>/dev/null || echo 0)
if [ "$EVENTS_COUNT" -eq 0 ]; then
    fail "phase-run-log has no events"
    cr_exit_summary
fi

pass "phase-run-log schema valid ($EVENTS_COUNT events)"

# ── 2. Build expected phase order from state.yaml ────────────────

PHASE_ORDER=()
while IFS= read -r p; do
    [ -z "$p" ] && continue
    PHASE_ORDER+=("$p")
done <<< "$(yq -r '.phase_order // [] | .[]' "$STATE_FILE" 2>/dev/null || echo "")"

PHASE_COUNT=${#PHASE_ORDER[@]}
if [ "$PHASE_COUNT" -eq 0 ]; then
    fail "No phases found in state.yaml phase_order"
    cr_exit_summary
fi

# ── 3. Check each completed phase ────────────────────────────────

ERRORS=0
COMPLETED_PHASES=()

for ((i=0; i<PHASE_COUNT; i++)); do
    phase="${PHASE_ORDER[$i]}"
    expected_order=$((i + 1))

    # Check state.yaml status.
    phase_status=$(yq -r ".phases.\"$phase\".status // \"\"" "$STATE_FILE" 2>/dev/null || echo "")

    if [ "$phase_status" != "complete" ]; then
        # Not complete — no run-log entry required.
        continue
    fi

    # Phase is complete in state.yaml — must have run-log proof.
    completed_event=$(yq -r ".events[] | select(.event==\"phase_completed\" and .phase==\"$phase\")" "$RUN_LOG" 2>/dev/null || echo "")
    if [ -z "$completed_event" ] || [ "$completed_event" = "null" ]; then
        fail "Phase '$phase' is complete in state.yaml but has NO phase_completed event in run-log"
        ERRORS=$((ERRORS + 1))
        continue
    fi

    COMPLETED_PHASES+=("$phase")

    # Check order matches.
    actual_order=$(yq -r ".events[] | select(.event==\"phase_completed\" and .phase==\"$phase\") | .order" "$RUN_LOG" 2>/dev/null || echo "0")
    if [ "$actual_order" != "$expected_order" ]; then
        fail "Phase '$phase' completed event has order=$actual_order (expected $expected_order)"
        ERRORS=$((ERRORS + 1))
    fi

    # Check validator.exit_code == 0.
    exit_code=$(yq -r ".events[] | select(.event==\"phase_completed\" and .phase==\"$phase\") | .validator.exit_code // -1" "$RUN_LOG" 2>/dev/null || echo "-1")
    if [ "$exit_code" != "0" ]; then
        fail "Phase '$phase' validator exit_code=$exit_code (expected 0)"
        ERRORS=$((ERRORS + 1))
    fi

    # Check output hashes still match.
    output_hashes=$(yq -r ".events[] | select(.event==\"phase_completed\" and .phase==\"$phase\") | .output_hashes // {}" "$RUN_LOG" 2>/dev/null || echo "{}")
    if [ "$output_hashes" != "{}" ] && [ -n "$output_hashes" ]; then
        # Extract keys from output_hashes.
        keys=$(echo "$output_hashes" | yq -r 'keys | .[]' 2>/dev/null || echo "")
        for key in $keys; do
            [ -z "$key" ] && continue
            stored_hash=$(echo "$output_hashes" | yq -r ".[\"$key\"]" 2>/dev/null || echo "")
            # Resolve path: round-level by default.
            f="$ROUND_DIR/$key"
            if [ -f "$f" ]; then
                current_hash=$(shasum -a 256 "$f" 2>/dev/null | cut -d' ' -f1 || echo "")
            elif [ -d "$f" ]; then
                current_hash=$(find "$f" -type f -exec shasum -a 256 {} \; 2>/dev/null | sort | shasum -a 256 | cut -d' ' -f1 || echo "")
            else
                current_hash=""
            fi
            if [ "$stored_hash" != "$current_hash" ]; then
                fail "Phase '$phase' output '$key' hash mismatch: stored=$stored_hash current=$current_hash"
                ERRORS=$((ERRORS + 1))
            fi
        done
    fi
done

# ── 4. Check no duplicate completed events ───────────────────────

for phase in "${PHASE_ORDER[@]}"; do
    count=$(yq -r "[.events[] | select(.event==\"phase_completed\" and .phase==\"$phase\")] | length" "$RUN_LOG" 2>/dev/null || echo 0)
    if [ "$count" -gt 1 ]; then
        fail "Phase '$phase' has $count completed events (expected 0 or 1)"
        ERRORS=$((ERRORS + 1))
    fi
done

# ── 5. Check close_round has completed event ─────────────────────

CLOSE_EVENT=$(yq -r ".events[] | select(.event==\"phase_completed\" and .phase==\"close_round\")" "$RUN_LOG" 2>/dev/null || echo "")
if [ -n "$CLOSE_EVENT" ] && [ "$CLOSE_EVENT" != "null" ]; then
    pass "close_round has completed event"
else
    # close_round may not be complete yet — only warn, don't fail.
    warn "close_round has no completed event (round may not be closed yet)"
fi

# ── 6. Check state.yaml complete count matches run-log ───────────

STATE_COMPLETE=$(yq -r '[.phases | to_entries[] | select(.value.status=="complete")] | length' "$STATE_FILE" 2>/dev/null || echo 0)
RUNLOG_COMPLETE=$(yq -r '[.events[] | select(.event=="phase_completed")] | length' "$RUN_LOG" 2>/dev/null || echo 0)

if [ "$STATE_COMPLETE" != "$RUNLOG_COMPLETE" ]; then
    fail "state.yaml has $STATE_COMPLETE complete phases, run-log has $RUNLOG_COMPLETE completed events"
    ERRORS=$((ERRORS + 1))
else
    pass "Complete phase count matches: $STATE_COMPLETE/$RUNLOG_COMPLETE"
fi

# ── 7. Check repair-log consistency ──────────────────────────────

REPAIR_LOG="$ROUND_DIR/repair-log.yaml"
if [ -f "$REPAIR_LOG" ]; then
    REPAIR_COUNT=$(yq -r '.repairs | length // 0' "$REPAIR_LOG" 2>/dev/null || echo 0)
    if [ "$REPAIR_COUNT" -gt 0 ]; then
        pass "Repair log has $REPAIR_COUNT entries"
    fi
fi

if [ "$ERRORS" -gt 0 ]; then
    fail "$ERRORS phase-run-log failure(s)"
    cr_exit_summary
fi

pass "Phase run log validation passed"
cr_exit_summary
