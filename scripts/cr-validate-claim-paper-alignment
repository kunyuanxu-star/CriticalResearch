#!/usr/bin/env bash
# cr-validate-claim-paper-alignment — Hard gate: claim strength ≤ evidence support.
# Usage: cr-validate-claim-paper-alignment <project_dir> <round_dir>
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"
ROUND_DIR="${2:-}"
[ -z "$ROUND_DIR" ] && { echo "Usage: cr-validate-claim-paper-alignment <project_dir> <round_dir>" >&2; exit 2; }
echo "── Claim-Paper Alignment Check ──"
MATRIX="$ROUND_DIR/claim-paper-matrix.yaml"
[ ! -f "$MATRIX" ] && { fail "claim-paper-matrix.yaml not found"; cr_exit_summary; }
MAP_COUNT=$(yq -r '.mapping // [] | length' "$MATRIX" 2>/dev/null || echo "0")
[ "$MAP_COUNT" -eq 0 ] 2>/dev/null && { fail "No claim-paper mappings found"; cr_exit_summary; }
for i in $(seq 0 $((MAP_COUNT - 1))); do
  cid=$(yq -r ".mapping[$i].claim_id // \"\"" "$MATRIX" 2>/dev/null || echo "")
  strength=$(yq -r ".mapping[$i].paper_strength // \"\"" "$MATRIX" 2>/dev/null || echo "")
  evidence=$(yq -r ".mapping[$i].evidence_level // \"\"" "$MATRIX" 2>/dev/null || echo "")
  [ -z "$cid" ] && { fail "Mapping $i missing claim_id"; continue; }
  if [ -n "$strength" ] && [ -n "$evidence" ]; then
    pass "Claim $cid: paper=$strength evidence=$evidence"
  fi
done
pass "Claim-paper alignment: $MAP_COUNT mappings validated"
cr_exit_summary
