#!/usr/bin/env bash
# cr-validate-research — Enforce that real research happened this round.
# Checks: research-plan.yaml, search-log.yaml, raw-sources/, source-index.yaml,
# evidence-ledger.yaml, query class coverage, source count, evidence levels,
# and that at least one evidence item weakens/contradicts a claim.
#
# Usage: cr-validate-research <project_dir> <round_dir>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

PROJECT_DIR="${1:-}"
ROUND_DIR="${2:-}"

if [ -z "$PROJECT_DIR" ] || [ -z "$ROUND_DIR" ]; then
    echo "Usage: cr-validate-research <project_dir> <round_dir>" >&2
    exit 2
fi

echo "── Research Enforcement ──"

STATE_FILE="$ROUND_DIR/state.yaml"
PAPER_MODE=false
if [ -f "$STATE_FILE" ]; then
    WM=$(yq -r '.workflow_mode // ""' "$STATE_FILE" 2>/dev/null || echo "")
    [ "$WM" = "paper" ] && PAPER_MODE=true
fi

if [ "$PAPER_MODE" = false ]; then
    # For non-paper modes, research is still required but less strict.
    if [ -f "$STATE_FILE" ]; then
        REQ_RESEARCH=$(yq -r '.required_research // false' "$STATE_FILE" 2>/dev/null || echo "false")
    else
        REQ_RESEARCH=false
    fi
    if [ "$REQ_RESEARCH" != "true" ]; then
        pass "Research not required for this round mode"
        cr_exit_summary
    fi
fi

# Read policy thresholds.
MIN_QUERIES=5
MIN_SOURCES=5
MIN_EVIDENCE=5
MIN_S_OR_A=2
if [ -f "$STATE_FILE" ]; then
    MIN_SOURCES=$(yq -r '.required_min_sources // 5' "$STATE_FILE" 2>/dev/null || echo "5")
    MIN_S_OR_A=$(yq -r '.required_source_levels.min_s_or_a // 2' "$STATE_FILE" 2>/dev/null || echo "2")
fi

ALL_PASSED=true

# 1. Research plan.
if [ -f "$ROUND_DIR/research-plan.yaml" ]; then
    pass "research-plan.yaml exists"
else
    fail "research-plan.yaml is missing"
    ALL_PASSED=false
fi

# 2. Search log.
if [ -f "$ROUND_DIR/search-log.yaml" ]; then
    QUERY_COUNT=$(yq -r '.searches | length // 0' "$ROUND_DIR/search-log.yaml" 2>/dev/null || echo "0")
    if [ "${QUERY_COUNT:-0}" -ge "$MIN_QUERIES" ]; then
        pass "search-log.yaml: $QUERY_COUNT queries (min $MIN_QUERIES)"

        # Check required query classes.
        CLASSES_FOUND=$(yq -r '.searches[].query_class // ""' "$ROUND_DIR/search-log.yaml" 2>/dev/null | sort -u | tr '\n' ' ')
        for req_class in core_problem strongest_baseline recent_top_conference production_or_real_world_case counterexample_or_failure; do
            if echo "$CLASSES_FOUND" | grep -qw "$req_class"; then
                pass "  Query class '$req_class': covered"
            else
                fail "  Query class '$req_class': not covered"
                ALL_PASSED=false
            fi
        done
    else
        fail "search-log.yaml: only $QUERY_COUNT queries (min $MIN_QUERIES)"
        ALL_PASSED=false
    fi
else
    fail "search-log.yaml is missing"
    ALL_PASSED=false
fi

# 3. Raw sources.
if [ -d "$ROUND_DIR/raw-sources" ]; then
    SRC_COUNT=$(find "$ROUND_DIR/raw-sources" -type f \( -name 'S*.json' -o -name 'S*.yaml' -o -name 'S*.md' \) 2>/dev/null | wc -l | tr -d ' ')
    if [ "${SRC_COUNT:-0}" -ge "$MIN_SOURCES" ]; then
        pass "raw-sources/: $SRC_COUNT source snapshots (min $MIN_SOURCES)"
    else
        fail "raw-sources/: only $SRC_COUNT source snapshots (min $MIN_SOURCES)"
        ALL_PASSED=false
    fi
else
    fail "raw-sources/ directory is missing"
    ALL_PASSED=false
fi

# 4. Source index.
if [ -f "$ROUND_DIR/source-index.yaml" ]; then
    IDX_COUNT=$(yq -r '.sources | length // 0' "$ROUND_DIR/source-index.yaml" 2>/dev/null || echo "0")
    if [ "${IDX_COUNT:-0}" -ge "$MIN_SOURCES" ]; then
        pass "source-index.yaml: $IDX_COUNT entries"

        # Check sha256 on each source.
        SHA_MISSING=0
        for i in $(seq 0 $((IDX_COUNT - 1))); do
            SRC_SHA=$(yq -r ".sources[$i].sha256 // \"\"" "$ROUND_DIR/source-index.yaml" 2>/dev/null || echo "")
            if [ -z "$SRC_SHA" ] || [ "$SRC_SHA" = "null" ]; then
                SHA_MISSING=$((SHA_MISSING + 1))
            fi
        done
        if [ "$SHA_MISSING" -gt 0 ]; then
            fail "source-index.yaml: $SHA_MISSING source(s) missing sha256"
            ALL_PASSED=false
        else
            pass "  All sources have sha256 hashes"
        fi
    else
        fail "source-index.yaml: only $IDX_COUNT entries (min $MIN_SOURCES)"
        ALL_PASSED=false
    fi
else
    fail "source-index.yaml is missing"
    ALL_PASSED=false
fi

# 4b. Provenance: search-log.selected_sources must appear in source-index.
if [ -f "$ROUND_DIR/search-log.yaml" ] && [ -f "$ROUND_DIR/source-index.yaml" ]; then
    SELECTED=$(yq -r '.searches[]?.selected_sources[]? // ""' "$ROUND_DIR/search-log.yaml" 2>/dev/null | sort -u || echo "")
    INDEXED=$(yq -r '.sources[]?.source_id // ""' "$ROUND_DIR/source-index.yaml" 2>/dev/null | sort -u || echo "")
    PROV_FAIL=0
    for sid in $SELECTED; do
        [ -z "$sid" ] && continue
        if ! echo "$INDEXED" | grep -qw "$sid"; then
            fail "  selected source $sid not found in source-index.yaml"
            PROV_FAIL=$((PROV_FAIL + 1))
            ALL_PASSED=false
        fi
    done
    [ "$PROV_FAIL" -eq 0 ] && pass "  All selected_sources appear in source-index.yaml"
fi

# 5. Evidence ledger.
if [ -f "$ROUND_DIR/evidence-ledger.yaml" ]; then
    EVID_COUNT=$(yq -r '.evidence | length // 0' "$ROUND_DIR/evidence-ledger.yaml" 2>/dev/null || echo "0")
    if [ "${EVID_COUNT:-0}" -ge "$MIN_EVIDENCE" ]; then
        pass "evidence-ledger.yaml: $EVID_COUNT entries (min $MIN_EVIDENCE)"

        # Count S/A level evidence.
        SA_COUNT=$(yq -r '[.evidence[] | select(.evidence_level == "S" or .evidence_level == "A")] | length' "$ROUND_DIR/evidence-ledger.yaml" 2>/dev/null || echo "0")
        if [ "${SA_COUNT:-0}" -ge "$MIN_S_OR_A" ]; then
            pass "  S/A-level evidence: $SA_COUNT (min $MIN_S_OR_A)"
        else
            fail "  S/A-level evidence: only $SA_COUNT (min $MIN_S_OR_A)"
            ALL_PASSED=false
        fi

        # Check every evidence links to source_id and at least one claim.
        NO_SRC=0
        NO_CLM=0
        for i in $(seq 0 $((EVID_COUNT - 1))); do
            SID=$(yq -r ".evidence[$i].source_id // \"\"" "$ROUND_DIR/evidence-ledger.yaml" 2>/dev/null || echo "")
            [ -z "$SID" ] || [ "$SID" = "null" ] && NO_SRC=$((NO_SRC + 1))
            CLM_COUNT=$(yq -r ".evidence[$i].related_claims | length // 0" "$ROUND_DIR/evidence-ledger.yaml" 2>/dev/null || echo "0")
            [ "${CLM_COUNT:-0}" -eq 0 ] && NO_CLM=$((NO_CLM + 1))
        done
        if [ "$NO_SRC" -gt 0 ]; then
            fail "  $NO_SRC evidence item(s) missing source_id link"
            ALL_PASSED=false
        fi
        if [ "$NO_CLM" -gt 0 ]; then
            fail "  $NO_CLM evidence item(s) missing claim links"
            ALL_PASSED=false
        fi

        # At least one weakening or contradicting evidence.
        WEAK_COUNT=$(yq -r '[.evidence[] | select(.relation == "weakens" or .relation == "contradicts")] | length' "$ROUND_DIR/evidence-ledger.yaml" 2>/dev/null || echo "0")
        if [ "${WEAK_COUNT:-0}" -gt 0 ]; then
            pass "  Weakening/contradicting evidence: $WEAK_COUNT item(s)"
        else
            fail "  No weakening or contradicting evidence found. At least one item must weaken/contradict a core claim."
            ALL_PASSED=false
        fi
    else
        fail "evidence-ledger.yaml: only $EVID_COUNT entries (min $MIN_EVIDENCE)"
        ALL_PASSED=false
    fi
else
    fail "evidence-ledger.yaml is missing"
    ALL_PASSED=false
fi

if [ "$ALL_PASSED" = false ]; then
    cr_exit_summary
fi

pass "Research enforcement: all checks passed"
cr_exit_summary
