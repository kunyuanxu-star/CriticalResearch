#!/usr/bin/env bash
# cr-step — Stage state machine for paper rounds.
# Usage: cr step <project> <subcommand> [args...]
#
# Subcommands:
#   status         Show current stage and what's missing
#   status --machine  Machine-readable output (for hook injection)
#   current        Print current stage name only
#   start          Set current stage to running
#   advance        Auto-start (open->running) then validate and advance
#   validate       Validate current stage only (no advance)
#   validate --stop-gate  Validate for stop hook (returns JSON)
#   set-stage <s>  Manually set current stage (for repair)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

WORKSPACE_ROOT="$(cr_workspace_root)"

usage() {
    echo "Usage: cr step <project> <subcommand> [args...]"
    echo ""
    echo "Subcommands:"
    echo "  status          Show current stage and missing requirements"
    echo "  current         Print current stage name only"
    echo "  start           Set current stage to running (open->running)"
    echo "  advance         Validate current stage and advance to next"
    echo "  validate        Validate current stage without advancing"
    echo "  set-stage <s>   Manually set current stage (repair only)"
    exit 2
}

PROJECT="${1:-}"
SUBCMD="${2:-}"

if [ -z "$PROJECT" ] || [ -z "$SUBCMD" ]; then
    usage
fi

PROJECT_DIR="$WORKSPACE_ROOT/$PROJECT"
if [ ! -d "$PROJECT_DIR" ]; then
    echo "Project directory not found: $PROJECT_DIR" >&2
    exit 1
fi

# Find active round.
ACTIVE_RND=$(jq -r '.active_round // 0' "$PROJECT_DIR/state/project-state.json" 2>/dev/null || echo "0")
if [ "$ACTIVE_RND" = "null" ] || [ "$ACTIVE_RND" -eq 0 ]; then
    echo "No active round." >&2
    exit 1
fi

ROUND_NUM=$(printf "%03d" "$ACTIVE_RND")
ROUND_DIR="$PROJECT_DIR/rounds/round-$ROUND_NUM"
STATE_FILE="$ROUND_DIR/state.yaml"

if [ ! -f "$STATE_FILE" ]; then
    echo "No state.yaml found in $ROUND_DIR. Run 'cr-new-round' with --mode paper first." >&2
    exit 1
fi

# ── Helpers ──────────────────────────────────────────────────────

get_current_stage() {
    yq -r '.current_stage // "s1_round_contract"' "$STATE_FILE" 2>/dev/null || \
        echo "s1_round_contract"
}

get_stage_status() {
    local stage="$1"
    yq -r ".stages.$stage.status // \"unknown\"" "$STATE_FILE" 2>/dev/null || echo "unknown"
}

get_next_stage() {
    local current="$1"
    local found=false
    local stages
    stages=$(yq -r '.stage_order // [] | .[]' "$STATE_FILE" 2>/dev/null)
    # Fallback to map keys if stage_order not present (backward compat).
    if [ -z "$stages" ]; then
        stages=$(yq -r '.stages | keys | .[]' "$STATE_FILE" 2>/dev/null)
    fi
    for s in $stages; do
        [ -z "$s" ] && continue
        if [ "$found" = true ]; then
            echo "$s"
            return
        fi
        if [ "$s" = "$current" ]; then
            found=true
        fi
    done
    echo ""
}

# ── Subcommands ──────────────────────────────────────────────────

case "$SUBCMD" in
    status)
        MACHINE_MODE=false
        [ "${3:-}" = "--machine" ] && MACHINE_MODE=true

        CURRENT=$(get_current_stage)
        STAGE_STATUS=$(get_stage_status "$CURRENT")

        # Collect missing outputs.
        REQ=$(yq -r ".stages.$CURRENT.required_outputs // [] | .[]" "$STATE_FILE" 2>/dev/null || echo "")
        MISSING=""
        for output in $REQ; do
            [ -z "$output" ] && continue
            case "$output" in
                *.yaml|*.md|*.json)
                    [ -f "$ROUND_DIR/$output" ] && continue
                    [ -f "$PROJECT_DIR/$output" ] && continue
                    MISSING="$MISSING $output"
                    ;;
                raw-sources)
                    [ -d "$ROUND_DIR/raw-sources" ] && [ -n "$(ls -A "$ROUND_DIR/raw-sources" 2>/dev/null)" ] && continue
                    MISSING="$MISSING raw-sources/"
                    ;;
                patches)
                    [ -d "$ROUND_DIR/patches" ] && [ -n "$(ls -A "$ROUND_DIR/patches" 2>/dev/null)" ] && continue
                    MISSING="$MISSING patches/"
                    ;;
                experiments)
                    [ -d "$ROUND_DIR/experiments" ] && [ -n "$(ls -A "$ROUND_DIR/experiments" 2>/dev/null)" ] && continue
                    MISSING="$MISSING experiments/"
                    ;;
            esac
        done

        MISSING=$(echo "$MISSING" | xargs)

        # Count completed stages.
        TOTAL_STAGES=$(yq -r '.stage_order | length // (.stages | keys | length)' "$STATE_FILE" 2>/dev/null || echo "8")
        COMPLETED=$(yq -r '.stages | to_entries | map(select(.value.status == "complete")) | length' "$STATE_FILE" 2>/dev/null || echo "0")

        if [ "$MACHINE_MODE" = true ]; then
            echo "Project: $PROJECT"
            echo "Active round: round-$ROUND_NUM"
            echo "Workflow mode: $(yq -r '.workflow_mode // "paper"' "$STATE_FILE")"
            echo "Current stage: $CURRENT ($STAGE_STATUS)"
            echo "Progress: $COMPLETED/$TOTAL_STAGES stages complete"
            if [ -n "$MISSING" ]; then
                echo "Missing:$MISSING"
            else
                echo "Missing: none"
            fi
            NEXT=$(get_next_stage "$CURRENT")
            if [ -n "$NEXT" ]; then
                echo "Next stage: $NEXT ($(get_stage_status "$NEXT"))"
            fi
        else
            echo "Project: $PROJECT"
            echo "Active round: round-$ROUND_NUM"
            echo "Workflow mode: $(yq -r '.workflow_mode // "paper"' "$STATE_FILE")"
            echo "Current stage: $CURRENT ($STAGE_STATUS)"
            echo "Progress: $COMPLETED/$TOTAL_STAGES stages complete"
            echo ""

            if [ -n "$MISSING" ]; then
                echo "Missing outputs:"
                for m in $MISSING; do
                    echo "  - $m"
                done
                echo ""
                echo "Required action: create the missing outputs above, then run 'cr step $PROJECT advance'."
            else
                echo "All required outputs present. Run 'cr step $PROJECT advance' to proceed."
            fi

            NEXT=$(get_next_stage "$CURRENT")
            if [ -n "$NEXT" ]; then
                echo "Next stage: $NEXT ($(get_stage_status "$NEXT"))"
            fi
        fi
        ;;

    current)
        get_current_stage
        ;;

    start)
        CURRENT=$(get_current_stage)
        STAGE_STATUS=$(get_stage_status "$CURRENT")

        if [ "$STAGE_STATUS" != "open" ]; then
            echo "Error: cannot start stage '$CURRENT' (status=$STAGE_STATUS, must be open)" >&2
            exit 2
        fi

        # Validate transition open->running.
        if [ -x "$SCRIPT_DIR/cr-validate-stage-transition" ]; then
            "$SCRIPT_DIR/cr-validate-stage-transition" "$STATE_FILE" "$CURRENT" "$STAGE_STATUS" "running" || exit 2
        fi

        NOW=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
        yq -i ".stages.\"$CURRENT\".status = \"running\"" "$STATE_FILE" 2>/dev/null
        yq -i ".stages.\"$CURRENT\".started_at = \"$NOW\"" "$STATE_FILE" 2>/dev/null

        # Write stage-run-log started event.
        STAGE_ORDER=$(yq -r ".stage_order | to_entries | .[] | select(.value == \"$CURRENT\") | .key // 0" "$STATE_FILE" 2>/dev/null || echo "0")
        STAGE_ORDER=$((STAGE_ORDER + 1))

        # Ensure run-log has schema header if empty or old format.
        RUN_LOG="$ROUND_DIR/stage-run-log.yaml"
        if [ ! -s "$RUN_LOG" ] || ! grep -q '^schema_version:' "$RUN_LOG" 2>/dev/null; then
            cat > "$RUN_LOG" << 'HDR'
schema_version: "1.0.0"
events:
HDR
        fi

        # Convert old empty-list format to block format.
        if grep -q '^events: \[\]' "$RUN_LOG" 2>/dev/null; then
            sed -i '' 's/^events: \[\]/events:/' "$RUN_LOG" 2>/dev/null || \
                sed -i 's/^events: \[\]/events:/' "$RUN_LOG"
        fi

        {
            echo "  - event: stage_started"
            echo "    stage: $CURRENT"
            echo "    order: $STAGE_ORDER"
            echo "    at: \"$NOW\""
            echo "    input_hashes:"

            # Read required_inputs from manifest snapshot (single source of truth).
            MANIFEST="$ROUND_DIR/stage-manifest.snapshot.yaml"
            if [ -f "$MANIFEST" ]; then
                # Find stage index in manifest.
                ST_IDX=$(yq -r ".stages | to_entries | .[] | select(.value.id == \"$CURRENT\") | .key // -1" "$MANIFEST" 2>/dev/null || echo "-1")
                if [ "$ST_IDX" -ge 0 ] 2>/dev/null; then
                    IN_COUNT=$(yq -r ".stages[$ST_IDX].required_inputs | length // 0" "$MANIFEST" 2>/dev/null || echo 0)
                    for j in $(seq 0 $((IN_COUNT - 1))); do
                        scoped_in=$(yq -r ".stages[$ST_IDX].required_inputs[$j].path // \"\"" "$MANIFEST" 2>/dev/null || echo "")
                        [ -z "$scoped_in" ] && continue
                        h=$("$SCRIPT_DIR/cr-hash-artifact" "$PROJECT_DIR" "$ROUND_DIR" "$scoped_in" 2>/dev/null || echo "unknown")
                        echo "      \"$scoped_in\": \"$h\""
                    done
                fi
            else
                # Fallback to state.yaml bare paths (backward compat).
                ALL_INPUTS=$(yq -r ".stages.\"$CURRENT\".required_inputs // [] | .[]" "$STATE_FILE" 2>/dev/null || echo "")
                for inp in $ALL_INPUTS; do
                    [ -z "$inp" ] && continue
                    f="$ROUND_DIR/$inp"
                    [ -f "$f" ] || f="$PROJECT_DIR/$inp"
                    [ -f "$f" ] || continue
                    h=$(shasum -a 256 "$f" 2>/dev/null | cut -d' ' -f1 || echo "unknown")
                    echo "      \"$inp\": \"$h\""
                done
            fi

            # If no hashes written, output empty dict marker.
            if [ ! -f "$MANIFEST" ] && [ -z "$ALL_INPUTS" ]; then
                echo "      {}"
            fi
        } >> "$RUN_LOG"
        echo "Stage '$CURRENT' started (open -> running)"
        ;;

    advance)
        CURRENT=$(get_current_stage)
        STAGE_STATUS=$(get_stage_status "$CURRENT")
        echo "Current stage: $CURRENT ($STAGE_STATUS)"

        # Auto-start: if stage is open, set to running first.
        if [ "$STAGE_STATUS" = "open" ]; then
            echo "Auto-starting stage..."
            "$0" "$PROJECT" start || { echo "Failed to start stage"; exit 2; }
            STAGE_STATUS="running"
        fi

        # Delegate to cr-complete-stage: validates, marks complete, unblocks next.
        if [ -x "$SCRIPT_DIR/cr-complete-stage" ]; then
            "$SCRIPT_DIR/cr-complete-stage" "$PROJECT_DIR" "$ROUND_DIR" "$CURRENT"
            EXIT_CODE=$?
            if [ "$EXIT_CODE" -ne 0 ]; then
                exit "$EXIT_CODE"
            fi
            exit 0
        fi

        # Fallback if cr-complete-stage not available.
        echo "Error: cr-complete-stage not found." >&2
        exit 2
        ;;

    validate)
        STOP_GATE=false
        [ "${3:-}" = "--stop-gate" ] && STOP_GATE=true

        CURRENT=$(get_current_stage)
        STAGE_STATUS=$(get_stage_status "$CURRENT")

        if [ "$STOP_GATE" = true ]; then
            # Stop gate mode: check if current stage is complete enough to allow stopping.
            if [ "$STAGE_STATUS" = "complete" ]; then
                # Stage complete — allow stop.
                echo '{"decision":"allow"}'
                exit 0
            fi

            # Check if stage has required outputs present.
            REQ=$(yq -r ".stages.$CURRENT.required_outputs // [] | .[]" "$STATE_FILE" 2>/dev/null || echo "")
            MISSING_COUNT=0
            MISSING_LIST=""
            for output in $REQ; do
                [ -z "$output" ] && continue
                case "$output" in
                    *.yaml|*.md|*.json)
                        [ -f "$ROUND_DIR/$output" ] && continue
                        [ -f "$PROJECT_DIR/$output" ] && continue
                        MISSING_COUNT=$((MISSING_COUNT + 1))
                        MISSING_LIST="$MISSING_LIST $output"
                        ;;
                    raw-sources|patches|experiments)
                        [ -d "$ROUND_DIR/$output" ] && [ -n "$(ls -A "$ROUND_DIR/$output" 2>/dev/null)" ] && continue
                        MISSING_COUNT=$((MISSING_COUNT + 1))
                        MISSING_LIST="$MISSING_LIST $output/"
                        ;;
                esac
            done

            if [ "$MISSING_COUNT" -gt 0 ]; then
                REASON="Stage '$CURRENT' ($STAGE_STATUS) has $MISSING_COUNT missing output(s):$MISSING_LIST. Complete the current stage before stopping. Run 'cr step $PROJECT status' to see required outputs."
                echo "{\"decision\":\"block\",\"reason\":\"$REASON\"}"
                exit 2
            fi

            # All outputs present but stage not marked complete — allow with note.
            echo '{"decision":"allow"}'
            exit 0
        fi

        # Normal validate mode: run stage validator.
        if [ -x "$SCRIPT_DIR/cr-validate-stage" ]; then
            exec "$SCRIPT_DIR/cr-validate-stage" "$PROJECT_DIR" "$ROUND_DIR" "$CURRENT"
        else
            echo "cr-validate-stage not found." >&2
            exit 2
        fi
        ;;

    set-stage)
        if [ "${CR_REPAIR_MODE:-0}" != "1" ]; then
            echo "Error: set-stage is restricted to repair mode." >&2
            echo "  Set CR_REPAIR_MODE=1 to override." >&2
            echo "  This will write to repair-log.yaml." >&2
            exit 2
        fi

        NEW_STAGE="${3:-}"
        if [ -z "$NEW_STAGE" ]; then
            echo "Usage: cr step <project> set-stage <stage_name>" >&2
            exit 2
        fi

        STAGE_EXISTS=$(yq -r ".stages.$NEW_STAGE.status // \"unknown\"" "$STATE_FILE" 2>/dev/null || echo "unknown")
        if [ "$STAGE_EXISTS" = "unknown" ]; then
            echo "Unknown stage: $NEW_STAGE" >&2
            exit 2
        fi

        # Block forward jumps when full_round_required is true.
        FULL_ROUND=$(yq -r '.execution_policy.full_round_required // false' "$STATE_FILE" 2>/dev/null || echo "false")
        if [ "$FULL_ROUND" = "true" ]; then
            CURRENT=$(get_current_stage)
            # Find indices in stage_order.
            CURRENT_IDX=-1
            NEW_IDX=-1
            IDX=0
            while IFS= read -r s; do
                [ -z "$s" ] && continue
                [ "$s" = "$CURRENT" ] && CURRENT_IDX=$IDX
                [ "$s" = "$NEW_STAGE" ] && NEW_IDX=$IDX
                IDX=$((IDX + 1))
            done < <(yq -r '.stage_order[]' "$STATE_FILE" 2>/dev/null)
            if [ "$NEW_IDX" -gt "$CURRENT_IDX" ] 2>/dev/null; then
                echo "Error: Cannot jump forward from '$CURRENT' (stage $CURRENT_IDX) to '$NEW_STAGE' (stage $NEW_IDX)." >&2
                echo "  set-stage in repair mode only allows backward or same-stage jumps." >&2
                echo "  Use 'cr step <project> advance' for forward progression." >&2
                exit 2
            fi
        fi

        PREV_STAGE=$(yq -r '.current_stage // "none"' "$STATE_FILE" 2>/dev/null || echo "none")
        yq -i ".current_stage = \"$NEW_STAGE\"" "$STATE_FILE" 2>/dev/null || true
        echo "Current stage set to: $NEW_STAGE"

        # Write repair log.
        NOW=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
        cat >> "$ROUND_DIR/repair-log.yaml" << YAMLREP
- timestamp: "$NOW"
  operator: "cr-step set-stage"
  previous_stage: "$PREV_STAGE"
  new_stage: "$NEW_STAGE"
  reason: "Manual repair via CR_REPAIR_MODE=1"
YAMLREP
        echo "Repair recorded in repair-log.yaml"
        ;;

    *)
        usage
        ;;
esac
