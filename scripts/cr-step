#!/usr/bin/env bash
# cr-step — Phase state machine for paper rounds.
# Usage: cr step <project> <subcommand> [args...]
#
# Subcommands:
#   status         Show current phase and what's missing
#   status --machine  Machine-readable output (for hook injection)
#   current        Print current phase name only
#   start          Set current phase to running
#   advance        Auto-start (open->running) then validate and advance
#   validate       Validate current phase only (no advance)
#   validate --stop-gate  Validate for stop hook (returns JSON)
#   set-phase <p>  Manually set current phase (for repair)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

WORKSPACE_ROOT="$(cr_workspace_root)"

usage() {
    echo "Usage: cr step <project> <subcommand> [args...]"
    echo ""
    echo "Subcommands:"
    echo "  status          Show current phase and missing requirements"
    echo "  current         Print current phase name only"
    echo "  start           Set current phase to running (open->running)"
    echo "  advance         Validate current phase and advance to next"
    echo "  validate        Validate current phase without advancing"
    echo "  set-phase <p>   Manually set current phase (repair only)"
    exit 2
}

PROJECT="${1:-}"
SUBCMD="${2:-}"

if [ -z "$PROJECT" ] || [ -z "$SUBCMD" ]; then
    usage
fi

PROJECT_DIR="$WORKSPACE_ROOT/$PROJECT"
if [ ! -d "$PROJECT_DIR" ]; then
    echo "Project directory not found: $PROJECT_DIR" >&2
    exit 1
fi

# Find active round.
ACTIVE_RND=$(jq -r '.active_round // 0' "$PROJECT_DIR/state/project-state.json" 2>/dev/null || echo "0")
if [ "$ACTIVE_RND" = "null" ] || [ "$ACTIVE_RND" -eq 0 ]; then
    echo "No active round." >&2
    exit 1
fi

ROUND_NUM=$(printf "%03d" "$ACTIVE_RND")
ROUND_DIR="$PROJECT_DIR/rounds/round-$ROUND_NUM"
STATE_FILE="$ROUND_DIR/state.yaml"

if [ ! -f "$STATE_FILE" ]; then
    echo "No state.yaml found in $ROUND_DIR. Run 'cr-new-round' with --mode paper first." >&2
    exit 1
fi

# ── Helpers ──────────────────────────────────────────────────────

get_current_phase() {
    yq -r '.current_phase // "snapshot_paper_state"' "$STATE_FILE" 2>/dev/null || \
        echo "snapshot_paper_state"
}

get_phase_status() {
    local phase="$1"
    yq -r ".phases.$phase.status // \"unknown\"" "$STATE_FILE" 2>/dev/null || echo "unknown"
}

get_next_phase() {
    local current="$1"
    local found=false
    local phases
    phases=$(yq -r '.phase_order // [] | .[]' "$STATE_FILE" 2>/dev/null)
    # Fallback to map keys if phase_order not present (backward compat).
    if [ -z "$phases" ]; then
        phases=$(yq -r '.phases | keys | .[]' "$STATE_FILE" 2>/dev/null)
    fi
    for p in $phases; do
        [ -z "$p" ] && continue
        if [ "$found" = true ]; then
            echo "$p"
            return
        fi
        if [ "$p" = "$current" ]; then
            found=true
        fi
    done
    echo ""
}

# ── Subcommands ──────────────────────────────────────────────────

case "$SUBCMD" in
    status)
        MACHINE_MODE=false
        [ "${3:-}" = "--machine" ] && MACHINE_MODE=true

        CURRENT=$(get_current_phase)
        PHASE_STATUS=$(get_phase_status "$CURRENT")

        # Collect missing outputs.
        REQ=$(yq -r ".phases.$CURRENT.required_outputs // [] | .[]" "$STATE_FILE" 2>/dev/null || echo "")
        MISSING=""
        for output in $REQ; do
            [ -z "$output" ] && continue
            case "$output" in
                *.yaml|*.md|*.json)
                    [ -f "$ROUND_DIR/$output" ] && continue
                    [ -f "$PROJECT_DIR/$output" ] && continue
                    MISSING="$MISSING $output"
                    ;;
                raw-sources)
                    [ -d "$ROUND_DIR/raw-sources" ] && [ -n "$(ls -A "$ROUND_DIR/raw-sources" 2>/dev/null)" ] && continue
                    MISSING="$MISSING raw-sources/"
                    ;;
                patches)
                    [ -d "$ROUND_DIR/patches" ] && [ -n "$(ls -A "$ROUND_DIR/patches" 2>/dev/null)" ] && continue
                    MISSING="$MISSING patches/"
                    ;;
                experiments)
                    [ -d "$ROUND_DIR/experiments" ] && [ -n "$(ls -A "$ROUND_DIR/experiments" 2>/dev/null)" ] && continue
                    MISSING="$MISSING experiments/"
                    ;;
            esac
        done

        MISSING=$(echo "$MISSING" | xargs)

        # Count completed phases.
        TOTAL_PHASES=$(yq -r '.phase_order | length // (.phases | keys | length)' "$STATE_FILE" 2>/dev/null || echo "14")
        COMPLETED=$(yq -r '.phases | to_entries | map(select(.value.status == "complete")) | length' "$STATE_FILE" 2>/dev/null || echo "0")

        if [ "$MACHINE_MODE" = true ]; then
            echo "Project: $PROJECT"
            echo "Active round: round-$ROUND_NUM"
            echo "Workflow mode: $(yq -r '.workflow_mode // "paper"' "$STATE_FILE")"
            echo "Current phase: $CURRENT ($PHASE_STATUS)"
            echo "Progress: $COMPLETED/$TOTAL_PHASES phases complete"
            if [ -n "$MISSING" ]; then
                echo "Missing:$MISSING"
            else
                echo "Missing: none"
            fi
            NEXT=$(get_next_phase "$CURRENT")
            if [ -n "$NEXT" ]; then
                echo "Next phase: $NEXT ($(get_phase_status "$NEXT"))"
            fi
        else
            echo "Project: $PROJECT"
            echo "Active round: round-$ROUND_NUM"
            echo "Workflow mode: $(yq -r '.workflow_mode // "paper"' "$STATE_FILE")"
            echo "Current phase: $CURRENT ($PHASE_STATUS)"
            echo "Progress: $COMPLETED/$TOTAL_PHASES phases complete"
            echo ""

            if [ -n "$MISSING" ]; then
                echo "Missing outputs:"
                for m in $MISSING; do
                    echo "  - $m"
                done
                echo ""
                echo "Required action: create the missing outputs above, then run 'cr step $PROJECT advance'."
            else
                echo "All required outputs present. Run 'cr step $PROJECT advance' to proceed."
            fi

            NEXT=$(get_next_phase "$CURRENT")
            if [ -n "$NEXT" ]; then
                echo "Next phase: $NEXT ($(get_phase_status "$NEXT"))"
            fi
        fi
        ;;

    current)
        get_current_phase
        ;;

    start)
        CURRENT=$(get_current_phase)
        PHASE_STATUS=$(get_phase_status "$CURRENT")

        if [ "$PHASE_STATUS" != "open" ]; then
            echo "Error: cannot start phase '$CURRENT' (status=$PHASE_STATUS, must be open)" >&2
            exit 2
        fi

        # Validate transition open->running.
        if [ -x "$SCRIPT_DIR/cr-validate-phase-transition" ]; then
            "$SCRIPT_DIR/cr-validate-phase-transition" "$STATE_FILE" "$CURRENT" "$PHASE_STATUS" "running" || exit 2
        fi

        NOW=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
        yq -i ".phases.\"$CURRENT\".status = \"running\"" "$STATE_FILE" 2>/dev/null
        yq -i ".phases.\"$CURRENT\".started_at = \"$NOW\"" "$STATE_FILE" 2>/dev/null

        # Write phase-run-log started event.
        PHASE_ORDER=$(yq -r ".phase_order | to_entries | .[] | select(.value == \"$CURRENT\") | .key // 0" "$STATE_FILE" 2>/dev/null || echo "0")
        PHASE_ORDER=$((PHASE_ORDER + 1))

        # Ensure run-log has schema header if empty or old format.
        RUN_LOG="$ROUND_DIR/phase-run-log.yaml"
        if [ ! -s "$RUN_LOG" ] || ! grep -q '^schema_version:' "$RUN_LOG" 2>/dev/null; then
            cat > "$RUN_LOG" << 'HDR'
schema_version: "1.0.0"
events:
HDR
        fi

        # Convert old empty-list format to block format.
        if grep -q '^events: \[\]' "$RUN_LOG" 2>/dev/null; then
            sed -i '' 's/^events: \[\]/events:/' "$RUN_LOG" 2>/dev/null || \
                sed -i 's/^events: \[\]/events:/' "$RUN_LOG"
        fi

        {
            echo "  - event: phase_started"
            echo "    phase: $CURRENT"
            echo "    order: $PHASE_ORDER"
            echo "    at: \"$NOW\""
            echo "    input_hashes:"
            ALL_INPUTS=$(yq -r ".phases.\"$CURRENT\".required_inputs // [] | .[]" "$STATE_FILE" 2>/dev/null || echo "")
            for inp in $ALL_INPUTS; do
                [ -z "$inp" ] && continue
                f="$ROUND_DIR/$inp"
                [ -f "$f" ] || f="$PROJECT_DIR/$inp"
                [ -f "$f" ] || continue
                h=$(shasum -a 256 "$f" 2>/dev/null | cut -d' ' -f1 || echo "unknown")
                echo "      \"$inp\": \"$h\""
            done
            [ -z "$ALL_INPUTS" ] && echo "      {}"
        } >> "$RUN_LOG"
        echo "Phase '$CURRENT' started (open -> running)"
        ;;

    advance)
        CURRENT=$(get_current_phase)
        PHASE_STATUS=$(get_phase_status "$CURRENT")
        echo "Current phase: $CURRENT ($PHASE_STATUS)"

        # Auto-start: if phase is open, set to running first.
        if [ "$PHASE_STATUS" = "open" ]; then
            echo "Auto-starting phase..."
            "$0" "$PROJECT" start || { echo "Failed to start phase"; exit 2; }
            PHASE_STATUS="running"
        fi

        # Delegate to cr-complete-phase: validates, marks complete, unblocks next.
        if [ -x "$SCRIPT_DIR/cr-complete-phase" ]; then
            exec "$SCRIPT_DIR/cr-complete-phase" "$PROJECT_DIR" "$ROUND_DIR" "$CURRENT"
        fi

        # Fallback if cr-complete-phase not available.
        echo "Error: cr-complete-phase not found." >&2
        exit 2
        ;;

    validate)
        STOP_GATE=false
        [ "${3:-}" = "--stop-gate" ] && STOP_GATE=true

        CURRENT=$(get_current_phase)
        PHASE_STATUS=$(get_phase_status "$CURRENT")

        if [ "$STOP_GATE" = true ]; then
            # Stop gate mode: check if current phase is complete enough to allow stopping.
            if [ "$PHASE_STATUS" = "complete" ]; then
                # Phase complete — allow stop.
                echo '{"decision":"allow"}'
                exit 0
            fi

            # Check if phase has required outputs present.
            REQ=$(yq -r ".phases.$CURRENT.required_outputs // [] | .[]" "$STATE_FILE" 2>/dev/null || echo "")
            MISSING_COUNT=0
            MISSING_LIST=""
            for output in $REQ; do
                [ -z "$output" ] && continue
                case "$output" in
                    *.yaml|*.md|*.json)
                        [ -f "$ROUND_DIR/$output" ] && continue
                        [ -f "$PROJECT_DIR/$output" ] && continue
                        MISSING_COUNT=$((MISSING_COUNT + 1))
                        MISSING_LIST="$MISSING_LIST $output"
                        ;;
                    raw-sources|patches|experiments)
                        [ -d "$ROUND_DIR/$output" ] && [ -n "$(ls -A "$ROUND_DIR/$output" 2>/dev/null)" ] && continue
                        MISSING_COUNT=$((MISSING_COUNT + 1))
                        MISSING_LIST="$MISSING_LIST $output/"
                        ;;
                esac
            done

            if [ "$MISSING_COUNT" -gt 0 ]; then
                REASON="Phase '$CURRENT' ($PHASE_STATUS) has $MISSING_COUNT missing output(s):$MISSING_LIST. Complete the current phase before stopping. Run 'cr step $PROJECT status' to see required outputs."
                echo "{\"decision\":\"block\",\"reason\":\"$REASON\"}"
                exit 2
            fi

            # All outputs present but phase not marked complete — allow with note.
            echo "{\"decision\":\"allow\"}"
            exit 0
        fi

        # Normal validate mode: run phase validator.
        if [ -x "$SCRIPT_DIR/cr-validate-phase" ]; then
            exec "$SCRIPT_DIR/cr-validate-phase" "$PROJECT_DIR" "$ROUND_DIR" "$CURRENT"
        else
            echo "cr-validate-phase not found." >&2
            exit 2
        fi
        ;;

    set-phase)
        if [ "${CR_REPAIR_MODE:-0}" != "1" ]; then
            echo "Error: set-phase is restricted to repair mode." >&2
            echo "  Set CR_REPAIR_MODE=1 to override." >&2
            echo "  This will write to repair-log.yaml." >&2
            exit 2
        fi

        NEW_PHASE="${3:-}"
        if [ -z "$NEW_PHASE" ]; then
            echo "Usage: cr step <project> set-phase <phase_name>" >&2
            exit 2
        fi

        PHASE_EXISTS=$(yq -r ".phases.$NEW_PHASE.status // \"unknown\"" "$STATE_FILE" 2>/dev/null || echo "unknown")
        if [ "$PHASE_EXISTS" = "unknown" ]; then
            echo "Unknown phase: $NEW_PHASE" >&2
            exit 2
        fi

        # Block forward jumps when full_round_required is true.
        FULL_ROUND=$(yq -r '.execution_policy.full_round_required // false' "$STATE_FILE" 2>/dev/null || echo "false")
        if [ "$FULL_ROUND" = "true" ]; then
            CURRENT=$(get_current_phase)
            # Find indices in phase_order.
            CURRENT_IDX=-1
            NEW_IDX=-1
            IDX=0
            while IFS= read -r p; do
                [ -z "$p" ] && continue
                [ "$p" = "$CURRENT" ] && CURRENT_IDX=$IDX
                [ "$p" = "$NEW_PHASE" ] && NEW_IDX=$IDX
                IDX=$((IDX + 1))
            done < <(yq -r '.phase_order[]' "$STATE_FILE" 2>/dev/null)
            if [ "$NEW_IDX" -gt "$CURRENT_IDX" ] 2>/dev/null; then
                echo "Error: Cannot jump forward from '$CURRENT' (phase $CURRENT_IDX) to '$NEW_PHASE' (phase $NEW_IDX)." >&2
                echo "  set-phase in repair mode only allows backward or same-phase jumps." >&2
                echo "  Use 'cr step <project> advance' for forward progression." >&2
                exit 2
            fi
        fi

        PREV_PHASE=$(yq -r '.current_phase // "none"' "$STATE_FILE" 2>/dev/null || echo "none")
        yq -i ".current_phase = \"$NEW_PHASE\"" "$STATE_FILE" 2>/dev/null || true
        echo "Current phase set to: $NEW_PHASE"

        # Write repair log.
        NOW=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
        cat >> "$ROUND_DIR/repair-log.yaml" << YAMLREP
- timestamp: "$NOW"
  operator: "cr-step set-phase"
  previous_phase: "$PREV_PHASE"
  new_phase: "$NEW_PHASE"
  reason: "Manual repair via CR_REPAIR_MODE=1"
YAMLREP
        echo "Repair recorded in repair-log.yaml"
        ;;

    *)
        usage
        ;;
esac
