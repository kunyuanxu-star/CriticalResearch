#!/usr/bin/env bash
# cr-validate-claim-evidence-matrix — Hard gate: every core claim in matrix, support levels assigned.
# Usage: cr-validate-claim-evidence-matrix <project_dir> <round_dir>
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"
ROUND_DIR="${2:-}"
[ -z "$ROUND_DIR" ] && { echo "Usage: cr-validate-claim-evidence-matrix <project_dir> <round_dir>" >&2; exit 2; }
echo "── Claim-Evidence Matrix Check ──"
MATRIX="$ROUND_DIR/claim-evidence-matrix.yaml"
[ ! -f "$MATRIX" ] && { fail "claim-evidence-matrix.yaml not found"; cr_exit_summary; }
CLAIM_ROWS=$(yq -r '.claim_rows // [] | length' "$MATRIX" 2>/dev/null || echo "0")
[ "$CLAIM_ROWS" -eq 0 ] 2>/dev/null && { fail "No claim rows in matrix"; cr_exit_summary; }
for i in $(seq 0 $((CLAIM_ROWS - 1))); do
  cid=$(yq -r ".claim_rows[$i].claim_id // \"\"" "$MATRIX" 2>/dev/null || echo "")
  sl=$(yq -r ".claim_rows[$i].support_level // \"\"" "$MATRIX" 2>/dev/null || echo "")
  gap=$(yq -r ".claim_rows[$i].evidence_gap // \"\"" "$MATRIX" 2>/dev/null || echo "")
  [ -z "$cid" ] && { fail "Row $i missing claim_id"; continue; }
  [ -z "$sl" ] && fail "Claim $cid missing support_level"
  [ -z "$gap" ] && [ "$sl" = "none" ] && fail "Claim $cid has no evidence — must flag as evidence_gap"
done
pass "Claim-evidence matrix: $CLAIM_ROWS claim rows validated"
cr_exit_summary
