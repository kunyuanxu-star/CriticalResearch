#!/usr/bin/env bash
# cr-stage — Stage state machine for CriticalResearch v2.
# Subcommands: status, advance, validate.
#
# Usage: cr stage <subcommand> <project>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

SUBCOMMAND="${1:-}"
PROJECT_ID="${2:-}"

usage() {
    echo "Usage: cr stage <status|advance|validate> <project>" >&2
    exit 2
}

if [ -z "$SUBCOMMAND" ] || [ -z "$PROJECT_ID" ]; then
    usage
fi

WORKSPACE_ROOT="$(cr_workspace_root)"
PROJECT_DIR="$WORKSPACE_ROOT/$PROJECT_ID"

# ── Find active round ───────────────────────────────────────────

find_active_round() {
    local state_file="$PROJECT_DIR/state/project-state.json"
    if [ ! -f "$state_file" ]; then
        echo "Error: project state file not found: $state_file" >&2
        exit 1
    fi
    local active
    active=$(jq -r '.active_round // "null"' "$state_file" 2>/dev/null || echo "null")
    if [ "$active" = "null" ] || [ "$active" = "0" ]; then
        echo "Error: no active round in project '$PROJECT_ID'." >&2
        exit 1
    fi
    local round_num
    round_num=$(printf "%03d" "$active")
    local round_dir="$PROJECT_DIR/rounds/round-$round_num"
    if [ ! -d "$round_dir" ]; then
        echo "Error: round directory not found: $round_dir" >&2
        exit 1
    fi
    echo "$round_dir"
}

ROUND_DIR="$(find_active_round)"
STATE_FILE="$ROUND_DIR/workflow-state.yaml"

if [ ! -f "$STATE_FILE" ]; then
    echo "Error: workflow-state.yaml not found in $ROUND_DIR" >&2
    exit 1
fi

# ── Shared helpers ──────────────────────────────────────────────

# Get the current stage name from state.yaml.
current_stage() {
    yq -r '.current_stage // ""' "$STATE_FILE" 2>/dev/null || echo ""
}

# Get stage status by name.
stage_status() {
    local stage="$1"
    yq -r ".stages.$stage.status // \"unknown\"" "$STATE_FILE" 2>/dev/null || echo "unknown"
}

# Get required outputs for a stage.
stage_required_outputs() {
    local stage="$1"
    yq -r ".stages.$stage.required_outputs // [] | .[]" "$STATE_FILE" 2>/dev/null || echo ""
}

# Get stage_order as a newline-separated list.
stage_order_list() {
    yq -r '.stage_order // [] | .[]' "$STATE_FILE" 2>/dev/null || echo ""
}

# ── Subcommand: status ──────────────────────────────────────────

cmd_status() {
    local cur
    cur=$(current_stage)
    if [ -z "$cur" ]; then
        echo "Error: no current_stage set in $STATE_FILE" >&2
        exit 1
    fi

    echo ""
    echo "═══ Stage Status — Project: $PROJECT_ID ═══"
    echo ""

    # Current stage and its required outputs.
    echo "▶ Current stage: $cur (status: $(stage_status "$cur"))"
    echo ""
    echo "  Required outputs:"
    local outputs
    outputs=$(stage_required_outputs "$cur")
    if [ -z "$outputs" ]; then
        echo "    (none)"
    else
        while IFS= read -r out; do
            [ -z "$out" ] && continue
            if [ -f "$ROUND_DIR/$out" ]; then
                echo "    ✓ $out"
            elif [ -d "$ROUND_DIR/$out" ]; then
                echo "    ✓ $out/ (directory exists)"
            elif [ -f "$PROJECT_DIR/$out" ]; then
                echo "    ✓ $out (project-level)"
            else
                echo "    ✗ $out"
            fi
        done <<< "$outputs"
    fi

    # Show completion status of all stages.
    echo ""
    echo "── All stages ──"
    local stages
    stages=$(stage_order_list)
    if [ -z "$stages" ]; then
        echo "  (no stage_order defined)"
    else
        while IFS= read -r s; do
            [ -z "$s" ] && continue
            local st
            st=$(stage_status "$s")
            local marker=""
            if [ "$s" = "$cur" ]; then
                marker=" ◀ current"
            fi
            case "$st" in
                complete) echo "  ${GREEN}✔${NC} $s — $st$marker" ;;
                running)  echo "  ${YELLOW}▶${NC} $s — $st$marker" ;;
                blocked)  echo "  ○ $s — $st$marker" ;;
                open)     echo "  ${YELLOW}▷${NC} $s — $st$marker" ;;
                *)        echo "  ? $s — $st$marker" ;;
            esac
        done <<< "$stages"
    fi

    echo ""
}

# ── Subcommand: validate ────────────────────────────────────────

cmd_validate() {
    local cur
    cur=$(current_stage)
    if [ -z "$cur" ]; then
        echo "Error: no current_stage set in $STATE_FILE" >&2
        exit 1
    fi

    local cur_status
    cur_status=$(stage_status "$cur")

    echo ""
    echo "═══ Validating Stage: $cur ═══"
    echo "  Status in state.yaml: $cur_status"
    echo ""

    # Delegate to cr-validate-stage for actual validation.
    "$SCRIPT_DIR/cr-validate-stage" "$PROJECT_DIR" "$ROUND_DIR" "$cur"
    local exit_code=$?

    echo ""

    if [ "$exit_code" -eq 0 ]; then
        echo "Stage '$cur' validation: ${GREEN}PASSED${NC}"
    else
        echo "Stage '$cur' validation: ${RED}FAILED${NC} (exit code $exit_code)"
    fi

    return "$exit_code"
}

# ── Subcommand: advance ─────────────────────────────────────────

cmd_advance() {
    local cur
    cur=$(current_stage)
    if [ -z "$cur" ]; then
        echo "Error: no current_stage set in $STATE_FILE" >&2
        exit 1
    fi

    local cur_status
    cur_status=$(stage_status "$cur")

    echo ""
    echo "═══ Advancing Stage — Project: $PROJECT_ID ═══"
    echo "  Current stage: $cur (status: $cur_status)"
    echo ""

    # Check if current stage is the closure (last) stage.
    local last_stage
    last_stage=$(stage_order_list | tail -1)
    if [ "$cur" = "$last_stage" ]; then
        echo "  ${YELLOW}[WARN]${NC} '$cur' is the last stage. Use 'cr round close $PROJECT_ID' instead."
        echo "  Run 'cr stage validate $PROJECT_ID' first if you want to check completeness."
        exit 2
    fi

    # Delegate to cr-complete-stage for canonical completion flow:
    # validates stage, records in stage-run-log, marks complete, auto-unblocks next stages.
    COMPLETE_STAGE="$SCRIPT_DIR/cr-complete-stage"
    if [ "$cur_status" != "complete" ]; then
        echo "  Current stage is not marked complete. Completing via cr-complete-stage..."
        echo ""

        if [ ! -x "$COMPLETE_STAGE" ]; then
            echo "  ${RED}[ERROR]${NC} cr-complete-stage not found or not executable." >&2
            exit 1
        fi

        if ! "$COMPLETE_STAGE" "$PROJECT_DIR" "$ROUND_DIR" "$cur"; then
            echo ""
            echo "  ${RED}[BLOCKED]${NC} Stage '$cur' could not be completed. Fix issues before advancing."
            exit 1
        fi
    else
        # Already complete — just auto-unblock next stages and advance current_stage.
        echo "  Stage '$cur' is already complete. Unblocking next stages..."
        # Re-run cr-complete-stage; it detects the stage is already complete and runs auto_unblock.
        if [ -x "$COMPLETE_STAGE" ]; then
            "$COMPLETE_STAGE" "$PROJECT_DIR" "$ROUND_DIR" "$cur" || true
        fi
    fi

    # After cr-complete-stage, current_stage is set to the first "open" stage.
    # Promote it from "open" to "running".
    local new_cur
    new_cur=$(current_stage)

    if [ -z "$new_cur" ]; then
        echo "  ${YELLOW}[WARN]${NC} No open stages remain. Current stage is unchanged." >&2
        return 0
    fi

    if [ "$new_cur" = "$cur" ]; then
        # cr-complete-stage didn't advance — something unexpected.
        # Try to find the next stage manually and advance.
        local stage_order
        stage_order=$(stage_order_list)
        local next=""
        local found=0
        while IFS= read -r s; do
            [ -z "$s" ] && continue
            if [ "$found" -eq 1 ]; then
                next="$s"
                break
            fi
            if [ "$s" = "$cur" ]; then
                found=1
            fi
        done <<< "$stage_order"

        if [ -z "$next" ]; then
            echo "  ${YELLOW}[WARN]${NC} No next stage after '$cur'. Round may be complete." >&2
            return 0
        fi

        new_cur="$next"
        local now
        now="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
        yq -i "
            .current_stage = \"$new_cur\" |
            .stages.$new_cur.status = \"running\" |
            .stages.$new_cur.started_at = \"$now\"
        " "$STATE_FILE"
    else
        # cr-complete-stage advanced current_stage to an "open" stage.
        # Promote it to "running".
        local now
        now="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
        yq -i "
            .stages.$new_cur.status = \"running\" |
            .stages.$new_cur.started_at = \"$now\"
        " "$STATE_FILE"
    fi

    echo ""
    echo "  Advanced to: $new_cur (status: running)"
    echo ""
    echo "  Required outputs:"
    local next_outputs
    next_outputs=$(stage_required_outputs "$new_cur")
    if [ -z "$next_outputs" ]; then
        echo "    (none)"
    else
        while IFS= read -r out; do
            [ -z "$out" ] && continue
            echo "    - $out"
        done <<< "$next_outputs"
    fi
    echo ""
}

case "$SUBCOMMAND" in
    status)
        cmd_status
        ;;
    validate)
        cmd_validate
        ;;
    advance)
        cmd_advance
        ;;
    *)
        echo "Error: unknown subcommand '$SUBCOMMAND'" >&2
        usage
        ;;
esac
