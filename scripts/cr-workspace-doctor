#!/usr/bin/env bash
# cr-workspace-doctor — Diagnose CriticalResearch v2 workspace health.
# Usage: cr workspace doctor
#
# Checks:
#   1. CR_SKILL_HOME is set and scripts/ is in PATH
#   2. .claude/settings.json exists and has all 6 required hooks
#   3. commands/critical-cs-research.md loads v2 version
#   4. .claude/commands/critical-cs-research.md exists and matches v2
#   5. _cr/workspace.yaml is valid
#   6. Hook wrappers are in PATH
#   7. yq and jq are available

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

WORKSPACE_ROOT="$(cr_workspace_root)"
SKILL_HOME="${CR_SKILL_HOME:-$(cr_skill_home)}"

ALL_OK=true
ISSUES=0

check_pass() { echo "  ${GREEN}[OK]${NC} $1"; }
check_fail() { echo "  ${RED}[FAIL]${NC} $1"; ISSUES=$((ISSUES + 1)); ALL_OK=false; }
check_warn() { echo "  ${YELLOW}[WARN]${NC} $1"; }

echo ""
echo "══ CriticalResearch Workspace Doctor ══"
echo "  Workspace: $WORKSPACE_ROOT"
echo "  Skill Home: $SKILL_HOME"
echo ""

# ── 1. Check yq and jq ──────────────────────────────────────────
echo "── Tooling ──"
if command -v yq >/dev/null 2>&1; then
    check_pass "yq available ($(yq --version 2>&1 | head -1))"
else
    check_fail "yq not found in PATH"
fi

if command -v jq >/dev/null 2>&1; then
    check_pass "jq available ($(jq --version 2>&1))"
else
    check_fail "jq not found in PATH"
fi

echo ""

# ── 2. Check CR_SKILL_HOME ──────────────────────────────────────
echo "── Environment ──"
if [ -n "${CR_SKILL_HOME:-}" ]; then
    check_pass "CR_SKILL_HOME is set: $CR_SKILL_HOME"
elif [ -d "$SKILL_HOME" ] && [ -f "$SKILL_HOME/SKILL.md" ]; then
    check_pass "Skill home resolved: $SKILL_HOME"
else
    check_fail "CR_SKILL_HOME not set and cannot resolve skill home"
fi

if echo "$PATH" | tr ':' '\n' | grep -qF "$SKILL_HOME/scripts"; then
    check_pass "scripts/ directory is in PATH"
else
    check_warn "scripts/ directory ($SKILL_HOME/scripts) is NOT in PATH"
fi

echo ""

# ── 3. Check _cr/workspace.yaml ─────────────────────────────────
echo "── Workspace ──"
if [ -f "$WORKSPACE_ROOT/_cr/workspace.yaml" ]; then
    check_pass "_cr/workspace.yaml exists"
    ws_version=$(yq -r '.schema_version // "?"' "$WORKSPACE_ROOT/_cr/workspace.yaml" 2>/dev/null || echo "?")
    if [ "$ws_version" = "?" ]; then
        check_fail "_cr/workspace.yaml has no schema_version"
    else
        check_pass "_cr/workspace.yaml schema_version: $ws_version"
    fi
else
    check_fail "_cr/workspace.yaml not found — run: cr workspace init"
fi

echo ""

# ── 4. Check .claude/settings.json ──────────────────────────────
echo "── Claude Configuration ──"
SETTINGS="$WORKSPACE_ROOT/.claude/settings.json"
if [ -f "$SETTINGS" ]; then
    check_pass ".claude/settings.json exists"

    has_userexp=false
    has_usersub=false
    has_pretool=false
    has_posttool=false
    has_stop=false
    has_config=false

    total_entries=$(jq '.hooks | length' "$SETTINGS" 2>/dev/null || echo "0")
    i=0
    while [ "$i" -lt "${total_entries:-0}" ]; do
        matcher=$(jq -r ".hooks[$i].matcher // \"\"" "$SETTINGS" 2>/dev/null || echo "")
        hooks_block=$(jq -r ".hooks[$i].hooks // []" "$SETTINGS" 2>/dev/null || echo "")

        if echo "$hooks_block" | jq -e '.[].command // "" | test("user-prompt-expansion")' >/dev/null 2>&1; then
            has_userexp=true
        fi
        if echo "$hooks_block" | jq -e '.[].command // "" | test("user-prompt-submit")' >/dev/null 2>&1; then
            has_usersub=true
        fi
        if echo "$hooks_block" | jq -e '.[].command // "" | test("pre-tool-use")' >/dev/null 2>&1; then
            if [ "$matcher" = "project_settings|local_settings|skills" ]; then
                has_config=true
            else
                has_pretool=true
            fi
        fi
        if echo "$hooks_block" | jq -e '.[].command // "" | test("post-tool-use")' >/dev/null 2>&1; then
            has_posttool=true
        fi
        if echo "$hooks_block" | jq -e '.[].command // "" | test("stop")' >/dev/null 2>&1; then
            has_stop=true
        fi
        i=$((i + 1))
    done

    [ "$has_userexp" = true ] && check_pass "UserPromptExpansion hook configured" || check_fail "UserPromptExpansion hook MISSING"
    [ "$has_usersub" = true ] && check_pass "UserPromptSubmit hook configured" || check_fail "UserPromptSubmit hook MISSING"
    [ "$has_pretool" = true ] && check_pass "PreToolUse hook configured" || check_fail "PreToolUse hook MISSING"
    [ "$has_posttool" = true ] && check_pass "PostToolUse hook configured" || check_fail "PostToolUse hook MISSING"
    [ "$has_stop" = true ] && check_pass "Stop hook configured" || check_fail "Stop hook MISSING"
    [ "$has_config" = true ] && check_pass "ConfigChange hook configured" || check_fail "ConfigChange hook MISSING"
else
    check_fail ".claude/settings.json not found"
fi

echo ""

# ── 5. Check slash commands ─────────────────────────────────────
echo "── Slash Commands ──"
V2_CMD="$SKILL_HOME/commands/critical-cs-research.md"
CLAUDE_CMD="$WORKSPACE_ROOT/.claude/commands/critical-cs-research.md"

if [ -f "$V2_CMD" ]; then
    check_pass "commands/critical-cs-research.md exists (v2 source)"
    if grep -q 'cr round start' "$V2_CMD" 2>/dev/null; then
        check_pass "commands/critical-cs-research.md is v2 (uses cr round start)"
    else
        check_fail "commands/critical-cs-research.md does NOT look like v2"
    fi
else
    check_fail "commands/critical-cs-research.md not found"
fi

if [ -f "$CLAUDE_CMD" ]; then
    check_pass ".claude/commands/critical-cs-research.md exists"
    if [ -f "$V2_CMD" ]; then
        if diff -q "$V2_CMD" "$CLAUDE_CMD" >/dev/null 2>&1; then
            check_pass ".claude/commands/critical-cs-research.md matches v2 source"
        else
            check_fail ".claude/commands/critical-cs-research.md DIFFERS from v2 source"
        fi
    fi
else
    check_fail ".claude/commands/critical-cs-research.md not found"
fi

echo ""

# ── 6. Check hook wrappers ──────────────────────────────────────
echo "── Hook Wrappers ──"
if command -v critical-research-hook >/dev/null 2>&1; then
    check_pass "critical-research-hook wrapper found in PATH"
else
    check_fail "critical-research-hook wrapper NOT in PATH"
fi

hook_scripts=(
    "cr-hook-user-prompt-expansion"
    "cr-hook-user-prompt-submit"
    "cr-hook-pre-tool-use"
    "cr-hook-post-tool-use"
    "cr-hook-stop"
    "cr-hook-config-change"
)
for hook in "${hook_scripts[@]}"; do
    if [ -x "$SKILL_HOME/scripts/$hook" ]; then
        check_pass "$hook is executable"
    else
        check_fail "$hook not executable or missing"
    fi
done

echo ""

# ── 7. Check workflow files ─────────────────────────────────────
echo "── Workflows ──"
wf_dir="$SKILL_HOME/workflows"
if [ -d "$wf_dir" ]; then
    wf_count=0
    for wf_path in "$wf_dir"/*/workflow.yaml; do
        [ -f "$wf_path" ] || continue
        wf_id=$(yq -r '.workflow_id // "?"' "$wf_path" 2>/dev/null || echo "?")
        stages_count=$(yq -r '.stage_order | length // 0' "$wf_path" 2>/dev/null || echo "0")
        check_pass "Workflow '$wf_id': $stages_count stages"
        wf_count=$((wf_count + 1))
    done
    if [ "$wf_count" -eq 0 ]; then
        check_warn "No workflow.yaml files found under workflows/"
    fi
else
    check_fail "workflows/ directory not found"
fi

echo ""

# ── Summary ─────────────────────────────────────────────────────
echo "═══════════════════════════════════════"
if [ "$ALL_OK" = true ]; then
    echo "  ${GREEN}All checks passed.${NC} Workspace is healthy."
else
    echo "  ${RED}$ISSUES issue(s) found.${NC} Fix issues above."
fi
echo "═══════════════════════════════════════"
echo ""

[ "$ALL_OK" = true ]
