#!/usr/bin/env bash
# cr-validate-source-integrity — Verify that source snapshots match their recorded hashes.
# Usage: cr-validate-source-integrity <round_dir>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

ROUND_DIR="${1:-}"

if [ -z "$ROUND_DIR" ]; then
    echo "Usage: cr-validate-source-integrity <round_dir>" >&2
    exit 2
fi

echo "── Source Integrity ──"

INDEX_FILE="$ROUND_DIR/source-index.yaml"
if [ ! -f "$INDEX_FILE" ]; then
    fail "source-index.yaml not found"
    cr_exit_summary
fi

ALL_PASSED=true
SRC_COUNT=$(yq -r '.sources | length // 0' "$INDEX_FILE" 2>/dev/null || echo "0")

if [ "${SRC_COUNT:-0}" -eq 0 ]; then
    fail "No sources in source-index.yaml"
    cr_exit_summary
fi

for i in $(seq 0 $((SRC_COUNT - 1))); do
    SRC_ID=$(yq -r ".sources[$i].source_id // \"\"" "$INDEX_FILE" 2>/dev/null || echo "")
    SNAP=$(yq -r ".sources[$i].snapshot_path // \"\"" "$INDEX_FILE" 2>/dev/null || echo "")
    EXPECTED_SHA=$(yq -r ".sources[$i].sha256 // \"\"" "$INDEX_FILE" 2>/dev/null || echo "")

    SNAP_PATH="$ROUND_DIR/$SNAP"
    if [ ! -f "$SNAP_PATH" ]; then
        fail "$SRC_ID: snapshot file missing at $SNAP"
        ALL_PASSED=false
        continue
    fi

    if command -v shasum >/dev/null 2>&1; then
        ACTUAL_SHA=$(shasum -a 256 "$SNAP_PATH" | awk '{print $1}')
    elif command -v sha256sum >/dev/null 2>&1; then
        ACTUAL_SHA=$(sha256sum "$SNAP_PATH" | awk '{print $1}')
    else
        warn "$SRC_ID: no sha256 tool available — skipping hash check"
        continue
    fi

    if [ "$ACTUAL_SHA" = "$EXPECTED_SHA" ]; then
        pass "$SRC_ID: hash matches"
    else
        fail "$SRC_ID: hash mismatch (expected $EXPECTED_SHA, got $ACTUAL_SHA)"
        ALL_PASSED=false
    fi
done

if [ "$ALL_PASSED" = false ]; then
    cr_exit_summary
fi

pass "Source integrity: all snapshots verified"
cr_exit_summary
