#!/usr/bin/env bash
# cr-validate-references — Bidirectional cross-reference validation.
# Checks that IDs referenced across artifacts resolve correctly:
#   critique → disposition → paper_patch → anchor → experiment_obligation
#
# Usage: cr-validate-references <round_dir> [project_dir]
#
# Exit codes:
#   0 — all references valid
#   2 — one or more failures

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

ROUND_DIR="${1:-}"
PROJECT_DIR="${2:-}"

if [ -z "$ROUND_DIR" ]; then
    echo "Usage: cr-validate-references <round_dir> [project_dir]" >&2
    exit 2
fi

ROUND_NAME="$(basename "$ROUND_DIR")"
echo ""
echo "══ Reference Validation: $ROUND_NAME ══"

# ── Collect all IDs in scope ──────────────────────────────────────

ALL_CRT_IDS=""
ALL_PP_IDS=""
ALL_EXP_IDS=""
ALL_CLM_IDS=""

# From critique-ledger.yaml (L1 authoritative), fall back to critique.md (L2).
if [ -f "$ROUND_DIR/critique-ledger.yaml" ]; then
    ALL_CRT_IDS=$(yq -r '.critiques[].critique_id // ""' "$ROUND_DIR/critique-ledger.yaml" 2>/dev/null | sort -u || echo "")
fi
if [ -z "$ALL_CRT_IDS" ] && [ -f "$ROUND_DIR/critique.md" ]; then
    ALL_CRT_IDS=$(grep -oE 'CRT-[0-9]{3}' "$ROUND_DIR/critique.md" 2>/dev/null | sort -u || echo "")
fi

# From patches/
PATCHES_DIR="$ROUND_DIR/patches"
if [ -d "$PATCHES_DIR" ]; then
    ALL_PP_IDS=$(find "$PATCHES_DIR" -name 'PP-*.yaml' -exec basename {} .yaml \; 2>/dev/null | sort -u || echo "")
fi

# From experiments/
EXPERIMENTS_DIR="$ROUND_DIR/experiments"
if [ -d "$EXPERIMENTS_DIR" ]; then
    ALL_EXP_IDS=$(find "$EXPERIMENTS_DIR" -name 'EXP-*.yaml' -exec basename {} .yaml \; 2>/dev/null | sort -u || echo "")
fi

# Claim truth source: claim-ledger.yaml (L0 authoritative).
CLAIM_LEDGER="$PROJECT_DIR/state/claim-ledger.yaml"
if [ -f "$CLAIM_LEDGER" ]; then
    ALL_CLM_IDS=$(yq -r '.claims[]?.claim_id // ""' "$CLAIM_LEDGER" 2>/dev/null | sort -u || echo "")
fi

# Paper mode: claim-ledger.yaml is required for cross-reference validation.
WM=$(grep -E '^workflow_mode:' "$ROUND_DIR/round.yaml" 2>/dev/null | sed 's/^workflow_mode:\s*//' | xargs || echo "")
if [ "$WM" = "paper" ]; then
    if [ ! -f "$CLAIM_LEDGER" ]; then
        fail "claim-ledger.yaml not found (required for paper mode)"
        ALL_PASSED=false
    elif [ -z "$ALL_CLM_IDS" ]; then
        fail "claim-ledger.yaml has no claims — cannot validate cross-references"
        ALL_PASSED=false
    fi
fi

# ── Check patch → critique references ─────────────────────────────

if [ -d "$PATCHES_DIR" ]; then
    for patch_file in "$PATCHES_DIR"/PP-*.yaml; do
        [ ! -f "$patch_file" ] && continue
        PP_ID=$(basename "$patch_file" .yaml)
        LINKED_CRT=$(yq -r '.created_from.critique_id // ""' "$patch_file" 2>/dev/null || echo "")
        if [ -n "$LINKED_CRT" ]; then
            if echo "$ALL_CRT_IDS" | grep -q "$LINKED_CRT" 2>/dev/null; then
                pass "$PP_ID → $LINKED_CRT (resolved)"
            else
                fail "$PP_ID → $LINKED_CRT: critique ID not found in critique-ledger.yaml"
            fi
        fi

        # Check experiment obligation references.
        EXP_REFS=$(grep -E '^\s*-\s*EXP-[0-9]{3}$' "$patch_file" 2>/dev/null | grep -oE 'EXP-[0-9]{3}' || echo "")
        for exp_ref in $EXP_REFS; do
            if echo "$ALL_EXP_IDS" | grep -q "$exp_ref" 2>/dev/null; then
                pass "$PP_ID → $exp_ref (resolved)"
            else
                fail "$PP_ID → $exp_ref: experiment obligation not found"
            fi
        done

        # Check superseded_by reference.
        SUPERSEDED_BY=$(grep -E '^superseded_by:' "$patch_file" 2>/dev/null | sed 's/^superseded_by:\s*//' | xargs || echo "")
        if [ -n "$SUPERSEDED_BY" ] && [ "$SUPERSEDED_BY" != '""' ]; then
            if echo "$ALL_PP_IDS" | grep -q "$SUPERSEDED_BY" 2>/dev/null; then
                pass "$PP_ID superseded_by $SUPERSEDED_BY (resolved)"
            else
                fail "$PP_ID superseded_by $SUPERSEDED_BY: target patch not found"
            fi
        fi
    done
fi

# ── Check experiment → patch references ────────────────────────────

if [ -d "$EXPERIMENTS_DIR" ]; then
    for exp_file in "$EXPERIMENTS_DIR"/EXP-*.yaml; do
        [ ! -f "$exp_file" ] && continue
        EXP_ID=$(basename "$exp_file" .yaml)
        LINKED_PATCH=$(grep -E '^linked_patch_id:' "$exp_file" 2>/dev/null | sed 's/^linked_patch_id:\s*//' | xargs || echo "")
        if [ -n "$LINKED_PATCH" ]; then
            if echo "$ALL_PP_IDS" | grep -q "$LINKED_PATCH" 2>/dev/null; then
                pass "$EXP_ID → $LINKED_PATCH (resolved)"
            else
                fail "$EXP_ID → $LINKED_PATCH: linked patch not found"
            fi
        fi

        TARGET_CLAIM=$(grep -E '^target_claim:' "$exp_file" 2>/dev/null | sed 's/^target_claim:\s*//' | xargs || echo "")
        if [ -n "$TARGET_CLAIM" ] && [ -n "$ALL_CLM_IDS" ]; then
            if echo "$ALL_CLM_IDS" | grep -q "$TARGET_CLAIM" 2>/dev/null; then
                pass "$EXP_ID → $TARGET_CLAIM (claim resolved)"
            else
                warn "$EXP_ID → $TARGET_CLAIM: claim ID not found in claim-ledger.yaml"
            fi
        fi
    done
fi

# ── Check disposition → patch references ──────────────────────────

DISPOSITIONS_FILE="$ROUND_DIR/dispositions.yaml"
if [ -f "$DISPOSITIONS_FILE" ] && command -v yq >/dev/null 2>&1; then
    DISP_JSON=$(yq -o json '.' "$DISPOSITIONS_FILE" 2>/dev/null || echo "[]")
    PAPER_PATCH_DISPS=$(printf '%s' "$DISP_JSON" | jq -r '(.dispositions // [])[] | select(.disposition_type == "paper_patch") | "\(.critique_id)|\(.linked_patch_id)"' 2>/dev/null)
    if [ -n "$PAPER_PATCH_DISPS" ]; then
        while IFS='|' read -r cid ppid; do
            [ -z "$cid" ] && continue
            if echo "$ALL_PP_IDS" | grep -q "$ppid" 2>/dev/null; then
                pass "disposition $cid → $ppid (resolved)"
            else
                fail "disposition $cid → $ppid: patch not found in patches/"
            fi
        done <<< "$PAPER_PATCH_DISPS"
    fi
fi

cr_exit_summary
