#!/usr/bin/env bash
# cr-hash-artifact — Compute deterministic sha256 for a scoped artifact path.
#
# Resolves scoped paths (project:/round:/workspace:) to actual files/directories
# and returns a deterministic content hash.
#
# Usage: cr-hash-artifact <project_dir> <round_dir> <scoped_path>
#
# Exit codes:
#   0 — hash computed successfully (stdout: sha256 hex)
#   1 — artifact not found or unresolvable
#   2 — usage error

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

PROJECT_DIR="${1:-}"
ROUND_DIR="${2:-}"
SCOPED_PATH="${3:-}"

if [ -z "$PROJECT_DIR" ] || [ -z "$ROUND_DIR" ] || [ -z "$SCOPED_PATH" ]; then
    echo "Usage: cr-hash-artifact <project_dir> <round_dir> <scoped_path>" >&2
    exit 2
fi

# Use cr-resolve-artifact-path to resolve the scoped path.
RESOLVER="$SCRIPT_DIR/cr-resolve-artifact-path"
if [ ! -x "$RESOLVER" ]; then
    echo "Error: cr-resolve-artifact-path not found" >&2
    exit 1
fi

RESOLVED=$("$RESOLVER" "$PROJECT_DIR" "$ROUND_DIR" "$SCOPED_PATH" 2>/dev/null || echo "")
if [ -z "$RESOLVED" ]; then
    echo "Error: failed to resolve $SCOPED_PATH" >&2
    exit 1
fi

ABS_PATH=$(echo "$RESOLVED" | jq -r '.absolute_path // ""' 2>/dev/null || echo "")
KIND=$(echo "$RESOLVED" | jq -r '.kind // ""' 2>/dev/null || echo "")

if [ -z "$ABS_PATH" ]; then
    echo "Error: unresolvable path: $SCOPED_PATH" >&2
    exit 1
fi

if [ ! -e "$ABS_PATH" ]; then
    echo "Error: artifact does not exist: $ABS_PATH" >&2
    exit 1
fi

# Compute hash based on kind.
if [ "$KIND" = "directory" ] || [ -d "$ABS_PATH" ]; then
    # Directory hash: content-only hash of all files.
    # Exclude paths via awk, sort hashes, then hash the sorted list.
    find "$ABS_PATH" -type f -exec shasum -a 256 {} \; 2>/dev/null | \
        awk '{print $1}' | sort | shasum -a 256 | cut -d' ' -f1
else
    # File hash: direct sha256.
    shasum -a 256 "$ABS_PATH" 2>/dev/null | cut -d' ' -f1
fi
