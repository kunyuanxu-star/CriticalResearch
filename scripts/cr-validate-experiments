#!/usr/bin/env bash
# cr-validate-experiments — Experiment obligation validation.
# Authoritative entry: experiment-obligations.yaml (L1).
# Obligations non-empty → each EXP-*.yaml must exist with required fields.
# Obligations empty → no_obligation_reason required + validated_patches must cover all PP.
#
# Usage: cr-validate-experiments <round_dir>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

ROUND_DIR="${1:-}"

if [ -z "$ROUND_DIR" ]; then
    echo "Usage: cr-validate-experiments <round_dir>" >&2
    exit 2
fi

echo ""
echo "══ Experiment Validation: $(basename "$ROUND_DIR") ══"

WORKFLOW_MODE=$(grep -E '^workflow_mode:' "$ROUND_DIR/round.yaml" 2>/dev/null | sed 's/^workflow_mode:\s*//' | xargs || echo "")
if [ "$WORKFLOW_MODE" != "paper" ]; then
    pass "Not paper mode — skipping"
    cr_exit_summary
fi

ALL_PASSED=true
OBLIGATIONS_FILE="$ROUND_DIR/experiment-obligations.yaml"
PATCHES_DIR="$ROUND_DIR/patches"
EXPERIMENTS_DIR="$ROUND_DIR/experiments"

[ -f "$OBLIGATIONS_FILE" ] || {
    fail "experiment-obligations.yaml not found"
    cr_exit_summary
}

OBL_COUNT=$(yq -r '.obligations | length // 0' "$OBLIGATIONS_FILE" 2>/dev/null || echo "0")
NO_REASON=$(yq -r '.no_experiment_needed_reason // ""' "$OBLIGATIONS_FILE" 2>/dev/null || echo "")
[ -z "$NO_REASON" ] || [ "$NO_REASON" = "null" ] && NO_REASON=""

if [ "${OBL_COUNT:-0}" -eq 0 ]; then
    # ── No-op mode ──────────────────────────────────────────────────
    if [ -z "$NO_REASON" ] || [ "$NO_REASON" = "null" ]; then
        fail "obligations is empty but no_experiment_needed_reason is missing"
        ALL_PASSED=false
    else
        pass "No experiment obligations: ${NO_REASON:0:80}..."
    fi

    PATCH_COUNT=$(find "$PATCHES_DIR" -name 'PP-*.yaml' -type f 2>/dev/null | wc -l | tr -d ' ')
    VALIDATED_COUNT=$(yq -r '.validated_patches | length // 0' "$OBLIGATIONS_FILE" 2>/dev/null || echo "0")

    if [ "${PATCH_COUNT:-0}" -gt 0 ] && [ "${VALIDATED_COUNT:-0}" -lt "${PATCH_COUNT:-0}" ]; then
        fail "validated_patches ($VALIDATED_COUNT) must cover all PP-*.yaml ($PATCH_COUNT) when obligations is empty"
        ALL_PASSED=false
    else
        pass "Validated patches: $VALIDATED_COUNT / $PATCH_COUNT"
    fi

    [ "$ALL_PASSED" = false ] && cr_exit_summary
    pass "Experiment no-op record valid"
    cr_exit_summary
fi

# ── Obligations mode ──────────────────────────────────────────────
pass "experiment-obligations.yaml: $OBL_COUNT obligation(s)"

for i in $(seq 0 $((OBL_COUNT - 1))); do
    OID=$(yq -r ".obligations[$i].obligation_id // \"\"" "$OBLIGATIONS_FILE" 2>/dev/null || echo "")
    PATH_REL=$(yq -r ".obligations[$i].path // \"\"" "$OBLIGATIONS_FILE" 2>/dev/null || echo "")
    PATCH_ID=$(yq -r ".obligations[$i].linked_patch_id // \"\"" "$OBLIGATIONS_FILE" 2>/dev/null || echo "")
    TARGET_CLAIM=$(yq -r ".obligations[$i].target_claim // \"\"" "$OBLIGATIONS_FILE" 2>/dev/null || echo "")

    [ -n "$OID" ] || { fail "obligations[$i]: missing obligation_id"; ALL_PASSED=false; }
    [ -n "$PATH_REL" ] || { fail "$OID: missing path"; ALL_PASSED=false; }
    [ -n "$PATCH_ID" ] || { fail "$OID: missing linked_patch_id"; ALL_PASSED=false; }
    [ -n "$TARGET_CLAIM" ] || { fail "$OID: missing target_claim"; ALL_PASSED=false; }

    EXP_PATH="$ROUND_DIR/$PATH_REL"
    [ -f "$EXP_PATH" ] || { fail "$OID: EXP file not found: $PATH_REL"; ALL_PASSED=false; }

    PP_PATH="$PATCHES_DIR/${PATCH_ID}.yaml"
    [ -f "$PP_PATH" ] || { fail "$OID: linked patch not found: $PATCH_ID"; ALL_PASSED=false; }

    if [ -f "$EXP_PATH" ]; then
        # Validate EXP file required fields.
        for field in target_claim baseline metric support_condition refute_condition; do
            val=$(grep -E "^${field}:" "$EXP_PATH" 2>/dev/null | sed "s/^${field}:\s*//" | xargs || echo "")
            [ -n "$val" ] || { fail "$OID: EXP file missing $field"; ALL_PASSED=false; }
        done
        pass "$OID: valid (patch=$PATCH_ID claim=$TARGET_CLAIM)"
    fi
done

# Reverse check: every experiments/EXP-*.yaml must appear in obligation index.
if [ -d "$EXPERIMENTS_DIR" ]; then
    for exp_file in "$EXPERIMENTS_DIR"/EXP-*.yaml; do
        [ -f "$exp_file" ] || continue
        rel="experiments/$(basename "$exp_file")"
        hit=$(yq -r "[.obligations[]? | select(.path == \"$rel\")] | length" "$OBLIGATIONS_FILE" 2>/dev/null || echo "0")
        [ "${hit:-0}" -gt 0 ] || { fail "$rel exists but is not listed in experiment-obligations.yaml"; ALL_PASSED=false; }
    done
fi

[ "$ALL_PASSED" = false ] && cr_exit_summary
pass "Experiment obligation validation passed"
cr_exit_summary
