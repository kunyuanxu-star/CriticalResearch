#!/usr/bin/env bash
# cr-record-decision â€” Record a human decision for a paper patch.
# Updates patch lifecycle status and writes to decision ledger.
#
# Usage: cr-record-decision <round_dir> <project_dir> <patch_id> <decision> [rationale]
#   decision: accepted | accepted_with_modifications | rejected | deferred | needs_more_evidence
#   (CLI aliases accept/reject/defer are normalized to the schema-compatible form.)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

ROUND_DIR="${1:-}"
PROJECT_DIR="${2:-}"
PATCH_ID="${3:-}"
DECISION_RAW="${4:-}"
RATIONALE="${5:-}"

if [ -z "$ROUND_DIR" ] || [ -z "$PROJECT_DIR" ] || [ -z "$PATCH_ID" ] || [ -z "$DECISION_RAW" ]; then
    echo "Usage: cr-record-decision <round_dir> <project_dir> <patch_id> <decision> [rationale]" >&2
    echo "  decision: accepted | accepted_with_modifications | rejected | deferred | needs_more_evidence" >&2
    echo "  (aliases: acceptâ†’accepted, rejectâ†’rejected, deferâ†’deferred)" >&2
    exit 2
fi

# Normalize CLI aliases to schema-compatible enum values.
DECISION=""
case "$DECISION_RAW" in
    accept)                    DECISION="accepted" ;;
    accept_with_modifications) DECISION="accepted_with_modifications" ;;
    reject)                    DECISION="rejected" ;;
    defer)                     DECISION="deferred" ;;
    needs_more_evidence)       DECISION="needs_more_evidence" ;;
    accepted|accepted_with_modifications|rejected|deferred) DECISION="$DECISION_RAW" ;;
    *) echo "Error: invalid decision '$DECISION_RAW'" >&2; exit 2 ;;
esac

PATCH_FILE="$ROUND_DIR/patches/${PATCH_ID}.yaml"
if [ ! -f "$PATCH_FILE" ]; then
    echo "Error: patch file not found: $PATCH_FILE" >&2
    exit 1
fi

NOW=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
DECISION_NUM=$(grep -cE '^decision_id:' "$PROJECT_DIR/state/human-review-queue.yaml" 2>/dev/null || echo 0)
DECISION_NUM=$((DECISION_NUM + 1))
DECISION_ID=$(printf "DEC-%03d" "$DECISION_NUM")

# Update patch lifecycle.
OLD_STATUS=$(grep -E '^lifecycle_status:' "$PATCH_FILE" 2>/dev/null | sed 's/^lifecycle_status:\s*//' | xargs || echo "proposed")

case "$DECISION" in
    accepted|accepted_with_modifications)
        NEW_STATUS="approved"
        [ "$DECISION" = "accepted_with_modifications" ] && RATIONALE="[MODIFIED] $RATIONALE"
        ;;
    rejected)
        NEW_STATUS="rejected"
        if grep -q '^rejection_reason:' "$PATCH_FILE" 2>/dev/null; then
            if [ "$(uname)" = "Darwin" ]; then
                sed -i '' "s|^rejection_reason:.*|rejection_reason: \"$RATIONALE\"|" "$PATCH_FILE"
            else
                sed -i "s|^rejection_reason:.*|rejection_reason: \"$RATIONALE\"|" "$PATCH_FILE"
            fi
        fi
        ;;
    deferred)
        NEW_STATUS="$OLD_STATUS"
        ;;
    needs_more_evidence)
        NEW_STATUS="$OLD_STATUS"
        ;;
esac

# Update lifecycle.
if [ "$NEW_STATUS" != "$OLD_STATUS" ]; then
    if [ "$(uname)" = "Darwin" ]; then
        sed -i '' "s|^lifecycle_status:.*|lifecycle_status: $NEW_STATUS|" "$PATCH_FILE"
    else
        sed -i "s|^lifecycle_status:.*|lifecycle_status: $NEW_STATUS|" "$PATCH_FILE"
    fi
    echo "  Patch $PATCH_ID: $OLD_STATUS -> $NEW_STATUS"
fi

# Record decision in human-review-queue.
QUEUE_FILE="$PROJECT_DIR/state/human-review-queue.yaml"
mkdir -p "$(dirname "$QUEUE_FILE")"
[ ! -f "$QUEUE_FILE" ] && echo "decisions: []" > "$QUEUE_FILE"

# Append decision to queue using a temp file (avoids sed quoting issues).
BLOCKING="true"
[ "$DECISION" = "deferred" ] && BLOCKING="false"

TMP_QUEUE=$(mktemp)
while IFS= read -r line; do
    echo "$line" >> "$TMP_QUEUE"
    if echo "$line" | grep -q '^decisions:' 2>/dev/null; then
        cat >> "$TMP_QUEUE" << ENTRY
  - decision_id: $DECISION_ID
    linked_patch_id: $PATCH_ID
    decision: $DECISION
    rationale: "$RATIONALE"
    blocks_round_close: $BLOCKING
    timestamp: $NOW
    resolved_at: $NOW
ENTRY
    fi
done < "$QUEUE_FILE"
mv "$TMP_QUEUE" "$QUEUE_FILE"

# Also write to decision-ledger (separate from queue â€” long-term audit history).
LEDGER="$PROJECT_DIR/state/decision-ledger.yaml"
[ ! -f "$LEDGER" ] && echo "decisions: []" > "$LEDGER"
TMP_LEDGER=$(mktemp)
while IFS= read -r line; do
    echo "$line" >> "$TMP_LEDGER"
    if echo "$line" | grep -q '^decisions:' 2>/dev/null; then
        cat >> "$TMP_LEDGER" << ENTRY
  - decision_id: $DECISION_ID
    linked_patch_id: $PATCH_ID
    decision: $DECISION
    rationale: "$RATIONALE"
    timestamp: $NOW
ENTRY
    fi
done < "$LEDGER"
mv "$TMP_LEDGER" "$LEDGER"

echo ""
echo "Decision $DECISION_ID recorded: $PATCH_ID -> $DECISION"
echo "  Rationale: $RATIONALE"
echo "  Recorded in: $QUEUE_FILE and $LEDGER"
