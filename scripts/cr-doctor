#!/usr/bin/env bash
# cr-doctor — Diagnostic check for CriticalResearch installation and workspace.
# Verifies dependencies, skill home, hooks, workspace, active project.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

echo "CriticalResearch Doctor"
echo "======================"
echo ""

ISSUES=0

# ── Dependencies ──────────────────────────────────────────────────
echo "── Dependencies ──"
for dep in jq git bash; do
    if command -v "$dep" >/dev/null 2>&1; then
        echo "  [OK] $dep ($(command -v "$dep"))"
    else
        echo "  [MISSING] $dep — required"
        ISSUES=$((ISSUES + 1))
    fi
done
if command -v yq >/dev/null 2>&1; then
    echo "  [OK] yq ($(command -v yq))"
else
    echo "  [MISSING] yq — required for paper mode (brew install yq)"
    ISSUES=$((ISSUES + 1))
fi

# ── Skill home ────────────────────────────────────────────────────
echo ""
echo "── Skill Home ──"
SKILL_HOME="${CR_SKILL_HOME:-}"
if [ -z "$SKILL_HOME" ]; then
    if [ -d "$HOME/.claude/skills/critical-cs-research" ]; then
        SKILL_HOME="$HOME/.claude/skills/critical-cs-research"
        echo "  [OK] CR_SKILL_HOME not set, found at default: $SKILL_HOME"
    else
        SKILL_HOME="$(cd "$SCRIPT_DIR/.." && pwd)"
        echo "  [WARN] CR_SKILL_HOME not set, using: $SKILL_HOME"
    fi
else
    echo "  [OK] CR_SKILL_HOME=$SKILL_HOME"
fi

# ── Hook wrapper ──────────────────────────────────────────────────
echo ""
echo "── Hook Wrapper ──"
if command -v critical-research-hook >/dev/null 2>&1; then
    echo "  [OK] critical-research-hook in PATH ($(command -v critical-research-hook))"
else
    if [ -x "$HOME/.local/bin/critical-research-hook" ]; then
        echo "  [WARN] critical-research-hook at ~/.local/bin/ but not in PATH"
    else
        echo "  [MISSING] critical-research-hook — run install.sh or add ~/.local/bin to PATH"
        ISSUES=$((ISSUES + 1))
    fi
fi

# ── Workspace ─────────────────────────────────────────────────────
echo ""
echo "── Workspace ──"
WORKSPACE_ROOT=$(cr_workspace_root 2>/dev/null || echo "")
if [ -f "$WORKSPACE_ROOT/_cr/workspace.yaml" ]; then
    echo "  [OK] Workspace found: $WORKSPACE_ROOT"
    WS_NAME=$(grep 'workspace_name:' "$WORKSPACE_ROOT/_cr/workspace.yaml" 2>/dev/null | sed 's/.*:\s*//' | xargs || echo "unknown")
    echo "       Name: $WS_NAME"
else
    echo "  [WARN] No _cr/workspace.yaml found at $WORKSPACE_ROOT — run 'cr workspace init'"
fi

# ── Active project ────────────────────────────────────────────────
echo ""
echo "── Active Project ──"
ACTIVE_PROJECT_FILE="$WORKSPACE_ROOT/_cr/active-project"
if [ -f "$ACTIVE_PROJECT_FILE" ]; then
    ACTIVE_PROJECT=$(cat "$ACTIVE_PROJECT_FILE")
    PROJECT_DIR="$WORKSPACE_ROOT/$ACTIVE_PROJECT"
    if [ -d "$PROJECT_DIR" ] && [ -f "$PROJECT_DIR/project.yaml" ]; then
        echo "  [OK] Active project: $ACTIVE_PROJECT"
        STATUS=$(jq -r '.status // "?"' "$PROJECT_DIR/state/project-state.json" 2>/dev/null || echo "?")
        ROUNDS=$(jq -r '.total_rounds // 0' "$PROJECT_DIR/state/project-state.json" 2>/dev/null || echo "0")
        ACTIVE=$(jq -r '.active_round // "none"' "$PROJECT_DIR/state/project-state.json" 2>/dev/null || echo "none")
        PROFILE=$(grep -E '^paper_profile:' "$PROJECT_DIR/project.yaml" 2>/dev/null | sed 's/^paper_profile:\s*//' | xargs || echo "generic")
        echo "       Status: $STATUS,  Rounds: $ROUNDS,  Active round: $ACTIVE,  Profile: $PROFILE"

        if [ "$ACTIVE" != "none" ] && [ "$ACTIVE" != "null" ]; then
            ROUND_NUM=$(printf "%03d" "$ACTIVE")
            ROUND_DIR="$PROJECT_DIR/rounds/round-$ROUND_NUM"
            if [ -d "$ROUND_DIR" ]; then
                WORKFLOW=$(grep -E '^workflow_mode:' "$ROUND_DIR/round.yaml" 2>/dev/null | sed 's/^workflow_mode:\s*//' | xargs || echo "deep")
                echo "       Active round: $ROUND_NUM (mode: $WORKFLOW)"
            fi
        fi
    else
        echo "  [WARN] Active project '$ACTIVE_PROJECT' not found — run 'cr start <topic>'"
    fi
else
    echo "  [INFO] No active project — run 'cr start <topic>'"
fi

# ── Recent validation ─────────────────────────────────────────────
echo ""
echo "── Quick Validation ──"
if [ -n "${ACTIVE_PROJECT:-}" ] && [ -d "${PROJECT_DIR:-}" ] && [ "${ACTIVE:-}" != "none" ] && [ "${ACTIVE:-}" != "null" ]; then
    echo "  Running quick artifact check on active round..."
    "$SCRIPT_DIR/cr-validate-artifacts" "$ROUND_DIR" 2>/dev/null || true
else
    echo "  (no active round to validate)"
fi

echo ""
if [ "$ISSUES" -gt 0 ]; then
    echo "══ $ISSUES issue(s) found ══"
    exit 1
else
    echo "══ All checks passed ══"
fi
