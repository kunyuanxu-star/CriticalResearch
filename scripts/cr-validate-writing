#!/usr/bin/env bash
# cr-validate-writing — Writing progress validation.
# Authoritative: writing-diff.yaml (L1). Fallback: writing-diff.md (L2).
# Checks that the paper draft was modified during the round.
#
# Usage: cr-validate-writing <project_dir> <round_dir>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

PROJECT_DIR="${1:-}"
ROUND_DIR="${2:-}"

if [ -z "$PROJECT_DIR" ] || [ -z "$ROUND_DIR" ]; then
    echo "Usage: cr-validate-writing <project_dir> <round_dir>" >&2
    exit 2
fi

PROJECT_NAME="$(basename "$PROJECT_DIR")"
ROUND_NAME="$(basename "$ROUND_DIR")"
echo ""
echo "══ Writing Validation: $PROJECT_NAME / $ROUND_NAME ══"

# ── Draft existence and mtime ────────────────────────────────────

PRIMARY_DRAFT=""
if [ -f "$PROJECT_DIR/writing/paper-draft.md" ]; then
    PRIMARY_DRAFT="$PROJECT_DIR/writing/paper-draft.md"
else
    fail "No paper-draft.md found"
    cr_exit_summary
fi

ROUND_START=""
if [ -f "$ROUND_DIR/round.yaml" ]; then
    ROUND_START=$(grep -E '^started_at:' "$ROUND_DIR/round.yaml" 2>/dev/null | sed 's/^started_at:\s*//' | xargs || echo "")
fi

if [ -n "$ROUND_START" ]; then
    if [[ "$OSTYPE" == "darwin"* ]]; then
        ROUND_EPOCH=$(date -j -f "%Y-%m-%dT%H:%M:%SZ" "$ROUND_START" +%s 2>/dev/null || echo 0)
        DRAFT_MTIME=$(stat -f %m "$PRIMARY_DRAFT" 2>/dev/null || echo 0)
    else
        ROUND_EPOCH=$(date -d "$ROUND_START" +%s 2>/dev/null || echo 0)
        DRAFT_MTIME=$(stat -c %Y "$PRIMARY_DRAFT" 2>/dev/null || echo 0)
    fi

    if [ "$DRAFT_MTIME" -gt "$ROUND_EPOCH" ]; then
        pass "Draft modified after round start"
    else
        fail "Draft not modified since round start — writing progress required"
    fi
else
    warn "Could not determine round start time — skipping mtime comparison"
fi

# ── Writing diff: writing-diff.yaml (L1) first, then writing-diff.md (L2) ──

DIFF_YAML="$ROUND_DIR/writing-diff.yaml"
DIFF_MD="$ROUND_DIR/writing-diff.md"

if [ -f "$DIFF_YAML" ]; then
    pass "writing-diff.yaml exists (L1 authoritative)"

    CHANGES=$(yq -r '.changes | length // 0' "$DIFF_YAML" 2>/dev/null || echo "0")
    if [ "${CHANGES:-0}" -gt 0 ]; then
        pass "  $CHANGES change(s) recorded"

        # Verify each change links a valid patch_id.
        for i in $(seq 0 $((CHANGES - 1))); do
            CID=$(yq -r ".changes[$i].change_id // \"\"" "$DIFF_YAML" 2>/dev/null || echo "")
            PID=$(yq -r ".changes[$i].patch_id // \"\"" "$DIFF_YAML" 2>/dev/null || echo "")
            if [ -n "$PID" ] && [ "$PID" != "null" ]; then
                PP_FILE="$ROUND_DIR/patches/${PID}.yaml"
                if [ -f "$PP_FILE" ]; then
                    pass "  $CID -> $PID: patch exists"
                else
                    fail "  $CID -> $PID: patch file not found"
                fi
            fi
        done
    else
        warn "  No changes recorded in writing-diff.yaml"
    fi

    # Check before/after hash.
    BEFORE=$(yq -r '.draft_before_sha256 // ""' "$DIFF_YAML" 2>/dev/null || echo "")
    AFTER=$(yq -r '.draft_after_sha256 // ""' "$DIFF_YAML" 2>/dev/null || echo "")
    if [ -n "$BEFORE" ] && [ "$BEFORE" != "null" ] && [ -n "$AFTER" ] && [ "$AFTER" != "null" ]; then
        if [ "$BEFORE" != "$AFTER" ]; then
            pass "  Draft hash changed (before → after)"
        else
            fail "  Draft before/after hash identical — no change detected"
        fi
    fi
elif [ -f "$DIFF_MD" ]; then
    warn "writing-diff.yaml not found; writing-diff.md present (L2). Consider migrating to YAML."
    for section in "Added" "Deleted" "Weakened" "Reframed" "Still Unstable"; do
        if grep -qi "$section" "$DIFF_MD" 2>/dev/null; then
            pass "  Section: $section"
        else
            fail "  Required section missing in writing-diff.md: $section"
        fi
    done
else
    fail "No writing diff found (writing-diff.yaml or writing-diff.md required)"
fi

cr_exit_summary
