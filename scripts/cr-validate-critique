#!/usr/bin/env bash
# cr-validate-critique — Validate critique-ledger.yaml structure.
# Checks that every medium+ critique has evidence_refs (unless internal_consistency),
# every high/fatal critique has must_create_patch=true, and required fields are present.
#
# Usage: cr-validate-critique <round_dir>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

ROUND_DIR="${1:-}"

if [ -z "$ROUND_DIR" ]; then
    echo "Usage: cr-validate-critique <round_dir>" >&2
    exit 2
fi

echo "── Critique Ledger Validation ──"

CRITIQUE_FILE="$ROUND_DIR/critique-ledger.yaml"
if [ ! -f "$CRITIQUE_FILE" ]; then
    # Fall back to critique.md — warn but don't fail for backward compat.
    if [ -f "$ROUND_DIR/critique.md" ]; then
        warn "critique-ledger.yaml not found; critique.md present (L2 only — consider migrating to critique-ledger.yaml)"
        cr_exit_summary
    fi
    fail "critique-ledger.yaml not found"
    cr_exit_summary
fi

ALL_PASSED=true

CRIT_COUNT=$(yq -r '.critiques | length // 0' "$CRITIQUE_FILE" 2>/dev/null || echo "0")
if [ "${CRIT_COUNT:-0}" -eq 0 ]; then
    # Allow structured no-op: no_medium_plus_critique with reason and checked_claims.
    NO_CRIT_REASON=$(yq -r '.no_medium_plus_critique.reason // ""' "$CRITIQUE_FILE" 2>/dev/null || echo "")
    CHECKED=$(yq -r '.no_medium_plus_critique.checked_claims | length // 0' "$CRITIQUE_FILE" 2>/dev/null || echo "0")
    if [ -n "$NO_CRIT_REASON" ] && [ "$NO_CRIT_REASON" != "null" ] && [ "${CHECKED:-0}" -gt 0 ]; then
        pass "No medium+ critiques with explicit no-op record: ${NO_CRIT_REASON:0:80}..."
        cr_exit_summary
    fi
    fail "No critiques in critique-ledger.yaml and no structured no_medium_plus_critique record"
    cr_exit_summary
fi

echo "Critique count: $CRIT_COUNT"

MEDIUM_PLUS=0
NO_EVIDENCE=0
NO_PATCH=0

for i in $(seq 0 $((CRIT_COUNT - 1))); do
    CID=$(yq -r ".critiques[$i].critique_id // \"\"" "$CRITIQUE_FILE" 2>/dev/null || echo "")
    SEV=$(yq -r ".critiques[$i].severity // \"\"" "$CRITIQUE_FILE" 2>/dev/null || echo "")
    ATK=$(yq -r ".critiques[$i].attack_type // \"\"" "$CRITIQUE_FILE" 2>/dev/null || echo "")
    TGT=$(yq -r ".critiques[$i].target_id // \"\"" "$CRITIQUE_FILE" 2>/dev/null || echo "")
    EVID_COUNT=$(yq -r ".critiques[$i].evidence_refs | length // 0" "$CRITIQUE_FILE" 2>/dev/null || echo "0")
    MUST_PATCH=$(yq -r ".critiques[$i].required_action.must_create_patch // false" "$CRITIQUE_FILE" 2>/dev/null || echo "false")

    # Check target_id exists.
    if [ -z "$TGT" ] || [ "$TGT" = "null" ]; then
        fail "$CID: missing target_id"
        ALL_PASSED=false
    fi

    # Medium+ critiques: require evidence_refs unless internal_consistency.
    case "$SEV" in
        medium|high|fatal)
            MEDIUM_PLUS=$((MEDIUM_PLUS + 1))
            if [ "${EVID_COUNT:-0}" -eq 0 ] && [ "$ATK" != "internal_consistency" ]; then
                fail "$CID ($SEV): no evidence_refs (attack_type=$ATK)"
                NO_EVIDENCE=$((NO_EVIDENCE + 1))
                ALL_PASSED=false
            fi
            ;;
    esac

    # High/fatal critiques: must_create_patch should be true.
    case "$SEV" in
        high|fatal)
            if [ "$MUST_PATCH" != "true" ]; then
                fail "$CID ($SEV): required_action.must_create_patch is not true"
                NO_PATCH=$((NO_PATCH + 1))
                ALL_PASSED=false
            fi
            ;;
    esac

    pass "$CID: severity=$SEV target=$TGT attack=$ATK"
done

echo ""
echo "Medium+: $MEDIUM_PLUS  Missing evidence: $NO_EVIDENCE  Missing patch obligation: $NO_PATCH"

if [ "$ALL_PASSED" = false ]; then
    cr_exit_summary
fi

pass "Critique ledger validation passed"
cr_exit_summary
