#!/usr/bin/env bash
# cr-validate-argument-flow — Hard gate: upstream/downstream consistency after patches.
# Usage: cr-validate-argument-flow <project_dir> <round_dir>
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"
ROUND_DIR="${2:-}"
[ -z "$ROUND_DIR" ] && { echo "Usage: cr-validate-argument-flow <project_dir> <round_dir>" >&2; exit 2; }
echo "── Argument Flow Check ──"
REPORT="$ROUND_DIR/argument-flow-report.yaml"
[ ! -f "$REPORT" ] && { fail "argument-flow-report.yaml not found"; cr_exit_summary; }
SECTIONS=("introduction_chain" "motivation_to_problem" "design_to_evaluation" "conclusion_to_claims")
for sec in "${SECTIONS[@]}"; do
  status=$(yq -r ".${sec} // \"missing\"" "$REPORT" 2>/dev/null || echo "missing")
  [ "$status" = "missing" ] && { fail "Flow check missing: $sec"; continue; }
  pass "Flow: $sec"
done
pass "Argument flow report validated"
cr_exit_summary
