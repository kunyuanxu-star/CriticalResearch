#!/usr/bin/env bash
# cr-project — Project lifecycle commands (init, status, list).
#
# Usage: cr-project <subcommand> [args...]
#
# Subcommands:
#   init <id> --domain <domain>   Create a new research project
#   status <project>              Show project status
#   list                          List all projects in workspace

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

# ── Helpers ───────────────────────────────────────────────────────

usage() {
    echo "Usage: cr project <init|status|list> [args...]" >&2
    echo "" >&2
    echo "  cr project init <id> --domain <domain>" >&2
    echo "  cr project status <project>" >&2
    echo "  cr project list" >&2
    exit 2
}

# Sanitize a project_id: lowercase, hyphens only, no leading/trailing hyphens,
# no consecutive hyphens. Replace underscores and spaces with hyphens.
sanitize_id() {
    local raw="$1"
    # lowercase
    local s="${raw,,}"
    # replace underscores and spaces with hyphens
    s="${s//[_ ]/-}"
    # remove anything that isn't alphanumeric or hyphen
    s="${s//[^a-z0-9-]/}"
    # strip leading/trailing hyphens
    s="${s#-}"
    s="${s%-}"
    # collapse consecutive hyphens
    while [[ "$s" == *--* ]]; do
        s="${s//--/-}"
    done
    # ensure starts with letter or digit (should be fine after stripping)
    if [ -z "$s" ]; then
        echo "Error: project id sanitizes to an empty string." >&2
        exit 2
    fi
    echo "$s"
}

# Ensure workspace is initialized (has _cr/workspace.yaml).
require_workspace() {
    WORKSPACE_ROOT="$(cr_workspace_root)"
    if [ ! -f "$WORKSPACE_ROOT/_cr/workspace.yaml" ]; then
        echo "Error: workspace not initialized. Run 'cr workspace init' first." >&2
        exit 1
    fi
}

# Ensure a project exists (directory + project.yaml).
# Usage: require_project <project_id> → sets PROJECT_DIR, PROJECT_FILE
require_project() {
    local pid="$1"
    WORKSPACE_ROOT="$(cr_workspace_root)"
    PROJECT_DIR="$WORKSPACE_ROOT/$pid"
    PROJECT_FILE="$PROJECT_DIR/project.yaml"
    if [ ! -d "$PROJECT_DIR" ] || [ ! -f "$PROJECT_FILE" ]; then
        echo "Error: project '$pid' not found at $PROJECT_DIR" >&2
        exit 1
    fi
}

# ── Subcommand: init ──────────────────────────────────────────────

cmd_init() {
    local raw_id="${1:-}"
    if [ -z "$raw_id" ]; then
        echo "Usage: cr project init <id> --domain <domain>" >&2
        exit 2
    fi
    shift

    # Parse --domain flag
    local domain=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --domain)
                domain="${2:-}"
                if [ -z "$domain" ]; then
                    echo "Error: --domain requires a value." >&2
                    exit 2
                fi
                shift 2
                ;;
            *)
                echo "Error: unknown flag: $1" >&2
                exit 2
                ;;
        esac
    done

    if [ -z "$domain" ]; then
        echo "Error: --domain is required." >&2
        exit 2
    fi

    local PROJECT_ID
    PROJECT_ID="$(sanitize_id "$raw_id")"

    require_workspace

    # Check project doesn't already exist
    if [ -d "$WORKSPACE_ROOT/$PROJECT_ID" ] && [ -f "$WORKSPACE_ROOT/$PROJECT_ID/project.yaml" ]; then
        echo "Error: project '$PROJECT_ID' already exists." >&2
        exit 1
    fi

    local NOW
    NOW="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

    # Create directory structure
    mkdir -p "$WORKSPACE_ROOT/$PROJECT_ID"/{documents,units,knowledge/cards,rounds,state}

    # Create project.yaml
    cat > "$WORKSPACE_ROOT/$PROJECT_ID/project.yaml" << YAML
project_id: $PROJECT_ID
domain: $domain
created_at: $NOW
description: ""
schema_version: "2.0.0"
YAML

    # Create state/project-state.json
    cat > "$WORKSPACE_ROOT/$PROJECT_ID/state/project-state.json" << JSON
{
  "project_id": "$PROJECT_ID",
  "status": "active",
  "active_round": null,
  "total_rounds": 0,
  "evidence_saturation": 0.0,
  "open_gaps": 0,
  "last_updated": "$NOW",
  "schema_version": "2.0.0"
}
JSON

    # Create documents/registry.yaml
    cat > "$WORKSPACE_ROOT/$PROJECT_ID/documents/registry.yaml" << YAML
schema_version: "2.0.0"
documents:
YAML

    # Set as active project
    echo "$PROJECT_ID" > "$WORKSPACE_ROOT/_cr/active-project"

    echo "Project '$PROJECT_ID' created at $WORKSPACE_ROOT/$PROJECT_ID"
    echo ""
    echo "Next steps:"
    echo "  cr document add $PROJECT_ID <doc-id> --type <type> --path <path>"
    echo "    Register a document (paper, proposal, survey, design-doc)."
    echo "  cr project status $PROJECT_ID"
    echo "    View project status at any time."
}

# ── Subcommand: status ────────────────────────────────────────────

cmd_status() {
    local pid="${1:-}"
    if [ -z "$pid" ]; then
        echo "Usage: cr project status <project>" >&2
        exit 2
    fi

    require_project "$pid"

    echo "Project: $pid"
    echo "  Domain:     $(grep -E '^domain:' "$PROJECT_FILE" 2>/dev/null | sed 's/^domain: *//')"
    echo "  Status:     $(grep -E '^status:' "$PROJECT_FILE" 2>/dev/null | sed 's/^status: *//' || echo 'active')"
    echo "  Created:    $(grep -E '^created_at:' "$PROJECT_FILE" 2>/dev/null | sed 's/^created_at: *//')"

    # Documents from registry.yaml
    local REGISTRY="$PROJECT_DIR/documents/registry.yaml"
    if [ -f "$REGISTRY" ]; then
        echo ""
        echo "Documents:"
        local doc_count
        doc_count=$(yq -r '.documents | length' "$REGISTRY" 2>/dev/null || echo "0")
        if [ "$doc_count" -gt 0 ] 2>/dev/null; then
            for i in $(seq 0 $((doc_count - 1))); do
                local doc_id doc_type doc_status
                doc_id=$(yq -r ".documents[$i].id" "$REGISTRY" 2>/dev/null || echo "?")
                doc_type=$(yq -r ".documents[$i].type" "$REGISTRY" 2>/dev/null || echo "?")
                doc_status=$(yq -r ".documents[$i].status // \"active\"" "$REGISTRY" 2>/dev/null || echo "?")
                echo "  - $doc_id ($doc_type) [$doc_status]"
            done
        else
            echo "  (none)"
        fi
    else
        echo ""
        echo "Documents: (registry not found)"
    fi

    # Active round
    echo ""
    echo "Rounds:"
    if [ -d "$PROJECT_DIR/rounds" ] && [ -n "$(ls -A "$PROJECT_DIR/rounds" 2>/dev/null)" ]; then
        for rd in "$PROJECT_DIR/rounds"/round-*; do
            if [ -f "$rd/contract.yaml" ]; then
                local rstatus rid
                rstatus=$(grep -E '^status:' "$rd/workflow-state.yaml" 2>/dev/null | head -1 | sed 's/^status: *//')
                [ -z "$rstatus" ] && rstatus="active"
                rid=$(grep -E '^round_id:' "$rd/workflow-state.yaml" 2>/dev/null | sed 's/^round_id: *//')
                echo "  - $rid ($rstatus)"
            fi
        done
    else
        echo "  (none)"
    fi
}

# ── Subcommand: list ──────────────────────────────────────────────

cmd_list() {
    require_workspace

    echo "Projects in workspace:"
    local found=0
    for d in "$WORKSPACE_ROOT"/*/; do
        local name
        name="$(basename "$d")"
        # skip _cr and hidden dirs
        [[ "$name" == _* ]] && continue
        if [ -f "$d/project.yaml" ]; then
            found=1
            local domain
            domain=$(grep -E '^domain:' "$d/project.yaml" 2>/dev/null | sed 's/^domain: *//')
            echo "  $name  ($domain)"
        fi
    done
    if [ "$found" -eq 0 ]; then
        echo "  (none)"
    fi
}

# ── Dispatch ──────────────────────────────────────────────────────

SUBCMD="${1:-}"
shift 2>/dev/null || true

case "$SUBCMD" in
    init)
        cmd_init "$@"
        ;;
    status)
        cmd_status "$@"
        ;;
    list)
        cmd_list "$@"
        ;;
    *)
        usage
        ;;
esac
