#!/usr/bin/env bash
# cr-validate-all-phases — Hard gate: require all phases complete before round close.
# Dynamic: reads phase_order from state.yaml instead of hardcoding a fixed list.
# A round cannot close unless every pre-close phase is individually complete with
# a timestamp.
#
# Usage: cr-validate-all-phases <project_dir> <round_dir> [preclose|postclose]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

PROJECT_DIR="${1:-}"
ROUND_DIR="${2:-}"

if [ -z "$PROJECT_DIR" ] || [ -z "$ROUND_DIR" ]; then
    echo "Usage: cr-validate-all-phases <project_dir> <round_dir> [preclose|postclose]" >&2
    exit 2

MODE="${3:-postclose}"
fi


MODE="${3:-postclose}"
STATE_FILE="$ROUND_DIR/state.yaml"

if [ ! -f "$STATE_FILE" ]; then
    fail "state.yaml not found in $ROUND_DIR"
    cr_exit_summary
fi

echo "── Phase Completeness Check ──"

FAIL=0
COMPLETED=0
TOTAL=0

# Read phase_order dynamically from state.yaml.
readarray -t PHASE_LIST < <(yq -r '.phase_order[]' "$STATE_FILE" 2>/dev/null || echo "")

if [ "${#PHASE_LIST[@]}" -eq 0 ]; then
    # Fallback: read phases keys directly.
    readarray -t PHASE_LIST < <(yq -r '.phases | keys[]' "$STATE_FILE" 2>/dev/null || echo "")
fi

if [ "${#PHASE_LIST[@]}" -eq 0 ]; then
    fail "No phases found in state.yaml — cannot validate phase completeness"
    cr_exit_summary
fi

# Phase count check: read closure_policy for expected minimum.
POLICY_COUNT=$(yq -r '.closure_policy.require_all_phases_complete // false' "$STATE_FILE" 2>/dev/null || echo "false")

for phase in "${PHASE_LIST[@]}"; do
    [ -z "$phase" ] && continue

    # preclose mode: skip close_round (not yet complete).
    # postclose mode: check close_round like every other phase.
    if [ "$MODE" = "preclose" ] && [ "$phase" = "close_round" ]; then
        continue
    fi

    TOTAL=$((TOTAL + 1))
    status=$(yq -r ".phases.$phase.status // \"missing\"" "$STATE_FILE" 2>/dev/null || echo "missing")
    completed_at=$(yq -r ".phases.$phase.completed_at // \"null\"" "$STATE_FILE" 2>/dev/null || echo "null")

    if [ "$status" != "complete" ]; then
        fail "Phase '$phase': status=$status (expected complete)"
        FAIL=1
        continue
    fi

    if [ "$completed_at" = "null" ] || [ -z "$completed_at" ]; then
        fail "Phase '$phase': complete but no completed_at timestamp"
        FAIL=1
        continue
    fi

    COMPLETED=$((COMPLETED + 1))
    pass "Phase '$phase': complete at $completed_at"
done

# Check closure_policy.require_all_phases_complete is true.
if [ "$POLICY_COUNT" != "true" ]; then
    warn "closure_policy.require_all_phases_complete is not true"
fi

echo ""
echo "Phases complete ($MODE): $COMPLETED / $TOTAL phases"

if [ "$FAIL" -ne 0 ]; then
    cr_exit_summary
fi

pass "All $TOTAL phases complete ($MODE)"
cr_exit_summary
