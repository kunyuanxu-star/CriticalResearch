#!/usr/bin/env bash
# cr-validate-full-paper-coverage — Hard gate: every phase must cover the full paper.
# Checks full-paper-coverage-plan.yaml coverage against every completed phase artifact.
# The user objective is a weighting lens, not a scope limiter.
#
# InvFull0-InvFull5 enforcement.
#
# Usage: cr-validate-full-paper-coverage <project_dir> <round_dir>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

PROJECT_DIR="${1:-}"
ROUND_DIR="${2:-}"

if [ -z "$PROJECT_DIR" ] || [ -z "$ROUND_DIR" ]; then
    echo "Usage: cr-validate-full-paper-coverage <project_dir> <round_dir>" >&2
    exit 2
fi

STATE_FILE="$ROUND_DIR/state.yaml"
COVERAGE_PLAN="$ROUND_DIR/full-paper-coverage-plan.yaml"
OBJECTIVE="$ROUND_DIR/round-objective.yaml"

if [ ! -f "$STATE_FILE" ]; then
    fail "state.yaml not found"
    cr_exit_summary
fi

echo "── Full-Paper Coverage Validation ──"

# 1. Coverage plan must exist.
if [ ! -f "$COVERAGE_PLAN" ]; then
    fail "full-paper-coverage-plan.yaml not found"
    cr_exit_summary
fi

# 2. Read the full paper inventory from the coverage plan.
REQUIRED_SECTIONS=$(yq -r '.paper_inventory.sections[]? | select(.required==true) | .section_id' "$COVERAGE_PLAN" 2>/dev/null || echo "")
REQUIRED_CLAIMS=$(yq -r '.paper_inventory.claims[]? | select(.required_full_pass==true) | .claim_id' "$COVERAGE_PLAN" 2>/dev/null || echo "")
REQUIRED_BASELINES=$(yq -r '.paper_inventory.baselines[]? | .baseline_id' "$COVERAGE_PLAN" 2>/dev/null || echo "")

if [ -z "$REQUIRED_SECTIONS" ]; then
    fail "Paper inventory has no required sections — inventory the full paper in S04"
    cr_exit_summary
fi

SEC_COUNT=$(echo "$REQUIRED_SECTIONS" | wc -l | tr -d ' ')
CLAIM_COUNT=$(echo "$REQUIRED_CLAIMS" | wc -l | tr -d ' ')
pass "Inventory: $SEC_COUNT sections, $CLAIM_COUNT claims"

# 3. Objective scope policy check.
if [ -f "$OBJECTIVE" ]; then
    MAY_LIMIT=$(yq -r '.scope_policy.objective_may_limit_scope // true' "$OBJECTIVE" 2>/dev/null || echo "true")
    [ "$MAY_LIMIT" = "false" ] && pass "Objective may NOT limit scope" || { fail "objective_may_limit_scope must be false"; }
fi

# 4. Per-phase coverage verification.
# Phases that must demonstrate full-paper coverage:
ANALYSIS_PHASES=(
    "snapshot_paper_state:paper-state.yaml:sections,claims"
    "load_project_knowledge:loaded-knowledge.yaml:sections,claims"
    "critique_claim_precision:critique-claim-precision.yaml:claims"
    "critique_novelty_and_baselines:critique-novelty-baseline.yaml:baselines"
    "critique_evidence_sufficiency:critique-evidence.yaml:claims"
    "critique_evaluation_contract:critique-evaluation.yaml:claims"
    "critique_writing_argument:critique-writing.yaml:sections"
    "merge_critique_ledger:critique-ledger.yaml:claims"
    "global_argument_pass:argument-flow-report.yaml:sections"
    "claim_evidence_alignment_pass:claim-paper-matrix.yaml:claims"
    "reviewer_readiness_pass:reviewer-readiness.yaml:sections"
)

COVERAGE_FAILS=0
for entry in "${ANALYSIS_PHASES[@]}"; do
    IFS=':' read -r phase artifact coverage_types <<< "$entry"
    PHASE_STATUS=$(yq -r ".phases.$phase.status // \"\"" "$STATE_FILE" 2>/dev/null || echo "")

    if [ "$PHASE_STATUS" = "complete" ]; then
        AF="$ROUND_DIR/$artifact"
        if [ ! -f "$AF" ]; then
            fail "Phase '$phase' complete but $artifact missing"
            COVERAGE_FAILS=$((COVERAGE_FAILS + 1))
            continue
        fi

        # Check full_paper_coverage field exists.
        HAS_COV=$(yq -r '.full_paper_coverage // ""' "$AF" 2>/dev/null || echo "")
        if [ -z "$HAS_COV" ] || [ "$HAS_COV" = "null" ]; then
            fail "Phase '$phase': $artifact has no full_paper_coverage field"
            COVERAGE_FAILS=$((COVERAGE_FAILS + 1))
            continue
        fi

        # Check sections_checked if this phase requires section coverage.
        if echo "$coverage_types" | grep -q "sections"; then
            CHECKED_SECS=$(yq -r '.full_paper_coverage.sections_checked[]? // ""' "$AF" 2>/dev/null || echo "")
            for sec in $REQUIRED_SECTIONS; do
                if ! echo "$CHECKED_SECS" | grep -qw "$sec"; then
                    fail "Phase '$phase': section '$sec' not in sections_checked"
                    COVERAGE_FAILS=$((COVERAGE_FAILS + 1))
                fi
            done
        fi

        # Check claims_checked if this phase requires claim coverage.
        if echo "$coverage_types" | grep -q "claims" && [ -n "$REQUIRED_CLAIMS" ]; then
            CHECKED_CLMS=$(yq -r '.full_paper_coverage.claims_checked[]? // ""' "$AF" 2>/dev/null || echo "")
            for clm in $REQUIRED_CLAIMS; do
                if ! echo "$CHECKED_CLMS" | grep -qw "$clm"; then
                    fail "Phase '$phase': claim '$clm' not in claims_checked"
                    COVERAGE_FAILS=$((COVERAGE_FAILS + 1))
                fi
            done
        fi

        # Check omissions must be empty.
        OMISSIONS=$(yq -r '.full_paper_coverage.omissions | length // 0' "$AF" 2>/dev/null || echo "0")
        if [ "${OMISSIONS:-0}" -gt 0 ]; then
            OM_REASON=$(yq -r '.full_paper_coverage.omissions[0].reason // ""' "$AF" 2>/dev/null || echo "")
            if [ -z "$OM_REASON" ] || [ "$OM_REASON" = "null" ]; then
                fail "Phase '$phase': has omissions without reason"
                COVERAGE_FAILS=$((COVERAGE_FAILS + 1))
            else
                warn "Phase '$phase': has omissions (${OM_REASON:0:60}...)"
            fi
        fi

        # Check objective_relevance.
        OBJ_LEVEL=$(yq -r '.objective_relevance.level // ""' "$AF" 2>/dev/null || echo "")
        OBJ_EXPLAIN=$(yq -r '.objective_relevance.explanation // ""' "$AF" 2>/dev/null || echo "")
        if [ -z "$OBJ_LEVEL" ] || [ "$OBJ_LEVEL" = "null" ]; then
            fail "Phase '$phase': no objective_relevance.level in $artifact"
            COVERAGE_FAILS=$((COVERAGE_FAILS + 1))
        elif [ -z "$OBJ_EXPLAIN" ] || [ "$OBJ_EXPLAIN" = "null" ] || [ ${#OBJ_EXPLAIN} -lt 10 ]; then
            fail "Phase '$phase': objective_relevance.explanation too short or missing"
            COVERAGE_FAILS=$((COVERAGE_FAILS + 1))
        else
            pass "Phase '$phase': coverage + objective OK ($OBJ_LEVEL)"
        fi
    fi
done

[ "$COVERAGE_FAILS" -gt 0 ] && { fail "$COVERAGE_FAILS coverage failure(s)"; }

cr_exit_summary
