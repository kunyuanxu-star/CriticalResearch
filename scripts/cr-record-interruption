#!/usr/bin/env bash
# cr-record-interruption — Record a forced session interruption.
# Called by stop hook when user explicitly requests force stop.
# Does NOT modify round state — only writes an audit log.
#
# Usage: cr-record-interruption <project_dir> <round_dir> [reason]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

PROJECT_DIR="${1:-}"
ROUND_DIR="${2:-}"
REASON="${3:-user_forced_stop}"

if [ -z "$PROJECT_DIR" ] || [ -z "$ROUND_DIR" ]; then
    echo "Usage: cr-record-interruption <project_dir> <round_dir> [reason]" >&2
    exit 2
fi

STATE_FILE="$ROUND_DIR/state.yaml"
NOW=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

CURRENT_PHASE=""
COMPLETED_COUNT=0
if [ -f "$STATE_FILE" ]; then
    CURRENT_PHASE=$(yq -r '.current_phase // ""' "$STATE_FILE" 2>/dev/null || echo "")
    COMPLETED_COUNT=$(yq -r '[.phases[] | select(.status=="complete")] | length' "$STATE_FILE" 2>/dev/null || echo "0")
fi

INTERRUPTION_LOG="$ROUND_DIR/interruption-log.yaml"
cat > "$INTERRUPTION_LOG" << EOF
schema_version: "1.0.0"
interrupted_at: $NOW
current_phase: ${CURRENT_PHASE:-unknown}
completed_phases: $COMPLETED_COUNT
reason: $REASON
round_status: incomplete
active_round_preserved: true
EOF

echo "Interruption recorded: $INTERRUPTION_LOG"
