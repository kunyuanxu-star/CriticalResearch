#!/usr/bin/env bash
# cr-unit — Unit management for CriticalResearch v2 project engine.
# Manages units within documents: add, list, status.
#
# Usage: cr-unit <subcommand> [args...]
#
# Subcommands:
#   add <project> <doc-id> <unit-id> --title <title>
#   list <project> <doc-id>
#   status <project> <doc-id> <unit-id>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

# ── Helpers ───────────────────────────────────────────────────────

usage() {
    echo "Usage: cr unit <add|list|status> [args...]" >&2
    echo "" >&2
    echo "  cr unit add <project> <doc-id> <unit-id> --title <title>" >&2
    echo "  cr unit list <project> <doc-id>" >&2
    echo "  cr unit status <project> <doc-id> <unit-id>" >&2
    exit 2
}

# Ensure a project exists. Sets WORKSPACE_ROOT, PROJECT_DIR, PROJECT_FILE.
require_project() {
    local pid="$1"
    WORKSPACE_ROOT="$(cr_workspace_root)"
    PROJECT_DIR="$WORKSPACE_ROOT/$pid"
    PROJECT_FILE="$PROJECT_DIR/project.yaml"
    if [ ! -d "$PROJECT_DIR" ] || [ ! -f "$PROJECT_FILE" ]; then
        echo "Error: project '$pid' not found at $PROJECT_DIR" >&2
        exit 1
    fi
}

# Validate a document exists in the registry. Exits on failure.
# Usage: require_document <project_dir> <doc-id>
require_document() {
    local proj_dir="$1"
    local doc_id="$2"
    local registry="$proj_dir/documents/registry.yaml"

    if [ ! -f "$registry" ]; then
        echo "Error: document registry not found at $registry" >&2
        exit 1
    fi

    if ! command -v yq >/dev/null 2>&1; then
        echo "Error: yq is required. Install with: brew install yq" >&2
        exit 1
    fi

    local found
    found=$(yq -r ".documents // [] | .[] | select(.id == \"$doc_id\") | .id" "$registry" 2>/dev/null || echo "")
    if [ -z "$found" ]; then
        echo "Error: document '$doc_id' not found in $registry" >&2
        exit 1
    fi
}

# ── Subcommand: add ──────────────────────────────────────────────

cmd_add() {
    local project="${1:-}"
    local doc_id="${2:-}"
    local unit_id="${3:-}"

    if [ -z "$project" ] || [ -z "$doc_id" ] || [ -z "$unit_id" ]; then
        echo "Usage: cr unit add <project> <doc-id> <unit-id> --title <title>" >&2
        exit 2
    fi
    shift 3

    # Parse --title flag.
    local title=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --title)
                title="${2:-}"
                if [ -z "$title" ]; then
                    echo "Error: --title requires a value." >&2
                    exit 2
                fi
                shift 2
                ;;
            *)
                echo "Error: unknown flag: $1" >&2
                exit 2
                ;;
        esac
    done

    if [ -z "$title" ]; then
        echo "Error: --title is required." >&2
        exit 2
    fi

    # Validate unit-id format: <doc-id>.<unit-name>
    local expected_prefix="${doc_id}."
    if [[ "$unit_id" != "$expected_prefix"* ]]; then
        echo "Error: unit-id must start with '<doc-id>.', got '$unit_id' (expected prefix: '$expected_prefix')" >&2
        exit 2
    fi

    local unit_name="${unit_id#$expected_prefix}"
    if [ -z "$unit_name" ]; then
        echo "Error: unit-id must have a unit name after '$expected_prefix'" >&2
        exit 2
    fi

    # Basic unit-name sanity: lowercase alphanumeric + hyphens only.
    if [[ ! "$unit_name" =~ ^[a-z0-9]([a-z0-9-]*[a-z0-9])?$ ]]; then
        echo "Error: unit name '$unit_name' must be lowercase alphanumeric with hyphens (no leading/trailing hyphens)." >&2
        exit 2
    fi

    require_project "$project"

    # Validate document exists.
    require_document "$PROJECT_DIR" "$doc_id"

    # Check or create the units file.
    local units_file="$PROJECT_DIR/units/${doc_id}.units.yaml"
    if [ ! -f "$units_file" ]; then
        # Create empty units file.
        echo "[]" > "$units_file"
    fi

    # Check unit-id not already present.
    local existing
    existing=$(yq -r ".[] | select(.id == \"$unit_id\") | .id" "$units_file" 2>/dev/null || echo "")
    if [ -n "$existing" ]; then
        echo "Error: unit '$unit_id' already exists in $units_file" >&2
        exit 1
    fi

    # Append the new unit.
    yq -i ". += [{\"id\": \"$unit_id\", \"title\": \"$title\", \"status\": \"active\"}]" "$units_file"

    echo "Unit '$unit_id' added to document '$doc_id' in project '$project'."
    echo "  Title:  $title"
    echo "  Status: active"
}

# ── Subcommand: list ─────────────────────────────────────────────

cmd_list() {
    local project="${1:-}"
    local doc_id="${2:-}"

    if [ -z "$project" ] || [ -z "$doc_id" ]; then
        echo "Usage: cr unit list <project> <doc-id>" >&2
        exit 2
    fi

    require_project "$project"
    require_document "$PROJECT_DIR" "$doc_id"

    local units_file="$PROJECT_DIR/units/${doc_id}.units.yaml"

    if [ ! -f "$units_file" ]; then
        echo "No units defined for document '$doc_id'."
        exit 0
    fi

    local count
    count=$(yq -r 'length' "$units_file" 2>/dev/null || echo "0")

    if [ "$count" -eq 0 ] 2>/dev/null; then
        echo "No units defined for document '$doc_id'."
        exit 0
    fi

    echo "Units for document '$doc_id' in project '$project':"
    echo ""

    for i in $(seq 0 $((count - 1))); do
        local uid utitle ustatus
        uid=$(yq -r ".[$i].id" "$units_file" 2>/dev/null || echo "?")
        utitle=$(yq -r ".[$i].title" "$units_file" 2>/dev/null || echo "?")
        ustatus=$(yq -r ".[$i].status // \"active\"" "$units_file" 2>/dev/null || echo "?")
        printf "  %-30s %s  [%s]\n" "$uid" "$utitle" "$ustatus"
    done
}

# ── Subcommand: status ───────────────────────────────────────────

cmd_status() {
    local project="${1:-}"
    local doc_id="${2:-}"
    local unit_id="${3:-}"

    if [ -z "$project" ] || [ -z "$doc_id" ] || [ -z "$unit_id" ]; then
        echo "Usage: cr unit status <project> <doc-id> <unit-id>" >&2
        exit 2
    fi

    require_project "$project"
    require_document "$PROJECT_DIR" "$doc_id"

    local units_file="$PROJECT_DIR/units/${doc_id}.units.yaml"

    if [ ! -f "$units_file" ]; then
        echo "Error: no units file found for document '$doc_id'." >&2
        exit 1
    fi

    local found
    found=$(yq -r ".[] | select(.id == \"$unit_id\") | .id" "$units_file" 2>/dev/null || echo "")
    if [ -z "$found" ]; then
        echo "Error: unit '$unit_id' not found in $units_file" >&2
        exit 1
    fi

    local utitle ustatus
    utitle=$(yq -r ".[] | select(.id == \"$unit_id\") | .title" "$units_file" 2>/dev/null)
    ustatus=$(yq -r ".[] | select(.id == \"$unit_id\") | .status // \"active\"" "$units_file" 2>/dev/null)

    echo "Unit: $unit_id"
    echo "  Document: $doc_id"
    echo "  Project:  $project"
    echo "  Title:    $utitle"
    echo "  Status:   $ustatus"
}

# ── Dispatch ──────────────────────────────────────────────────────

SUBCMD="${1:-}"
shift 2>/dev/null || true

case "$SUBCMD" in
    add)
        cmd_add "$@"
        ;;
    list)
        cmd_list "$@"
        ;;
    status)
        cmd_status "$@"
        ;;
    *)
        usage
        ;;
esac
