#!/usr/bin/env bash
# cr-guard-path — PreToolUse path guard (Inv0).
# Checks whether a proposed write target is allowed.
# Called by the PreToolUse hook before Bash/Edit/Write/MultiEdit operations.
#
# Usage: cr-guard-path <tool_name> <tool_input_json>
#   tool_name: Bash, Edit, Write, or MultiEdit
#   tool_input_json: the tool's input as JSON string
#
# Exit codes:
#   0 — path is allowed
#   1 — path is blocked (outputs JSON for hook decision:block)
#   2 — usage error

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

# Patterns that identify skill source files (must not appear in research projects).
SKILL_SOURCE_PATTERNS=(
    "SKILL.md"
    "/workflow/"
    "/roles/"
    "/scripts/"
    "/schemas/"
    "/hooks/"
)

# Patterns for state mutation files that must only be modified via cr CLI commands.
# Direct writes/edits to these files are blocked.
STATE_MUTATION_PATTERNS=(
    "*/round.yaml"
    "*/state.yaml"
    "*/project-state.json"
    "*/patches/PP-"
    "*/closure-report.yaml"
    "*/satisfaction.json"
)

is_state_mutation_path() {
    local path="$1"
    for pattern in "${STATE_MUTATION_PATTERNS[@]}"; do
        case "$path" in
            *"$pattern"*) return 0 ;;
        esac
    done
    return 1
}

# Allowed directories/files within a research project.
# Writes outside these paths trigger a warning (non-blocking for now).
ALLOWED_RESEARCH_DIRS=(
    "/literature/"
    "/writing/"
    "/rounds/"
    "/state/"
    "/patches/"
    "/experiments/"
    "/knowledge/"
    "/exports/"
    "project.yaml"
    "README.md"
)

is_allowed_research_path() {
    local path="$1"
    for allowed in "${ALLOWED_RESEARCH_DIRS[@]}"; do
        case "$path" in
            *"$allowed"*|*"$allowed") return 0 ;;
        esac
    done
    return 1
}

TOOL_NAME="${1:-}"
TOOL_INPUT="${2:-}"

if [ -z "$TOOL_NAME" ]; then
    echo '{"decision":"block","reason":"cr-guard-path: tool name required"}' >&2
    exit 2
fi

# Extract file paths from tool input.
# This is a best-effort extraction; it handles the common patterns.
extract_paths() {
    local input="$1"
    # Try to extract "file_path" or "command" from JSON input.
    echo "$input" | grep -oE '"(file_path|command)":\s*"[^"]*"' 2>/dev/null | \
        sed 's/.*": "//' | sed 's/"$//' || true
}

# Check if a path matches any prohibited pattern for research projects.
is_skill_source_path() {
    local path="$1"
    for pattern in "${SKILL_SOURCE_PATTERNS[@]}"; do
        case "$path" in
            *"$pattern"*) return 0 ;;
        esac
    done
    return 1
}

# Check if a path is inside a research project (any directory with project.yaml).
is_research_project_path() {
    local path="$1"
    # Normalize: strip trailing filename to get the target directory.
    local dir
    if [ -d "$path" ]; then
        dir="$path"
    else
        dir=$(dirname "$path" 2>/dev/null || echo "$path")
    fi

    # Walk up from the target looking for project.yaml.
    while [ "$dir" != "/" ] && [ "$dir" != "." ]; do
        if [ -f "$dir/project.yaml" ]; then
            return 0
        fi
        # Stop at workspace root (has _cr/ directory).
        if [ -d "$dir/_cr" ]; then
            break
        fi
        dir=$(dirname "$dir")
    done
    return 1
}

PATHS=$(extract_paths "$TOOL_INPUT")

if [ -z "$PATHS" ]; then
    # Can't extract paths — allow (false negative is safer than false positive
    # for a guard that can't fully parse input).
    exit 0
fi

BLOCKED=""
while IFS= read -r file_path; do
    [ -z "$file_path" ] && continue

    # Only guard research project directories.
    if ! is_research_project_path "$file_path"; then
        continue
    fi

    # Block skill source files in research projects.
    if is_skill_source_path "$file_path"; then
        BLOCKED="$file_path"
        break
    fi

    # Block direct edits to state mutation files.
    # These must only be modified via cr step advance, cr close-round, or cr patch apply.
    if is_state_mutation_path "$file_path"; then
        BLOCKED="$file_path"
        break
    fi

    # Warn about writes outside allowed research directories.
    if ! is_allowed_research_path "$file_path"; then
        echo "[cr-guard-path] WARNING: writing outside allowed research dirs: $file_path" >&2
    fi

    # Reject paths with parent directory traversal in research projects.
    case "$file_path" in
        *".."*)
            BLOCKED="$file_path"
            break
            ;;
    esac
done <<< "$PATHS"

if [ -n "$BLOCKED" ]; then
    echo "{\"decision\":\"block\",\"reason\":\"cr-guard-path: write to prohibited path blocked: $BLOCKED\"}" >&2
    exit 1
fi

exit 0
