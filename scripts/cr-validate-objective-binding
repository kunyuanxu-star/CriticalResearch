#!/usr/bin/env bash
# cr-validate-objective-binding — Hard gate: every completed phase must demonstrate
# it addressed the round objective. The user objective is a weighting lens —
# every phase must show how it served the primary focus.
#
# Usage: cr-validate-objective-binding <project_dir> <round_dir>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

PROJECT_DIR="${1:-}"
ROUND_DIR="${2:-}"

if [ -z "$PROJECT_DIR" ] || [ -z "$ROUND_DIR" ]; then
    echo "Usage: cr-validate-objective-binding <project_dir> <round_dir>" >&2
    exit 2
fi

STATE_FILE="$ROUND_DIR/state.yaml"
OBJECTIVE="$ROUND_DIR/round-objective.yaml"

if [ ! -f "$STATE_FILE" ]; then
    fail "state.yaml not found"
    cr_exit_summary
fi

echo "── Objective Binding Validation ──"

# 1. Round objective must exist.
if [ ! -f "$OBJECTIVE" ]; then
    fail "round-objective.yaml not found — user request was never recorded"
    cr_exit_summary
fi

OBJ_TEXT=$(yq -r '.normalized_objective // ""' "$OBJECTIVE" 2>/dev/null || echo "")
RAW_REQ=$(yq -r '.raw_user_request // ""' "$OBJECTIVE" 2>/dev/null || echo "")
SCOPE_POLICY=$(yq -r '.scope_policy.objective_may_limit_scope' "$OBJECTIVE" 2>/dev/null || echo "true")
[ -z "$SCOPE_POLICY" ] || [ "$SCOPE_POLICY" = "null" ] && SCOPE_POLICY="true"

[ -n "$OBJ_TEXT" ] && pass "Round objective recorded: ${OBJ_TEXT:0:80}" || { fail "round-objective.yaml has no normalized_objective"; }
[ "$SCOPE_POLICY" = "false" ] && pass "Objective may not limit scope" || { fail "objective_may_limit_scope must be false"; }

# 2. Check that completed phases have objective_relevance.
ANALYSIS_PHASES=(
    "load_project_knowledge:loaded-knowledge.yaml"
    "define_round_objective:round-objective.yaml"
    "plan_research_questions:research-questions.yaml"
    "merge_critique_ledger:critique-ledger.yaml"
    "generate_dispositions:dispositions.yaml"
    "global_argument_pass:argument-flow-report.yaml"
    "claim_evidence_alignment_pass:claim-paper-matrix.yaml"
    "reviewer_readiness_pass:reviewer-readiness.yaml"
    "distill_thinking_knowledge:thinking-knowledge-delta.yaml"
    "apply_knowledge_delta:knowledge-delta.yaml"
    "close_round:closure-report.yaml"
)

MISSING_OBJ=0
for entry in "${ANALYSIS_PHASES[@]}"; do
    phase="${entry%%:*}"
    artifact="${entry##*:}"
    PHASE_STATUS=$(yq -r ".phases.$phase.status // \"\"" "$STATE_FILE" 2>/dev/null || echo "")

    if [ "$PHASE_STATUS" = "complete" ]; then
        AF="$ROUND_DIR/$artifact"
        if [ -f "$AF" ]; then
            RELEVANCE=$(yq -r '.objective_relevance.level // ""' "$AF" 2>/dev/null || echo "")
            EXPLANATION=$(yq -r '.objective_relevance.explanation // ""' "$AF" 2>/dev/null || echo "")
            if [ -n "$RELEVANCE" ] && [ "$RELEVANCE" != "null" ]; then
                pass "Objective binding: $phase ($RELEVANCE)"
            else
                fail "Phase '$phase' complete but $artifact has no objective_relevance.level"
                MISSING_OBJ=$((MISSING_OBJ + 1))
            fi
            if [ -z "$EXPLANATION" ] || [ "$EXPLANATION" = "null" ]; then
                fail "Phase '$phase' has objective_relevance but no explanation"
                MISSING_OBJ=$((MISSING_OBJ + 1))
            fi
        fi
    fi
done

[ "$MISSING_OBJ" -gt 0 ] && { fail "$MISSING_OBJ objective-binding failure(s)"; }

cr_exit_summary
