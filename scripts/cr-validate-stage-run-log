#!/usr/bin/env bash
# cr-validate-stage-run-log — Hard gate: every completed stage must have execution proof.
# Validates the stage-run-log.yaml against the state.yaml and actual artifacts.
# Enforces paired started+completed events with matching order, stage, timestamps,
# input hashes, and output hashes.
#
# Usage: cr-validate-stage-run-log <project_dir> <round_dir>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

PROJECT_DIR="${1:-}"
ROUND_DIR="${2:-}"

if [ -z "$PROJECT_DIR" ] || [ -z "$ROUND_DIR" ]; then
    echo "Usage: cr-validate-stage-run-log <project_dir> <round_dir>" >&2
    exit 2
fi

echo "── Stage Run Log Validation ──"

RUN_LOG="$ROUND_DIR/stage-run-log.yaml"
STATE_FILE="$ROUND_DIR/state.yaml"

if [ ! -f "$RUN_LOG" ]; then
    fail "stage-run-log.yaml not found"
    cr_exit_summary
fi

if [ ! -f "$STATE_FILE" ]; then
    fail "state.yaml not found"
    cr_exit_summary
fi

# ── 1. Schema check ──────────────────────────────────────────────

SCHEMA_VERSION=$(yq -r '.schema_version // ""' "$RUN_LOG" 2>/dev/null || echo "")
if [ "$SCHEMA_VERSION" != "1.0.0" ]; then
    fail "stage-run-log schema_version='$SCHEMA_VERSION' (expected 1.0.0)"
fi

EVENTS_COUNT=$(yq -r '.events | length // 0' "$RUN_LOG" 2>/dev/null || echo 0)
if [ "$EVENTS_COUNT" -eq 0 ]; then
    fail "stage-run-log has no events"
    cr_exit_summary
fi

pass "stage-run-log schema valid ($EVENTS_COUNT events)"

# ── 2. Build expected stage order from state.yaml ────────────────

STAGE_ORDER=()
while IFS= read -r s; do
    [ -z "$s" ] && continue
    STAGE_ORDER+=("$s")
done <<< "$(yq -r '.stage_order // [] | .[]' "$STATE_FILE" 2>/dev/null || echo "")"

STAGE_COUNT=${#STAGE_ORDER[@]}
if [ "$STAGE_COUNT" -eq 0 ]; then
    fail "No stages found in state.yaml stage_order"
    cr_exit_summary
fi

# ── 3. Check each completed stage has paired started+completed ───

ERRORS=0
COMPLETED_STAGES=()

for ((i=0; i<STAGE_COUNT; i++)); do
    stage="${STAGE_ORDER[$i]}"
    expected_order=$((i + 1))

    # Check state.yaml status.
    stage_status=$(yq -r ".stages.\"$stage\".status // \"\"" "$STATE_FILE" 2>/dev/null || echo "")

    if [ "$stage_status" != "complete" ]; then
        # Not complete — no run-log entry required.
        continue
    fi

    # Stage is complete in state.yaml — must have BOTH started and completed events.
    started_event=$(yq -r ".events[] | select(.event==\"stage_started\" and .stage==\"$stage\")" "$RUN_LOG" 2>/dev/null || echo "")
    completed_event=$(yq -r ".events[] | select(.event==\"stage_completed\" and .stage==\"$stage\")" "$RUN_LOG" 2>/dev/null || echo "")

    if [ -z "$started_event" ] || [ "$started_event" = "null" ]; then
        fail "Stage '$stage': complete in state.yaml but NO stage_started event in run-log"
        ERRORS=$((ERRORS + 1))
        continue
    fi

    if [ -z "$completed_event" ] || [ "$completed_event" = "null" ]; then
        fail "Stage '$stage': complete in state.yaml but NO stage_completed event in run-log"
        ERRORS=$((ERRORS + 1))
        continue
    fi

    COMPLETED_STAGES+=("$stage")

    # 3a. Check started.order == completed.order == expected_order.
    started_order=$(yq -r ".events[] | select(.event==\"stage_started\" and .stage==\"$stage\") | .order" "$RUN_LOG" 2>/dev/null || echo "0")
    completed_order=$(yq -r ".events[] | select(.event==\"stage_completed\" and .stage==\"$stage\") | .order" "$RUN_LOG" 2>/dev/null || echo "0")

    if [ "$started_order" != "$expected_order" ]; then
        fail "Stage '$stage' started event has order=$started_order (expected $expected_order)"
        ERRORS=$((ERRORS + 1))
    fi
    if [ "$completed_order" != "$expected_order" ]; then
        fail "Stage '$stage' completed event has order=$completed_order (expected $expected_order)"
        ERRORS=$((ERRORS + 1))
    fi

    # 3b. Check completed.at >= started.at.
    started_at=$(yq -r ".events[] | select(.event==\"stage_started\" and .stage==\"$stage\") | .at" "$RUN_LOG" 2>/dev/null || echo "")
    completed_at=$(yq -r ".events[] | select(.event==\"stage_completed\" and .stage==\"$stage\") | .at" "$RUN_LOG" 2>/dev/null || echo "")
    if [ -n "$started_at" ] && [ -n "$completed_at" ] && [ "$started_at" != "null" ] && [ "$completed_at" != "null" ]; then
        # Simple string comparison works for ISO8601 timestamps.
        if [ "$completed_at" \< "$started_at" ]; then
            fail "Stage '$stage' completed_at ($completed_at) < started_at ($started_at)"
            ERRORS=$((ERRORS + 1))
        fi
    fi

    # 3c. Check validator.exit_code == 0.
    exit_code=$(yq -r ".events[] | select(.event==\"stage_completed\" and .stage==\"$stage\") | .validator.exit_code // -1" "$RUN_LOG" 2>/dev/null || echo "-1")
    if [ "$exit_code" != "0" ]; then
        fail "Stage '$stage' validator exit_code=$exit_code (expected 0)"
        ERRORS=$((ERRORS + 1))
    fi

    # 3d. Check required_outputs non-empty → output_hashes non-empty.
    req_outputs=$(yq -r ".stages.\"$stage\".required_outputs // [] | .[]" "$STATE_FILE" 2>/dev/null || echo "")
    has_req_outputs=false
    for ro in $req_outputs; do
        [ -z "$ro" ] && continue
        has_req_outputs=true
        break
    done
    output_hashes=$(yq -r ".events[] | select(.event==\"stage_completed\" and .stage==\"$stage\") | .output_hashes // {}" "$RUN_LOG" 2>/dev/null || echo "{}")
    hash_keys=$(echo "$output_hashes" | yq -r 'keys | length' 2>/dev/null || echo "0")
    if [ "$has_req_outputs" = true ] && [ "$hash_keys" -eq 0 ]; then
        fail "Stage '$stage' has required_outputs but output_hashes is empty"
        ERRORS=$((ERRORS + 1))
    fi

    # 3e. Check output hashes still match current files.
    HASH_ARTIFACT="$SCRIPT_DIR/cr-hash-artifact"
    if [ "$output_hashes" != "{}" ] && [ -n "$output_hashes" ]; then
        keys=$(echo "$output_hashes" | yq -r 'keys | .[]' 2>/dev/null || echo "")
        for key in $keys; do
            [ -z "$key" ] && continue
            stored_hash=$(echo "$output_hashes" | yq -r ".[\"$key\"]" 2>/dev/null || echo "")
            # Scoped path: use cr-hash-artifact. Bare path: use legacy resolution.
            if [[ "$key" == *":"* ]] && [ -x "$HASH_ARTIFACT" ]; then
                current_hash=$("$HASH_ARTIFACT" "$PROJECT_DIR" "$ROUND_DIR" "$key" 2>/dev/null || echo "")
            else
                f="$ROUND_DIR/$key"
                if [ -f "$f" ]; then
                    current_hash=$(shasum -a 256 "$f" 2>/dev/null | cut -d' ' -f1 || echo "")
                elif [ -d "$f" ]; then
                    current_hash=$(find "$f" -type f -exec shasum -a 256 {} \; 2>/dev/null | awk '{print $1}' | sort | shasum -a 256 | cut -d' ' -f1 || echo "")
                elif [ -f "$PROJECT_DIR/$key" ]; then
                    current_hash=$(shasum -a 256 "$PROJECT_DIR/$key" 2>/dev/null | cut -d' ' -f1 || echo "")
                else
                    current_hash=""
                fi
            fi
            if [ "$stored_hash" != "$current_hash" ]; then
                fail "Stage '$stage' output '$key' hash mismatch: stored=$stored_hash current=$current_hash"
                ERRORS=$((ERRORS + 1))
            fi
        done
    fi

    # 3f. Check input_hashes present and match current files.
    input_hashes=$(yq -r ".events[] | select(.event==\"stage_started\" and .stage==\"$stage\") | .input_hashes // {}" "$RUN_LOG" 2>/dev/null || echo "{}")
    if [ "$input_hashes" != "{}" ] && [ -n "$input_hashes" ]; then
        keys=$(echo "$input_hashes" | yq -r 'keys | .[]' 2>/dev/null || echo "")
        for key in $keys; do
            [ -z "$key" ] && continue
            stored_hash=$(echo "$input_hashes" | yq -r ".[\"$key\"]" 2>/dev/null || echo "")
            if [[ "$key" == *":"* ]] && [ -x "$HASH_ARTIFACT" ]; then
                current_hash=$("$HASH_ARTIFACT" "$PROJECT_DIR" "$ROUND_DIR" "$key" 2>/dev/null || echo "")
            else
                f="$ROUND_DIR/$key"
                [ -f "$f" ] || f="$PROJECT_DIR/$key"
                if [ -f "$f" ]; then
                    current_hash=$(shasum -a 256 "$f" 2>/dev/null | cut -d' ' -f1 || echo "")
                else
                    current_hash=""
                fi
            fi
            if [ -n "$stored_hash" ] && [ "$stored_hash" != "$current_hash" ]; then
                fail "Stage '$stage' input '$key' hash mismatch: stored=$stored_hash current=$current_hash"
                ERRORS=$((ERRORS + 1))
            fi
        done
    fi

    # 3g. Manifest-driven required input/output hash completeness.
    MANIFEST="$ROUND_DIR/stage-manifest.snapshot.yaml"
    HASH_ARTIFACT="$SCRIPT_DIR/cr-hash-artifact"
    if [ -f "$MANIFEST" ]; then
        # Use manifest snapshot as single source of truth.
        # Get required_inputs from manifest — use scoped path as key, do NOT strip.
        req_in_count=$(yq -r ".stages[] | select(.id == \"$stage\") | .required_inputs | length // 0" "$MANIFEST" 2>/dev/null || echo 0)
        for j in $(seq 0 $((req_in_count - 1))); do
            scoped_path=$(yq -r ".stages[] | select(.id == \"$stage\") | .required_inputs[$j].path // \"\"" "$MANIFEST" 2>/dev/null || echo "")
            [ -z "$scoped_path" ] && continue
            # Scoped path must contain a colon separator.
            if [[ "$scoped_path" != *":"* ]]; then
                fail "Stage '$stage' input '$scoped_path' is a bare path (expected scoped path like project:... or round:...)"
                ERRORS=$((ERRORS + 1))
                continue
            fi
            has_key=$(echo "$input_hashes" | yq -r "has(\"$scoped_path\")" 2>/dev/null || echo "false")
            if [ "$has_key" != "true" ]; then
                fail "Stage '$stage' required input '$scoped_path' missing from input_hashes"
                ERRORS=$((ERRORS + 1))
            fi
        done

        # Get required_outputs from manifest.
        req_out_count=$(yq -r ".stages[] | select(.id == \"$stage\") | .required_outputs | length // 0" "$MANIFEST" 2>/dev/null || echo 0)
        declared_outputs=""
        for j in $(seq 0 $((req_out_count - 1))); do
            scoped_path=$(yq -r ".stages[] | select(.id == \"$stage\") | .required_outputs[$j].path // \"\"" "$MANIFEST" 2>/dev/null || echo "")
            [ -z "$scoped_path" ] && continue
            if [[ "$scoped_path" != *":"* ]]; then
                fail "Stage '$stage' output '$scoped_path' is a bare path (expected scoped path like round:...)"
                ERRORS=$((ERRORS + 1))
                continue
            fi
            declared_outputs="$declared_outputs $scoped_path"
            has_key=$(echo "$output_hashes" | yq -r "has(\"$scoped_path\")" 2>/dev/null || echo "false")
            if [ "$has_key" != "true" ]; then
                fail "Stage '$stage' required output '$scoped_path' missing from output_hashes"
                ERRORS=$((ERRORS + 1))
            fi
        done

        # Check for extra keys in output_hashes not declared in manifest.
        out_keys=$(echo "$output_hashes" | yq -r 'keys | .[]' 2>/dev/null || echo "")
        for ok in $out_keys; do
            [ -z "$ok" ] && continue
            # Extra keys must also be scoped; bare keys are rejected.
            if [[ "$ok" != *":"* ]]; then
                fail "Stage '$stage' output_hashes has bare key '$ok' (must use scoped path like round:...)"
                ERRORS=$((ERRORS + 1))
                continue
            fi
            found=false
            for declared in $declared_outputs; do
                if [ "$declared" = "$ok" ]; then
                    found=true
                    break
                fi
            done
            if [ "$found" = false ]; then
                fail "Stage '$stage' output_hashes has extra key '$ok' not in manifest required_outputs"
                ERRORS=$((ERRORS + 1))
            fi
        done

        # Check for bare keys in input_hashes.
        in_keys_check=$(echo "$input_hashes" | yq -r 'keys | .[]' 2>/dev/null || echo "")
        for ik in $in_keys_check; do
            [ -z "$ik" ] && continue
            if [[ "$ik" != *":"* ]]; then
                fail "Stage '$stage' input_hashes has bare key '$ik' (must use scoped path like project:...)"
                ERRORS=$((ERRORS + 1))
            fi
        done

        # 3e+. Verify stored hashes still match current artifacts (using scoped paths).
        if [ -x "$HASH_ARTIFACT" ]; then
            for scoped_path in $declared_outputs; do
                [ -z "$scoped_path" ] && continue
                stored_hash=$(echo "$output_hashes" | yq -r ".[\"$scoped_path\"]" 2>/dev/null || echo "")
                [ -z "$stored_hash" ] && continue
                current_hash=$("$HASH_ARTIFACT" "$PROJECT_DIR" "$ROUND_DIR" "$scoped_path" 2>/dev/null || echo "")
                if [ "$stored_hash" != "$current_hash" ]; then
                    fail "Stage '$stage' output '$scoped_path' hash mismatch: stored=$stored_hash current=$current_hash"
                    ERRORS=$((ERRORS + 1))
                fi
            done

            # Also verify input hashes.
            in_keys=$(echo "$input_hashes" | yq -r 'keys | .[]' 2>/dev/null || echo "")
            for scoped_path in $in_keys; do
                [ -z "$scoped_path" ] && continue
                stored_hash=$(echo "$input_hashes" | yq -r ".[\"$scoped_path\"]" 2>/dev/null || echo "")
                [ -z "$stored_hash" ] && continue
                current_hash=$("$HASH_ARTIFACT" "$PROJECT_DIR" "$ROUND_DIR" "$scoped_path" 2>/dev/null || echo "")
                if [ "$stored_hash" != "$current_hash" ]; then
                    fail "Stage '$stage' input '$scoped_path' hash mismatch: stored=$stored_hash current=$current_hash"
                    ERRORS=$((ERRORS + 1))
                fi
            done
        fi
    else
        # Fallback: use state.yaml required_inputs/required_outputs (bare paths allowed).
        req_inputs=$(yq -r ".stages.\"$stage\".required_inputs // [] | .[]" "$STATE_FILE" 2>/dev/null || echo "")
        for key in $req_inputs; do
            [ -z "$key" ] && continue
            if [ "${key: -1}" = "/" ]; then
                continue
            fi
            has_key=$(echo "$input_hashes" | yq -r "has(\"$key\")" 2>/dev/null || echo "false")
            if [ "$has_key" != "true" ]; then
                fail "Stage '$stage' required input '$key' missing from input_hashes"
                ERRORS=$((ERRORS + 1))
            fi
        done

        req_outputs=$(yq -r ".stages.\"$stage\".required_outputs // [] | .[]" "$STATE_FILE" 2>/dev/null || echo "")
        declared_outputs=""
        for key in $req_outputs; do
            [ -z "$key" ] && continue
            declared_outputs="$declared_outputs $key"
            has_key=$(echo "$output_hashes" | yq -r "has(\"$key\")" 2>/dev/null || echo "false")
            if [ "$has_key" != "true" ]; then
                fail "Stage '$stage' required output '$key' missing from output_hashes"
                ERRORS=$((ERRORS + 1))
            fi
        done

        out_keys=$(echo "$output_hashes" | yq -r 'keys | .[]' 2>/dev/null || echo "")
        for ok in $out_keys; do
            [ -z "$ok" ] && continue
            found=false
            for declared in $declared_outputs; do
                if [ "$declared" = "$ok" ]; then
                    found=true
                    break
                fi
            done
            if [ "$found" = false ]; then
                fail "Stage '$stage' output_hashes has extra key '$ok' not in required_outputs"
                ERRORS=$((ERRORS + 1))
            fi
        done
    fi
done

# ── 4. Check no duplicate events per stage ───────────────────────

for stage in "${STAGE_ORDER[@]}"; do
    started_count=$(yq -r "[.events[] | select(.event==\"stage_started\" and .stage==\"$stage\")] | length" "$RUN_LOG" 2>/dev/null || echo 0)
    completed_count=$(yq -r "[.events[] | select(.event==\"stage_completed\" and .stage==\"$stage\")] | length" "$RUN_LOG" 2>/dev/null || echo 0)
    if [ "$started_count" -gt 1 ]; then
        fail "Stage '$stage' has $started_count started events (expected 0 or 1)"
        ERRORS=$((ERRORS + 1))
    fi
    if [ "$completed_count" -gt 1 ]; then
        fail "Stage '$stage' has $completed_count completed events (expected 0 or 1)"
        ERRORS=$((ERRORS + 1))
    fi
done

# ── 5. Check s8_round_closure has started+completed events ───────

CLOSE_STARTED=$(yq -r ".events[] | select(.event==\"stage_started\" and .stage==\"s8_round_closure\")" "$RUN_LOG" 2>/dev/null || echo "")
CLOSE_COMPLETED=$(yq -r ".events[] | select(.event==\"stage_completed\" and .stage==\"s8_round_closure\")" "$RUN_LOG" 2>/dev/null || echo "")
if [ -n "$CLOSE_STARTED" ] && [ "$CLOSE_STARTED" != "null" ] && [ -n "$CLOSE_COMPLETED" ] && [ "$CLOSE_COMPLETED" != "null" ]; then
    pass "s8_round_closure has started + completed events"
elif [ -n "$CLOSE_COMPLETED" ] && [ "$CLOSE_COMPLETED" != "null" ] && [ -z "$CLOSE_STARTED" ]; then
    fail "s8_round_closure has completed event but NO started event"
    ERRORS=$((ERRORS + 1))
else
    # s8_round_closure may not be complete yet — only warn.
    warn "s8_round_closure has no completed event (round may not be closed yet)"
fi

# ── 6. Check state.yaml complete count matches run-log ───────────

STATE_COMPLETE=$(yq -r '[.stages | to_entries[] | select(.value.status=="complete")] | length' "$STATE_FILE" 2>/dev/null || echo 0)
RUNLOG_STARTED=$(yq -r '[.events[] | select(.event=="stage_started")] | length' "$RUN_LOG" 2>/dev/null || echo 0)
RUNLOG_COMPLETE=$(yq -r '[.events[] | select(.event=="stage_completed")] | length' "$RUN_LOG" 2>/dev/null || echo 0)

if [ "$STATE_COMPLETE" != "$RUNLOG_COMPLETE" ]; then
    fail "state.yaml has $STATE_COMPLETE complete stages, run-log has $RUNLOG_COMPLETE completed events"
    ERRORS=$((ERRORS + 1))
else
    pass "Complete stage count matches: $STATE_COMPLETE/$RUNLOG_COMPLETE"
fi

if [ "$RUNLOG_STARTED" != "$RUNLOG_COMPLETE" ]; then
    fail "run-log has $RUNLOG_STARTED started events but $RUNLOG_COMPLETE completed events (must be equal)"
    ERRORS=$((ERRORS + 1))
fi

# ── 7. Check repair-log consistency ──────────────────────────────

REPAIR_LOG="$ROUND_DIR/repair-log.yaml"
if [ -f "$REPAIR_LOG" ]; then
    REPAIR_COUNT=$(yq -r '.repairs | length // 0' "$REPAIR_LOG" 2>/dev/null || echo 0)
    if [ "$REPAIR_COUNT" -gt 0 ]; then
        pass "Repair log has $REPAIR_COUNT entries"
    fi
fi

if [ "$ERRORS" -gt 0 ]; then
    fail "$ERRORS stage-run-log failure(s)"
    cr_exit_summary
fi

pass "Stage run log validation passed"
cr_exit_summary
