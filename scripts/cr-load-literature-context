#!/usr/bin/env bash
# cr-load-literature-context — Emit relevant literature cards for related-work writing.
# Prompt scaffolding: outputs matching literature cards that the agent should
# reference when writing or updating the related work section.
#
# Usage: cr-load-literature-context <workspace_root> [topic]
#
# Output: Markdown list of relevant literature cards with summaries.
# Exit codes:
#   0 — cards found or empty (no match is not an error)

set -euo pipefail

WORKSPACE_ROOT="${1:-}"
TOPIC="${2:-}"

if [ -z "$WORKSPACE_ROOT" ]; then
    echo "Usage: cr-load-literature-context <workspace_root> [topic]" >&2
    exit 1
fi

LIT_DIR="$WORKSPACE_ROOT/_cr/knowledge/literature"
if [ ! -d "$LIT_DIR" ]; then
    echo "WARNING: No literature knowledge directory at $LIT_DIR" >&2
    echo "No literature context loaded." >&2
    exit 0
fi

echo "## Loaded Literature Context"
echo ""

CARD_TYPES=("papers" "systems" "concepts" "debates" "comparisons")

for ctype in "${CARD_TYPES[@]}"; do
    CTYPE_DIR="$LIT_DIR/$ctype"
    [ ! -d "$CTYPE_DIR" ] && continue

    CARDS=$(find "$CTYPE_DIR" -name '*.md' -type f 2>/dev/null || echo "")
    [ -z "$CARDS" ] && continue

    for card_file in $CARDS; do
        CARD_ID=$(basename "$card_file" .md)

        # Extract understanding level and one-sentence summary.
        UNDERSTANDING=$(grep -E '(understanding_level|Understanding level):' "$card_file" 2>/dev/null | head -1 | sed 's/.*:\s*//' | xargs || echo "L0")
        ONE_SENTENCE=$(grep -E '(One-Sentence Understanding|one_sentence_understanding|Current Understanding|Definition)' "$card_file" 2>/dev/null | head -1 | sed 's/^#*\s*//' | cut -c1-200 || echo "")

        # Relevance: if topic provided, check card areas/keywords.
        if [ -n "$TOPIC" ]; then
            if ! grep -qi "$TOPIC" "$card_file" 2>/dev/null; then
                continue
            fi
        fi

        echo "- **[$ctype] $CARD_ID** (L: $UNDERSTANDING): $ONE_SENTENCE"
    done
done

echo ""
echo "Use these cards to ground related-work discussion and baseline comparisons."
