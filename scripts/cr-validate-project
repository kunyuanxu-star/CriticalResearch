#!/usr/bin/env bash
# cr-validate-project — Project manifest validation (Inv1).
# Checks that a research project has all required manifest files.
#
# Usage: cr-validate-project <project_dir>
#
# Exit codes:
#   0 — all checks passed
#   2 — one or more failures

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

PROJECT_DIR="${1:-}"

if [ -z "$PROJECT_DIR" ]; then
    echo "Usage: cr-validate-project <project_dir>" >&2
    exit 2
fi

if [ ! -d "$PROJECT_DIR" ]; then
    fail "Project directory not found: $PROJECT_DIR"
    cr_exit_summary
fi

PROJECT_NAME="$(basename "$PROJECT_DIR")"
echo ""
echo "══ Project Validation: $PROJECT_NAME ══"

# ── Required files ───────────────────────────────────────────────

# project.yaml must exist.
if [ -f "$PROJECT_DIR/project.yaml" ]; then
    pass "project.yaml exists"
else
    fail "project.yaml not found — every project must have a manifest"
fi

# state/project-state.json must exist.
if [ -f "$PROJECT_DIR/state/project-state.json" ]; then
    pass "state/project-state.json exists"
else
    fail "state/project-state.json not found — project state file required"
fi

# writing/paper-draft.md (or presentation-draft.md) must exist.
if [ -f "$PROJECT_DIR/writing/paper-draft.md" ] || [ -f "$PROJECT_DIR/writing/presentation-draft.md" ]; then
    pass "writing/ draft file exists"
else
    fail "writing/paper-draft.md (or presentation-draft.md) not found"
fi

# literature/ directory must exist.
if [ -d "$PROJECT_DIR/literature" ]; then
    pass "literature/ directory exists"
else
    fail "literature/ directory not found"
fi

# rounds/ directory must exist.
if [ -d "$PROJECT_DIR/rounds" ]; then
    pass "rounds/ directory exists"
else
    fail "rounds/ directory not found"
fi

# ── Optional: schema validation of project.yaml ──────────────────

if [ -f "$PROJECT_DIR/project.yaml" ]; then
    SCHEMA_PATH="$(cr_schema_path "project.schema.json")"
    if [ -n "$SCHEMA_PATH" ]; then
        cr_validate_schema "$PROJECT_DIR/project.yaml" "$SCHEMA_PATH" "yaml"
    fi
fi

if [ -f "$PROJECT_DIR/state/project-state.json" ]; then
    SCHEMA_PATH="$(cr_schema_path "project-state.schema.json")"
    if [ -n "$SCHEMA_PATH" ]; then
        cr_validate_schema "$PROJECT_DIR/state/project-state.json" "$SCHEMA_PATH" "json"
    fi
fi

# ── Check for skill source pollution (Inv0) ──────────────────────

echo ""
echo "── Path Guard (Inv0) ──"

SKILL_FILES=("SKILL.md" "workflow/" "roles/" "scripts/" "schemas/" "hooks/")
for forbidden in "${SKILL_FILES[@]}"; do
    if [ -e "$PROJECT_DIR/$forbidden" ]; then
        fail "Skill source pollution detected: $PROJECT_DIR/$forbidden"
    fi
done

if [ "$CR_ERRORS" -eq 0 ]; then
    # Only pass if no new errors were added in this section.
    pass "No skill source pollution in project directory"
fi

cr_exit_summary
