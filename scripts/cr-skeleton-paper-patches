#!/usr/bin/env bash
# cr-skeleton-paper-patches — Deterministic skeleton generator for paper patches.
# Reads dispositions.yaml and creates PP-XXX.yaml skeleton files for every
# disposition with disposition_type=paper_patch that has no existing patch file.
#
# Usage: cr-skeleton-paper-patches <round_dir> <project_dir>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

ROUND_DIR="${1:-}"
PROJECT_DIR="${2:-}"

if [ -z "$ROUND_DIR" ] || [ -z "$PROJECT_DIR" ]; then
    echo "Usage: cr-skeleton-paper-patches <round_dir> <project_dir>" >&2
    exit 2
fi

DISPOSITIONS_FILE="$ROUND_DIR/dispositions.yaml"
if [ ! -f "$DISPOSITIONS_FILE" ]; then
    echo "No dispositions.yaml — nothing to skeletonize."
    exit 0
fi

PATCHES_DIR="$ROUND_DIR/patches"
mkdir -p "$PATCHES_DIR"

ROUND_NAME=$(basename "$ROUND_DIR")
NOW=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
CREATED=0

# Find dispositions needing paper patches.
if command -v yq >/dev/null 2>&1; then
    DISP_JSON=$(yq -o json '.' "$DISPOSITIONS_FILE" 2>/dev/null || echo "[]")
    PENDING=$(printf '%s' "$DISP_JSON" | jq -r '(.dispositions // [])[] | select(.disposition_type == "paper_patch" and .status == "open") | "\(.critique_id)|\(.linked_patch_id // "")|\(.severity // "high")|\(.justification // "")"' 2>/dev/null)
else
    echo "yq not available — cannot parse dispositions. Run: brew install yq" >&2
    exit 1
fi

if [ -z "$PENDING" ]; then
    echo "No pending paper_patch dispositions."
    exit 0
fi

while IFS='|' read -r critique_id linked_patch severity justification; do
    [ -z "$critique_id" ] && continue

    # Determine patch ID.
    if [ -n "$linked_patch" ] && [ "$linked_patch" != "null" ]; then
        PP_ID="$linked_patch"
    else
        # Auto-assign: max existing + 1.
        MAX_ID=$(find "$PATCHES_DIR" -name 'PP-*.yaml' -type f 2>/dev/null | sed 's/.*PP-//;s/\.yaml//' | sort -n | tail -1)
        MAX_ID="${MAX_ID:-0}"
        NEXT=$((MAX_ID + 1))
        PP_ID=$(printf "PP-%03d" "$NEXT")
    fi

    PATCH_FILE="$PATCHES_DIR/${PP_ID}.yaml"

    if [ -f "$PATCH_FILE" ]; then
        echo "  $PP_ID already exists — skipping"
        continue
    fi

    # Write skeleton.
    cat > "$PATCH_FILE" << YAML
# $PP_ID — Paper Patch Skeleton
# Fill in proposed_change, knowledge_implication, and affected_anchors.

patch_id: $PP_ID
linked_critique: $critique_id
linked_claim: ""
linked_round: $ROUND_NAME
severity: $severity

patch_type:
  - weaken_claim

affected_anchors:
  - abstract

proposed_change:
  before: "[FILL: current text or claim in paper draft]"
  after: "[FILL: proposed replacement]"
  rationale: "[FILL: why this addresses $critique_id]"

experiment_obligations: []

needs_human_decision: false
human_decision_rationale: ""

options: []
agent_recommendation:
  choice: ""
  reason: ""

knowledge_implication:
  literature_updates: []
  thinking_candidates:
    - rule: "[FILL: reusable rule learned from this patch]"
      category: writing_rule

lifecycle_status: proposed
lifecycle_history:
  - from: ""
    to: proposed
    timestamp: "$NOW"
    reason: "Skeleton created from disposition $critique_id."

superseded_by: ""
rejection_reason: ""
created_at: "$NOW"
updated_at: "$NOW"
applied_at: ""
applied_diff_anchor: ""
YAML

    echo "  Created $PP_ID (from $critique_id)"
    CREATED=$((CREATED + 1))

done <<< "$PENDING"

echo ""
echo "Created $CREATED skeleton patch(es) in $PATCHES_DIR/"
echo "Next: fill in proposed_change, knowledge_implication, affected_anchors."
echo "Then run: cr-validate-paper-patches $ROUND_DIR"
