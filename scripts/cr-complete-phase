#!/usr/bin/env bash
# cr-complete-phase — The ONLY way to mark a phase complete.
# Validates the phase via cr-validate-phase, then updates state.yaml.
# Manual edits to phase status in state.yaml are blocked by cr-guard-path.
#
# Usage: cr-complete-phase <project_dir> <round_dir> <phase>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

PROJECT_DIR="${1:-}"
ROUND_DIR="${2:-}"
PHASE="${3:-}"

if [ -z "$PROJECT_DIR" ] || [ -z "$ROUND_DIR" ] || [ -z "$PHASE" ]; then
    echo "Usage: cr-complete-phase <project_dir> <round_dir> <phase>" >&2
    exit 2
fi

STATE_FILE="$ROUND_DIR/state.yaml"

if [ ! -f "$STATE_FILE" ]; then
    echo "Error: state.yaml not found in $ROUND_DIR" >&2
    exit 2
fi

# Check phase exists.
PHASE_STATUS=$(yq -r ".phases.$PHASE.status // \"unknown\"" "$STATE_FILE" 2>/dev/null || echo "unknown")
if [ "$PHASE_STATUS" = "unknown" ]; then
    echo "Error: phase '$PHASE' not found in state.yaml" >&2
    exit 2
fi

# ── Only allow completing current_phase ────────────────────────────

CURRENT_PHASE=$(yq -r '.current_phase // ""' "$STATE_FILE" 2>/dev/null || echo "")
if [ "$PHASE" != "$CURRENT_PHASE" ]; then
    echo "Error: Cannot complete phase '$PHASE'; current_phase is '$CURRENT_PHASE'" >&2
    echo "  Phases must be completed in phase_order sequence." >&2
    exit 2
fi

# ── Helper: check module review ──────────────────────────────────

check_module_review() {
    local phase="$1"
    local round_dir="$2"
    local mod=""
    case "$phase" in
        freeze_full_paper_coverage)       mod="M0" ;;
        generate_search_strategy)         mod="M1" ;;
        update_literature_knowledge)      mod="M2" ;;
        synthesize_evaluation_gaps)       mod="M3" ;;
        merge_critique_ledger)            mod="M4" ;;
        generate_experiment_obligations)  mod="M5" ;;
        reviewer_readiness_pass)          mod="M6" ;;
        prepare_next_round)               mod="M7" ;;
    esac
    [ -z "$mod" ] && return 0

    local review_file="$round_dir/phase-reviews/${mod}-review.yaml"
    if [ -f "$review_file" ]; then
        local review_status
        review_status=$(yq -r '.status // ""' "$review_file" 2>/dev/null || echo "")
        local review_blocking
        review_blocking=$(yq -r '.blocking_findings | length // 0' "$review_file" 2>/dev/null || echo 0)
        if [ "$review_status" = "pass" ] && [ "$review_blocking" -eq 0 ] 2>/dev/null; then
            return 0
        fi
    fi
    return 1
}

# ── Helper: auto-unblock next phases ─────────────────────────────

auto_unblock() {
    local state_file="$1"
    local all_phases
    all_phases=$(yq -r '.phase_order // [] | .[]' "$state_file" 2>/dev/null)
    [ -z "$all_phases" ] && all_phases=$(yq -r '.phases | keys | .[]' "$state_file" 2>/dev/null)
    for p in $all_phases; do
        [ -z "$p" ] && continue
        local p_status
        p_status=$(yq -r ".phases.$p.status // \"\"" "$state_file" 2>/dev/null)
        [ "$p_status" != "blocked" ] && continue

        local all_deps_met=true
        local deps
        deps=$(yq -r ".phases.$p.depends_on // [] | .[]" "$state_file" 2>/dev/null)
        for dep in $deps; do
            [ -z "$dep" ] && continue
            local dep_status
            dep_status=$(yq -r ".phases.$dep.status // \"\"" "$state_file" 2>/dev/null)
            if [ "$dep_status" != "complete" ]; then
                all_deps_met=false
                break
            fi
        done

        if [ "$all_deps_met" = true ]; then
            yq -i ".phases.$p.status = \"open\"" "$state_file" 2>/dev/null
            echo "  Unblocked: $p"
        fi
    done

    # Set current_phase to the first open phase.
    for p in $all_phases; do
        [ -z "$p" ] && continue
        local p_status
        p_status=$(yq -r ".phases.$p.status // \"\"" "$state_file" 2>/dev/null)
        if [ "$p_status" = "open" ]; then
            yq -i ".current_phase = \"$p\"" "$state_file" 2>/dev/null
            echo "Current phase: $p"
            break
        fi
    done
}

# ── Already complete: check review and unblock if possible ───────

if [ "$PHASE_STATUS" = "complete" ]; then
    echo "Phase '$PHASE' is already complete."

    if ! check_module_review "$PHASE" "$ROUND_DIR"; then
        echo "Module review still pending. Cannot advance."
        exit 0
    fi

    # Review OK — auto-unblock and exit.
    auto_unblock "$STATE_FILE"
    exit 0
fi

if [ "$PHASE_STATUS" = "blocked" ]; then
    echo "Error: phase '$PHASE' is blocked. Complete its dependencies first:"
    yq -r ".phases.$PHASE.depends_on[]" "$STATE_FILE" 2>/dev/null | while read -r dep; do
        dep_status=$(yq -r ".phases.$dep.status // \"unknown\"" "$STATE_FILE" 2>/dev/null)
        echo "  - $dep: $dep_status"
    done
    exit 2
fi

# Collect all inputs and outputs for phase-run-log recording.
ALL_OUTPUTS=$(yq -r ".phases.$PHASE.required_outputs // [] | .[]" "$STATE_FILE" 2>/dev/null || echo "")
ALL_INPUTS=$(yq -r ".phases.$PHASE.required_inputs // [] | .[]" "$STATE_FILE" 2>/dev/null || echo "")

# ── Validate state transition ──────────────────────────────────────

TRANSITION_VALIDATOR="$SCRIPT_DIR/cr-validate-phase-transition"
if [ -x "$TRANSITION_VALIDATOR" ]; then
    if ! "$TRANSITION_VALIDATOR" "$STATE_FILE" "$PHASE" "$PHASE_STATUS" "complete"; then
        echo ""
        echo "State transition $PHASE_STATUS -> complete is FORBIDDEN for phase '$PHASE'."
        echo "  Repair path: set phase to 'running' first, re-validate, then complete."
        echo "  If repairing from repair_required, ensure you have re-run the phase."
        exit 2
    fi
else
    echo "Warning: cr-validate-phase-transition not found — skipping transition check."
fi

# ── Phase-specific completion predicate ─────────────────────────────

COMPLETION_ALL_OUTPUTS=$(yq -r ".phases.$PHASE.completion_predicate.all_outputs_exist" "$STATE_FILE" 2>/dev/null || echo "true")
[ -z "$COMPLETION_ALL_OUTPUTS" ] || [ "$COMPLETION_ALL_OUTPUTS" = "null" ] && COMPLETION_ALL_OUTPUTS="true"
COMPLETION_VALIDATOR=$(yq -r ".phases.$PHASE.completion_predicate.validator_passed" "$STATE_FILE" 2>/dev/null || echo "true")
[ -z "$COMPLETION_VALIDATOR" ] || [ "$COMPLETION_VALIDATOR" = "null" ] && COMPLETION_VALIDATOR="true"

if [ "$COMPLETION_ALL_OUTPUTS" != "true" ]; then
    echo "Error: completion_predicate.all_outputs_exist is false for phase '$PHASE'" >&2
    exit 2
fi

# Run phase validator. Must pass before marking complete.
echo "Validating phase '$PHASE'..."
PHASE_VALIDATOR="$SCRIPT_DIR/cr-validate-phase"
if [ -x "$PHASE_VALIDATOR" ]; then
    if ! "$PHASE_VALIDATOR" "$PROJECT_DIR" "$ROUND_DIR" "$PHASE"; then
        echo ""
        echo "Phase '$PHASE' validation FAILED. Fix issues before completing this phase."
        exit 2
    fi
else
    echo "Warning: cr-validate-phase not found — checking required outputs only."
    REQ=$(yq -r ".phases.$PHASE.required_outputs // [] | .[]" "$STATE_FILE" 2>/dev/null || echo "")
    for output in $REQ; do
        [ -z "$output" ] && continue
        case "$output" in
            *.yaml|*.md|*.json)
                if [ ! -f "$ROUND_DIR/$output" ] && [ ! -f "$PROJECT_DIR/$output" ]; then
                    echo "Error: required output '$output' is missing" >&2
                    exit 2
                fi
                ;;
            raw-sources|patches|experiments)
                if [ ! -d "$ROUND_DIR/$output" ] || [ -z "$(ls -A "$ROUND_DIR/$output" 2>/dev/null)" ]; then
                    echo "Error: required output '$output/' is missing or empty" >&2
                    exit 2
                fi
                ;;
        esac
    done
fi

# ── All checks passed — mark phase complete ──────────────────────

NOW=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

yq -i ".phases.$PHASE.status = \"complete\" | .phases.$PHASE.completed_at = \"$NOW\"" "$STATE_FILE" 2>/dev/null || {
    echo "Error: failed to update state.yaml" >&2
    exit 2
}

echo "Phase '$PHASE' marked complete at $NOW"

# ── Record phase-run-log (execution proof) ────────────────────────

PHASE_ORDER=$(yq -r ".phase_order | to_entries | .[] | select(.value == \"$PHASE\") | .key // 0" "$STATE_FILE" 2>/dev/null || echo "0")
PHASE_ORDER=$((PHASE_ORDER + 1))
RUN_LOG="$ROUND_DIR/phase-run-log.yaml"

# Get started_at from state.yaml for the phase_started event.
STARTED_AT=$(yq -r ".phases.\"$PHASE\".started_at // \"$NOW\"" "$STATE_FILE" 2>/dev/null || echo "$NOW")

# Compute validator script hash.
VALIDATOR_SCRIPT="$SCRIPT_DIR/cr-validate-phase"
VALIDATOR_SHA256="unknown"
if [ -f "$VALIDATOR_SCRIPT" ]; then
    VALIDATOR_SHA256=$(shasum -a 256 "$VALIDATOR_SCRIPT" 2>/dev/null | cut -d' ' -f1 || echo "unknown")
fi

# Ensure run-log has schema header if empty or old format.
if [ ! -s "$RUN_LOG" ] || ! grep -q '^schema_version:' "$RUN_LOG" 2>/dev/null; then
    cat > "$RUN_LOG" << 'HDR'
schema_version: "1.0.0"
events:
HDR
fi

# Convert old empty-list format to block format.
if grep -q '^events: \[\]' "$RUN_LOG" 2>/dev/null; then
    sed -i '' 's/^events: \[\]/events:/' "$RUN_LOG" 2>/dev/null || \
        sed -i 's/^events: \[\]/events:/' "$RUN_LOG"
fi

# Write phase_completed event.
{
    echo "  - event: phase_completed"
    echo "    phase: $PHASE"
    echo "    order: $PHASE_ORDER"
    echo "    at: \"$NOW\""
    echo "    status_transition:"
    echo "      from: \"$PHASE_STATUS\""
    echo "      to: complete"
    echo "    validator:"
    echo "      path: \"scripts/cr-validate-phase\""
    echo "      sha256: \"$VALIDATOR_SHA256\""
    echo "      exit_code: 0"
    echo "    output_hashes:"
    for out in $ALL_OUTPUTS; do
        [ -z "$out" ] && continue
        f="$ROUND_DIR/$out"
        if [ -f "$f" ]; then
            h=$(shasum -a 256 "$f" 2>/dev/null | cut -d' ' -f1 || echo "unknown")
            echo "      \"$out\": \"$h\""
        elif [ -d "$f" ]; then
            h=$(find "$f" -type f -exec shasum -a 256 {} \; 2>/dev/null | awk '{print $1}' | sort | shasum -a 256 | cut -d' ' -f1 || echo "unknown")
            echo "      \"$out\": \"$h\""
        fi
    done
    [ -z "$ALL_OUTPUTS" ] && echo "      {}"
} >> "$RUN_LOG"
echo "  Phase execution recorded in phase-run-log.yaml"

# ── Module review checkpoint ─────────────────────────────────────
# If this phase is the last in a module, the module review must exist
# and have status=pass before the next module's phases can unblock.

if ! check_module_review "$PHASE" "$ROUND_DIR"; then
    echo ""
    echo "══ Module Review Checkpoint ══"
    echo "Phase '$PHASE' completes a module."
    echo "Module review is required before proceeding to the next module."
    echo ""
    echo "Run: cr review-module $(basename "$PROJECT_DIR") <module>"
    echo ""
    echo "Phase '$PHASE' is COMPLETE. The next module is BLOCKED pending review."
    exit 0
fi

# ── Auto-unblock next phases whose dependencies are now satisfied ──

auto_unblock "$STATE_FILE"
