#!/usr/bin/env bash
# cr-validate-anchors — Anchor resolution validation.
# Checks that patch affected_anchors resolve to declared anchors in paper-draft.md.
# Patch application proof (after_text, writing-diff.yaml) is handled by
# cr-validate-patch-application — this script only checks anchor existence.
#
# Usage: cr-validate-anchors <round_dir> <project_dir>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

ROUND_DIR="${1:-}"
PROJECT_DIR="${2:-}"

if [ -z "$ROUND_DIR" ] || [ -z "$PROJECT_DIR" ]; then
    echo "Usage: cr-validate-anchors <round_dir> <project_dir>" >&2
    exit 2
fi

echo ""
echo "══ Anchor Validation: $(basename "$ROUND_DIR") ══"

DRAFT_FILE="$PROJECT_DIR/writing/paper-draft.md"
ALL_PASSED=true

if [ ! -f "$DRAFT_FILE" ]; then
    fail "paper-draft.md not found at $DRAFT_FILE"
    cr_exit_summary
fi

# Collect all declared anchors from the draft.
# Supports both formats: <!-- CR-ANCHOR: ID --> and <!-- anchor: id -->
declare -A DRAFT_ANCHORS
while IFS= read -r line; do
    # CR-ANCHOR format
    cr_a=$(echo "$line" | grep -oE 'CR-ANCHOR:\s*([A-Za-z0-9_-]+)' | sed 's/CR-ANCHOR:\s*//' || echo "")
    [ -n "$cr_a" ] && DRAFT_ANCHORS["$cr_a"]=1
    # Legacy anchor format
    legacy_a=$(echo "$line" | grep -oE 'anchor:\s*([a-z_][a-z0-9_.]*)' | sed 's/anchor:\s*//' || echo "")
    [ -n "$legacy_a" ] && DRAFT_ANCHORS["$legacy_a"]=1
done < "$DRAFT_FILE"

if [ ${#DRAFT_ANCHORS[@]} -eq 0 ]; then
    warn "No anchors found in paper-draft.md"
else
    pass "Found ${#DRAFT_ANCHORS[@]} anchor(s) in paper-draft.md"
fi

# Check patch anchors resolve.
PATCHES_DIR="$ROUND_DIR/patches"
if [ ! -d "$PATCHES_DIR" ]; then
    pass "No patches directory — nothing to validate"
    cr_exit_summary
fi

for patch_file in "$PATCHES_DIR"/PP-*.yaml; do
    [ -f "$patch_file" ] || continue
    PP_ID=$(basename "$patch_file" .yaml)

    # Read lifecycle and affected_anchors via yq.
    LIFECYCLE=$(yq -r '.lifecycle_status // ""' "$patch_file" 2>/dev/null || echo "")
    ANCHOR_COUNT=$(yq -r '.affected_anchors | length // 0' "$patch_file" 2>/dev/null || echo "0")

    if [ "${ANCHOR_COUNT:-0}" -eq 0 ]; then
        warn "$PP_ID: no affected_anchors declared"
        continue
    fi

    for i in $(seq 0 $((ANCHOR_COUNT - 1))); do
        anchor=$(yq -r ".affected_anchors[$i] // \"\"" "$patch_file" 2>/dev/null || echo "")
        [ -z "$anchor" ] && continue

        if [ -n "${DRAFT_ANCHORS[$anchor]:-}" ]; then
            pass "$PP_ID -> $anchor (resolved)"
        else
            case "$LIFECYCLE" in
                applied|recorded|validated)
                    fail "$PP_ID -> $anchor: anchor not found in draft (lifecycle=$LIFECYCLE)"
                    ALL_PASSED=false
                    ;;
                *)
                    warn "$PP_ID -> $anchor: anchor not yet in draft (lifecycle=$LIFECYCLE)"
                    ;;
            esac
        fi
    done
done

if [ "$ALL_PASSED" = false ]; then
    cr_exit_summary
fi

pass "Anchor validation passed"
cr_exit_summary
