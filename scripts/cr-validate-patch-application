#!/usr/bin/env bash
# cr-validate-patch-application — Verify that applied/recorded patches
# actually modified the paper draft. Checks that patch target sections
# contain the after_text or that the draft changed since patch creation.
#
# Usage: cr-validate-patch-application <project_dir> <round_dir>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

PROJECT_DIR="${1:-}"
ROUND_DIR="${2:-}"

if [ -z "$PROJECT_DIR" ] || [ -z "$ROUND_DIR" ]; then
    echo "Usage: cr-validate-patch-application <project_dir> <round_dir>" >&2
    exit 2
fi

DRAFT="$PROJECT_DIR/writing/paper-draft.md"
if [ ! -f "$DRAFT" ]; then
    fail "paper-draft.md not found"
    cr_exit_summary
fi

PATCHES_DIR="$ROUND_DIR/patches"
if [ ! -d "$PATCHES_DIR" ]; then
    pass "No patches directory — nothing to verify"
    cr_exit_summary
fi

echo "── Patch Application Verification ──"

ALL_PASSED=true
PATCH_FILES=$(find "$PATCHES_DIR" -name 'PP-*.yaml' -type f 2>/dev/null || echo "")

if [ -z "$PATCH_FILES" ]; then
    pass "No patches to verify"
    cr_exit_summary
fi

for patch_file in $PATCH_FILES; do
    PATCH_ID=$(basename "$patch_file" .yaml)
    LIFECYCLE=$(yq -r '.lifecycle_status // ""' "$patch_file" 2>/dev/null || echo "")

    case "$LIFECYCLE" in
        applied|recorded|validated)
            # These patches should have affected the draft.
            ANCHORS=$(yq -r '.affected_anchors // [] | .[]' "$patch_file" 2>/dev/null || echo "")
            AFTER_TEXT=$(yq -r '.proposed_change.after // ""' "$patch_file" 2>/dev/null || echo "")

            # Check: do the affected anchors exist in the draft?
            ANCHOR_FOUND=false
            for anchor in $ANCHORS; do
                [ -z "$anchor" ] && continue
                if grep -q "<!-- anchor: $anchor -->" "$DRAFT" 2>/dev/null; then
                    ANCHOR_FOUND=true
                    pass "$PATCH_ID: anchor '$anchor' found in draft"
                else
                    warn "$PATCH_ID: anchor '$anchor' not found in draft"
                fi
            done

            if [ "$ANCHOR_FOUND" = false ] && [ -n "$ANCHORS" ]; then
                fail "$PATCH_ID ($LIFECYCLE): no affected anchors found in draft"
                ALL_PASSED=false
            fi

            # Check: does after_text (first 60 chars) appear in draft?
            if [ -n "$AFTER_TEXT" ] && [ "$AFTER_TEXT" != "null" ]; then
                AFTER_SNIPPET=$(echo "$AFTER_TEXT" | head -1 | cut -c1-80)
                if grep -qF "$AFTER_SNIPPET" "$DRAFT" 2>/dev/null; then
                    pass "$PATCH_ID ($LIFECYCLE): after_text found in draft"
                else
                    warn "$PATCH_ID ($LIFECYCLE): after_text snippet not found in draft — manual verification needed"
                fi
            fi

            # Check writing-diff.yaml references this patch.
            DIFF_YAML="$ROUND_DIR/writing-diff.yaml"
            if [ -f "$DIFF_YAML" ]; then
                if grep -q "$PATCH_ID" "$DIFF_YAML" 2>/dev/null; then
                    pass "$PATCH_ID: referenced in writing-diff.yaml"
                else
                    warn "$PATCH_ID ($LIFECYCLE): not referenced in writing-diff.yaml"
                fi
            fi
            ;;

        proposed|needs_human_decision|approved)
            pass "$PATCH_ID ($LIFECYCLE): not yet applied — skipped"
            ;;

        rejected|superseded)
            pass "$PATCH_ID ($LIFECYCLE): terminal — skipped"
            ;;

        *)
            warn "$PATCH_ID: unknown lifecycle '$LIFECYCLE'"
            ;;
    esac
done

if [ "$ALL_PASSED" = false ]; then
    cr_exit_summary
fi

pass "Patch application verification passed"
cr_exit_summary
