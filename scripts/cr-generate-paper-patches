#!/usr/bin/env bash
# cr-generate-paper-patches — Emit agent instructions for generating paper patches.
# This is prompt scaffolding: it outputs the context an agent needs to generate
# paper patches from critique dispositions, not a deterministic generator.
#
# Usage: cr-generate-paper-patches <round_dir> <project_dir>

set -euo pipefail

ROUND_DIR="${1:-}"
PROJECT_DIR="${2:-}"

if [ -z "$ROUND_DIR" ] || [ -z "$PROJECT_DIR" ]; then
    echo "Usage: cr-generate-paper-patches <round_dir> <project_dir>" >&2
    exit 2
fi

ROUND_NAME=$(basename "$ROUND_DIR")

echo "## Paper Patch Generation Task"
echo ""
echo "Generate paper patches for all unresolved critique dispositions in round $ROUND_NAME."
echo ""
echo "### Context Files"
echo "- Critique file: \`$ROUND_DIR/critique.md\`"
echo "- Dispositions: \`$ROUND_DIR/dispositions.yaml\`"
echo "- Paper draft: \`$PROJECT_DIR/writing/paper-draft.md\`"
echo "- Patch template: \`templates/paper-patch.yaml\`"
echo "- Schema: \`schemas/paper_patch.schema.json\`"
echo ""

# Find unsolved dispositions.
if [ -f "$ROUND_DIR/dispositions.yaml" ] && command -v yq >/dev/null 2>&1; then
    echo "### Pending Dispositions"
    echo ""
    yq -o json '.' "$ROUND_DIR/dispositions.yaml" 2>/dev/null | \
        jq -r '(.dispositions // [])[] | select(.status == "open" and (.disposition_type == "paper_patch" or .disposition_type == "experiment_obligation")) | "- \(.critique_id): \(.disposition_type) — \(.justification)"' 2>/dev/null || \
        echo "(could not parse dispositions — check the file manually)"
fi

echo ""
echo "### Instructions"
echo ""
echo "For each pending disposition with disposition_type=paper_patch:"
echo ""
echo "1. Read the linked critique from \`critique.md\`"
echo "2. Identify affected paper sections and draft anchors"
echo "3. Fill in a \`PP-XXX.yaml\` file in \`$ROUND_DIR/patches/\` using the template"
echo "4. Assign the next available PP number (check existing patches for max + 1)"
echo "5. Ensure every patch includes:"
echo "   - Proposed change with before/after/rationale"
echo "   - Lifecycle status (proposed or needs_human_decision)"
echo "   - Knowledge implication (literature_updates + thinking_candidates)"
echo "6. If the patch changes a core claim, set needs_human_decision=true and add experiment obligations"
echo "7. Update the disposition record: set status=resolved, resolved_at=timestamp"
echo ""
echo "### Validation"
echo "After generation, run: \`cr-validate-paper-patches $ROUND_DIR\`"
