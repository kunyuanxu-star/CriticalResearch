#!/usr/bin/env bash
# cr-validate-literature — Literature card validation.
# Checks literature knowledge cards for required fields, understanding level
# consistency, and cross-references.
#
# Usage: cr-validate-literature <workspace_root>
#
# Exit codes:
#   0 — all checks passed
#   2 — one or more failures

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

WORKSPACE_ROOT="${1:-$(cr_workspace_root)}"

LIT_DIR="$WORKSPACE_ROOT/_cr/knowledge/literature"
if [ ! -d "$LIT_DIR" ]; then
    echo "No literature knowledge directory at $LIT_DIR"
    exit 0
fi

echo ""
echo "══ Literature Validation ══"

CARD_TYPES=("papers" "systems" "concepts" "debates" "comparisons")

for ctype in "${CARD_TYPES[@]}"; do
    CTYPE_DIR="$LIT_DIR/$ctype"
    [ ! -d "$CTYPE_DIR" ] && continue

    CARDS=$(find "$CTYPE_DIR" -name '*.md' -type f 2>/dev/null || echo "")
    [ -z "$CARDS" ] && continue

    for card_file in $CARDS; do
        CARD_ID=$(basename "$card_file" .md)

        # Required sections.
        HAS_TITLE=$(grep -cE '^# ' "$card_file" 2>/dev/null || echo 0)
        HAS_UNDERSTANDING=$(grep -cE '(understanding_level|One-Sentence Understanding|Current Understanding|Definition)' "$card_file" 2>/dev/null || echo 0)
        HAS_WHAT_SUPPORTS=$(grep -cE '(What It Supports|what_it_supports)' "$card_file" 2>/dev/null || echo 0)
        HAS_WHAT_WEAKENS=$(grep -cE '(What It Weakens|what_it_weakens)' "$card_file" 2>/dev/null || echo 0)
        HAS_HISTORY=$(grep -cE '(Understanding History|understanding_history)' "$card_file" 2>/dev/null || echo 0)

        [ "$HAS_TITLE" -ge 1 ] || fail "$ctype/$CARD_ID: missing title"
        [ "$HAS_UNDERSTANDING" -ge 1 ] || fail "$ctype/$CARD_ID: missing understanding content"
        [ "$HAS_WHAT_SUPPORTS" -ge 1 ] || warn "$ctype/$CARD_ID: missing 'What It Supports' section"
        [ "$HAS_WHAT_WEAKENS" -ge 1 ] || warn "$ctype/$CARD_ID: missing 'What It Weakens' section"
        [ "$HAS_HISTORY" -ge 1 ] || warn "$ctype/$CARD_ID: missing understanding history"

        # Understanding level check.
        UNDERSTANDING=$(grep -E '(understanding_level|Understanding level):' "$card_file" 2>/dev/null | head -1 | sed 's/.*:\s*//' | xargs || echo "")
        if [ -n "$UNDERSTANDING" ]; then
            VALID_LEVELS=("L0" "L1" "L2" "L3" "L4" "L5")
            LEVEL_VALID=false
            for vl in "${VALID_LEVELS[@]}"; do
                [ "$UNDERSTANDING" = "$vl" ] && LEVEL_VALID=true && break
            done
            if [ "$LEVEL_VALID" = true ]; then
                pass "$ctype/$CARD_ID: understanding level $UNDERSTANDING"
            else
                fail "$ctype/$CARD_ID: invalid understanding level '$UNDERSTANDING'"
            fi
        fi

        # Claim linkage check.
        HAS_CLAIM_LINK=$(grep -cE '(CLM-[0-9]{3}|supports.*claim|weakens.*claim)' "$card_file" 2>/dev/null || echo 0)
        if [ "$HAS_CLAIM_LINK" -ge 1 ]; then
            pass "$ctype/$CARD_ID: has claim linkage"
        else
            warn "$ctype/$CARD_ID: no claim linkage — card may be isolated from project claims"
        fi
    done
done

cr_exit_summary
