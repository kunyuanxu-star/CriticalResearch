#!/usr/bin/env bash
# cr-validate-phase-manifest-consistency — Hard gate: all phase definitions must be
# consistent with phase-manifest.yaml (the single source of truth).
# Checks: phase count, ordering, prompt existence, fields per phase,
#         close_round position, schema coverage, phase_order alignment.
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"
SKILL_HOME="$(cr_skill_home)"
MANIFEST="$SKILL_HOME/workflow/phase-manifest.yaml"
echo "── Phase Manifest Consistency Check ──"
[ ! -f "$MANIFEST" ] && { fail "phase-manifest.yaml not found"; cr_exit_summary; }

# ── 1. Top-level checks ───────────────────────────────────────────

MANIFEST_COUNT=$(yq -r '.phase_count' "$MANIFEST" 2>/dev/null || echo "0")
[ "$MANIFEST_COUNT" = "37" ] && pass "Manifest: 37 phases" || { fail "Manifest phase_count=$MANIFEST_COUNT"; }

CLOSE_IS_PHASE=$(yq -r '.close_round_is_phase' "$MANIFEST" 2>/dev/null || echo "false")
[ "$CLOSE_IS_PHASE" = "true" ] && pass "Manifest: close_round_is_phase" || fail "close_round_is_phase not true"

# ── 2. close_round must be last ───────────────────────────────────

LAST_PHASE=$(yq -r ".phases[$((MANIFEST_COUNT - 1))].id" "$MANIFEST" 2>/dev/null || echo "")
if [ "$LAST_PHASE" = "close_round" ]; then
    pass "close_round is the last phase (order $MANIFEST_COUNT)"
else
    fail "close_round is NOT the last phase (last=$LAST_PHASE)"
fi

# ── 3. Phase order alignment with round-state template ────────────

TEMPLATE="$SKILL_HOME/templates/round-state.yaml"
if [ -f "$TEMPLATE" ]; then
    TEMPLATE_ORDER_MATCH=true
    for i in $(seq 0 36); do
        manifest_id=$(yq -r ".phases[$i].id" "$MANIFEST" 2>/dev/null || echo "")
        template_id=$(yq -r ".phase_order[$i]" "$TEMPLATE" 2>/dev/null || echo "")
        if [ "$manifest_id" != "$template_id" ]; then
            fail "Phase order mismatch at index $i: manifest=$manifest_id template=$template_id"
            TEMPLATE_ORDER_MATCH=false
        fi
    done
    [ "$TEMPLATE_ORDER_MATCH" = true ] && pass "Manifest phase_order matches round-state template"
else
    warn "round-state.yaml template not found — skipping phase_order alignment check"
fi

# ── 4. Each phase has required fields ─────────────────────────────

MISSING_PROMPTS=0
MISSING_SCHEMA=0
for i in $(seq 0 36); do
    pid=$(yq -r ".phases[$i].id" "$MANIFEST" 2>/dev/null || echo "")
    [ -z "$pid" ] && { fail "Phase $i has no id"; continue; }

    # Prompt file exists.
    PROMPT="$SKILL_HOME/prompts/phases/${pid}.md"
    [ -f "$PROMPT" ] || { fail "Missing prompt: prompts/phases/${pid}.md"; MISSING_PROMPTS=$((MISSING_PROMPTS+1)); }

    # state_required == running.
    sr=$(yq -r ".phases[$i].state_required // \"\"" "$MANIFEST" 2>/dev/null || echo "")
    [ "$sr" != "running" ] && fail "Phase $pid state_required=$sr (must be running)"

    # Each required output has schema or explicit no_schema_reason.
    output_count=$(yq -r ".phases[$i].required_outputs | length" "$MANIFEST" 2>/dev/null || echo 0)
    for j in $(seq 0 $((output_count - 1))); do
        out_path=$(yq -r ".phases[$i].required_outputs[$j].path // \"\"" "$MANIFEST" 2>/dev/null || echo "")
        out_schema=$(yq -r ".phases[$i].required_outputs[$j].schema // \"\"" "$MANIFEST" 2>/dev/null || echo "")
        no_schema=$(yq -r ".phases[$i].required_outputs[$j].no_schema_reason // \"\"" "$MANIFEST" 2>/dev/null || echo "")
        if [ -z "$out_schema" ] || [ "$out_schema" = "null" ]; then
            if [ -z "$no_schema" ] || [ "$no_schema" = "null" ]; then
                # Directories and some files don't need schemas.
                case "$out_path" in
                    *patches/|*experiments/|*raw-sources/|*source-notes/) ;; # directories ok without schema
                    *search-queue.yaml|*human-decisions.yaml|*closure-report.yaml|*literature-delta.yaml) ;; # explicit exemptions
                    *writing/paper-draft.md) ;; # project-level draft, no schema
                    *)
                        fail "Phase $pid output '$out_path' missing schema or no_schema_reason"
                        MISSING_SCHEMA=$((MISSING_SCHEMA+1))
                        ;;
                esac
            fi
        else
            # Schema path is relative to skill home.
            schema_file="$SKILL_HOME/$out_schema"
            [ -f "$schema_file" ] || { fail "Phase $pid schema not found: $out_schema"; MISSING_SCHEMA=$((MISSING_SCHEMA+1)); }
        fi
    done
done

[ "$MISSING_PROMPTS" -gt 0 ] && fail "$MISSING_PROMPTS prompts missing"
[ "$MISSING_PROMPTS" -eq 0 ] && pass "All phases have prompts"

[ "$MISSING_SCHEMA" -gt 0 ] && fail "$MISSING_SCHEMA schema issues"
[ "$MISSING_SCHEMA" -eq 0 ] && pass "All required outputs have schemas or explicit exemptions"

# ── 5. Check validator pipeline has required hard gates ───────────

REGISTRY="$SKILL_HOME/schemas/artifact-registry.json"
if [ -f "$REGISTRY" ]; then
    HAS_PHASE_RUN_LOG=$(jq -r '.validator_pipeline.validators[] | select(.name=="cr-validate-phase-run-log") | .name' "$REGISTRY" 2>/dev/null || echo "")
    HAS_ALL_PHASES=$(jq -r '.validator_pipeline.validators[] | select(.name=="cr-validate-all-phases") | .name' "$REGISTRY" 2>/dev/null || echo "")
    HAS_TRANSACTION=$(jq -r '.validator_pipeline.validators[] | select(.name=="cr-validate-transaction-chain") | .name' "$REGISTRY" 2>/dev/null || echo "")

    [ -n "$HAS_PHASE_RUN_LOG" ] && pass "Validator pipeline includes cr-validate-phase-run-log" || fail "Missing cr-validate-phase-run-log in validator pipeline"
    [ -n "$HAS_ALL_PHASES" ] && pass "Validator pipeline includes cr-validate-all-phases" || fail "Missing cr-validate-all-phases in validator pipeline"
    [ -n "$HAS_TRANSACTION" ] && pass "Validator pipeline includes cr-validate-transaction-chain" || fail "Missing cr-validate-transaction-chain in validator pipeline"
else
    warn "artifact-registry.json not found — skipping pipeline check"
fi

cr_exit_summary
