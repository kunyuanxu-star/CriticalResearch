#!/usr/bin/env bash
# cr-validate — Validation runner for CriticalResearch v2.
# Runs engine-level validators, then workflow-specific validators for the active round.
#
# Usage:
#   cr-validate <project>                  Run all engine + workflow validators
#   cr-validate <project> --round <id>     Run validators for a specific round

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

SKILL_HOME="$(cr_skill_home)"
ENGINE_VALIDATORS="$SKILL_HOME/engine/validators"

PROJECT_ID="${1:-}"
ROUND_FLAG=""

shift 2>/dev/null || true
while [ $# -gt 0 ]; do
    case "$1" in
        --round)
            ROUND_FLAG="${2:-}"
            shift 2
            ;;
        *)
            shift
            ;;
    esac
done

if [ -z "$PROJECT_ID" ]; then
    echo "Usage: cr-validate <project> [--round <round-id>]" >&2
    exit 2
fi

WORKSPACE_ROOT="$(cr_workspace_root)"
PROJECT_DIR="$WORKSPACE_ROOT/$PROJECT_ID"

if [ ! -d "$PROJECT_DIR" ]; then
    echo "Error: project directory not found: $PROJECT_DIR" >&2
    exit 1
fi

echo "=== CriticalResearch v2 Validator Pipeline ==="
echo "Project: $PROJECT_ID"
echo ""
VALIDATION_FAILED=0

run_validator() {
    local label="$1"
    local script="$2"
    shift 2
    if [ -x "$script" ]; then
        echo "── $label ──"
        if ! "$script" "$@"; then
            VALIDATION_FAILED=1
        fi
        echo ""
    else
        echo "── $label (SKIP: not found) ──"
        VALIDATION_FAILED=1
        echo ""
    fi
}

run_validator "Project Schema"         "$ENGINE_VALIDATORS/cr-validate-project" "$PROJECT_DIR"
run_validator "Document Registry"      "$ENGINE_VALIDATORS/cr-validate-document-registry" "$PROJECT_DIR"
run_validator "Unit Registry"          "$ENGINE_VALIDATORS/cr-validate-unit-registry" "$PROJECT_DIR"

# ── Round-specific validators ──

ROUND_DIR=""
if [ -n "$ROUND_FLAG" ]; then
    ROUND_DIR="$PROJECT_DIR/rounds/$ROUND_FLAG"
else
    # Determine active round from project state or find latest round.
    if [ -f "$PROJECT_DIR/state/project-state.json" ]; then
        ACTIVE_RND=$(jq -r '.active_round // ""' "$PROJECT_DIR/state/project-state.json" 2>/dev/null || echo "")
        if [ -n "$ACTIVE_RND" ]; then
            ROUND_DIR="$PROJECT_DIR/rounds/round-$(printf "%03d" "$ACTIVE_RND")"
            if [ ! -d "$ROUND_DIR" ]; then
                # Try finding latest round directory.
                ROUND_DIR=$(find "$PROJECT_DIR/rounds" -maxdepth 1 -type d -name 'round-*' 2>/dev/null | sort -V | tail -1 || echo "")
            fi
        fi
    fi
fi

if [ -n "$ROUND_DIR" ] && [ -d "$ROUND_DIR" ]; then
    ROUND_ID=$(basename "$ROUND_DIR")
    echo "Round: $ROUND_ID"

    CONTRACT_FILE="$ROUND_DIR/contract.yaml"
    STATE_FILE="$ROUND_DIR/workflow-state.yaml"

    if [ -f "$CONTRACT_FILE" ]; then
        run_validator "Round Contract"      "$ENGINE_VALIDATORS/cr-validate-round-contract" "$CONTRACT_FILE"
        run_validator "Single Mutable Doc"  "$ENGINE_VALIDATORS/cr-validate-single-mutable-document" "$CONTRACT_FILE"
        run_validator "Target Units"        "$ENGINE_VALIDATORS/cr-validate-target-units" "$CONTRACT_FILE"
        run_validator "Readonly Context"    "$ENGINE_VALIDATORS/cr-validate-readonly-context" "$CONTRACT_FILE"
    fi

    if [ -f "$STATE_FILE" ]; then
        run_validator "Workflow State"      "$ENGINE_VALIDATORS/cr-validate-workflow-state" "$ROUND_DIR"
    fi

    # Check for patch trace, document diff, knowledge delta
    if [ -f "$ROUND_DIR/patch-trace.yaml" ]; then
        run_validator "Patch Trace"         "$ENGINE_VALIDATORS/cr-validate-patch-trace" "$ROUND_DIR"
    fi
    if [ -f "$ROUND_DIR/document-diff.yaml" ]; then
        run_validator "Document Diff"       "$ENGINE_VALIDATORS/cr-validate-document-diff" "$ROUND_DIR"
    fi
    if [ -f "$ROUND_DIR/knowledge-delta.yaml" ]; then
        run_validator "Knowledge Delta"     "$ENGINE_VALIDATORS/cr-validate-knowledge-delta" "$ROUND_DIR"
    fi

    # ── Workflow-specific validators ──
    if [ -f "$CONTRACT_FILE" ]; then
        WORKFLOW_ID=$(grep -E '^\s+id:' "$CONTRACT_FILE" 2>/dev/null | head -1 | sed 's/.*id: *//' | tr -d '"' || echo "")
        if [ -n "$WORKFLOW_ID" ] && [ -f "$SKILL_HOME/workflows/$WORKFLOW_ID/workflow.yaml" ]; then
            echo "── Workflow: $WORKFLOW_ID ──"
            # Run workflow-specific validators listed in workflow.yaml
            WF_VALIDATORS=$(yq -r '.validators[] // ""' "$SKILL_HOME/workflows/$WORKFLOW_ID/workflow.yaml" 2>/dev/null || echo "")
            for v in $WF_VALIDATORS; do
                # Check workflow validators dir first, then engine validators
                WF_VAL="$SKILL_HOME/workflows/$WORKFLOW_ID/validators/$v"
                if [ -x "$WF_VAL" ]; then
                    run_validator "$v" "$WF_VAL" "$CONTRACT_FILE"
                elif [ -x "$ENGINE_VALIDATORS/$v" ]; then
                    run_validator "$v" "$ENGINE_VALIDATORS/$v" "$CONTRACT_FILE"
                else
                    echo "  [SKIP] Validator not found: $v"
                fi
            done
        fi
    fi

    # Round closure check (only if all stages claim complete)
    if [ -f "$STATE_FILE" ]; then
        PENDING=$(grep -c 'status: blocked\|status: open\|status: running' "$STATE_FILE" 2>/dev/null || echo "0")
        if [ "$PENDING" = "0" ]; then
            run_validator "Round Closure" "$ENGINE_VALIDATORS/cr-validate-round-closure" "$ROUND_DIR"
        fi
    fi
fi

if [ "$VALIDATION_FAILED" -ne 0 ]; then
    echo "=== Validation failed ==="
    exit 1
fi
echo "=== Validation complete ==="
exit 0