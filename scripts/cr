#!/usr/bin/env bash
# cr — CriticalResearch CLI dispatcher v2.
# Workflow-specific project engine — routes to sub-command scripts.
#
# Usage: cr <command> [args...]
#
# Commands:
#   project <sub>            Project lifecycle (init, status, list)
#   document <sub>           Document management (add, list, status)
#   unit <sub>               Unit management (add, list, status)
#   round <sub>              Round lifecycle (start, status, close)
#   stage <sub>              Stage state machine (status, advance, validate)
#   validate <project>       Run project invariant checks
#   scope <subcommand>       Session scope management (open, close, check, status, audit)
#   workspace init            Initialize Research workspace with _cr/ structure
#   workspace scan            List all projects in workspace
#   status                    Show workspace and active project status

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

COMMAND="${1:-}"
shift 2>/dev/null || true

usage() {
    echo "Usage: cr <command> [args...]"
    echo ""
    echo "Commands:"
    echo "  project init <id> --domain <domain>   Create a new research project"
    echo "  project status <project>              Show project status"
    echo "  project list                          List all projects"
    echo ""
    echo "  document add <project> <id> --type <type> --path <path>"
    echo "  document list <project>               List documents in project"
    echo "  document status <project> <doc-id>    Show document status"
    echo ""
    echo "  unit add <project> <doc-id> <unit-id> --title <title>"
    echo "  unit list <project> <doc-id>          List units in document"
    echo "  unit status <project> <doc-id> <unit-id>"
    echo ""
    echo "  round start <project> --workflow <id> --doc <id> [--unit <id>] [--mode <mode>] --objective <text>"
    echo "  round status <project>                Show round status"
    echo "  round close <project>                 Validate and close active round"
    echo ""
    echo "  stage status <project>                Show current stage and required outputs"
    echo "  stage advance <project>               Validate and advance to next stage"
    echo "  stage validate <project>              Validate current stage without advancing"
    echo ""
    echo "  validate <project>                    Run all engine and workflow validators"
    echo "  validate <project> --round <round-id> Run validators for specific round"
    echo ""
    echo "  scope <subcommand>                    Session scope management"
    echo "  workspace init                        Initialize Research workspace"
    echo "  workspace scan                        List projects in workspace"
    echo "  status                                Show workspace and project status"
    echo ""
    echo "Run 'cr' from within a Research workspace directory (containing _cr/)."
    exit 2
}

# Determine workspace root.
WORKSPACE_ROOT="$(cr_workspace_root)"

case "$COMMAND" in
    project)
        exec "$SCRIPT_DIR/cr-project" "$@"
        ;;
    document)
        exec "$SCRIPT_DIR/cr-document" "$@"
        ;;
    unit)
        exec "$SCRIPT_DIR/cr-unit" "$@"
        ;;
    round)
        exec "$SCRIPT_DIR/cr-round" "$@"
        ;;
    stage)
        exec "$SCRIPT_DIR/cr-stage" "$@"
        ;;
    validate)
        exec "$SCRIPT_DIR/cr-validate" "$@"
        ;;
    scope)
        # Delegate to existing cr-scope script.
        exec "$SCRIPT_DIR/cr-scope" "$@"
        ;;
    workspace)
        SUB="${1:-}"
        case "$SUB" in
            init)
                mkdir -p "$WORKSPACE_ROOT/_cr"/{sessions,workspace}
                if [ ! -f "$WORKSPACE_ROOT/_cr/workspace.yaml" ]; then
                    cat > "$WORKSPACE_ROOT/_cr/workspace.yaml" << YAML
schema_version: "2.0.0"
created_at: $(date -u +"%Y-%m-%dT%H:%M:%SZ")
projects: []
YAML
                fi
                echo "Workspace initialized at $WORKSPACE_ROOT"
                ;;
            scan)
                echo "Projects in workspace:"
                find "$WORKSPACE_ROOT" -maxdepth 1 -type d -not -name '_cr' -not -name '.' -not -path "$WORKSPACE_ROOT" | while read -r d; do
                    if [ -f "$d/project.yaml" ]; then
                        echo "  $(basename "$d")"
                    fi
                done
                ;;
            *)
                echo "Usage: cr workspace <init|scan>" >&2
                exit 2
                ;;
        esac
        ;;
    status)
        echo "Workspace: $WORKSPACE_ROOT"
        if [ -f "$WORKSPACE_ROOT/_cr/active-project" ]; then
            ACTIVE=$(cat "$WORKSPACE_ROOT/_cr/active-project")
            echo "Active project: $ACTIVE"
            PROJECT_DIR="$WORKSPACE_ROOT/$ACTIVE"
            if [ -d "$PROJECT_DIR" ] && [ -f "$PROJECT_DIR/project.yaml" ]; then
                echo "  Status: $(grep -E '^status:' "$PROJECT_DIR/project.yaml" 2>/dev/null || echo 'active')"
                echo "  Domain: $(grep -E '^domain:' "$PROJECT_DIR/project.yaml" 2>/dev/null | sed 's/domain: *//')"
                # Show active round if any
                if [ -f "$PROJECT_DIR/state/project-state.json" ]; then
                    echo "  Active round: $(jq -r '.active_round // "none"' "$PROJECT_DIR/state/project-state.json")"
                fi
            fi
        else
            echo "No active project."
        fi
        ;;
    # ── Legacy compatibility (redirect with deprecation warning) ──
    start)
        echo "[DEPRECATED] 'cr start' is removed. Use 'cr project init <id> --domain <domain>'." >&2
        exit 2
        ;;
    continue)
        echo "[DEPRECATED] 'cr continue' is removed. Use 'cr round status' to see active round." >&2
        exit 2
        ;;
    close-round)
        echo "[DEPRECATED] 'cr close-round' is removed. Use 'cr round close <project>'." >&2
        exit 2
        ;;
    step)
        echo "[DEPRECATED] 'cr step' is removed. Use 'cr stage <status|advance|validate>'." >&2
        exit 2
        ;;
    migrate-to-paper-mode)
        echo "[DEPRECATED] 'cr migrate-to-paper-mode' is removed. Workflows are now first-class." >&2
        exit 2
        ;;
    run-round)
        echo "[DEPRECATED] 'cr run-round' is removed. Use 'cr stage advance' in a loop." >&2
        exit 2
        ;;
    research)
        echo "[DEPRECATED] 'cr research' is removed. Research is handled by workflow stages." >&2
        exit 2
        ;;
    apply-knowledge)
        echo "[DEPRECATED] 'cr apply-knowledge' is removed. Knowledge deltas are applied during closure." >&2
        exit 2
        ;;
    ask-next)
        echo "[DEPRECATED] 'cr ask-next' is removed. Human decisions are surfaced during stage execution." >&2
        exit 2
        ;;
    complete-phase)
        echo "[DEPRECATED] 'cr complete-phase' is removed. Use 'cr stage advance'." >&2
        exit 2
        ;;
    promote-knowledge)
        echo "[DEPRECATED] 'cr promote-knowledge' is removed. Knowledge promotion is handled by workflow validators." >&2
        exit 2
        ;;
    *)
        usage
        ;;
esac
