#!/usr/bin/env bash
# cr-validate-phase — Validate that a specific phase's required outputs exist and pass schema checks.
# Usage: cr-validate-phase <project_dir> <round_dir> <phase_name>
# Returns 0 if phase is complete, 2 if requirements not met.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

PROJECT_DIR="${1:-}"
ROUND_DIR="${2:-}"
PHASE="${3:-}"

if [ -z "$PROJECT_DIR" ] || [ -z "$ROUND_DIR" ] || [ -z "$PHASE" ]; then
    echo "Usage: cr-validate-phase <project_dir> <round_dir> <phase>" >&2
    exit 2
fi

STATE_FILE="$ROUND_DIR/state.yaml"
if [ ! -f "$STATE_FILE" ]; then
    fail "state.yaml not found in $ROUND_DIR"
    cr_exit_summary
fi

# Check phase exists in state.yaml.
PHASE_STATUS=$(yq -r ".phases.$PHASE.status // \"unknown\"" "$STATE_FILE" 2>/dev/null || echo "unknown")
if [ "$PHASE_STATUS" = "unknown" ]; then
    fail "Phase '$PHASE' not found in state.yaml"
    cr_exit_summary
fi

# Check depends_on phases are complete.
echo "Phase: $PHASE (status: $PHASE_STATUS)"
DEPS=$(yq -r ".phases.$PHASE.depends_on // [] | .[]" "$STATE_FILE" 2>/dev/null || echo "")
for dep in $DEPS; do
    [ -z "$dep" ] && continue
    DEP_STATUS=$(yq -r ".phases.$dep.status // \"unknown\"" "$STATE_FILE" 2>/dev/null || echo "unknown")
    if [ "$DEP_STATUS" != "complete" ]; then
        fail "Dependency '$dep' is not complete (status: $DEP_STATUS)"
    else
        pass "Dependency '$dep' is complete"
    fi
done

# Check required outputs exist.
REQ=$(yq -r ".phases.$PHASE.required_outputs // [] | .[]" "$STATE_FILE" 2>/dev/null || echo "")
ALL_PRESENT=true
for output in $REQ; do
    [ -z "$output" ] && continue
    case "$output" in
        *.yaml|*.md|*.json)
            if [ -f "$ROUND_DIR/$output" ]; then
                pass "Output '$output' exists"
            elif [ -f "$PROJECT_DIR/$output" ]; then
                pass "Output '$output' exists (project-level)"
            else
                fail "Output '$output' is missing"
                ALL_PRESENT=false
            fi
            ;;
        raw-sources)
            if [ -d "$ROUND_DIR/raw-sources" ] && [ -n "$(ls -A "$ROUND_DIR/raw-sources" 2>/dev/null)" ]; then
                pass "Output 'raw-sources/' exists and is non-empty"
            else
                fail "Output 'raw-sources/' is missing or empty"
                ALL_PRESENT=false
            fi
            ;;
        patches)
            if [ -d "$ROUND_DIR/patches" ] && [ -n "$(ls -A "$ROUND_DIR/patches" 2>/dev/null)" ]; then
                pass "Output 'patches/' exists and is non-empty"
            else
                fail "Output 'patches/' is missing or empty"
                ALL_PRESENT=false
            fi
            ;;
        experiments)
            if [ -d "$ROUND_DIR/experiments" ] && [ -n "$(ls -A "$ROUND_DIR/experiments" 2>/dev/null)" ]; then
                pass "Output 'experiments/' exists and is non-empty"
            else
                fail "Output 'experiments/' is missing or empty"
                ALL_PRESENT=false
            fi
            ;;
        *)
            warn "Unknown output type '$output' — skipping"
            ;;
    esac
done

# Phase-specific validators.
case "$PHASE" in
    run_retrieval)
        # Only require search-log.yaml and raw-sources/ at this phase.
        if [ -f "$ROUND_DIR/search-log.yaml" ]; then
            Q_COUNT=$(yq -r '.searches | length // 0' "$ROUND_DIR/search-log.yaml" 2>/dev/null || echo "0")
            if [ "${Q_COUNT:-0}" -ge 5 ]; then
                pass "search-log.yaml: $Q_COUNT queries"
            else
                fail "search-log.yaml: $Q_COUNT queries (min 5 required)"
                ALL_PRESENT=false
            fi
        fi
        if [ -d "$ROUND_DIR/raw-sources" ]; then
            SRC_COUNT=$(find "$ROUND_DIR/raw-sources" -type f 2>/dev/null | wc -l | tr -d ' ')
            if [ "${SRC_COUNT:-0}" -ge 5 ]; then
                pass "raw-sources/: $SRC_COUNT files"
            else
                fail "raw-sources/: $SRC_COUNT files (min 5 required)"
                ALL_PRESENT=false
            fi
        fi
        ;;
    ingest_sources)
        if [ -x "$SCRIPT_DIR/cr-validate-source-integrity" ]; then
            "$SCRIPT_DIR/cr-validate-source-integrity" "$ROUND_DIR" || ALL_PRESENT=false
        fi
        ;;
    normalize_evidence)
        if [ -x "$SCRIPT_DIR/cr-validate-evidence-claim-links" ]; then
            "$SCRIPT_DIR/cr-validate-evidence-claim-links" "$ROUND_DIR" "$PROJECT_DIR" || ALL_PRESENT=false
        fi
        ;;
    adversarial_critique)
        if [ ! -f "$ROUND_DIR/critique.yaml" ] && [ ! -f "$ROUND_DIR/critique.md" ]; then
            fail "Critique output required for adversarial_critique phase"
            ALL_PRESENT=false
        fi
        ;;
    generate_dispositions)
        if [ -f "$ROUND_DIR/dispositions.yaml" ]; then
            DISP_COUNT=$(yq -r '.dispositions | length // 0' "$ROUND_DIR/dispositions.yaml" 2>/dev/null || echo "0")
            if [ "$DISP_COUNT" -gt 0 ]; then
                pass "Dispositions: $DISP_COUNT record(s)"
            else
                fail "dispositions.yaml is empty"
                ALL_PRESENT=false
            fi
        fi
        ;;
    generate_paper_patches)
        if [ -d "$ROUND_DIR/patches" ]; then
            PATCH_COUNT=$(find "$ROUND_DIR/patches" -name 'PP-*.yaml' -type f 2>/dev/null | wc -l | tr -d ' ')
            if [ "${PATCH_COUNT:-0}" -gt 0 ]; then
                pass "Paper patches: $PATCH_COUNT file(s)"
            else
                fail "No PP-*.yaml files in patches/"
                ALL_PRESENT=false
            fi
        fi
        ;;
    apply_patches_to_draft)
        if [ -f "$ROUND_DIR/writing-diff.yaml" ]; then
            DIFF_COUNT=$(yq -r '.applied_patches | length // 0' "$ROUND_DIR/writing-diff.yaml" 2>/dev/null || echo "0")
            if [ "${DIFF_COUNT:-0}" -gt 0 ]; then
                pass "Applied patches recorded in writing-diff.yaml: $DIFF_COUNT"
            else
                warn "writing-diff.yaml has no applied_patches entries"
            fi
        elif [ -f "$ROUND_DIR/writing-diff.md" ]; then
            if grep -qE '(Added|Deleted|Weakened|Reframed)' "$ROUND_DIR/writing-diff.md" 2>/dev/null; then
                pass "writing-diff.md has content"
            else
                fail "writing-diff.md is empty"
                ALL_PRESENT=false
            fi
        else
            fail "No writing-diff found"
            ALL_PRESENT=false
        fi
        ;;
esac

if [ "$ALL_PRESENT" = false ]; then
    cr_exit_summary
fi

pass "Phase '$PHASE' validation passed"
cr_exit_summary
