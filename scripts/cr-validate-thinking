#!/usr/bin/env bash
# cr-validate-thinking — Validate thinking card structure against schema.
# Usage: cr-validate-thinking <card_path> [card_path...]
# If no args, validates all cards under _cr/knowledge/thinking/cards/.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

echo "── Thinking Card Validation ──"

SCHEMA_FILE=$(cr_schema_path "thinking_card.schema.json")
if [ -z "$SCHEMA_FILE" ] || [ ! -f "$SCHEMA_FILE" ]; then
    warn "thinking_card.schema.json not found — skipping"
    cr_exit_summary
fi

# If paths provided, validate those. Otherwise find all cards.
CARDS=()
if [ $# -gt 0 ]; then
    CARDS=("$@")
else
    WORKSPACE_ROOT="$(cr_workspace_root)"
    CARDS_DIR="$WORKSPACE_ROOT/_cr/knowledge/thinking/cards"
    if [ -d "$CARDS_DIR" ]; then
        while IFS= read -r -d '' card; do
            CARDS+=("$card")
        done < <(find "$CARDS_DIR" -name '*.md' -type f -print0 2>/dev/null || true)
    fi
fi

if [ ${#CARDS[@]} -eq 0 ]; then
    warn "No thinking cards found to validate"
    cr_exit_summary
fi

ALL_PASSED=true
for card in "${CARDS[@]}"; do
    CARD_NAME=$(basename "$card")
    # Extract YAML frontmatter from Markdown card.
    if grep -q '^---$' "$card" 2>/dev/null; then
        # Has frontmatter — validate it.
        FRONTMATTER=$(sed -n '/^---$/,/^---$/p' "$card" | sed '1d;$d' 2>/dev/null || echo "")
        if [ -n "$FRONTMATTER" ]; then
            # Convert to JSON for schema validation.
            CARD_JSON=$(echo "$FRONTMATTER" | yq -o json '.' 2>/dev/null || echo "")
            if [ -n "$CARD_JSON" ] && [ "$CARD_JSON" != "null" ]; then
                if cr_validate_json_schema "$CARD_JSON" "$(cat "$SCHEMA_FILE")" 2>/dev/null; then
                    pass "$CARD_NAME: schema valid"
                else
                    fail "$CARD_NAME: schema validation failed"
                    ALL_PASSED=false
                fi
            else
                warn "$CARD_NAME: could not parse frontmatter"
            fi
        else
            warn "$CARD_NAME: no frontmatter found"
        fi
    else
        warn "$CARD_NAME: no YAML frontmatter delimiters"
    fi
done

if [ "$ALL_PASSED" = false ]; then
    cr_exit_summary
fi

pass "Thinking card validation passed"
cr_exit_summary
