#!/usr/bin/env bash
# cr-stop-gate — Master stop scheduler v2. Decides whether a session may stop.
# Uses workflow-state.yaml and contract.yaml instead of 8-stage state.yaml.
#
# Checks:
#   1. Active round exists (round dir with workflow-state.yaml)
#   2. Current stage completeness
#   3. Round closure status
#   4. Validator pipeline (if round claims closed)
#
# Output (stdout): JSON
#   {"decision":"approve"} or
#   {"decision":"block","reason":"...","systemMessage":"..."}
#
# Exit codes:
#   0 — allow stop
#   1 — block stop

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

PROJECT_DIR="${1:-}"
FORCE_STOP=false
[ "${2:-}" = "--force" ] && FORCE_STOP=true

if [ -z "$PROJECT_DIR" ]; then
    echo '{"decision":"approve"}'
    exit 0
fi

# ── No active project → allow stop ──────────────────────────────

if [ ! -d "$PROJECT_DIR" ]; then
    echo '{"decision":"approve"}'
    exit 0
fi

# ── No project.yaml → allow stop ────────────────────────────────

if [ ! -f "$PROJECT_DIR/project.yaml" ]; then
    echo '{"decision":"approve"}'
    exit 0
fi

# ── Find active round ──────────────────────────────────────────

ROUND_DIR=""
# Try state/project-state.json first (backward compat)
if [ -f "$PROJECT_DIR/state/project-state.json" ]; then
    ACTIVE_RND=$(jq -r '.active_round // empty' "$PROJECT_DIR/state/project-state.json" 2>/dev/null || echo "")
    if [ -n "$ACTIVE_RND" ] && [ "$ACTIVE_RND" != "null" ]; then
        ROUND_NUM=$(printf "%03d" "$ACTIVE_RND")
        ROUND_DIR="$PROJECT_DIR/rounds/round-$ROUND_NUM"
    fi
fi

# Fallback: find latest round directory
if [ -z "$ROUND_DIR" ] || [ ! -d "$ROUND_DIR" ]; then
    ROUND_DIR=$(find "$PROJECT_DIR/rounds" -maxdepth 1 -type d -name 'round-*' 2>/dev/null | sort -V | tail -1 || echo "")
fi

if [ -z "$ROUND_DIR" ] || [ ! -d "$ROUND_DIR" ]; then
    echo '{"decision":"approve"}'
    exit 0
fi

ROUND_ID=$(basename "$ROUND_DIR")

# ── Check workflow-state.yaml ──────────────────────────────────

STATE_FILE="$ROUND_DIR/workflow-state.yaml"
if [ ! -f "$STATE_FILE" ]; then
    echo '{"decision":"approve","reason":"No workflow-state.yaml in round — may be an old-format round"}'
    exit 0
fi

CURRENT_STAGE=$(grep -E '^current_stage:' "$STATE_FILE" 2>/dev/null | sed 's/current_stage: *//' | tr -d '"' || echo "")
WF_STATUS=$(grep -E '^status:' "$STATE_FILE" 2>/dev/null | sed 's/status: *//' | tr -d '"' || echo "")

# ── Round already closed → allow stop ───────────────────────────

if [ "$WF_STATUS" = "closed" ]; then
    echo '{"decision":"approve"}'
    exit 0
fi

# ── Force stop ──────────────────────────────────────────────────

if [ "$FORCE_STOP" = true ]; then
    NOW=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    COMPLETED_COUNT=$(grep -c 'status: complete' "$STATE_FILE" 2>/dev/null || echo "0")
    INTERRUPTION_LOG="$ROUND_DIR/interruption-log.yaml"
    cat > "$INTERRUPTION_LOG" << EOF
schema_version: "2.0.0"
interrupted_at: $NOW
current_stage: $CURRENT_STAGE
completed_stages: $COMPLETED_COUNT
reason: user_forced_stop
round_status: incomplete
active_round_preserved: true
EOF
    PROJECT_NAME=$(basename "$PROJECT_DIR")
    cat << EOF
{"decision":"approve","reason":"User explicitly requested stop. Round $ROUND_ID interrupted (not completed). Interruption logged.","systemMessage":"Stop approved via force flag. Round $ROUND_ID is INTERRUPTED (not complete).\n\nTo resume: cr stage status $PROJECT_NAME\nTo close: cr round close $PROJECT_NAME"}
EOF
    exit 0
fi

# ── Current stage incomplete → block ────────────────────────────

# Extract stage status for current_stage
STAGE_STATUS=$(grep -A1 "  $CURRENT_STAGE:" "$STATE_FILE" 2>/dev/null | grep 'status:' | sed 's/.*status: *//' | tr -d '"' || echo "")

if [ -n "$CURRENT_STAGE" ] && [ "$STAGE_STATUS" != "complete" ] && [ "$CURRENT_STAGE" != "closure" ]; then
    PROJECT_NAME=$(basename "$PROJECT_DIR")
    REASON="Stage '$CURRENT_STAGE' is incomplete."
    cat << EOF
{"decision":"block","reason":"$REASON","systemMessage":"Stage '$CURRENT_STAGE' is incomplete. Complete required outputs and run: cr stage advance $PROJECT_NAME"}
EOF
    exit 1
fi

# ── Check if all stages are complete ────────────────────────────

STAGE_TOTAL=$(grep -cE '^\s+[a-z_]+:$' "$STATE_FILE" 2>/dev/null | head -1 || echo "0")
STAGE_COMPLETE=$(grep -c 'status: complete' "$STATE_FILE" 2>/dev/null || echo "0")
# Don't count the root status line
STAGE_TOTAL=$(grep -E '^  [a-z]' "$STATE_FILE" 2>/dev/null | grep -c ':$' || echo "0")

if [ "$STAGE_COMPLETE" -lt "$STAGE_TOTAL" ]; then
    REMAINING=$((STAGE_TOTAL - STAGE_COMPLETE))
    PROJECT_NAME=$(basename "$PROJECT_DIR")
    REASON="Round $ROUND_ID is not complete. ($STAGE_COMPLETE/$STAGE_TOTAL stages complete, $REMAINING remaining. Current stage: $CURRENT_STAGE)"
    cat << EOF
{"decision":"block","reason":"$REASON","systemMessage":"$REASON\n\nContinue executing remaining stages. All stages must complete before stopping.\n\nRun: cr stage status $PROJECT_NAME\nRun: cr stage advance $PROJECT_NAME to progress."}
EOF
    exit 1
fi

# ── All stages complete but round not closed → block ────────────

if [ "$STAGE_COMPLETE" -ge "$STAGE_TOTAL" ] && [ "$WF_STATUS" != "closed" ]; then
    PROJECT_NAME=$(basename "$PROJECT_DIR")
    REASON="All stages complete but round has not been closed. Run 'cr round close $PROJECT_NAME' first."
    echo "{\"decision\":\"block\",\"reason\":\"$REASON\",\"systemMessage\":\"$REASON\"}"
    exit 1
fi

# ── Default block ───────────────────────────────────────────────

REASON="Round $ROUND_ID is incomplete (status: ${WF_STATUS:-unknown}). Complete required outputs or explicitly request stop to override."
echo "{\"decision\":\"block\",\"reason\":\"$REASON\",\"systemMessage\":\"$REASON\"}"
exit 1
