#!/usr/bin/env bash
# cr-stop-gate — Master stop scheduler. Decides whether a session may stop.
# Extracted from cr-validate-stop with manifest-driven checks.
#
# Checks:
#   1. Active round exists
#   2. Manifest snapshot exists
#   3. Current stage completeness
#   4. Round closure status
#   5. Validator pipeline (if round claims complete)
#
# Output (stdout): JSON
#   {"decision":"approve"} or
#   {"decision":"block","reason":"...","systemMessage":"..."}
#
# Exit codes:
#   0 — allow stop
#   1 — block stop

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

PROJECT_DIR="${1:-}"
FORCE_STOP=false
[ "${2:-}" = "--force" ] && FORCE_STOP=true

if [ -z "$PROJECT_DIR" ]; then
    echo '{"decision":"approve"}'
    exit 0
fi

# ── No active project → allow stop ──────────────────────────────

if [ ! -d "$PROJECT_DIR" ]; then
    echo '{"decision":"approve"}'
    exit 0
fi

# ── No project state → allow stop ───────────────────────────────

STATE_FILE="$PROJECT_DIR/state/project-state.json"
if [ ! -f "$STATE_FILE" ]; then
    echo '{"decision":"approve"}'
    exit 0
fi

# ── No active round → allow stop ────────────────────────────────

ACTIVE_ROUND=$(jq -r '.active_round // empty' "$STATE_FILE" 2>/dev/null || echo "")
if [ -z "$ACTIVE_ROUND" ] || [ "$ACTIVE_ROUND" = "null" ]; then
    echo '{"decision":"approve"}'
    exit 0
fi

ROUND_NUM=$(printf "%03d" "$ACTIVE_ROUND")
ROUND_DIR="$PROJECT_DIR/rounds/round-$ROUND_NUM"

# ── No round directory → allow stop ─────────────────────────────

if [ ! -d "$ROUND_DIR" ]; then
    echo '{"decision":"approve"}'
    exit 0
fi

# ── Manifest snapshot check ─────────────────────────────────────

MANIFEST="$ROUND_DIR/stage-manifest.snapshot.yaml"
if [ ! -f "$MANIFEST" ]; then
    echo '{"decision":"block","reason":"stage-manifest.snapshot.yaml missing — round was not started via cr-start-paper-round","systemMessage":"Round is missing its manifest snapshot. This round may have been created with an old setup script."}'
    exit 1
fi

# ── State.yaml check ────────────────────────────────────────────

STATE_FILE="$ROUND_DIR/state.yaml"
if [ ! -f "$STATE_FILE" ]; then
    echo '{"decision":"block","reason":"state.yaml missing","systemMessage":"Round state file is missing. Cannot determine stage completion."}'
    exit 1
fi

CURRENT_STAGE=$(yq -r '.current_stage // ""' "$STATE_FILE" 2>/dev/null || echo "")
STAGE_STATUS=$(yq -r ".stages.\"$CURRENT_STAGE\".status // \"\"" "$STATE_FILE" 2>/dev/null || echo "")

# ── Force stop (user explicitly requested) ──────────────────────
# Force stop takes priority over ALL other checks. It only interrupts
# the session. It does NOT complete the round, does NOT clear active_round,
# and does NOT modify state.yaml or round.yaml.
# It writes an interruption-log.yaml for audit and recovery.

if [ "$FORCE_STOP" = true ]; then
    NOW=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    # Count completed stages.
    COMPLETED_COUNT=$(yq -r '[.stages[] | select(.status=="complete")] | length' "$STATE_FILE" 2>/dev/null || echo "0")

    # Write interruption log.
    INTERRUPTION_LOG="$ROUND_DIR/interruption-log.yaml"
    cat > "$INTERRUPTION_LOG" << EOF
schema_version: "1.0.0"
interrupted_at: $NOW
current_stage: $CURRENT_STAGE
completed_stages: $COMPLETED_COUNT
reason: user_forced_stop
round_status: incomplete
active_round_preserved: true
EOF

    cat << EOF
{"decision":"approve","reason":"User explicitly requested stop. Active round $ROUND_NUM interrupted (not completed). Interruption logged at $INTERRUPTION_LOG. Session may be resumed.","systemMessage":"Stop approved via force flag. Round $ROUND_NUM is INTERRUPTED (not complete).\n\nTo resume: cr step $(basename "$PROJECT_DIR") status\nTo close: complete all stages, generate reviews, then cr close-round $(basename "$PROJECT_DIR")"}
EOF
    exit 0
fi

# ── Current stage incomplete → block ────────────────────────────

if [ -n "$CURRENT_STAGE" ] && [ "$STAGE_STATUS" != "complete" ] && [ "$CURRENT_STAGE" != "s8_round_closure" ]; then
    STAGE_VALIDATOR="$SCRIPT_DIR/cr-validate-stage"
    if [ -x "$STAGE_VALIDATOR" ]; then
        if ! "$STAGE_VALIDATOR" "$PROJECT_DIR" "$ROUND_DIR" "$CURRENT_STAGE" >/tmp/cr-stop-stage.out 2>&1; then
            REASON=$(head -c 3000 /tmp/cr-stop-stage.out 2>/dev/null || echo "Stage $CURRENT_STAGE validation failed")
            PROJECT_NAME=$(basename "$PROJECT_DIR")
            cat << EOF
{"decision":"block","reason":"$REASON","systemMessage":"Stage '$CURRENT_STAGE' is incomplete. Complete required outputs and run: cr step $PROJECT_NAME advance\n\n$REASON"}
EOF
            exit 1
        fi
    fi
fi

# ── Stage-run-log proof check ───────────────────────────────────
# If round has completed stages, the run-log must prove them.

RUN_LOG_VALIDATOR="$SCRIPT_DIR/cr-validate-stage-run-log"
if [ -x "$RUN_LOG_VALIDATOR" ]; then
    if ! "$RUN_LOG_VALIDATOR" "$PROJECT_DIR" "$ROUND_DIR" >/tmp/cr-runlog-stop.out 2>&1; then
        REASON=$(head -c 2000 /tmp/cr-runlog-stop.out 2>/dev/null || echo "Stage run log validation failed")
        PROJECT_NAME=$(basename "$PROJECT_DIR")
        cat << EOF
{"decision":"block","reason":"$REASON","systemMessage":"Stage run log proof is incomplete or inconsistent.\n\n$REASON\n\nRun: cr step $PROJECT_NAME status\nThen: cr step $PROJECT_NAME advance"}
EOF
        exit 1
    fi
fi

# ── Check round status ──────────────────────────────────────────

ROUND_STATUS=""
if [ -f "$ROUND_DIR/round.yaml" ]; then
    ROUND_STATUS=$(grep -E '^status:' "$ROUND_DIR/round.yaml" 2>/dev/null | sed 's/^status:\s*//' | xargs || echo "")
fi

# Round claims complete → run validator pipeline for confirmation.
if [ "$ROUND_STATUS" = "complete" ]; then
    PIPELINE="$SCRIPT_DIR/cr-run-validator-pipeline"
    if [ -x "$PIPELINE" ]; then
        if "$PIPELINE" "$PROJECT_DIR" "$ROUND_DIR" 2>/dev/null; then
            echo '{"decision":"approve"}'
            exit 0
        else
            REASON="Round marked complete but validator pipeline failed. Run 'cr validate' to see failures."
            echo "{\"decision\":\"block\",\"reason\":\"$REASON\",\"systemMessage\":\"$REASON\"}"
            exit 1
        fi
    fi
    echo '{"decision":"approve"}'
    exit 0
fi

# ── Block: round incomplete ─────────────────────────────────────

FULL_ROUND=$(yq -r '.execution_policy.full_round_required' "$STATE_FILE" 2>/dev/null || echo "false")
[ -z "$FULL_ROUND" ] || [ "$FULL_ROUND" = "null" ] && FULL_ROUND="false"
ALLOW_PARTIAL=$(yq -r '.execution_policy.allow_partial_stop' "$STATE_FILE" 2>/dev/null || echo "true")
[ -z "$ALLOW_PARTIAL" ] || [ "$ALLOW_PARTIAL" = "null" ] && ALLOW_PARTIAL="true"

if [ "$FULL_ROUND" = "true" ] && [ "$ALLOW_PARTIAL" != "true" ]; then
    STAGE_TOTAL=$(yq -r '.stage_order | length' "$STATE_FILE" 2>/dev/null || echo "0")
    STAGE_COMPLETE=$(yq -r '[.stages[] | select(.status=="complete")] | length' "$STATE_FILE" 2>/dev/null || echo "0")

    if [ "$STAGE_COMPLETE" -lt "$STAGE_TOTAL" ]; then
        REMAINING=$((STAGE_TOTAL - STAGE_COMPLETE))
        PROJECT_NAME=$(basename "$PROJECT_DIR")
        REASON="Full CriticalResearch round is not closed. ($STAGE_COMPLETE/$STAGE_TOTAL stages complete, $REMAINING remaining. Current stage: $CURRENT_STAGE)"
        cat << EOF
{"decision":"block","reason":"$REASON","systemMessage":"$REASON\n\nContinue executing remaining stages. The round must complete all $STAGE_TOTAL stages before stopping.\n\nRun 'cr step $PROJECT_NAME status' to see current progress.\nSet execution_policy.allow_partial_stop=true only for human decisions or unrecoverable errors."}
EOF
        exit 1
    fi

    # All stages complete but round not closed — must run s8_round_closure.
    ROUND_STATUS=$(yq -r '.status // ""' "$STATE_FILE" 2>/dev/null || echo "")
    if [ "$ROUND_STATUS" != "complete" ] && [ "$ROUND_STATUS" != "closed" ]; then
        PROJECT_NAME=$(basename "$PROJECT_DIR")
        REASON="All $STAGE_TOTAL stages complete but round has not been closed. Run 'cr close-round $PROJECT_NAME' first."
        echo "{\"decision\":\"block\",\"reason\":\"$REASON\",\"systemMessage\":\"$REASON\"}"
        exit 1
    fi
fi

# ── Default block ───────────────────────────────────────────────

REASON="Round $ROUND_NUM is incomplete (status: ${ROUND_STATUS:-unknown}). Complete required outputs or explicitly request stop to override."
echo "{\"decision\":\"block\",\"reason\":\"$REASON\",\"systemMessage\":\"$REASON\"}"
exit 1
