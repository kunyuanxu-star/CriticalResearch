#!/usr/bin/env bash
# cr-validate-paper-patches — Paper patch and critique disposition validation.
# Checks that every medium+ critique has a disposition record, paper patches
# follow valid lifecycle transitions, IDs are unique, and Knowledge Implication
# fields are present.
#
# Usage: cr-validate-paper-patches <round_dir>
#
# Exit codes:
#   0 — all checks passed
#   2 — one or more failures

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

ROUND_DIR="${1:-}"

if [ -z "$ROUND_DIR" ]; then
    echo "Usage: cr-validate-paper-patches <round_dir>" >&2
    exit 2
fi

if [ ! -d "$ROUND_DIR" ]; then
    fail "Round directory not found: $ROUND_DIR"
    cr_exit_summary
fi

ROUND_NAME="$(basename "$ROUND_DIR")"
echo ""
echo "══ Paper Patch Validation: $ROUND_NAME ══"

# ── Check if this is a paper mode round ────────────────────────────

ROUND_YAML="$ROUND_DIR/round.yaml"
WORKFLOW_MODE=""
if [ -f "$ROUND_YAML" ]; then
    WORKFLOW_MODE=$(grep -E '^workflow_mode:' "$ROUND_YAML" 2>/dev/null | sed 's/^workflow_mode:\s*//' | xargs || echo "")
fi

if [ "$WORKFLOW_MODE" != "paper" ]; then
    echo "  Round is not in paper mode (workflow_mode=$WORKFLOW_MODE). Skipping paper-patch validation."
    cr_exit_summary
fi

echo "  Workflow mode: paper"

# ── Check disposition records exist ─────────────────────────────────

# Collect CRT IDs from critique-ledger.yaml (L1 authoritative), fallback to critique.md.
DISPOSITIONS_FILE="$ROUND_DIR/dispositions.yaml"
DISPOSITIONS_JSON=""

if [ -f "$DISPOSITIONS_FILE" ]; then
    if command -v yq >/dev/null 2>&1; then
        DISPOSITIONS_JSON=$(yq -o json '.' "$DISPOSITIONS_FILE" 2>/dev/null || echo "[]")
    else
        warn "yq not available — cannot parse dispositions.yaml, checking for file presence only"
        DISPOSITIONS_JSON="[]"
    fi
else
    # Paper mode requires dispositions.
    DISPOSITIONS_JSON="[]"
fi

# ── Check critiques have dispositions ──────────────────────────────

CRITIQUE_FILE="$ROUND_DIR/critique-ledger.yaml"
if [ -f "$CRITIQUE_FILE" ]; then
    # Extract critique IDs with medium+ severity.
    MEDIUM_PLUS_IDS=$(yq -r '[.critiques[]? | select(.severity == "fatal" or .severity == "high" or .severity == "medium")] | .[].critique_id // ""' "$CRITIQUE_FILE" 2>/dev/null | sort -u || echo "")
    HIGH_SEVERITY_COUNT=$(echo "$MEDIUM_PLUS_IDS" | grep -c 'CRT-' 2>/dev/null || echo 0)

    if [ "${HIGH_SEVERITY_COUNT:-0}" -gt 0 ]; then
        # Count critique IDs found.
        CRT_COUNT=0
        for cid in $MEDIUM_PLUS_IDS; do
            CRT_COUNT=$((CRT_COUNT + 1))
        done

        # Check if each critique has a disposition.
        if [ "$DISPOSITIONS_JSON" != "[]" ] && command -v jq >/dev/null 2>&1; then
            for cid in $MEDIUM_PLUS_IDS; do
                HAS_DISP=$(printf '%s' "$DISPOSITIONS_JSON" | jq -r --arg cid "$cid" '(.dispositions // [])[] | select(.critique_id == $cid) | .critique_id' 2>/dev/null)
                if [ -z "$HAS_DISP" ]; then
                    fail "Critique $cid has no disposition record"
                fi
            done
        else
            if [ ! -f "$DISPOSITIONS_FILE" ]; then
                fail "dispositions.yaml not found — paper mode requires disposition records for all medium+ critiques"
            else
                pass "dispositions.yaml exists (full validation requires yq/jq)"
            fi
        fi
    else
        # Check for structured no-op record in critique-ledger.yaml.
        NO_CRIT=$(yq -r '.no_medium_plus_critique.reason // ""' "$CRITIQUE_FILE" 2>/dev/null || echo "")
        if [ -n "$NO_CRIT" ] && [ "$NO_CRIT" != "null" ]; then
            pass "Structured no-critique record: ${NO_CRIT:0:80}..."
        else
            fail "No medium+ critiques found and no no_medium_plus_critique record in critique-ledger.yaml"
            ALL_PASSED=false
        fi
    fi
fi

# ── Validate paper patches ─────────────────────────────────────────

PATCHES_DIR="$ROUND_DIR/patches"
if [ -d "$PATCHES_DIR" ]; then
    PATCH_FILES=$(find "$PATCHES_DIR" -name 'PP-*.yaml' -type f 2>/dev/null || echo "")

    if [ -n "$PATCH_FILES" ]; then
        # Track IDs for uniqueness check.
        declare -A SEEN_IDS

        for patch_file in $PATCH_FILES; do
            PATCH_ID=$(grep -E '^patch_id:' "$patch_file" 2>/dev/null | sed 's/^patch_id:\s*//' | xargs || echo "")

            if [ -z "$PATCH_ID" ] || [[ ! "$PATCH_ID" =~ ^PP-[0-9]{3}$ ]]; then
                fail "Invalid or missing patch_id in $(basename "$patch_file")"
                continue
            fi

            # ID uniqueness check (per project scope).
            if [ -n "${SEEN_IDS[$PATCH_ID]:-}" ]; then
                fail "Duplicate patch ID: $PATCH_ID (also in ${SEEN_IDS[$PATCH_ID]})"
            else
                SEEN_IDS[$PATCH_ID]=$(basename "$patch_file")
            fi

            # Validate against paper_patch schema if jq+schemas available.
            SCHEMA_PATH="$(cr_schema_path "paper_patch.schema.json")"
            if [ -n "$SCHEMA_PATH" ]; then
                if ! command -v yq >/dev/null 2>&1; then
                    fail "$PATCH_ID: yq required for paper-mode schema validation"
                else
                    PATCH_JSON=$(yq -o json '.' "$patch_file" 2>/dev/null || echo "")
                    if [ -z "$PATCH_JSON" ] || [ "$PATCH_JSON" = "null" ]; then
                        fail "$PATCH_ID: failed to parse YAML"
                    elif ! cr_validate_json_schema "$PATCH_JSON" "$(cat "$SCHEMA_PATH")"; then
                        fail "$PATCH_ID: schema validation failed (hard gate)"
                    fi
                fi
            else
                fail "$PATCH_ID: paper_patch.schema.json not found — cannot validate"
            fi

            # ── Lifecycle validation ────────────────────────────────
            LIFECYCLE_STATUS=$(grep -E '^lifecycle_status:' "$patch_file" 2>/dev/null | sed 's/^lifecycle_status:\s*//' | xargs || echo "")
            VALID_STATUSES=("proposed" "needs_human_decision" "approved" "recorded" "applied" "rejected" "superseded")
            STATUS_VALID=false
            for vs in "${VALID_STATUSES[@]}"; do
                [ "$LIFECYCLE_STATUS" = "$vs" ] && STATUS_VALID=true && break
            done
            if [ "$STATUS_VALID" = false ]; then
                fail "$PATCH_ID: invalid lifecycle_status '$LIFECYCLE_STATUS'"
            fi

            # Check terminal states have required fields.
            if [ "$LIFECYCLE_STATUS" = "rejected" ]; then
                REJ_REASON=$(grep -E '^rejection_reason:' "$patch_file" 2>/dev/null | sed 's/^rejection_reason:\s*//' | xargs || echo "")
                [ -z "$REJ_REASON" ] && fail "$PATCH_ID: lifecycle_status=rejected but no rejection_reason"
            fi

            if [ "$LIFECYCLE_STATUS" = "superseded" ]; then
                SUPERSEDED_BY=$(grep -E '^superseded_by:' "$patch_file" 2>/dev/null | sed 's/^superseded_by:\s*//' | xargs || echo "")
                [ -z "$SUPERSEDED_BY" ] && fail "$PATCH_ID: lifecycle_status=superseded but no superseded_by"
            fi

            # ── Knowledge Implication check ──────────────────────────
            HAS_KNOWLEDGE_IMPL=$(grep -cE '^knowledge_implication:' "$patch_file" 2>/dev/null || echo 0)
            if [ "$HAS_KNOWLEDGE_IMPL" -eq 0 ]; then
                fail "$PATCH_ID: missing knowledge_implication field"
            else
                # Check literature_updates and thinking_candidates exist.
                HAS_LIT=$(grep -cE 'literature_updates:' "$patch_file" 2>/dev/null || echo 0)
                HAS_THINK=$(grep -cE 'thinking_candidates:' "$patch_file" 2>/dev/null || echo 0)
                [ "$HAS_LIT" -ge 1 ] && pass "  $PATCH_ID: knowledge_implication.literature_updates present" || fail "  $PATCH_ID: knowledge_implication.literature_updates missing"
                [ "$HAS_THINK" -ge 1 ] && pass "  $PATCH_ID: knowledge_implication.thinking_candidates present" || fail "  $PATCH_ID: knowledge_implication.thinking_candidates missing"
            fi

            # ── Human gate check ─────────────────────────────────────
            NEEDS_HUMAN=$(grep -E '^needs_human_decision:' "$patch_file" 2>/dev/null | sed 's/^needs_human_decision:\s*//' | xargs || echo "false")
            if [ "$NEEDS_HUMAN" = "true" ]; then
                HUMAN_RATIONALE=$(grep -E '^human_decision_rationale:' "$patch_file" 2>/dev/null | sed 's/^human_decision_rationale:\s*//' | xargs || echo "")
                [ -z "$HUMAN_RATIONALE" ] && fail "$PATCH_ID: needs_human_decision=true but no human_decision_rationale"
                [ -n "$HUMAN_RATIONALE" ] && pass "  $PATCH_ID: human decision rationale present"
            fi

            pass "$PATCH_ID: validated (status=$LIFECYCLE_STATUS)"
        done
    else
        warn "patches/ directory exists but no PP-*.yaml files found"
    fi
else
    # Paper mode requires a patches directory.
    warn "patches/ directory not found — paper mode rounds should contain patches/"
fi

# ── Check patch→disposition linkage ─────────────────────────────────

if [ -f "$DISPOSITIONS_FILE" ] && [ -d "$PATCHES_DIR" ] && command -v yq >/dev/null 2>&1; then
    # For each disposition with type=paper_patch, verify linked patch exists.
    DISP_JSON=$(yq -o json '.' "$DISPOSITIONS_FILE" 2>/dev/null || echo "[]")
    PAPER_PATCH_DISPS=$(printf '%s' "$DISP_JSON" | jq -r '(.dispositions // [])[] | select(.disposition_type == "paper_patch") | "\(.critique_id) -> \(.linked_patch_id)"' 2>/dev/null)
    if [ -n "$PAPER_PATCH_DISPS" ]; then
        while IFS= read -r line; do
            [ -z "$line" ] && continue
            CRT_ID=$(echo "$line" | sed 's/ ->.*//')
            PP_ID=$(echo "$line" | sed 's/.* -> //')
            if [ ! -f "$PATCHES_DIR/${PP_ID}.yaml" ]; then
                fail "Disposition for $CRT_ID references missing patch: $PP_ID"
            else
                pass "Disposition $CRT_ID -> $PP_ID (patch exists)"
            fi
        done <<< "$PAPER_PATCH_DISPS"
    fi
fi

cr_exit_summary
