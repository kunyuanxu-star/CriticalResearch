#!/usr/bin/env bash
# cr-start-round — Strong setup script for an 8-stage document-targeted round.
# Creates the round directory, snapshots the manifest, generates state,
# and prepares all runtime files.
#
# Usage: cr-start-round <project> <objective> [--doc <doc-id>]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cr-common.sh"

PROJECT_ID="${1:-}"
RAW_OBJECTIVE="${2:-}"
DOC_TARGET="paper"
DOC_TYPE="paper"

# Parse optional --doc flag from remaining args (shifted by caller or here)
if [ "${3:-}" = "--doc" ]; then
    DOC_TARGET="${4:-paper}"
    DOC_TYPE="${4:-paper}"
fi

if [ -z "$PROJECT_ID" ]; then
    echo "Usage: cr-start-round <project> [objective] [--doc <doc-id>]" >&2
    exit 2
fi
WORKSPACE_ROOT="$(cr_workspace_root)"
PROJECT_DIR="$WORKSPACE_ROOT/$PROJECT_ID"

# ── 1. Check workspace initialized ────────────────────────────────

if [ ! -f "$WORKSPACE_ROOT/_cr/workspace.yaml" ]; then
    echo "Error: workspace not initialized. Run 'cr workspace init' first." >&2
    exit 1
fi

# ── 2. Check project exists ───────────────────────────────────────

if [ ! -d "$PROJECT_DIR" ] || [ ! -f "$PROJECT_DIR/project.yaml" ]; then
    echo "Error: project '$PROJECT_ID' not found at $PROJECT_DIR" >&2
    exit 1
fi

# ── 3. Check no active round ──────────────────────────────────────

STATE_FILE="$PROJECT_DIR/state/project-state.json"
if [ -f "$STATE_FILE" ]; then
    ACTIVE_ROUND=$(jq -r '.active_round // "null"' "$STATE_FILE" 2>/dev/null || echo "null")
    if [ "$ACTIVE_ROUND" != "null" ] && [ "$ACTIVE_ROUND" != "0" ]; then
        echo "Error: project '$PROJECT_ID' already has active round $ACTIVE_ROUND." >&2
        echo "  Close it first: cr close-round $PROJECT_ID" >&2
        exit 1
    fi
else
    echo "Error: project state file missing: $STATE_FILE" >&2
    exit 1
fi

# ── 4. Check target document exists ───────────────────────────────

DOC_PATH="$PROJECT_DIR/documents/${DOC_TARGET}.md"
if [ ! -f "$DOC_PATH" ]; then
    # Backward compat: fall back to legacy writing/paper-draft.md
    if [ "$DOC_TARGET" = "paper" ] && [ -f "$PROJECT_DIR/writing/paper-draft.md" ]; then
        DOC_PATH="$PROJECT_DIR/writing/paper-draft.md"
    else
        echo "Error: documents/${DOC_TARGET}.md not found. Document rounds require a draft." >&2
        exit 1
    fi
fi

# ── 5. Check state/claim-ledger.yaml ──────────────────────────────

CLAIM_LEDGER="$PROJECT_DIR/state/claim-ledger.yaml"
if [ ! -f "$CLAIM_LEDGER" ]; then
    echo "Warning: state/claim-ledger.yaml missing — creating empty template." >&2
    cat > "$CLAIM_LEDGER" << YAML
schema_version: "1.0.0"
claims: []
# NOTE: This claim ledger is empty. Populate before starting research.
YAML
    echo "  Marked for completion: claim-ledger.yaml needs to be populated." >&2
fi

# ── 6. Determine round number ─────────────────────────────────────

ROUNDS_DIR="$PROJECT_DIR/rounds"
mkdir -p "$ROUNDS_DIR"

NEXT_ROUND=1
if [ -d "$ROUNDS_DIR" ]; then
    EXISTING=$(find "$ROUNDS_DIR" -maxdepth 1 -type d -name 'round-*' 2>/dev/null | wc -l | tr -d ' ')
    NEXT_ROUND=$((EXISTING + 1))
fi

ROUND_NUM=$(printf "%03d" "$NEXT_ROUND")
ROUND_DIR="$ROUNDS_DIR/round-$ROUND_NUM"

if [ -d "$ROUND_DIR" ]; then
    echo "Error: round directory already exists: $ROUND_DIR" >&2
    exit 1
fi

mkdir -p "$ROUND_DIR"

# ── 7. Snapshot stage manifest ────────────────────────────────────

SKILL_HOME="$(cr_skill_home)"
MANIFEST="$SKILL_HOME/workflow/stage-manifest.yaml"
MANIFEST_SNAPSHOT="$ROUND_DIR/stage-manifest.snapshot.yaml"

if [ ! -f "$MANIFEST" ]; then
    echo "Error: stage manifest not found: $MANIFEST" >&2
    exit 1
fi

cp "$MANIFEST" "$MANIFEST_SNAPSHOT"
echo "  Snapshotted stage manifest to $MANIFEST_SNAPSHOT"

NOW="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

# ── 8. Generate round.yaml ────────────────────────────────────────

cat > "$ROUND_DIR/round.yaml" << RND
round_id: $NEXT_ROUND
project_id: $PROJECT_ID
round_type: $DOC_TYPE
status: open
started_at: $NOW
completed_at: null
target_gap: null
workflow_mode: $DOC_TYPE
document_target: $DOC_TARGET
document_type: $DOC_TYPE
required_outputs:
  - report
  - evidence_ledger
  - critique_ledger
  - review_disposition
  - revision_plan
  - patch_plan
  - patch_trace
  - writing_diff_yaml
  - knowledge_delta
  - knowledge_apply_log
  - paper_patch
  - experiment_obligation
notes: ""
schema_version: "1.0.0"
RND

echo "  Generated round.yaml"

# ── 9. Generate state.yaml from manifest snapshot ─────────────────

STATE_YAML="$ROUND_DIR/state.yaml"

# Build the state.yaml dynamically from the manifest.
# We preserve the full structure: execution_policy, stage_order, stages map.

cat > "$STATE_YAML" << HEADER
schema_version: "4.0.0"
project_id: "$PROJECT_ID"
round_id: $NEXT_ROUND
workflow_mode: $DOC_TYPE
status: open
document_target: $DOC_TARGET
document_type: $DOC_TYPE
current_stage: s1_round_contract

required_research: true
required_min_sources: 5
required_source_levels:
  min_s_or_a: 2
  allow_b: true
  allow_c_only_as_lead: true

execution_policy:
  invocation_mode: slash_command
  full_round_required: true
  full_paper_required: true
  required_stage_count: 8
  allow_partial_stop: false
  stop_only_on:
    - round_closed
    - human_decision_required
    - unrecoverable_tool_error

stage_order:
HEADER
# Append stage_order from manifest.
for i in $(seq 0 7); do
    sid=$(yq -r ".stages[$i].id" "$MANIFEST_SNAPSHOT" 2>/dev/null || echo "")
    [ -n "$sid" ] && echo "  - $sid" >> "$STATE_YAML"
done

# Append stages block.
echo "" >> "$STATE_YAML"
echo "stages:" >> "$STATE_YAML"

for i in $(seq 0 7); do
    sid=$(yq -r ".stages[$i].id" "$MANIFEST_SNAPSHOT" 2>/dev/null || echo "")
    [ -z "$sid" ] && continue

    order=$((i + 1))
    prompt_path=$(yq -r ".stages[$i].prompt // \"prompts/core/${sid}.md\"" "$MANIFEST_SNAPSHOT" 2>/dev/null)

    # Get required_inputs from manifest or use defaults.
    required_inputs=$(yq -r ".stages[$i].required_inputs // []" "$MANIFEST_SNAPSHOT" 2>/dev/null || echo "[]")
    has_structured_inputs=false
    if [ "$required_inputs" != "[]" ] && [ "$required_inputs" != "null" ]; then
        input_len=$(yq -r ".stages[$i].required_inputs | length" "$MANIFEST_SNAPSHOT" 2>/dev/null || echo 0)
        [ "$input_len" -gt 0 ] 2>/dev/null && has_structured_inputs=true
    fi

    required_outputs=$(yq -r ".stages[$i].required_outputs // []" "$MANIFEST_SNAPSHOT" 2>/dev/null || echo "[]")
    has_structured_outputs=false
    if [ "$required_outputs" != "[]" ] && [ "$required_outputs" != "null" ]; then
        output_len=$(yq -r ".stages[$i].required_outputs | length" "$MANIFEST_SNAPSHOT" 2>/dev/null || echo 0)
        [ "$output_len" -gt 0 ] 2>/dev/null && has_structured_outputs=true
    fi

    forbidden_actions=$(yq -r ".stages[$i].forbidden_actions // []" "$MANIFEST_SNAPSHOT" 2>/dev/null || echo "[]")
    has_forbidden=false
    if [ "$forbidden_actions" != "[]" ] && [ "$forbidden_actions" != "null" ]; then
        fb_len=$(yq -r ".stages[$i].forbidden_actions | length" "$MANIFEST_SNAPSHOT" 2>/dev/null || echo 0)
        [ "$fb_len" -gt 0 ] 2>/dev/null && has_forbidden=true
    fi

    no_op_allowed=$(yq -r ".stages[$i].no_op_allowed // false" "$MANIFEST_SNAPSHOT" 2>/dev/null || echo "false")

    # Determine status: first stage is open, rest blocked.
    if [ "$i" -eq 0 ]; then
        stage_status="open"
    else
        stage_status="blocked"
    fi

    cat >> "$STATE_YAML" << STAGE
  $sid:
    status: $stage_status
    order: $order
    started_at: null
    completed_at: null
    prompt: $prompt_path
    prompt_hash: null
STAGE

    # Add depends_on (from manifest).
    deps=$(yq -r ".stages[$i].dependencies // [] | .[]" "$MANIFEST_SNAPSHOT" 2>/dev/null || echo "")
    if [ -n "$deps" ]; then
        echo "    depends_on:" >> "$STATE_YAML"
        for dep in $deps; do
            echo "      - $dep" >> "$STATE_YAML"
        done
    else
        echo "    depends_on: []" >> "$STATE_YAML"
    fi

    # required_inputs (strip scope prefix for state.yaml compatibility)
    if [ "$has_structured_inputs" = true ]; then
        echo "    required_inputs:" >> "$STATE_YAML"
        yq -r ".stages[$i].required_inputs[] | \"- \" + .path" "$MANIFEST_SNAPSHOT" 2>/dev/null | sed 's/^/      /' | sed 's/^      - project:/      - /; s/^      - round:/      - /; s/^      - workspace:/      - /' >> "$STATE_YAML" || true
    else
        echo "    required_inputs: []" >> "$STATE_YAML"
    fi

    # required_outputs (strip scope prefix for state.yaml compatibility)
    if [ "$has_structured_outputs" = true ]; then
        echo "    required_outputs:" >> "$STATE_YAML"
        yq -r ".stages[$i].required_outputs[] | \"- \" + .path" "$MANIFEST_SNAPSHOT" 2>/dev/null | sed 's/^/      /' | sed 's/^      - project:/      - /; s/^      - round:/      - /; s/^      - workspace:/      - /' >> "$STATE_YAML" || true
    else
        echo "    required_outputs: []" >> "$STATE_YAML"
    fi

    # allowed_write_scopes (strip scope prefix for state.yaml compatibility)
    if [ "$has_structured_outputs" = true ]; then
        echo "    allowed_write_scopes:" >> "$STATE_YAML"
        yq -r ".stages[$i].required_outputs[] | .path" "$MANIFEST_SNAPSHOT" 2>/dev/null | sed 's/^/      - /' | sed 's/^      - project:/      - /; s/^      - round:/      - /; s/^      - workspace:/      - /' >> "$STATE_YAML" || true
    else
        echo "    allowed_write_scopes: []" >> "$STATE_YAML"
    fi

    # forbidden_actions
    if [ "$has_forbidden" = true ]; then
        echo "    forbidden_actions:" >> "$STATE_YAML"
        yq -r ".stages[$i].forbidden_actions[]" "$MANIFEST_SNAPSHOT" 2>/dev/null | sed 's/^/      - /' >> "$STATE_YAML" || true
    else
        echo "    forbidden_actions: []" >> "$STATE_YAML"
    fi

    cat >> "$STATE_YAML" << REST
    no_op_policy:
      allowed: $no_op_allowed
      required_justification_fields: []
    completion_predicate:
      all_outputs_exist: true
      validator_passed: true
      no_unresolved_blockers: true
    stage_validators_hint: []
REST
done

# Append closure_policy.
cat >> "$STATE_YAML" << POLICY

closure_policy:
  require_all_stages_complete: true
  require_exact_stage_count: 8
  require_no_skipped_stages: true
  require_external_research: true
  require_no_pending_human_decisions: true
  require_transaction_chain_complete: true
  require_patch_for_medium_plus_critique: true
  require_experiment_for_claim_patch: true
  require_draft_diff_for_applied_patch: true
  require_knowledge_writeback: true
  close_round_is_stage: true
  require_stage_run_log: true
POLICY

echo "  Generated state.yaml (round $NEXT_ROUND, 8 stages)"

# ── 10. Generate round-contract.yaml ──────────────────────────────

cat > "$ROUND_DIR/round-contract.yaml" << OBJ
schema_version: "1.0.0"
round_id: $NEXT_ROUND
contract:
  target: "$RAW_OBJECTIVE"
  scope:
    sections: []
    claims: []
    forbidden_scope: []
  intensity: standard
  required_outputs:
    - evidence_ledger
    - critique_ledger
    - review_disposition
    - revision_plan
    - patch_plan
    - patch_trace
    - writing_diff
    - knowledge_delta
    - next_round_targets
  success_criteria: []

no_contract_reason: null
OBJ

echo "  Generated round-contract.yaml"

# ── 11. Generate stage-contracts ──────────────────────────────────

mkdir -p "$ROUND_DIR/stage-contracts"
for i in $(seq 0 7); do
    sid=$(yq -r ".stages[$i].id" "$MANIFEST_SNAPSHOT" 2>/dev/null || echo "")
    [ -z "$sid" ] && continue
    order=$((i + 1))
    contract_file="$ROUND_DIR/stage-contracts/$(printf "%02d" "$order")-${sid}.contract.yaml"

    cat > "$contract_file" << CONTRACT
schema_version: "1.0.0"
stage_id: $sid
order: $order
contract_type: stage_execution
required:
  inputs_exist: true
  outputs_exist: true
  schema_valid: true
  semantic_validator_passed: true
  objective_binding_present: true
  full_paper_coverage_present: true
forbidden:
  skip_stage: true
  manual_state_edit: true
  out_of_scope_writes: true
CONTRACT
done

echo "  Generated stage-contracts/ (8 files)"

# ── 12. Generate empty runtime files ──────────────────────────────

cat > "$ROUND_DIR/stage-run-log.yaml" << PRL
schema_version: "1.0.0"
events:
PRL

cat > "$ROUND_DIR/audit-log.yaml" << AUD
schema_version: "1.0.0"
events: []
AUD

cat > "$ROUND_DIR/repair-log.yaml" << REP
schema_version: "1.0.0"
repairs: []
REP

# ── 13. Update project-state.json ─────────────────────────────────

TMP_STATE="$PROJECT_DIR/state/project-state.json.tmp"
jq --arg round "$NEXT_ROUND" --arg now "$NOW" \
    '.active_round = ($round | tonumber) | .total_rounds = ($round | tonumber) | .last_updated = $now' \
    "$STATE_FILE" > "$TMP_STATE" && mv "$TMP_STATE" "$STATE_FILE"

# ── 14. Output stage 1 prompt ─────────────────────────────────────

echo ""
echo ""
echo "══ Round $ROUND_NUM Started ══"
echo "Project: $PROJECT_ID"
echo "Round:   round-$ROUND_NUM"
echo "Status:  open"
echo "Stage:   1/8 s1_round_contract"
echo "Document: $DOC_TARGET ($DOC_TYPE)"
echo ""

STAGE1_PROMPT="$SKILL_HOME/prompts/core/s1_round_contract.md"
ADAPTER_PROMPT="$SKILL_HOME/prompts/adapters/${DOC_TYPE}.md"
if [ -f "$STAGE1_PROMPT" ]; then
    echo "── Stage 1 Prompt ──"
    echo ""
    cat "$STAGE1_PROMPT"
    if [ -f "$ADAPTER_PROMPT" ]; then
        echo ""
        echo "── Document Adapter ($DOC_TYPE) ──"
        echo ""
        cat "$ADAPTER_PROMPT"
    fi
else
    echo "Stage 1 prompt not found at $STAGE1_PROMPT"
fi
