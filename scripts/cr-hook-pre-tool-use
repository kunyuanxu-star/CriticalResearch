#!/usr/bin/env bash
# CriticalResearch PreToolUse hook. Minimal write guard only.

set -euo pipefail

deny() {
    local reason="$1"
    python3 - "$reason" <<'PY'
import json
import sys

print(json.dumps({
    "hookSpecificOutput": {
        "hookEventName": "PreToolUse",
        "permissionDecision": "deny",
        "permissionDecisionReason": sys.argv[1],
    }
}))
PY
    exit 0
}

allow() {
    exit 0
}

INPUT="$(cat)"

json_field() {
    local path="$1"
    CR_HOOK_INPUT="$INPUT" CR_HOOK_PATH="$path" python3 - <<'PY'
import json
import os

try:
    data = json.loads(os.environ.get("CR_HOOK_INPUT") or "{}")
except json.JSONDecodeError:
    data = {}

value = data
for part in os.environ["CR_HOOK_PATH"].split("."):
    if isinstance(value, dict):
        value = value.get(part, "")
    else:
        value = ""
    if value in (None, ""):
        value = ""
        break

print(value if isinstance(value, str) else "")
PY
}

TOOL_NAME="$(json_field tool_name)"
[ -z "$TOOL_NAME" ] && TOOL_NAME="$(json_field tool)"

[ -z "$TOOL_NAME" ] && allow

case "$TOOL_NAME" in
    Write|Edit|MultiEdit)
        FILE_PATH="$(json_field tool_input.file_path)"
        [ -z "$FILE_PATH" ] && allow
        case "$FILE_PATH" in
            /*) ABS="$FILE_PATH" ;;
            *) ABS="$(pwd)/$FILE_PATH" ;;
        esac
        case "$ABS" in
            */_cr/workspace.yaml|*/_cr/active-project)
                deny "Direct edits to CriticalResearch workspace state are blocked. Use cr commands."
                ;;
            */runs/run-*/research.md)
                # Editing the active artifact is allowed; deleting it via Bash is guarded below.
                allow
                ;;
            *)
                allow
                ;;
        esac
        ;;
    Bash)
        CMD="$(json_field tool_input.command)"
        if printf '%s' "$CMD" | grep -Eq 'rm[[:space:]].*runs/run-[0-9][0-9][0-9]/research\.md'; then
            deny "Deleting an active research.md is blocked."
        fi
        allow
        ;;
    *)
        allow
        ;;
esac
