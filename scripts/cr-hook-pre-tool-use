#!/usr/bin/env bash
# CriticalResearch PreToolUse hook. Minimal write guard only.

set -euo pipefail

deny() {
    local reason="$1"
    jq -n --arg reason "$reason" '{
      hookSpecificOutput: {
        hookEventName: "PreToolUse",
        permissionDecision: "deny",
        permissionDecisionReason: $reason
      }
    }'
    exit 0
}

allow() {
    exit 0
}

INPUT="$(cat)"
TOOL_NAME="$(printf '%s' "$INPUT" | jq -r '.tool_name // .tool // empty' 2>/dev/null || true)"

[ -z "$TOOL_NAME" ] && allow

case "$TOOL_NAME" in
    Write|Edit|MultiEdit)
        FILE_PATH="$(printf '%s' "$INPUT" | jq -r '.tool_input.file_path // empty' 2>/dev/null || true)"
        [ -z "$FILE_PATH" ] && allow
        case "$FILE_PATH" in
            /*) ABS="$FILE_PATH" ;;
            *) ABS="$(pwd)/$FILE_PATH" ;;
        esac
        case "$ABS" in
            */_cr/workspace.yaml|*/_cr/active-project)
                deny "Direct edits to CriticalResearch workspace state are blocked. Use cr commands."
                ;;
            */runs/run-*/research.md)
                # Editing the active artifact is allowed; deleting it via Bash is guarded below.
                allow
                ;;
            *)
                allow
                ;;
        esac
        ;;
    Bash)
        CMD="$(printf '%s' "$INPUT" | jq -r '.tool_input.command // empty' 2>/dev/null || true)"
        if printf '%s' "$CMD" | grep -Eq 'rm[[:space:]].*runs/run-[0-9][0-9][0-9]/research\.md'; then
            deny "Deleting an active research.md is blocked."
        fi
        allow
        ;;
    *)
        allow
        ;;
esac
