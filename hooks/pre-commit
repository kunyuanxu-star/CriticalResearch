#!/usr/bin/env bash
# CriticalResearch pre-commit smoke gate.

set -euo pipefail

if [ "${CR_SKIP_PRECOMMIT:-0}" = "1" ]; then
    echo "CR_SKIP_PRECOMMIT=1 - skipping checks"
    exit 0
fi

ERRORS=0
fail() { echo "  [FAIL] $1"; ERRORS=$((ERRORS + 1)); }
pass() { echo "  [OK] $1"; }

echo "CriticalResearch pre-commit"

python3 -m py_compile engine/research_loop/cli.py && pass "engine/research_loop/cli.py compiles" || fail "engine/research_loop/cli.py compile failed"
bash -n scripts/cr && pass "scripts/cr syntax" || fail "scripts/cr syntax"
bash -n scripts/critical-research-hook && pass "hook wrapper syntax" || fail "hook wrapper syntax"
bash -n scripts/cr-hook-stop && pass "stop hook syntax" || fail "stop hook syntax"
bash -n scripts/cr-hook-pre-tool-use && pass "pre-tool hook syntax" || fail "pre-tool hook syntax"

if [ "$ERRORS" -gt 0 ]; then
    echo "Blocked: $ERRORS failure(s)"
    exit 1
fi

echo "Passed"
