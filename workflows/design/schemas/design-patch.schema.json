{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://critical-research/schemas/design-patch",
  "title": "Design Patch",
  "description": "Patch payload schema for design workflow modifications.",
  "type": "object",
  "required": ["design_payload"],
  "properties": {
    "design_payload": {
      "type": "object",
      "required": ["text_changes"],
      "properties": {
        "invariants_added": {
          "type": "array",
          "items": { "type": "string" },
          "description": "New invariants added to the design"
        },
        "invariants_removed": {
          "type": "array",
          "items": { "type": "string" }
        },
        "invariants_revised": {
          "type": "array",
          "items": { "type": "string" }
        },
        "interfaces_changed": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Interface names that were modified"
        },
        "lifecycle_changes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "State transition changes"
        },
        "component_changes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "failure_model_changes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "text_changes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["unit", "operation"],
            "properties": {
              "unit": { "type": "string" },
              "operation": { "type": "string", "enum": ["insert", "replace", "delete"] },
              "anchor_after": { "type": "string" },
              "content": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
