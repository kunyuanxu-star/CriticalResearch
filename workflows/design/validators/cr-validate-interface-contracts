#!/usr/bin/env python3
"""cr-validate-interface-contracts — Checks that interface changes are documented."""
import sys, yaml
from pathlib import Path

def load_yaml(p): 
    with open(p) as f: return yaml.safe_load(f)

def main():
    if len(sys.argv) < 2: print("Usage: cr-validate-interface-contracts <round_dir>"); sys.exit(1)
    rd = Path(sys.argv[1])
    pd = rd / "patches"
    if not pd.exists(): sys.exit(0)
    
    errs = []
    for pf in pd.glob("*.yaml"):
        try:
            patch = load_yaml(str(pf))
            payload = patch.get("design_payload") or patch.get("payload",{})
            if patch.get("patch_type","") == "interface_contract_update" and not payload.get("interfaces_changed"):
                errs.append(f"WARN: interface_contract_update patch {pf.name} has no interfaces_changed")
        except: pass
    
    if errs: 
        for e in errs: print(e); sys.exit(1)
    print("PASS: Interface contract validation passed")

if __name__ == "__main__": main()
