#!/usr/bin/env bash
# cr-validate-design-failure-model — Validate failure model is defined.
# Checks design-state.yaml for non-empty failure_models array with well-formed entries.
#
# Usage: cr-validate-design-failure-model <round_dir>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/../../../scripts/cr-common.sh"

ROUND_DIR="${1:-}"
[ -z "$ROUND_DIR" ] && { echo "Usage: cr-validate-design-failure-model <round_dir>" >&2; exit 2; }

echo "══ Design Failure Model: $(basename "$ROUND_DIR") ══"

STATE_FILE="$ROUND_DIR/design-state.yaml"
[ ! -f "$STATE_FILE" ] && { fail "design-state.yaml not found"; cr_exit_summary; }
pass "design-state.yaml present"

ALL_PASSED=true

FM_COUNT=$(yq -r '.failure_models | length // 0' "$STATE_FILE" 2>/dev/null || echo "0")
if [ "${FM_COUNT:-0}" -eq 0 ]; then
    fail "No failure models defined in design-state.yaml"
    cr_exit_summary
fi

pass "$FM_COUNT failure model(s) defined"

for i in $(seq 0 $((FM_COUNT - 1))); do
    FMNAME=$(yq -r ".failure_models[$i].failure_mode // \"\"" "$STATE_FILE" 2>/dev/null || echo "")
    TRIGGERS=$(yq -r ".failure_models[$i].trigger_conditions | length // 0" "$STATE_FILE" 2>/dev/null || echo "0")
    MITIG=$(yq -r ".failure_models[$i].mitigation // \"\"" "$STATE_FILE" 2>/dev/null || echo "")
    RISK=$(yq -r ".failure_models[$i].residual_risk // \"\"" "$STATE_FILE" 2>/dev/null || echo "")

    [ -z "$FMNAME" ] || [ "$FMNAME" = "null" ] && { fail "failure_model[$i]: missing failure_mode"; ALL_PASSED=false; }
    [ "${TRIGGERS:-0}" -eq 0 ] && { fail "$FMNAME: no trigger_conditions"; ALL_PASSED=false; }
    [ -z "$MITIG" ] || [ "$MITIG" = "null" ] && { fail "$FMNAME: missing mitigation"; ALL_PASSED=false; }
    [ -z "$RISK" ] || [ "$RISK" = "null" ] && { fail "$FMNAME: missing residual_risk"; ALL_PASSED=false; }
done

[ "$ALL_PASSED" = false ] && cr_exit_summary
pass "Design failure model validation passed"
cr_exit_summary
