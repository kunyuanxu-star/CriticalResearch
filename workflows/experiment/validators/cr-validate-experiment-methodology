#!/usr/bin/env bash
# Usage: cr-validate-experiment-methodology <round_dir>
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/../../../scripts/cr-common.sh"

ROUND_DIR="${1:-}"
if [ -z "$ROUND_DIR" ]; then
    echo "Usage: cr-validate-experiment-methodology <round_dir>" >&2
    exit 2
fi

echo "── Experiment Methodology Validation ──"

METHOD_FILE="$ROUND_DIR/methodology-design.yaml"
if [ -f "$METHOD_FILE" ]; then
    N_TARGET=$(yq -r '.sampling_plan.target_sample_size // 0' "$METHOD_FILE" 2>/dev/null || echo "0")
    PA_EFFECT=$(yq -r '.sampling_plan.power_analysis.effect_size // ""' "$METHOD_FILE" 2>/dev/null || echo "")
    [ "${N_TARGET:-0}" -le 0 ] && fail "sampling_plan.target_sample_size missing or zero" || pass "sampling_plan: target N=$N_TARGET"
    [ -z "$PA_EFFECT" ] || [ "$PA_EFFECT" = "null" ] && fail "power_analysis.effect_size missing" || pass "power_analysis: effect_size=$PA_EFFECT"

    PRIMARY_TEST=$(yq -r '.analysis_plan.primary_test // ""' "$METHOD_FILE" 2>/dev/null || echo "")
    EFFECT_SIZE=$(yq -r '.analysis_plan.effect_size_measure // ""' "$METHOD_FILE" 2>/dev/null || echo "")
    [ -z "$PRIMARY_TEST" ] || [ "$PRIMARY_TEST" = "null" ] && fail "analysis_plan.primary_test missing" || pass "analysis_plan: primary_test=$PRIMARY_TEST"
    [ -z "$EFFECT_SIZE" ] || [ "$EFFECT_SIZE" = "null" ] && fail "effect_size_measure missing" || pass "effect_size_measure=$EFFECT_SIZE"
else
    fail "methodology-design.yaml not found"
fi

EXEC_FILE="$ROUND_DIR/experiment-execution-plan.yaml"
if [ -f "$EXEC_FILE" ]; then
    RECRUIT=$(yq -r '.participant_flow.recruitment_method // ""' "$EXEC_FILE" 2>/dev/null || echo "")
    DEBRIEF=$(yq -r '.participant_flow.debriefing_procedure // ""' "$EXEC_FILE" 2>/dev/null || echo "")
    [ -z "$RECRUIT" ] || [ "$RECRUIT" = "null" ] && fail "participant_flow.recruitment_method missing"
    [ -z "$DEBRIEF" ] || [ "$DEBRIEF" = "null" ] && fail "participant_flow.debriefing_procedure missing"

    IC_COUNT=$(yq -r '.data_collection.integrity_checks | length // 0' "$EXEC_FILE" 2>/dev/null || echo "0")
    [ "${IC_COUNT:-0}" -eq 0 ] && fail "data_collection.integrity_checks is empty" || pass "data_collection: $IC_COUNT integrity check(s)"

    for phase in pre_experiment during_experiment post_experiment; do
        QA_COUNT=$(yq -r ".quality_assurance.${phase} | length // 0" "$EXEC_FILE" 2>/dev/null || echo "0")
        [ "${QA_COUNT:-0}" -eq 0 ] && fail "quality_assurance.${phase} is empty" || pass "quality_assurance.${phase}: $QA_COUNT checkpoint(s)"
    done
else
    warn "experiment-execution-plan.yaml not found (may not exist until stage 5)"
fi

cr_exit_summary
