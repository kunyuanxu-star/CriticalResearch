{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://critical-research/schemas/experiment-patch",
  "title": "Experiment Patch",
  "description": "Patch payload schema for experiment workflow.",
  "type": "object",
  "required": ["experiment_payload"],
  "properties": {
    "experiment_payload": {
      "type": "object",
      "required": ["text_changes"],
      "properties": {
        "hypothesis_changes": { "type": "array", "items": { "type": "string" } },
        "methodology_changes": { "type": "array", "items": { "type": "string" } },
        "results": { "type": "array", "items": { "type": "object" } },
        "obligations_fulfilled": { "type": "array", "items": { "type": "string" } },
        "text_changes": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object", "required": ["unit","operation"],
            "properties": {
              "unit": { "type": "string" },
              "operation": { "type": "string", "enum": ["insert","replace","delete"] },
              "anchor_after": { "type": "string" },
              "content": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
