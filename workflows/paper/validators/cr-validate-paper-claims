#!/usr/bin/env bash
# cr-validate-paper-claims — Check all claims have evidence backing in evidence-ledger.yaml.
# Usage: cr-validate-paper-claims <round_dir>
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/../../../scripts/cr-common.sh"
ROUND_DIR="${1:-}"
[ -z "$ROUND_DIR" ] && { echo "Usage: cr-validate-paper-claims <round_dir>" >&2; exit 2; }
echo "── Paper Claims Validation ──"

E="$ROUND_DIR/evidence-ledger.yaml"
M="$ROUND_DIR/claim-evidence-map.yaml"
[ ! -f "$E" ] && { fail "evidence-ledger.yaml not found"; cr_exit_summary; }

EC=$(yq -r '.evidence | length // 0' "$E" 2>/dev/null || echo "0")
[ "${EC:-0}" -ge 5 ] && pass "Evidence items: $EC" || fail "Evidence items: $EC (need >= 5)"

MS=$(yq -r '[.evidence[] | select(.source_id == "" or .source_id == null)] | length' "$E" 2>/dev/null || echo "0")
[ "${MS:-0}" -eq 0 ] && pass "All evidence items have source_id" || fail "$MS evidence items missing source_id"

WK=$(yq -r '[.evidence[] | select(.evidence_category == "weakening")] | length' "$E" 2>/dev/null || echo "0")
[ "${WK:-0}" -ge 1 ] && pass "Weakening evidence: $WK item(s)" || fail "No weakening evidence required"

[ ! -f "$M" ] && { fail "claim-evidence-map.yaml not found"; cr_exit_summary; }
MC=$(yq -r '.mappings | length // 0' "$M" 2>/dev/null || echo "0")
[ "${MC:-0}" -gt 0 ] || { fail "No claim mappings in claim-evidence-map.yaml"; cr_exit_summary; }

UB=$(yq -r '[.mappings[] | select((.supporting_evidence | length) == 0 and (.missing_evidence | length) == 0)] | length' "$M" 2>/dev/null || echo "0")
[ "${UB:-0}" -eq 0 ] && pass "All $MC claims have supporting or missing evidence" || fail "$UB claim(s) lack evidence backing"

# Cross-check: evidence IDs referenced in mappings must exist in evidence-ledger
ALL_IDS=$(yq -r '.evidence[].evidence_id // ""' "$E" 2>/dev/null)
for i in $(seq 0 $((MC - 1))); do
    for ref in $(yq -r ".mappings[$i].supporting_evidence[] // \"\"" "$M" 2>/dev/null); do
        [ -z "$ref" ] && continue
        echo "$ALL_IDS" | grep -qxF "$ref" || fail "Evidence ref '$ref' not found in evidence-ledger"
    done
done

cr_exit_summary
