#!/usr/bin/env python3
"""cr-validate-paper-units — Validates paper patch target units against registry."""
import sys, yaml
from pathlib import Path
def load_yaml(p): 
    with open(p) as f: return yaml.safe_load(f)
def main():
    if len(sys.argv) < 2: print("Usage: cr-validate-paper-units <round_dir|contract.yaml> [project_root]"); sys.exit(1)
    arg = sys.argv[1]; arg_path = Path(arg)
    if arg_path.is_dir():
        round_dir = arg_path; contract_path = str(arg_path / "contract.yaml")
    else:
        contract_path = arg; round_dir = Path(contract_path).parent
    project_root = sys.argv[2] if len(sys.argv)>2 else str(round_dir.parent.parent)
    c = load_yaml(contract_path)
    if c.get("workflow",{}).get("id")!="paper": print("SKIP"); sys.exit(0)
    did = c["mutable_document"]["id"]; rp = Path(project_root)/"units"/f"{did}.units.yaml"
    if not rp.exists(): print(f"FAIL: {rp}"); sys.exit(1)
    ru = set()
    for u in load_yaml(str(rp)).get("units",[]):
        key = u.get("unit_id") or u.get("id")
        if key:
            ru.add(key)
    pd = round_dir/"patches"
    if not pd.exists(): sys.exit(0)
    errs = []
    for pf in pd.glob("*.yaml"):
        try:
            p = load_yaml(str(pf))
            for u in p.get("target_units",[]):
                if u not in ru: errs.append(f"FAIL: {u} not in registry")
        except: pass
    if errs: 
        for e in errs: print(e); sys.exit(1)
    print("PASS")
if __name__=="__main__": main()
