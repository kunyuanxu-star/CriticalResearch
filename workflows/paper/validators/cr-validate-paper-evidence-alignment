#!/usr/bin/env bash
# cr-validate-paper-evidence-alignment — Check claim-evidence map is complete.
# Verifies every mapping has affected_sections, evidence backing, and
# missing_evidence entries have priority set.
# Usage: cr-validate-paper-evidence-alignment <round_dir>
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/../../../scripts/cr-common.sh"
ROUND_DIR="${1:-}"
[ -z "$ROUND_DIR" ] && { echo "Usage: cr-validate-paper-evidence-alignment <round_dir>" >&2; exit 2; }
echo "── Paper Evidence Alignment ──"

M="$ROUND_DIR/claim-evidence-map.yaml"
[ ! -f "$M" ] && { fail "claim-evidence-map.yaml not found"; cr_exit_summary; }

MC=$(yq -r '.mappings | length // 0' "$M" 2>/dev/null || echo "0")
[ "${MC:-0}" -gt 0 ] || { fail "No claim mappings"; cr_exit_summary; }

NO_SEC=0; NO_EV=0; NO_PRI=0
for i in $(seq 0 $((MC - 1))); do
    CID=$(yq -r ".mappings[$i].claim_id // \"?\"" "$M" 2>/dev/null || echo "?")
    SEC=$(yq -r ".mappings[$i].affected_sections | length // 0" "$M" 2>/dev/null || echo "0")
    SUP=$(yq -r ".mappings[$i].supporting_evidence | length // 0" "$M" 2>/dev/null || echo "0")
    WEAK=$(yq -r ".mappings[$i].weakening_evidence | length // 0" "$M" 2>/dev/null || echo "0")
    MIS=$(yq -r ".mappings[$i].missing_evidence | length // 0" "$M" 2>/dev/null || echo "0")

    [ "${SEC:-0}" -gt 0 ] || { warn "$CID: no affected_sections"; NO_SEC=$((NO_SEC + 1)); }
    if [ "${SUP:-0}" -eq 0 ] && [ "${WEAK:-0}" -eq 0 ] && [ "${MIS:-0}" -eq 0 ]; then
        fail "$CID: no supporting, weakening, or missing evidence"; NO_EV=$((NO_EV + 1))
    fi
    if [ "${MIS:-0}" -gt 0 ]; then
        for j in $(seq 0 $((MIS - 1))); do
            PRI=$(yq -r ".mappings[$i].missing_evidence[$j].priority // \"\"" "$M" 2>/dev/null || echo "")
            [ -n "$PRI" ] && [ "$PRI" != "null" ] || { fail "$CID: missing_evidence[$j] has no priority"; NO_PRI=$((NO_PRI + 1)); }
        done
    fi
done

[ "$NO_SEC" -eq 0 ] && pass "All claims have affected_sections" || true
[ "$NO_EV" -eq 0 ] && pass "All claims have evidence backing" || true
[ "$NO_PRI" -eq 0 ] && pass "All missing_evidence entries have priority" || true
cr_exit_summary
