#!/usr/bin/env python3
"""cr-validate-paper-patch — Validates paper patch types and payload."""
import sys, yaml
from pathlib import Path
def load_yaml(p): 
    with open(p) as f: return yaml.safe_load(f)
VALID = {"paragraph_rewrite","section_restructure","claim_weakening","claim_strengthening","related_work_repositioning","evaluation_obligation_addition","contribution_rewrite"}
def main():
    if len(sys.argv)<2: print("Usage: cr-validate-paper-patch <round_dir>"); sys.exit(1)
    rd = Path(sys.argv[1]); pd = rd/"patches"
    if not pd.exists() or not list(pd.glob("*.yaml")): print("FAIL: no patches"); sys.exit(1)
    errs = []
    for pf in pd.glob("*.yaml"):
        try:
            p = load_yaml(str(pf))
            if p.get("patch_type","") not in VALID: errs.append(f"FAIL: unknown type in {pf.name}")
            pl = p.get("paper_payload") or p.get("payload",{})
            if not pl.get("text_changes"): errs.append(f"FAIL: text_changes required in {pf.name}")
        except Exception as e: errs.append(f"FAIL: {pf.name}: {e}")
    if errs: 
        for e in errs: print(e); sys.exit(1)
    print("PASS")
if __name__=="__main__": main()
