#!/usr/bin/env bash
# cr-validate-proposal-patch — Proposal patch payload validation.
# Usage: cr-validate-proposal-patch <round_dir>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/../../../scripts/cr-common.sh"

ROUND_DIR="${1:-}"
if [ -z "$ROUND_DIR" ]; then
    echo "Usage: cr-validate-proposal-patch <round_dir>" >&2
    exit 2
fi

echo "── Proposal Patch Validation ──"

PATCHES_DIR="$ROUND_DIR/patches"
if [ ! -d "$PATCHES_DIR" ]; then
    warn "patches/ directory not found"
    cr_exit_summary
fi

PATCH_FILES=$(find "$PATCHES_DIR" -name 'PP-*.yaml' -type f 2>/dev/null || echo "")
[ -z "$PATCH_FILES" ] && { warn "no PP-*.yaml patches found"; cr_exit_summary; }

for patch_file in $PATCH_FILES; do
    PATCH_ID=$(basename "$patch_file" .yaml)
    HAS_PROPOSAL=$(yq -r '.proposal // "missing"' "$patch_file" 2>/dev/null || echo "missing")
    [ "$HAS_PROPOSAL" = "missing" ] || [ "$HAS_PROPOSAL" = "null" ] && { fail "$PATCH_ID: missing 'proposal' payload section"; continue; }

    GC_COUNT=$(yq -r '.proposal.goal_changes | length // 0' "$patch_file" 2>/dev/null || echo "0")
    if [ "${GC_COUNT:-0}" -eq 0 ]; then
        fail "$PATCH_ID: proposal.goal_changes is empty"
    else
        for gci in $(seq 0 $((GC_COUNT - 1))); do
            GC_VAL=$(yq -r ".proposal.goal_changes[$gci]" "$patch_file" 2>/dev/null || echo "")
            [ ${#GC_VAL} -lt 5 ] && fail "$PATCH_ID: goal_change[$gci] too short (min 5 chars)"
        done
    fi

    SC_COUNT=$(yq -r '.proposal.scope_changes | length // 0' "$patch_file" 2>/dev/null || echo "0")
    [ "${SC_COUNT:-0}" -eq 0 ] && fail "$PATCH_ID: proposal.scope_changes is empty" || pass "$PATCH_ID: $GC_COUNT goal_change(s), $SC_COUNT scope_change(s)"
done

cr_exit_summary
