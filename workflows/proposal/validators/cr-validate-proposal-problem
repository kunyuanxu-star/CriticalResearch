#!/usr/bin/env python3
"""cr-validate-proposal-problem — Validates problem statement quality."""
import sys, yaml
from pathlib import Path
def load_yaml(p): 
    with open(p) as f: return yaml.safe_load(f)
def main():
    if len(sys.argv)<2: print("Usage: cr-validate-proposal-problem <round_dir>"); sys.exit(1)
    rd = Path(sys.argv[1])
    ps = rd / "problem-state.yaml"
    if not ps.exists(): print("SKIP: no problem-state.yaml"); sys.exit(0)
    d = load_yaml(str(ps))
    if not d: print("WARN: problem-state.yaml is empty"); sys.exit(1)
    print("PASS")
if __name__=="__main__": main()
