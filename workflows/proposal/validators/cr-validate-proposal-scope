#!/usr/bin/env python3
"""cr-validate-proposal-scope — Validates scope boundaries are defined."""
import sys, yaml
from pathlib import Path
def load_yaml(p): 
    with open(p) as f: return yaml.safe_load(f)
def main():
    if len(sys.argv)<2: print("Usage: cr-validate-proposal-scope <round_dir>"); sys.exit(1)
    rd = Path(sys.argv[1])
    ss = rd / "scope-strategy.yaml"
    if not ss.exists(): print("SKIP: no scope-strategy.yaml"); sys.exit(0)
    d = load_yaml(str(ss))
    if not d: print("WARN: scope-strategy.yaml is empty"); sys.exit(1)
    print("PASS")
if __name__=="__main__": main()
