{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://critical-research/schemas/proposal-patch",
  "title": "Proposal Patch",
  "description": "Patch payload schema for proposal workflow modifications.",
  "type": "object",
  "required": ["proposal_payload"],
  "properties": {
    "proposal_payload": {
      "type": "object",
      "required": ["text_changes"],
      "properties": {
        "problem_change": { "type": "string" },
        "contribution_changes": { "type": "array", "items": { "type": "string" } },
        "risk_updates": { "type": "array", "items": { "type": "string" } },
        "milestone_updates": { "type": "array", "items": { "type": "string" } },
        "scope_changes": { "type": "array", "items": { "type": "string" } },
        "text_changes": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object", "required": ["unit","operation"],
            "properties": {
              "unit": { "type": "string" },
              "operation": { "type": "string", "enum": ["insert","replace","delete"] },
              "anchor_after": { "type": "string" },
              "content": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
