{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://critical-research/schemas/survey-patch",
  "title": "Survey Patch",
  "description": "Patch payload schema for survey workflow modifications.",
  "type": "object",
  "required": ["survey_payload"],
  "properties": {
    "survey_payload": {
      "type": "object",
      "required": ["text_changes"],
      "properties": {
        "taxonomy_changes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of taxonomy structure changes (new classes, redefinitions)"
        },
        "comparison_dimensions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Comparison dimensions added or modified"
        },
        "sources_added": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Source IDs added to the survey"
        },
        "sources_removed": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Source IDs removed from the survey"
        },
        "text_changes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["unit", "operation"],
            "properties": {
              "unit": {
                "type": "string",
                "description": "Unit ID being modified"
              },
              "operation": {
                "type": "string",
                "enum": ["insert", "replace", "delete"]
              },
              "anchor_after": {
                "type": "string",
                "description": "Marker text or anchor to insert/delete relative to"
              },
              "content": {
                "type": "string",
                "description": "New content for insert or replacement text"
              }
            }
          }
        }
      }
    }
  }
}
