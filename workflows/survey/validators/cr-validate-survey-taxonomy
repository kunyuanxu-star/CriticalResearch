#!/usr/bin/env bash
# cr-validate-survey-taxonomy — Survey taxonomy dimension validation.
# Checks that taxonomy dimensions are declared and non-empty in either
# round-contract.yaml (scope.taxonomy_dimensions) or survey-state.yaml
# (taxonomy.dimensions).
#
# Usage: cr-validate-survey-taxonomy <round_dir>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/../../scripts/cr-common.sh"

ROUND_DIR="${1:-}"

if [ -z "$ROUND_DIR" ]; then
    echo "Usage: cr-validate-survey-taxonomy <round_dir>" >&2
    exit 2
fi

ROUND_NAME="$(basename "$ROUND_DIR")"
echo ""
echo "══ Survey Taxonomy Validation: $ROUND_NAME ══"

ALL_PASSED=true
FOUND=false

# Check round-contract.yaml for scope.taxonomy_dimensions.
CONTRACT_FILE="$ROUND_DIR/round-contract.yaml"
if [ -f "$CONTRACT_FILE" ]; then
    DIM_COUNT=$(yq -r '.contract.scope.taxonomy_dimensions | length // 0' "$CONTRACT_FILE" 2>/dev/null || echo "0")
    if [ "${DIM_COUNT:-0}" -gt 0 ]; then
        pass "round-contract.yaml: $DIM_COUNT taxonomy dimension(s) in scope"
        FOUND=true
    else
        warn "round-contract.yaml: no taxonomy_dimensions in scope"
    fi
fi

# Check survey-state.yaml for taxonomy.dimensions.
STATE_FILE="$ROUND_DIR/survey-state.yaml"
if [ -f "$STATE_FILE" ]; then
    TAX_DIM_COUNT=$(yq -r '.taxonomy.dimensions | length // 0' "$STATE_FILE" 2>/dev/null || echo "0")
    if [ "${TAX_DIM_COUNT:-0}" -gt 0 ]; then
        pass "survey-state.yaml: $TAX_DIM_COUNT taxonomy dimension(s)"
        FOUND=true
    else
        warn "survey-state.yaml: no taxonomy.dimensions"
    fi
fi

if [ "$FOUND" = false ]; then
    fail "No taxonomy dimensions found in round-contract.yaml or survey-state.yaml"
    ALL_PASSED=false
fi

if [ "$ALL_PASSED" = false ]; then
    cr_exit_summary
fi

pass "Survey taxonomy validation passed"
cr_exit_summary
