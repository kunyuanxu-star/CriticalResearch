#!/usr/bin/env python3
"""
cr-validate-survey-evidence — Verifies that survey claims have source
evidence backing in the evidence ledger.
"""
import sys
import yaml
from pathlib import Path


def load_yaml(path: str) -> dict:
    with open(path) as f:
        return yaml.safe_load(f)


def validate_survey_evidence(round_dir: str) -> list[str]:
    errs = []

    # Check evidence-ledger exists
    ev_file = Path(round_dir) / "evidence-ledger.yaml"
    if not ev_file.exists():
        errs.append("FAIL: evidence-ledger.yaml missing — survey rounds require evidence")
        return errs

    try:
        evidence = load_yaml(str(ev_file))
        entries = evidence.get("entries") or evidence.get("evidence") or []
        if not entries:
            errs.append("WARN: evidence-ledger.yaml has no evidence entries")
    except Exception as e:
        errs.append(f"FAIL: Cannot parse evidence-ledger.yaml: {e}")
        return errs

    # Check each patch's source_trace references valid evidence IDs
    patches_dir = Path(round_dir) / "patches"
    if not patches_dir.exists():
        return errs

    ev_ids = set()
    for entry in entries:
        eid = entry.get("id") or entry.get("evidence_id") or ""
        if eid:
            ev_ids.add(eid)

    for patch_file in patches_dir.glob("*.yaml"):
        try:
            patch = load_yaml(str(patch_file))
            trace = patch.get("source_trace", {})
            refs = trace.get("evidence", [])
            for ref in refs:
                if ref not in ev_ids and ev_ids:
                    errs.append(f"WARN in {patch_file.name}: evidence ref '{ref}' not found in evidence-ledger")
        except Exception as e:
            pass

    if not errs:
        print("PASS: Survey evidence validation passed")
    return errs


def main():
    if len(sys.argv) < 2:
        print("Usage: cr-validate-survey-evidence <round_dir>")
        sys.exit(1)

    round_dir = sys.argv[1]
    errs = validate_survey_evidence(round_dir)

    if errs:
        for e in errs:
            print(e)
        sys.exit(1)
    else:
        sys.exit(0)


if __name__ == "__main__":
    main()
