#!/usr/bin/env python3
"""
cr-validate-survey-patch — Validates that survey patches conform to the
survey-patch schema and have valid patch types.
"""
import sys
import yaml
from pathlib import Path


def load_yaml(path: str) -> dict:
    with open(path) as f:
        return yaml.safe_load(f)


VALID_PATCH_TYPES = {
    "taxonomy_revision",
    "related_work_section_rewrite",
    "comparison_matrix_update",
    "gap_analysis_update",
    "missing_source_addition",
    "terminology_revision",
}


def validate_survey_patch(round_dir: str) -> list[str]:
    errs = []

    patches_dir = Path(round_dir) / "patches"
    if not patches_dir.exists() or not list(patches_dir.glob("*.yaml")):
        errs.append("FAIL: No survey patches found")
        return errs

    for patch_file in patches_dir.glob("*.yaml"):
        try:
            patch = load_yaml(str(patch_file))

            # Check patch_type
            ptype = patch.get("patch_type", "")
            if ptype not in VALID_PATCH_TYPES:
                errs.append(f"FAIL in {patch_file.name}: unknown patch_type '{ptype}' — must be one of {VALID_PATCH_TYPES}")

            # Check payload
            payload = patch.get("survey_payload") or patch.get("payload", {})
            if not payload.get("text_changes"):
                errs.append(f"FAIL in {patch_file.name}: survey_payload.text_changes is required")

            # Check text_changes structure
            for tc in payload.get("text_changes", []):
                if not tc.get("unit"):
                    errs.append(f"FAIL in {patch_file.name}: text_change missing 'unit' field")
                if not tc.get("operation"):
                    errs.append(f"FAIL in {patch_file.name}: text_change missing 'operation' field")
                elif tc["operation"] not in ("insert", "replace", "delete"):
                    errs.append(f"FAIL in {patch_file.name}: unknown operation '{tc['operation']}' — must be insert/replace/delete")

        except Exception as e:
            errs.append(f"FAIL: Cannot parse {patch_file.name}: {e}")

    if not errs:
        print("PASS: All survey patches are valid")
    return errs


def main():
    if len(sys.argv) < 2:
        print("Usage: cr-validate-survey-patch <round_dir>")
        sys.exit(1)

    round_dir = sys.argv[1]
    errs = validate_survey_patch(round_dir)

    if errs:
        for e in errs:
            print(e)
        sys.exit(1)
    else:
        sys.exit(0)


if __name__ == "__main__":
    main()
