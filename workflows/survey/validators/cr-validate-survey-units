#!/usr/bin/env python3
"""
cr-validate-survey-units — Validates that all survey patches target units
declared in the unit registry for the survey document.
"""
import sys
import yaml
from pathlib import Path


def load_yaml(path: str) -> dict:
    with open(path) as f:
        return yaml.safe_load(f)


def validate_survey_units(contract_path: str, project_root: str) -> list[str]:
    errs = []

    contract = load_yaml(contract_path)
    if contract.get("workflow", {}).get("id") != "survey":
        print("SKIP: Not a survey workflow round")
        return errs

    md = contract.get("mutable_document", {})
    doc_id = md.get("id")

    unit_registry_path = Path(project_root) / "units" / f"{doc_id}.units.yaml"
    if not unit_registry_path.exists():
        errs.append(f"FAIL: Unit registry not found: {unit_registry_path}")
        return errs

    registry = load_yaml(str(unit_registry_path))
    registry_units = set()
    for u in registry.get("units", []):
        key = u.get("unit_id") or u.get("id")
        if key:
            registry_units.add(key)

    round_dir = Path(contract_path).parent
    patches_dir = round_dir / "patches"
    if not patches_dir.exists():
        return errs

    for patch_file in patches_dir.glob("*.yaml"):
        try:
            patch = load_yaml(str(patch_file))
            units = patch.get("target_units", [])
            sv_payload = patch.get("survey_payload") or patch.get("payload", {})
            text_changes = sv_payload.get("text_changes", [])
            changed_units = {tc.get("unit") for tc in text_changes if tc.get("unit")}

            for unit in units:
                if unit not in registry_units:
                    errs.append(f"Inv4 violation in {patch_file.name}: target unit '{unit}' not in registry")
            for unit in changed_units:
                if unit not in registry_units:
                    errs.append(f"Inv4 violation in {patch_file.name}: text_change unit '{unit}' not in registry")
        except Exception as e:
            errs.append(f"FAIL: Cannot parse {patch_file.name}: {e}")

    if not errs:
        print("PASS: All survey patch units exist in registry")
    return errs


def main():
    if len(sys.argv) < 2:
        print("Usage: cr-validate-survey-units <contract.yaml> [project_root]")
        sys.exit(1)

    contract_path = sys.argv[1]
    project_root = sys.argv[2] if len(sys.argv) > 2 else str(Path(contract_path).parent.parent.parent)
    errs = validate_survey_units(contract_path, project_root)

    if errs:
        for e in errs:
            print(e)
        sys.exit(1)
    else:
        sys.exit(0)


if __name__ == "__main__":
    main()
