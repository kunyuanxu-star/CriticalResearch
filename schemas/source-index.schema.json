{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Source Index Schema",
  "description": "Indexes all raw source snapshots ingested during a research round.",
  "type": "object",
  "required": ["round_id", "sources"],
  "properties": {
    "round_id": { "type": "integer", "minimum": 1 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source_id", "title", "source_type", "retrieved_at", "snapshot_path", "sha256"],
        "properties": {
          "source_id": { "type": "string", "pattern": "^S[0-9]{3}$" },
          "url": { "type": "string" },
          "title": { "type": "string", "minLength": 1 },
          "source_type": { "type": "string", "enum": ["paper", "system_doc", "code_repo", "blog_post", "issue_thread", "benchmark", "survey", "other"] },
          "retrieved_at": { "type": "string" },
          "snapshot_path": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "metadata": {
            "type": "object",
            "properties": {
              "venue": { "type": "string" },
              "year": { "type": "integer" },
              "authors": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    }
  }
}
