{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stage Manifest Schema",
  "description": "Schema for workflow/stage-manifest.yaml — the single source of truth for stage definitions in an 8-stage paper round.",
  "type": "object",
  "required": ["schema_version", "stage_count", "close_round_is_stage", "execution_policy", "stages"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "stage_count": {
      "type": "integer",
      "minimum": 8,
      "maximum": 8
    },
    "close_round_is_stage": {
      "type": "boolean",
      "enum": [true]
    },
    "execution_policy": {
      "type": "object",
      "required": ["full_round_required", "full_paper_required", "required_stage_count", "allow_partial_stop", "stop_only_on"],
      "properties": {
        "full_round_required": { "type": "boolean", "enum": [true] },
        "full_paper_required": { "type": "boolean", "enum": [true] },
        "required_stage_count": { "type": "integer", "minimum": 8, "maximum": 8 },
        "allow_partial_stop": { "type": "boolean", "enum": [false] },
        "stop_only_on": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "stages": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": { "$ref": "#/definitions/stage" }
    }
  },
  "definitions": {
    "stage": {
      "type": "object",
      "required": [
        "order", "id", "prompt", "dependencies",
        "required_inputs", "required_outputs", "allowed_write_scopes",
        "forbidden_actions", "objective_binding_required",
        "full_paper_coverage_required", "external_review_required",
        "state_required", "no_op_allowed"
      ],
      "properties": {
        "order": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8
        },
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "prompt": {
          "type": "string",
          "pattern": "^prompts/stages/s[0-9]_[a-z0-9_]+\\.md$"
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
        },
        "required_inputs": {
          "type": "array",
          "items": { "$ref": "#/definitions/artifact_ref" }
        },
        "required_outputs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/output_ref" }
        },
        "allowed_write_scopes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "forbidden_actions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "objective_binding_required": { "type": "boolean" },
        "full_paper_coverage_required": { "type": "boolean" },
        "external_review_required": { "type": "boolean", "enum": [false] },
        "state_required": {
          "type": "string",
          "enum": ["running"]
        },
        "no_op_allowed": { "type": "boolean" },
        "coverage_exemption_reason_required": { "type": "boolean" }
      }
    },
    "artifact_ref": {
      "type": "object",
      "required": ["path", "type"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^(project:|round:|workspace:)[^\\s]+$"
        },
        "type": {
          "type": "string",
          "enum": ["yaml", "markdown", "json", "directory"]
        }
      }
    },
    "output_ref": {
      "type": "object",
      "required": ["path", "type"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^(project:|round:|workspace:)[^\\s]+$"
        },
        "type": {
          "type": "string",
          "enum": ["yaml", "markdown", "json", "directory"]
        },
        "schema": {
          "type": "string",
          "pattern": "^schemas/[a-z0-9_-]+\\.schema\\.json$"
        },
        "no_schema_reason": {
          "type": "string",
          "minLength": 10
        }
      }
    }
  }
}
