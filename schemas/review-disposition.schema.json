{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Review Disposition Schema",
  "description": "Per-critique disposition: severity, evidence, decision, required_action, affected_sections. Extends the retired dispositions.schema.json.",
  "type": "object",
  "required": ["schema_version", "round_id", "dispositions"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "round_id": {
      "type": "integer",
      "minimum": 1
    },
    "dispositions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "disposition_id",
          "critique_id",
          "disposition_type",
          "justification",
          "status",
          "required_action"
        ],
        "properties": {
          "disposition_id": {
            "type": "string",
            "pattern": "^DSP-[0-9]{3}$"
          },
          "critique_id": {
            "type": "string",
            "pattern": "^CRT-[0-9]{3}$"
          },
          "disposition_type": {
            "type": "string",
            "enum": [
              "paper_patch",
              "experiment_obligation",
              "claim_deleted",
              "deferred",
              "rejected_with_reason",
              "no_op"
            ]
          },
          "linked_patch_id": {
            "type": "string",
            "pattern": "^PP-[0-9]{3}$"
          },
          "linked_experiment_id": {
            "type": "string",
            "pattern": "^EXP-[0-9]{3}$"
          },
          "justification": {
            "type": "string",
            "minLength": 10
          },
          "status": {
            "type": "string",
            "enum": ["open", "resolved", "pending_human_decision"]
          },
          "severity": {
            "type": "string",
            "enum": ["fatal", "high", "medium"]
          },
          "required_action": {
            "type": "object",
            "required": ["action_type", "target_section", "rationale"],
            "properties": {
              "action_type": {
                "type": "string",
                "enum": ["strengthen", "weaken", "reframe", "delete", "defer", "add_experiment"]
              },
              "target_section": {
                "type": "string"
              },
              "rationale": {
                "type": "string",
                "minLength": 10
              }
            }
          },
          "affected_claims": {
            "type": "array",
            "items": { "type": "string", "pattern": "^CLM-[0-9]{3}$" }
          },
          "affected_sections": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "no_disposition_reason": {
      "type": "string",
      "minLength": 10
    },
    "validated_critiques": {
      "type": "array",
      "items": { "type": "string", "pattern": "^CRT-[0-9]{3}$" }
    }
  }
}
