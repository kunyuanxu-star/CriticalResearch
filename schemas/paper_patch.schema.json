{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://critical-research/schemas/paper_patch.schema.json",
  "title": "Paper Patch",
  "description": "Schema for a paper patch — a proposed change to the paper draft triggered by a critique disposition of type paper_patch.",
  "type": "object",
  "required": ["patch_id", "linked_critique", "linked_round", "severity", "patch_type", "affected_anchors", "proposed_change", "lifecycle_status", "knowledge_implication"],
  "properties": {
    "patch_id": {
      "type": "string",
      "description": "Unique patch identifier within the project.",
      "pattern": "^PP-[0-9]{3}$"
    },
    "linked_critique": {
      "type": "string",
      "description": "Critique that triggered this patch.",
      "pattern": "^CRT-[0-9]{3}$"
    },
    "linked_claim": {
      "type": "string",
      "description": "Claim this patch affects (optional).",
      "pattern": "^CLM-[0-9]{3}$"
    },
    "linked_round": {
      "type": "string",
      "description": "Round that produced this patch."
    },
    "severity": {
      "type": "string",
      "description": "Severity of the triggering critique.",
      "enum": ["fatal", "high", "medium"]
    },
    "patch_type": {
      "type": "array",
      "description": "Types of changes this patch makes.",
      "items": {
        "type": "string",
        "enum": ["weaken_claim", "strengthen_claim", "reframe_contribution", "add_evidence", "remove_claim", "add_limitation", "narrow_scope", "add_evaluation", "rewrite_section", "add_related_work", "fix_terminology", "restructure_argument"]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "affected_anchors": {
      "type": "array",
      "description": "Paper sections this patch targets.",
      "items": {
        "type": "string",
        "enum": ["abstract", "introduction", "background", "motivation", "design", "implementation", "evaluation_plan", "related_work", "discussion", "conclusion"]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "proposed_change": {
      "type": "object",
      "description": "Before/after description of the proposed text change.",
      "required": ["before", "after", "rationale"],
      "properties": {
        "before": { "type": "string", "description": "Current text or claim." },
        "after": { "type": "string", "description": "Proposed replacement text or claim." },
        "rationale": { "type": "string", "description": "Why this change addresses the critique." }
      }
    },
    "experiment_obligations": {
      "type": "array",
      "description": "Linked experiment obligations if this patch changes a claim.",
      "items": {
        "type": "string",
        "pattern": "^EXP-[0-9]{3}$"
      },
      "default": []
    },
    "needs_human_decision": {
      "type": "boolean",
      "description": "Whether this patch requires human judgment gate before application."
    },
    "human_decision_rationale": {
      "type": "string",
      "description": "Why human judgment is required (required when needs_human_decision is true)."
    },
    "options": {
      "type": "array",
      "description": "Alternative resolution options presented to the human reviewer.",
      "items": {
        "type": "object",
        "required": ["label", "description"],
        "properties": {
          "label": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "agent_recommendation": {
      "type": "object",
      "description": "Agent's recommended option and reasoning.",
      "properties": {
        "choice": { "type": "string" },
        "reason": { "type": "string" }
      }
    },
    "knowledge_implication": {
      "type": "object",
      "description": "What reusable knowledge this patch teaches us.",
      "required": ["literature_updates", "thinking_candidates"],
      "properties": {
        "literature_updates": {
          "type": "array",
          "description": "Literature cards to create or update.",
          "items": { "type": "string" }
        },
        "thinking_candidates": {
          "type": "array",
          "description": "Thinking rule candidates derived from this patch.",
          "items": {
            "type": "object",
            "required": ["rule", "category"],
            "properties": {
              "rule": { "type": "string", "description": "Candidate rule statement." },
              "category": {
                "type": "string",
                "enum": ["research_principle", "writing_rule", "reviewer_pattern", "anti_pattern", "experiment_pattern"]
              }
            }
          }
        }
      }
    },
    "lifecycle_status": {
      "type": "string",
      "description": "Current state in the patch lifecycle.",
      "enum": ["proposed", "needs_human_decision", "approved", "recorded", "applied", "rejected", "superseded"]
    },
    "lifecycle_history": {
      "type": "array",
      "description": "Ordered history of lifecycle transitions.",
      "items": {
        "type": "object",
        "required": ["from", "to", "timestamp"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "reason": { "type": "string" }
        }
      }
    },
    "superseded_by": {
      "type": "string",
      "description": "Patch ID that supersedes this one (required when lifecycle_status is superseded).",
      "pattern": "^PP-[0-9]{3}$"
    },
    "rejection_reason": {
      "type": "string",
      "description": "Reason for rejection (required when lifecycle_status is rejected)."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "applied_at": {
      "type": "string",
      "format": "date-time",
      "description": "When this patch was applied to paper-draft.md."
    },
    "applied_diff_anchor": {
      "type": "string",
      "description": "Anchor in diff-log.md recording the applied change."
    }
  },
  "additionalProperties": false
}
