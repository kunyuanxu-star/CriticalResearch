{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Experiment Obligations Schema",
  "description": "Records experiment obligations for a round. May have zero obligations with an explicit no-op reason.",
  "type": "object",
  "required": ["schema_version", "round_id", "obligations"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "round_id": { "type": "integer", "minimum": 1 },
    "phase": { "type": "string" },
    "obligations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["obligation_id", "linked_patch_id", "target_claim"],
        "properties": {
          "obligation_id": { "type": "string", "pattern": "^EXP-[0-9]{3}$" },
          "path": { "type": "string" },
          "linked_patch_id": { "type": "string", "pattern": "^PP-[0-9]{3}$" },
          "target_claim": { "type": "string" },
          "claim_type": { "type": "string" },
          "baseline": { "type": "string" },
          "metric": { "type": "string" },
          "support_condition": { "type": "string" },
          "refute_condition": { "type": "string" },
          "status": { "type": "string", "enum": ["planned", "designed", "executed", "analyzed", "integrated"] }
        }
      }
    },
    "no_obligation_reason": { "type": ["string", "null"] },
    "validated_patches": {
      "type": "array",
      "items": { "type": "string", "pattern": "^PP-[0-9]{3}$" }
    }
  }
}
