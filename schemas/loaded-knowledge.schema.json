{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Loaded Knowledge Schema",
  "description": "Global knowledge cards loaded for this round, with usage contract specifying where they must be referenced.",
  "type": "object",
  "required": ["schema_version", "round_id", "loaded_cards"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "round_id": { "type": "integer", "minimum": 1 },
    "loaded_cards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["card_id", "card_type", "reason_loaded"],
        "properties": {
          "card_id": { "type": "string" },
          "card_type": { "type": "string", "enum": ["thinking", "literature"] },
          "maturity": { "type": "string", "enum": ["candidate", "used", "validated", "canonical", "deprecated"] },
          "path": { "type": "string" },
          "reason_loaded": { "type": "string" },
          "required_use": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "ignored_cards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["card_id", "reason_ignored"],
        "properties": {
          "card_id": { "type": "string" },
          "reason_ignored": { "type": "string" }
        }
      }
    },
    "usage_contract": {
      "type": "object",
      "properties": {
        "must_reference_loaded_cards_in": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
