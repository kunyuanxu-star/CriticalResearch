{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Next Round Targets Schema",
  "description": "Candidate risks and priorities for the next round, with structured options and rationale. Required by S8 round_closure.",
  "type": "object",
  "required": ["schema_version", "round_id", "candidates"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "round_id": {
      "type": "integer",
      "minimum": 1
    },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["candidate_id", "title", "rationale"],
        "properties": {
          "candidate_id": {
            "type": "string",
            "pattern": "^NRC-[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 5
          },
          "rationale": {
            "type": "string",
            "minLength": 10
          },
          "linked_critiques": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^CRT-[0-9]{3}$"
            }
          },
          "linked_claims": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^CLM-[0-9]{3}$"
            }
          },
          "priority": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          }
        }
      }
    }
  }
}
