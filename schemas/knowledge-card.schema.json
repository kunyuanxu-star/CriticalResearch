{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Knowledge Card Schema",
  "description": "Global knowledge card with scope, anti-scope, maturity, and provenance. Used across rounds and projects.",
  "type": "object",
  "required": ["schema_version", "id", "type", "title", "status", "scope", "rule", "derived_from_rounds"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "id": { "type": "string", "pattern": "^KW-[A-Z]+-[0-9]{4}$" },
    "type": { "type": "string", "enum": ["literature_fact", "domain_rule", "method_knowledge", "writing_rule", "reviewer_pattern", "project_note"] },
    "title": { "type": "string" },
    "status": { "type": "string", "enum": ["candidate", "validated", "canonical", "deprecated"] },
    "scope": {
      "type": "object",
      "properties": {
        "domains": { "type": "array", "items": { "type": "string" } },
        "paper_sections": { "type": "array", "items": { "type": "string" } },
        "paper_types": { "type": "array", "items": { "type": "string" } }
      }
    },
    "applies_when": { "type": "array", "items": { "type": "string" } },
    "does_not_apply_when": { "type": "array", "items": { "type": "string" } },
    "rule": { "type": "string" },
    "evidence": {
      "type": "object",
      "properties": {
        "derived_from_rounds": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "project": { "type": "string" },
              "round": { "type": "integer" },
              "artifacts": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "maturity": {
      "type": "object",
      "properties": {
        "level": { "type": "string", "enum": ["candidate", "validated", "canonical"] },
        "validation_count": { "type": "integer", "minimum": 0 }
      }
    },
    "last_used": {
      "type": "object",
      "properties": {
        "project": { "type": "string" },
        "round": { "type": "integer" }
      }
    },
    "deprecation": {
      "type": "object",
      "properties": {
        "reason": { "type": "string" },
        "superseded_by": { "type": "string" }
      }
    }
  }
}
