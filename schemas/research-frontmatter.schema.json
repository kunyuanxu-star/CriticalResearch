{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CriticalResearch research.md frontmatter",
  "type": "object",
  "required": [
    "schema_version",
    "project_id",
    "run_id",
    "status",
    "phase",
    "objective",
    "mode",
    "loop_count",
    "loop_budget",
    "weakest_link",
    "next_action",
    "validation",
    "convergence",
    "gate",
    "debug_trace",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "project_id": { "type": "string" },
    "run_id": { "type": "string", "pattern": "^run-[0-9]{3}$" },
    "status": {
      "enum": ["draft", "forming", "reviewing", "repairing", "complete", "blocked", "gated", "budget_exhausted", "invalid"]
    },
    "phase": { "enum": ["init", "formation", "review", "repair", "final"] },
    "objective": { "type": "string" },
    "mode": { "enum": ["quick", "standard", "deep"] },
    "loop_count": { "type": "integer", "minimum": 0 },
    "loop_budget": { "type": "integer", "minimum": 1 },
    "weakest_link": {
      "enum": ["basic_system", "contradiction", "strawman", "root_cause", "insight", "design", "proof_plan", "evidence", "writing", "scope"]
    },
    "next_action": { "type": "string" },
    "validation": {
      "type": "object",
      "required": ["error_count", "warning_count", "blocking_attack_count"],
      "properties": {
        "error_count": { "type": "integer", "minimum": 0 },
        "warning_count": { "type": "integer", "minimum": 0 },
        "blocking_attack_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "convergence": {
      "type": "object",
      "required": ["stall_count", "repeated_attack_count", "scope_challenge_count", "progress_signal"],
      "properties": {
        "stall_count": { "type": "integer", "minimum": 0 },
        "repeated_attack_count": { "type": "integer", "minimum": 0 },
        "scope_challenge_count": { "type": "integer", "minimum": 0 },
        "progress_signal": { "type": "string" }
      },
      "additionalProperties": false
    },
    "gate": {
      "type": "object",
      "required": ["type", "description"],
      "properties": {
        "type": {
          "enum": ["none", "user_input", "external_evidence", "data_access", "compute", "literature", "implementation"]
        },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "debug_trace": { "type": "boolean" },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" }
  }
}
