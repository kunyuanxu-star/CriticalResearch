{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Anchor Specification Schema",
  "description": "Maps anchor IDs to named sections in the paper draft. Used by cr-validate-anchors and cr-validate-patch-application to verify patch targets resolve to real draft locations.",
  "type": "object",
  "required": ["schema_version", "anchors"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "anchors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["anchor_id", "section", "file"],
        "properties": {
          "anchor_id": { "type": "string" },
          "section": { "type": "string", "enum": ["abstract", "introduction", "background", "motivation", "problem", "design", "implementation", "evaluation", "evaluation_plan", "related_work", "discussion", "limitations", "conclusion", "appendix"] },
          "file": { "type": "string" },
          "line_start": { "type": "integer", "minimum": 1 },
          "line_end": { "type": "integer", "minimum": 1 },
          "description": { "type": "string" }
        }
      }
    }
  }
}
