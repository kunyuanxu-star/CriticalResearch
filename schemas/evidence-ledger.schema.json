{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Evidence Ledger Schema",
  "description": "Structured, normalized evidence items, each linked to a source and a claim. This is the authoritative evidence artifact for paper rounds.",
  "type": "object",
  "required": ["round_id", "evidence"],
  "properties": {
    "round_id": { "type": "integer", "minimum": 1 },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["evidence_id", "source_id", "source_type", "evidence_level", "related_claims", "relation", "direct_support", "does_not_support", "applicable_scenario", "allowed_wording", "forbidden_wording"],
        "properties": {
          "evidence_id": { "type": "string", "pattern": "^E[0-9]{3}$" },
          "source_id": { "type": "string", "pattern": "^S[0-9]{3}$" },
          "source_type": { "type": "string" },
          "evidence_level": { "type": "string", "enum": ["S", "A", "B", "C", "D"] },
          "related_claims": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^CLM-[0-9]{3}$" }
          },
          "relation": { "type": "string", "enum": ["supports", "weakens", "contextualizes", "contradicts"] },
          "direct_support": { "type": "string", "minLength": 10 },
          "does_not_support": { "type": "string", "minLength": 10 },
          "applicable_scenario": { "type": "string", "minLength": 5 },
          "allowed_wording": { "type": "string", "minLength": 10 },
          "forbidden_wording": { "type": "string", "minLength": 10 }
        }
      }
    }
  }
}
