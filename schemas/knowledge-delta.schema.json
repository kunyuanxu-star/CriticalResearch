{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Knowledge Delta Schema",
  "description": "Structured YAML transaction recording reusable knowledge generated this round. This is the authoritative knowledge artifact; knowledge-delta.md is a human-readable report.",
  "type": "object",
  "required": ["schema_version", "round_id", "updates"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "round_id": { "type": "integer", "minimum": 1 },
    "no_update_justification": { "type": ["string", "null"] },
    "updates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["update_id", "update_type", "scope", "operation"],
        "properties": {
          "update_id": { "type": "string", "pattern": "^KDU-[0-9]{3}$" },
          "update_type": { "type": "string", "enum": ["thinking_rule", "literature_card", "research_principle", "writing_rule", "evaluation_pattern"] },
          "scope": { "type": "string", "enum": ["candidate_reusable", "bank_update", "project_local"] },
          "operation": { "type": "string", "enum": ["create_card", "update_card", "append_comparison", "deprecate_card"] },
          "proposed_card_id": { "type": "string" },
          "target_path": { "type": "string" },
          "generated_from": {
            "type": "object",
            "properties": {
              "patches": { "type": "array", "items": { "type": "string", "pattern": "^PP-[0-9]{3}$" } },
              "critiques": { "type": "array", "items": { "type": "string", "pattern": "^CRT-[0-9]{3}$" } },
              "evidence": { "type": "array", "items": { "type": "string", "pattern": "^E[0-9]{3}$" } }
            }
          },
          "rule": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "statement": { "type": "string", "minLength": 10 },
              "applies_to": { "type": "array", "items": { "type": "string" } },
              "anti_examples": { "type": "array", "items": { "type": "string" } }
            }
          },
          "content_summary": { "type": "string" },
          "maturity": { "type": "string", "enum": ["candidate", "used", "validated", "canonical", "deprecated"] }
        }
      }
    }
  }
}
