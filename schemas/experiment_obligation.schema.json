{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://critical-research/schemas/experiment_obligation.schema.json",
  "title": "Experiment Obligation",
  "description": "Schema for an experiment obligation — records what must be measured when a claim-level paper patch is proposed.",
  "type": "object",
  "required": ["experiment_id", "target_claim", "baseline", "metric", "support_condition", "refute_condition"],
  "properties": {
    "experiment_id": {
      "type": "string",
      "pattern": "^EXP-[0-9]{3}$"
    },
    "target_claim": {
      "type": "string",
      "description": "The claim this experiment is designed to support or refute.",
      "pattern": "^CLM-[0-9]{3}$"
    },
    "linked_patch_id": {
      "type": "string",
      "description": "Paper patch that triggered this obligation.",
      "pattern": "^PP-[0-9]{3}$"
    },
    "linked_round": { "type": "string" },
    "baseline": {
      "type": "string",
      "description": "The strongest baseline system or approach to compare against."
    },
    "test_cases": {
      "type": "array",
      "description": "Specific test scenarios.",
      "items": {
        "type": "object",
        "required": ["name", "description", "expected_outcome"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "expected_outcome": { "type": "string" },
          "is_negative_test": { "type": "boolean", "description": "Whether this test attempts to violate the claimed property." }
        }
      },
      "minItems": 1
    },
    "metric": {
      "type": "string",
      "description": "Primary metric for evaluating the claim."
    },
    "support_condition": {
      "type": "string",
      "description": "What result would support the claim."
    },
    "refute_condition": {
      "type": "string",
      "description": "What result would refute the claim."
    },
    "claim_type": {
      "type": "string",
      "enum": ["performance", "accuracy", "security", "privacy", "correctness", "usability", "expressiveness", "scalability", "generality", "theoretical", "measurement", "causal", "design"],
      "description": "Claim type per evaluation-contracts.md taxonomy."
    },
    "workload_plan": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["proposed", "designed", "executed", "analyzed", "integrated"],
      "default": "proposed"
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
