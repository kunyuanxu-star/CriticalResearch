{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dispositions Schema",
  "description": "Round-level disposition records wrapper. Contains an array of individual disposition entries plus optional no-op record.",
  "type": "object",
  "required": [
    "schema_version",
    "round_id",
    "dispositions"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "round_id": {
      "type": "integer",
      "minimum": 1
    },
    "dispositions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "critique_id",
          "disposition_type",
          "justification",
          "status"
        ],
        "properties": {
          "critique_id": {
            "type": "string",
            "pattern": "^CRT-[0-9]{3}$"
          },
          "disposition_type": {
            "type": "string",
            "enum": [
              "paper_patch",
              "experiment_obligation",
              "claim_deleted",
              "deferred",
              "rejected_with_reason",
              "no_op"
            ]
          },
          "linked_patch_id": {
            "type": "string",
            "pattern": "^PP-[0-9]{3}$"
          },
          "linked_experiment_id": {
            "type": "string",
            "pattern": "^EXP-[0-9]{3}$"
          },
          "justification": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "resolved"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "fatal",
              "high",
              "medium"
            ]
          }
        }
      }
    },
    "no_disposition_reason": {
      "type": "string"
    },
    "validated_critiques": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^CRT-[0-9]{3}$"
      }
    }
  }
}