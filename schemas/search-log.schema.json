{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Search Log Schema",
  "description": "Records every search query executed during a research round, with results and source selection.",
  "type": "object",
  "required": ["round_id", "searches"],
  "properties": {
    "round_id": { "type": "integer", "minimum": 1 },
    "searches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["query_id", "query", "adapter", "executed_at", "returned_count", "selected_sources"],
        "properties": {
          "query_id": { "type": "string", "pattern": "^Q[0-9]{3}$" },
          "query_class": { "type": "string", "enum": ["core_problem", "strongest_baseline", "recent_top_conference", "production_or_real_world_case", "counterexample_or_failure"] },
          "query": { "type": "string", "minLength": 5 },
          "adapter": { "type": "string", "enum": ["web", "scholar", "arxiv", "github", "manual"] },
          "executed_at": { "type": "string" },
          "returned_count": { "type": "integer", "minimum": 0 },
          "selected_sources": {
            "type": "array",
            "items": { "type": "string", "pattern": "^S[0-9]{3}$" }
          },
          "rejected_sources": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["url", "reason"],
              "properties": {
                "url": { "type": "string" },
                "reason": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
