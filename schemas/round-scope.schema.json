{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Round Scope Schema",
  "description": "Frozen scope boundary. Required by S04 freeze_round_scope.",
  "type": "object",
  "required": ["schema_version"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
  }
}
