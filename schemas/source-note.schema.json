{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Source Note Schema",
  "description": "Deep-reading notes per source. Required by S10 read_sources.",
  "type": "object",
  "required": ["schema_version"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
  }
}
