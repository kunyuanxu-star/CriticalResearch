{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://critical-research/schemas/literature_card.schema.json",
  "title": "Literature Knowledge Card",
  "description": "Schema for a literature knowledge card — papers, systems, concepts, or debates with understanding levels L0-L5.",
  "type": "object",
  "required": ["card_id", "card_type", "title", "understanding_level"],
  "properties": {
    "card_id": { "type": "string", "description": "Unique card identifier (e.g., transformer-attention, mapreduce)." },
    "card_type": { "type": "string", "enum": ["paper", "system", "concept", "debate", "comparison"] },
    "title": { "type": "string" },
    "area": { "type": "array", "items": { "type": "string" } },
    "venue": { "type": "string" },
    "year": { "type": "integer" },
    "understanding_level": { "type": "string", "enum": ["L0", "L1", "L2", "L3", "L4", "L5"] },
    "previous_level": { "type": "string", "enum": ["L0", "L1", "L2", "L3", "L4", "L5"] },
    "updated_by_round": { "type": "string" },
    "reason_for_upgrade": { "type": "string" },
    "one_sentence_understanding": { "type": "string" },
    "core_mechanism": { "type": "string" },
    "what_it_supports": { "type": "array", "items": { "type": "string" } },
    "what_it_weakens": { "type": "array", "items": { "type": "string" } },
    "what_it_does_not_prove": { "type": "array", "items": { "type": "string" } },
    "relevance_to_projects": { "type": "object", "description": "Per-project relevance notes." },
    "positioning_guidance": { "type": "string" },
    "understanding_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["round", "description"],
        "properties": {
          "round": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "open_questions": { "type": "array", "items": { "type": "string" } },
    "linked_knowledge": { "type": "array", "items": { "type": "string" }, "description": "Linked thinking or literature card IDs." },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
