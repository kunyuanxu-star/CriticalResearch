{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CriticalResearch autonomous progress",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "iteration",
    "status",
    "last_seen",
    "stale_count",
    "total_findings",
    "validation_error_count",
    "warning_count",
    "blocking_attack_count",
    "weakest_link",
    "current_direction_id",
    "terminal_reason"
  ],
  "properties": {
    "schema_version": { "const": "3.0.0" },
    "run_id": { "type": "string", "pattern": "^run-[0-9]{3}$" },
    "iteration": { "type": "integer", "minimum": 0 },
    "status": {
      "enum": ["draft", "forming", "reviewing", "repairing", "complete", "blocked", "gated", "budget_exhausted", "invalid"]
    },
    "last_seen": { "type": "string" },
    "stale_count": { "type": "integer", "minimum": 0 },
    "total_findings": { "type": "integer", "minimum": 0 },
    "validation_error_count": { "type": "integer", "minimum": 0 },
    "warning_count": { "type": "integer", "minimum": 0 },
    "blocking_attack_count": { "type": "integer", "minimum": 0 },
    "weakest_link": {
      "enum": ["basic_system", "contradiction", "strawman", "root_cause", "insight", "design", "proof_plan", "evidence", "writing", "scope"]
    },
    "current_direction_id": { "type": ["string", "null"] },
    "terminal_reason": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
