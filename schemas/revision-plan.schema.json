{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Revision Plan Schema",
  "description": "Claim-level, structure-level, and evidence-level revision decisions derived from review dispositions.",
  "type": "object",
  "required": ["schema_version", "round_id", "revisions"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "round_id": {
      "type": "integer",
      "minimum": 1
    },
    "revisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["revision_id", "level", "decision", "rationale"],
        "properties": {
          "revision_id": {
            "type": "string",
            "pattern": "^REV-[0-9]{3}$"
          },
          "level": {
            "type": "string",
            "enum": ["claim", "structure", "evidence"]
          },
          "decision": {
            "type": "string",
            "minLength": 5
          },
          "rationale": {
            "type": "string",
            "minLength": 10
          },
          "source_dispositions": {
            "type": "array",
            "items": { "type": "string", "pattern": "^DSP-[0-9]{3}$" }
          },
          "source_critiques": {
            "type": "array",
            "items": { "type": "string", "pattern": "^CRT-[0-9]{3}$" }
          },
          "target_sections": {
            "type": "array",
            "items": { "type": "string" }
          },
          "target_claims": {
            "type": "array",
            "items": { "type": "string", "pattern": "^CLM-[0-9]{3}$" }
          },
          "status": {
            "type": "string",
            "enum": ["pending_human_decision", "approved", "blocked", "implemented"]
          }
        }
      }
    },
    "no_revision_reason": {
      "type": "string",
      "minLength": 10
    }
  }
}
