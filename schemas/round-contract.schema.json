{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Round Contract Schema",
  "description": "Formalizes user intent into target, scope, intensity, required outputs, forbidden scope, and success criteria for a paper-improvement round.",
  "type": "object",
  "required": ["schema_version", "round_id", "contract"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "round_id": {
      "type": "integer",
      "minimum": 1
    },
    "contract": {
      "type": "object",
      "required": ["target", "scope", "intensity", "required_outputs", "success_criteria"],
      "properties": {
        "target": {
          "type": "string",
          "minLength": 10
        },
        "scope": {
          "type": "object",
          "required": ["sections", "claims", "forbidden_scope"],
          "properties": {
            "sections": {
              "type": "array",
              "items": { "type": "string" }
            },
            "claims": {
              "type": "array",
              "items": { "type": "string", "pattern": "^CLM-[0-9]{3}$" }
            },
            "forbidden_scope": {
              "type": "array",
              "items": { "type": "string", "minLength": 5 }
            }
          }
        },
        "intensity": {
          "type": "string",
          "enum": ["triage", "standard", "deep"]
        },
        "required_outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "evidence_ledger",
              "critique_ledger",
              "review_disposition",
              "revision_plan",
              "patch_plan",
              "patch_trace",
              "writing_diff",
              "knowledge_delta",
              "next_round_targets"
            ]
          }
        },
        "success_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["criterion_id", "statement"],
            "properties": {
              "criterion_id": {
                "type": "string",
                "pattern": "^SC-[0-9]{3}$"
              },
              "statement": {
                "type": "string",
                "minLength": 10
              },
              "metric": {
                "type": "string"
              },
              "threshold": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "no_contract_reason": {
      "type": "string",
      "minLength": 10
    }
  }
}
