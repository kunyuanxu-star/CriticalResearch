{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "No-Patch Decision Schema",
  "description": "Structured record when no paper patches are generated in a round.",
  "type": "object",
  "required": [
    "schema_version",
    "round_id",
    "no_patch_reason"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "round_id": {
      "type": "integer",
      "minimum": 1
    },
    "no_patch_reason": {
      "type": "string",
      "minLength": 10
    },
    "validated_dispositions": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^DSP-[0-9]{3}$"
      }
    }
  }
}