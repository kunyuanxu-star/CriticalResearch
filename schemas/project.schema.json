{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://critical-research/schemas/project.schema.json",
  "title": "Project Manifest",
  "description": "Schema for project.yaml — project metadata and document registry.",
  "type": "object",
  "required": ["project_id", "schema_version"],
  "properties": {
    "project_id": {
      "type": "string",
      "description": "Unique project identifier.",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "target_standard": {
      "type": "string",
      "description": "Target quality standard or venue."
    },
    "paper_profile": {
      "type": "string",
      "description": "Legacy profile field for backward compatibility."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "description": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "documents": {
      "$ref": "document-registry.schema.json"
    }
  },
  "additionalProperties": true
}
