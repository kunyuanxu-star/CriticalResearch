{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Research Plan Schema",
  "description": "Defines the research plan for a paper round, including research questions, query classes, and success criteria.",
  "type": "object",
  "required": ["round_id", "target_gap", "research_questions", "required_query_classes", "success_criteria"],
  "properties": {
    "round_id": { "type": "integer", "minimum": 1 },
    "target_gap": { "type": "string" },
    "research_questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "question", "affected_claims"],
        "properties": {
          "id": { "type": "string", "pattern": "^RQ[0-9]+$" },
          "question": { "type": "string", "minLength": 10 },
          "affected_claims": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^CLM-[0-9]{3}$" }
          }
        }
      }
    },
    "required_query_classes": {
      "type": "array",
      "minItems": 5,
      "uniqueItems": true,
      "items": { "type": "string", "enum": ["core_problem", "strongest_baseline", "recent_top_conference", "production_or_real_world_case", "counterexample_or_failure"] }
    },
    "success_criteria": {
      "type": "object",
      "required": ["min_queries", "min_sources", "min_s_or_a_sources", "must_find_or_record_failure_for_each_query_class"],
      "properties": {
        "min_queries": { "type": "integer", "minimum": 1 },
        "min_sources": { "type": "integer", "minimum": 1 },
        "min_s_or_a_sources": { "type": "integer", "minimum": 1 },
        "must_find_or_record_failure_for_each_query_class": { "type": "boolean" }
      }
    }
  }
}
