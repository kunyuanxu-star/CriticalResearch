{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Round State Schema (Strict Paper State Machine)",
  "description": "Per-round 37-phase strict state machine. Tracks phase status, dependencies, required inputs/outputs, allowed/forbidden actions, and no-op policies. Upgraded from 14-phase paper mode to 37-phase strict paper.",
  "type": "object",
  "required": ["schema_version", "project_id", "round_id", "workflow_mode", "status", "current_phase", "phase_order", "phases", "closure_policy"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "project_id": { "type": "string" },
    "round_id": { "type": "integer", "minimum": 1 },
    "workflow_mode": { "type": "string", "enum": ["triage", "standard", "deep", "paper"] },
    "status": { "type": "string", "enum": ["open", "in_progress", "complete"] },
    "current_phase": { "type": "string" },
    "required_research": { "type": "boolean" },
    "required_min_sources": { "type": "integer", "minimum": 0 },
    "required_source_levels": {
      "type": "object",
      "properties": {
        "min_s_or_a": { "type": "integer", "minimum": 0 },
        "allow_b": { "type": "boolean" },
        "allow_c_only_as_lead": { "type": "boolean" }
      }
    },
    "phase_order": {
      "type": "array",
      "minItems": 37,
      "maxItems": 37,
      "items": { "type": "string" }
    },
    "phases": {
      "type": "object",
      "properties": {
        "snapshot_paper_state": { "$ref": "#/$defs/phase" },
        "load_project_knowledge": { "$ref": "#/$defs/phase" },
        "define_round_risk": { "$ref": "#/$defs/phase" },
        "freeze_round_scope": { "$ref": "#/$defs/phase" },
        "plan_research_questions": { "$ref": "#/$defs/phase" },
        "generate_search_strategy": { "$ref": "#/$defs/phase" },
        "execute_retrieval": { "$ref": "#/$defs/phase" },
        "triage_sources": { "$ref": "#/$defs/phase" },
        "ingest_sources": { "$ref": "#/$defs/phase" },
        "read_sources": { "$ref": "#/$defs/phase" },
        "normalize_evidence": { "$ref": "#/$defs/phase" },
        "build_related_work_map": { "$ref": "#/$defs/phase" },
        "update_literature_knowledge": { "$ref": "#/$defs/phase" },
        "synthesize_claim_evidence": { "$ref": "#/$defs/phase" },
        "synthesize_baseline_positioning": { "$ref": "#/$defs/phase" },
        "synthesize_evaluation_gaps": { "$ref": "#/$defs/phase" },
        "critique_claim_precision": { "$ref": "#/$defs/phase" },
        "critique_novelty_and_baselines": { "$ref": "#/$defs/phase" },
        "critique_evidence_sufficiency": { "$ref": "#/$defs/phase" },
        "critique_evaluation_contract": { "$ref": "#/$defs/phase" },
        "critique_writing_argument": { "$ref": "#/$defs/phase" },
        "merge_critique_ledger": { "$ref": "#/$defs/phase" },
        "generate_dispositions": { "$ref": "#/$defs/phase" },
        "resolve_human_decisions": { "$ref": "#/$defs/phase" },
        "generate_paper_patches": { "$ref": "#/$defs/phase" },
        "generate_experiment_obligations": { "$ref": "#/$defs/phase" },
        "plan_writing_changes": { "$ref": "#/$defs/phase" },
        "apply_local_section_patches": { "$ref": "#/$defs/phase" },
        "validate_patch_application": { "$ref": "#/$defs/phase" },
        "global_argument_pass": { "$ref": "#/$defs/phase" },
        "claim_evidence_alignment_pass": { "$ref": "#/$defs/phase" },
        "reviewer_readiness_pass": { "$ref": "#/$defs/phase" },
        "distill_literature_knowledge": { "$ref": "#/$defs/phase" },
        "distill_thinking_knowledge": { "$ref": "#/$defs/phase" },
        "apply_knowledge_delta": { "$ref": "#/$defs/phase" },
        "prepare_next_round": { "$ref": "#/$defs/phase" },
        "close_round": { "$ref": "#/$defs/phase" }
      }
    },
    "closure_policy": {
      "type": "object",
      "properties": {
        "require_all_phases_complete": { "type": "boolean" },
        "require_external_research": { "type": "boolean" },
        "require_no_skipped_phases": { "type": "boolean" },
        "require_no_pending_human_decisions": { "type": "boolean" },
        "require_transaction_chain_complete": { "type": "boolean" },
        "require_patch_for_medium_plus_critique": { "type": "boolean" },
        "require_experiment_for_claim_patch": { "type": "boolean" },
        "require_draft_diff_for_applied_patch": { "type": "boolean" },
        "require_knowledge_writeback": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "phase": {
      "type": "object",
      "required": ["status", "depends_on", "required_outputs"],
      "properties": {
        "status": { "type": "string", "enum": ["blocked", "open", "running", "waiting_human", "repair_required", "complete"] },
        "started_at": { "type": ["string", "null"] },
        "completed_at": { "type": ["string", "null"] },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" }
        },
        "required_inputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "required_outputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allowed_actions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Actions permitted during this phase"
        },
        "forbidden_actions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Actions forbidden during this phase"
        },
        "no_op_policy": {
          "type": "object",
          "properties": {
            "allowed": { "type": "boolean" },
            "required_justification_fields": {
              "type": "array",
              "items": { "type": "string" }
            },
            "artifact_path": { "type": "string" }
          }
        },
        "completion_predicate": {
          "type": "object",
          "properties": {
            "all_outputs_exist": { "type": "boolean" },
            "validator_passed": { "type": "boolean" },
            "no_unresolved_blockers": { "type": "boolean" }
          }
        },
        "phase_validators_hint": {
          "type": "array",
          "items": { "type": "string" }
        },
        "prompt": {
          "type": "string",
          "description": "Path to the phase-specific prompt file"
        },
        "prompt_hash": {
          "type": ["string", "null"],
          "description": "SHA256 hash of the prompt file for integrity verification"
        }
      }
    }
  }
}