{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://critical-research/schemas/thinking_card.schema.json",
  "title": "Thinking Knowledge Card",
  "description": "Schema for a reusable thinking rule card — research principles, writing rules, reviewer patterns, anti-patterns, or experiment patterns with maturity tracking.",
  "type": "object",
  "required": ["card_id", "card_type", "title", "status", "rule", "why_this_matters", "learned_from", "how_to_apply"],
  "properties": {
    "card_id": {
      "type": "string",
      "description": "Unique card identifier within workspace scope.",
      "pattern": "^(RP|WR|RV|AP|EP)-[0-9]{4}$"
    },
    "card_type": {
      "type": "string",
      "enum": ["research_principle", "writing_rule", "reviewer_pattern", "anti_pattern", "experiment_pattern"]
    },
    "title": {
      "type": "string",
      "description": "Short descriptive title (e.g., 'Strongest Baseline First')."
    },
    "status": {
      "type": "string",
      "description": "Maturity state of this rule.",
      "enum": ["candidate", "used", "validated", "canonical", "deprecated"]
    },
    "rule": {
      "type": "string",
      "description": "The rule statement — concise and actionable."
    },
    "why_this_matters": {
      "type": "string",
      "description": "Why this rule improves research quality."
    },
    "learned_from": {
      "type": "array",
      "description": "Sources: critiques, patches, debates, decisions that produced this rule.",
      "items": {
        "type": "object",
        "required": ["source_type", "source_id", "description"],
        "properties": {
          "source_type": { "type": "string", "enum": ["critique", "paper_patch", "human_decision", "debate", "writing_diff"] },
          "source_id": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "how_to_apply": {
      "type": "array",
      "description": "Step-by-step application instructions.",
      "items": { "type": "string" }
    },
    "failure_mode": {
      "type": "string",
      "description": "When this rule should NOT be applied (overuse risk)."
    },
    "applies_to": {
      "type": "array",
      "description": "Paper domains or claim types this rule applies to.",
      "items": { "type": "string" }
    },
    "does_not_apply_to": {
      "type": "array",
      "description": "Contexts where this rule is inappropriate.",
      "items": { "type": "string" }
    },
    "linked_cards": {
      "type": "array",
      "description": "Related thinking card IDs.",
      "items": { "type": "string", "pattern": "^(RP|WR|RV|AP|EP)-[0-9]{4}$" }
    },
    "usage_history": {
      "type": "array",
      "description": "Recorded uses of this rule across projects and rounds.",
      "items": {
        "type": "object",
        "required": ["project", "round", "description"],
        "properties": {
          "project": { "type": "string" },
          "round": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "promotion_history": {
      "type": "array",
      "description": "Status transitions with evidence.",
      "items": {
        "type": "object",
        "required": ["from", "to", "timestamp", "evidence"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "evidence": { "type": "string" },
          "approved_by": { "type": "string", "description": "Required for validated→canonical promotion." }
        }
      }
    },
    "deprecation_reason": {
      "type": "string",
      "description": "Required when status is deprecated."
    },
    "contradicted_by": {
      "type": "string",
      "description": "Evidence that contradicted this rule (for deprecation)."
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
