{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Paper State Schema (v3)",
  "description": "Frozen snapshot of current paper claims, baselines, assumptions, risks, and fragile sections. Required by S01 snapshot_paper_state.",
  "type": "object",
  "required": ["schema_version", "round_id", "thesis", "core_claims", "fragile_claims"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "round_id": { "type": "integer", "minimum": 1 },
    "paper_snapshot": {
      "type": "object",
      "properties": {
        "draft_path": { "type": "string" },
        "draft_sha256": { "type": "string" },
        "last_modified": { "type": "string" }
      }
    },
    "thesis": {
      "type": "object",
      "required": ["statement"],
      "properties": {
        "statement": { "type": "string" },
        "scope": { "type": "string" },
        "claimed_contribution": { "type": "string" }
      }
    },
    "research_object": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "one_sentence": { "type": "string" }
      }
    },
    "problem_setting": {
      "type": "object",
      "properties": {
        "domain": { "type": "string" },
        "constraints": { "type": "array", "items": { "type": "string" } }
      }
    },
    "target_property": {
      "type": "object",
      "properties": {
        "property_id": { "type": "string" },
        "name": { "type": "string" },
        "definition": { "type": "string" },
        "falsifiability": { "type": "string" }
      }
    },
    "core_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim_id", "text", "status"],
        "properties": {
          "claim_id": { "type": "string" },
          "text": { "type": "string" },
          "status": { "type": "string", "enum": ["unstable", "defensible", "stable", "deleted"] },
          "scope": { "type": "string" },
          "assumption": { "type": "string" },
          "evidence_status": { "type": "string", "enum": ["none", "anecdotal", "partial", "strong", "conclusive"] }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "assumption_id": { "type": "string" },
          "description": { "type": "string" },
          "linked_claims": { "type": "array", "items": { "type": "string" } },
          "justification": { "type": "string" }
        }
      }
    },
    "current_baselines": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "baseline_id": { "type": "string" },
          "name": { "type": "string" },
          "closest_to_this_work": { "type": "boolean" },
          "key_difference": { "type": "string" }
        }
      }
    },
    "evaluation_contract": {
      "type": "object",
      "properties": {
        "method": { "type": "string" },
        "metrics": { "type": "array", "items": { "type": "string" } },
        "baseline_comparison": { "type": "string" },
        "success_criterion": { "type": "string" }
      }
    },
    "fragile_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim_id", "fragility_reason"],
        "properties": {
          "claim_id": { "type": "string" },
          "fragility_reason": { "type": "string" },
          "weakest_evidence_link": { "type": "string" }
        }
      }
    },
    "at_risk_sections": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "section_anchor": { "type": "string" },
          "risk_type": { "type": "string" },
          "vulnerability": { "type": "string" }
        }
      }
    },
    "known_open_critiques": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "critique_id": { "type": "string" },
          "summary": { "type": "string" },
          "unresolved": { "type": "boolean" }
        }
      }
    }
  }
}
