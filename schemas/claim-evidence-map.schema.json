{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Claim Evidence Map Schema",
  "description": "Maps each claim to supporting, weakening, missing evidence and affected sections.",
  "type": "object",
  "required": ["schema_version", "round_id", "mappings"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "round_id": {
      "type": "integer",
      "minimum": 1
    },
    "mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim_id", "affected_sections"],
        "properties": {
          "claim_id": {
            "type": "string",
            "pattern": "^CLM-[0-9]{3}$"
          },
          "supporting_evidence": {
            "type": "array",
            "items": { "type": "string", "pattern": "^E[0-9]{3}$" }
          },
          "weakening_evidence": {
            "type": "array",
            "items": { "type": "string", "pattern": "^E[0-9]{3}$" }
          },
          "missing_evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["description", "required_to_support"],
              "properties": {
                "description": { "type": "string", "minLength": 10 },
                "required_to_support": { "type": "string", "minLength": 5 },
                "priority": { "type": "string", "enum": ["high", "medium", "low"] }
              }
            }
          },
          "affected_sections": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
