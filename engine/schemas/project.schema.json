{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://critical-research/schemas/project.schema.json",
  "title": "Project Manifest v2",
  "description": "V2 project manifest with domain field and document registry reference.",
  "type": "object",
  "required": ["project_id", "domain", "schema_version"],
  "properties": {
    "project_id": {
      "type": "string",
      "description": "Unique project identifier.",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "domain": {
      "type": "string",
      "description": "CS domain: systems, networking, security, databases, pl, architecture, ml, se, hci, visualization, graphics, theory",
      "enum": ["systems", "networking", "security", "databases", "pl", "architecture", "ml", "se", "hci", "visualization", "graphics", "theory"]
    },
    "target_standard": {
      "type": "string",
      "description": "Target quality standard or venue."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "description": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "path", "status"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["survey", "design-doc", "paper", "proposal", "experiment-plan"]
          },
          "path": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["active", "archived"]
          }
        }
      }
    }
  },
  "additionalProperties": false
}
