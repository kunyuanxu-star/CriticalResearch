{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://critical-research/schemas/document-diff.schema.json",
  "title": "Document Diff",
  "description": "Records all document changes made during a round.",
  "type": "object",
  "required": ["schema_version", "round_id", "document_id", "document_path", "changes"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "round_id": {
      "type": "string",
      "pattern": "^round-[0-9]{3}$"
    },
    "document_id": {
      "type": "string"
    },
    "document_path": {
      "type": "string"
    },
    "changes": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": ["unit_id", "change_type", "description"],
        "properties": {
          "unit_id": { "type": "string" },
          "change_type": {
            "type": "string",
            "enum": ["add", "modify", "delete", "reorder"]
          },
          "description": {
            "type": "string",
            "minLength": 10
          },
          "patch_id": { "type": "string" },
          "before_hash": { "type": "string" },
          "after_hash": { "type": "string" }
        }
      }
    }
  }
}
