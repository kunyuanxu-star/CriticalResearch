{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://critical-research/schemas/workflow-patch.schema.json",
  "title": "Workflow Patch Envelope",
  "description": "Generic patch envelope with workflow-specific payload. The payload is validated against the workflow's patch schema.",
  "type": "object",
  "required": ["schema_version", "patch_id", "workflow", "project_id", "round_id", "target_document", "target_units", "source_trace", "patch_type", "status", "payload"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "patch_id": {
      "type": "string",
      "pattern": "^[A-Z]{2}-[0-9]{3}$"
    },
    "workflow": {
      "type": "string",
      "enum": ["survey", "design", "paper", "proposal", "experiment"]
    },
    "project_id": {
      "type": "string"
    },
    "round_id": {
      "type": "string",
      "pattern": "^round-[0-9]{3}$"
    },
    "target_document": {
      "type": "object",
      "required": ["id", "path"],
      "properties": {
        "id": { "type": "string" },
        "path": { "type": "string" }
      }
    },
    "target_units": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_trace": {
      "type": "object",
      "required": ["contract", "evidence", "critiques", "dispositions", "revision_plan"],
      "properties": {
        "contract": { "type": "string" },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "critiques": {
          "type": "array",
          "items": { "type": "string" }
        },
        "dispositions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "revision_plan": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "patch_type": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "applied", "rejected"]
    },
    "payload": {
      "type": "object",
      "description": "Workflow-specific patch payload. Schema validated separately."
    }
  }
}
