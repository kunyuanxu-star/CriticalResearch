{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://critical-research/schemas/patch-envelope",
  "title": "Patch Envelope",
  "description": "Generic patch envelope with workflow-specific payload. Every patch must trace to contract, unit, critique, disposition, and diff (Inv8).",
  "type": "object",
  "required": [
    "schema_version",
    "patch_id",
    "workflow",
    "project_id",
    "round_id",
    "target_document",
    "target_units",
    "patch_type",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "patch_id": {
      "type": "string",
      "description": "Unique patch identifier within the round (e.g., SP-003, DP-001, PP-002)",
      "pattern": "^[A-Z]+P-\\d{3}$"
    },
    "workflow": {
      "type": "string",
      "enum": ["survey", "design", "paper", "proposal", "experiment"]
    },
    "project_id": {
      "type": "string"
    },
    "round_id": {
      "type": "string"
    },
    "target_document": {
      "type": "object",
      "required": ["id", "path"],
      "properties": {
        "id": { "type": "string" },
        "path": { "type": "string" }
      }
    },
    "target_units": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Units within the target document being modified"
    },
    "source_trace": {
      "type": "object",
      "properties": {
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "critiques": {
          "type": "array",
          "items": { "type": "string" }
        },
        "decisions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "patch_type": {
      "type": "string",
      "description": "Workflow-specific patch type"
    },
    "status": {
      "type": "string",
      "enum": ["applied", "deferred", "rejected", "pending"],
      "description": "Patch MUST be verified as applied before marking 'applied' (Inv9)"
    },
    "payload": {
      "type": "object",
      "description": "Workflow-specific payload — validated by workflow-specific schema",
      "additionalProperties": true
    }
  }
}
