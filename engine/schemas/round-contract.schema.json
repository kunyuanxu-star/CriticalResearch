{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://critical-research/schemas/round-contract",
  "title": "Round Contract",
  "description": "The control plane for a single CriticalResearch round.",
  "type": "object",
  "required": [
    "schema_version",
    "round_id",
    "project_id",
    "workflow",
    "mutable_document",
    "target_units",
    "scope_policy",
    "user_objective",
    "required_outputs",
    "success_criteria"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2.0.0"
    },
    "round_id": {
      "type": "string",
      "description": "Unique round identifier within the project (e.g., round-017)",
      "pattern": "^round-\\d{3,}$"
    },
    "project_id": {
      "type": "string",
      "description": "Project this round belongs to (Inv0)"
    },
    "workflow": {
      "type": "object",
      "required": ["id", "version"],
      "properties": {
        "id": {
          "type": "string",
          "enum": ["survey", "design", "paper", "proposal", "experiment"]
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "workflow_file": {
          "type": "string"
        }
      }
    },
    "mutable_document": {
      "type": "object",
      "required": ["id", "type", "path"],
      "description": "Exactly one document that can be modified (Inv3)",
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["survey", "design-doc", "paper", "proposal", "experiment-plan"]
        },
        "path": { "type": "string" }
      }
    },
    "target_units": {
      "type": "object",
      "required": ["primary"],
      "properties": {
        "primary": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Primary target units within the mutable document (Inv4)"
        },
        "secondary": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Secondary units that may be modified if needed"
        }
      }
    },
    "read_only_context": {
      "type": "object",
      "properties": {
        "documents": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Documents readable but not modifiable (Inv5)"
        },
        "project_knowledge": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Knowledge artifacts to load as context"
        },
        "global_knowledge_cards": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["card_id", "title", "path", "maturity"],
            "properties": {
              "card_id": { "type": "string" },
              "title": { "type": "string" },
              "path": { "type": "string" },
              "maturity": { "type": "string" }
            }
          },
          "description": "Global knowledge cards from _cr/knowledge/ loaded for this round"
        }
      }
    },
    "scope_policy": {
      "type": "object",
      "required": [
        "exactly_one_mutable_document",
        "allow_cross_document_read",
        "allow_cross_document_write",
        "allow_project_knowledge_update",
        "allow_unit_scope"
      ],
      "properties": {
        "exactly_one_mutable_document": { "type": "boolean", "const": true },
        "allow_cross_document_read": { "type": "boolean" },
        "allow_cross_document_write": { "type": "boolean", "const": false },
        "allow_project_knowledge_update": { "type": "boolean" },
        "allow_unit_scope": { "type": "boolean" }
      }
    },
    "user_objective": {
      "type": "string",
      "minLength": 1,
      "description": "Natural-language description of what this round should accomplish"
    },
    "required_outputs": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "success_criteria": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Verifiable conditions for round completion"
    },
    "next_round_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["workflow", "document", "unit", "objective"],
        "properties": {
          "workflow": { "type": "string" },
          "document": { "type": "string" },
          "unit": { "type": "string" },
          "objective": { "type": "string" }
        }
      },
      "description": "Cross-document changes discovered during this round (Inv10)"
    }
  }
}
