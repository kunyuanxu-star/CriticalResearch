{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://critical-research/schemas/unit-registry",
  "title": "Unit Registry",
  "description": "Registry of modifiable units within a single document, demarcated by HTML anchors.",
  "type": "object",
  "required": ["schema_version", "document_id", "document_path", "units"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "document_id": {
      "type": "string",
      "description": "Document this unit registry belongs to"
    },
    "document_path": {
      "type": "string",
      "description": "Path to the document relative to project root"
    },
    "units": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["unit_id", "title", "anchors", "unit_type", "status"],
        "properties": {
          "unit_id": {
            "type": "string",
            "description": "Scoped unit identifier (e.g., survey.sandboxed-containers)",
            "pattern": "^[a-z_-]+\\.[a-z0-9_-]+$"
          },
          "title": {
            "type": "string",
            "description": "Human-readable unit title"
          },
          "anchors": {
            "type": "object",
            "required": ["start", "end"],
            "properties": {
              "start": {
                "type": "string",
                "description": "Opening HTML comment anchor (e.g., <!-- unit:survey.foo:start -->)"
              },
              "end": {
                "type": "string",
                "description": "Closing HTML comment anchor (e.g., <!-- unit:survey.foo:end -->)"
              }
            }
          },
          "unit_type": {
            "type": "string",
            "description": "Semantic type of this unit (e.g., related-work-section, design-principle)"
          },
          "status": {
            "type": "string",
            "enum": ["active", "draft", "archived"]
          },
          "maturity": {
            "type": "object",
            "description": "Maturity assessment for this unit",
            "properties": {
              "evidence": { "type": "string", "enum": ["missing", "partial", "complete"] },
              "taxonomy": { "type": "string", "enum": ["missing", "partial", "complete"] },
              "critique": { "type": "string", "enum": ["missing", "partial", "complete"] },
              "writing": { "type": "string", "enum": ["missing", "partial", "complete"] }
            }
          },
          "related_project_claims": {
            "type": "array",
            "items": { "type": "string" }
          },
          "related_documents": {
            "type": "object",
            "properties": {
              "read_only": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
