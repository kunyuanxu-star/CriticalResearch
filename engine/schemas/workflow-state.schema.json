{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://critical-research/schemas/workflow-state.schema.json",
  "title": "Workflow State",
  "description": "Tracks workflow stage progression for a single round.",
  "type": "object",
  "required": ["schema_version", "project_id", "round_id", "workflow_id", "status", "current_stage", "started_at", "stage_order", "stages"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "project_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "round_id": {
      "type": "string",
      "pattern": "^round-[0-9]{3}$"
    },
    "workflow_id": {
      "type": "string",
      "enum": ["survey", "design", "paper", "proposal", "experiment"]
    },
    "status": {
      "type": "string",
      "enum": ["running", "closed", "blocked"]
    },
    "current_stage": {
      "type": "string"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "stage_order": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "stages": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["pending", "running", "complete", "blocked"]
          },
          "completed_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
