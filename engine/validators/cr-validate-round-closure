#!/usr/bin/env python3
"""
cr-validate-round-closure — Verifies that all required_outputs from the
contract are present in the round directory.
"""
import sys
import yaml
from pathlib import Path


def load_yaml(path: str) -> dict:
    with open(path) as f:
        return yaml.safe_load(f)


def validate_closure(contract_path: str, round_dir: str) -> list[str]:
    errs = []

    contract = load_yaml(contract_path)
    required = contract.get("required_outputs", [])
    rd = Path(round_dir)

    for output_name in required:
        # "patches/" — check directory exists and has contents
        if output_name.endswith("/"):
            dir_path = rd / output_name.rstrip("/")
            if not dir_path.exists() or not list(dir_path.iterdir()):
                errs.append(f"FAIL: Required output '{output_name}' missing or empty")
            continue

        # Regular file check
        file_path = rd / output_name
        if not file_path.exists():
            errs.append(f"FAIL: Required output '{output_name}' missing")

    # closure.md is always required
    closure_file = rd / "closure.md"
    if not closure_file.exists():
        errs.append("FAIL: closure.md is required for every round")

    if not errs:
        print(f"PASS: All {len(required)} required outputs present")
    return errs


def main():
    if len(sys.argv) < 2:
        print("Usage: cr-validate-round-closure <contract.yaml>")
        sys.exit(1)

    contract_path = sys.argv[1]
    round_dir = str(Path(contract_path).parent)
    errs = validate_closure(contract_path, round_dir)

    if errs:
        for e in errs:
            print(e)
        sys.exit(1)
    else:
        sys.exit(0)


if __name__ == "__main__":
    main()
