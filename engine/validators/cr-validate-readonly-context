#!/usr/bin/env bash
# cr-validate-readonly-context — Ensure no document-diff changes reference
# documents listed as read-only in the round contract.
#
# Usage: cr-validate-readonly-context <round_dir>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/../../scripts/cr-common.sh"

ROUND_DIR="${1:-}"

if [ -z "$ROUND_DIR" ]; then
    echo "Usage: cr-validate-readonly-context <round_dir>" >&2
    exit 2
fi

CONTRACT="$ROUND_DIR/contract.yaml"
if [ ! -f "$CONTRACT" ]; then
    fail "contract.yaml not found in $ROUND_DIR"
    cr_exit_summary
fi

# Extract read-only document paths from contract.
RO_DOCS=$(sed -n '/^read_only_context:/,/^[a-z]/p' "$CONTRACT" \
    | sed -n '/^  documents:/,/^  [a-z]/p' \
    | grep '^    - ' \
    | sed 's/^    - //')

if [ -z "$RO_DOCS" ]; then
    pass "No read-only documents declared — nothing to check"
    cr_exit_summary
fi

DIFF_FILE="$ROUND_DIR/document-diff.yaml"
if [ ! -f "$DIFF_FILE" ]; then
    pass "No document-diff.yaml — no changes to violate read-only context"
    cr_exit_summary
fi

# Check each diff change's document_path against read-only list.
DIFF_DOC_PATH=$(grep 'document_path:' "$DIFF_FILE" | sed 's/.*document_path: *//' | xargs)

for ro_doc in $RO_DOCS; do
    [ -z "$ro_doc" ] && continue
    if [ "$DIFF_DOC_PATH" = "$ro_doc" ]; then
        fail "document-diff.yaml references read-only document: $ro_doc"
    else
        pass "document-diff.yaml does not reference read-only document: $ro_doc"
    fi
done

cr_exit_summary
