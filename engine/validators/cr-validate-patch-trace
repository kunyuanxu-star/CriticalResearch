#!/usr/bin/env python3
"""
cr-validate-patch-trace — Verifies that every patch traces to a critique,
disposition, and target unit (Inv7, Inv8).
"""
import sys
import yaml
from pathlib import Path


def load_yaml(path: str) -> dict:
    with open(path) as f:
        return yaml.safe_load(f)


def validate_patch_trace(round_dir: str) -> list[str]:
    errs = []

    patches_dir = Path(round_dir) / "patches"
    if not patches_dir.exists() or not list(patches_dir.glob("*.yaml")):
        errs.append("FAIL: No patches found in round")
        return errs

    for patch_file in patches_dir.glob("*.yaml"):
        try:
            patch = load_yaml(str(patch_file))

            # Inv8: patch must have source_trace
            trace = patch.get("source_trace", {})
            if not trace:
                errs.append(f"Inv8 violation in {patch_file.name}: missing source_trace — patch must trace to critique/evidence/decision")

            # Inv8: patch must have target_units
            units = patch.get("target_units", [])
            if not units:
                errs.append(f"Inv8 violation in {patch_file.name}: missing target_units — patch must declare which units it modifies")

            # Inv9: if status is 'applied', verify document-diff covers it
            if patch.get("status") == "applied":
                diff_file = Path(round_dir) / "document-diff.yaml"
                if diff_file.exists():
                    diff = load_yaml(str(diff_file))
                    patch_id = patch.get("patch_id", "unknown")
                    # Check if patch_id is mentioned in diff
                    diff_text = yaml.dump(diff)
                    if patch_id not in diff_text:
                        errs.append(f"Inv9 warning in {patch_file.name}: patch '{patch_id}' marked applied but not found in document-diff.yaml")
                else:
                    errs.append(f"Inv9 violation in {patch_file.name}: patch '{patch.get('patch_id')}' marked applied but no document-diff.yaml exists")

        except Exception as e:
            errs.append(f"FAIL: Cannot parse {patch_file.name}: {e}")

    if not errs:
        print(f"PASS: All patches have valid traces")
    return errs


def main():
    if len(sys.argv) < 2:
        print("Usage: cr-validate-patch-trace <round_dir>")
        sys.exit(1)

    round_dir = sys.argv[1]
    errs = validate_patch_trace(round_dir)

    if errs:
        for e in errs:
            print(e)
        sys.exit(1)
    else:
        sys.exit(0)


if __name__ == "__main__":
    main()
