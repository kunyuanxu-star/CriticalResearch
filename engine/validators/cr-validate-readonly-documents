#!/usr/bin/env python3
"""
cr-validate-readonly-documents — Verifies that no patches or diffs write to
documents declared as read_only_context (Inv5).
"""
import sys
import yaml
from pathlib import Path


def load_yaml(path: str) -> dict:
    with open(path) as f:
        return yaml.safe_load(f)


def validate_readonly(contract_path: str, round_dir: str) -> list[str]:
    errs = []

    contract = load_yaml(contract_path)
    read_only_docs = set()
    ctx = contract.get("read_only_context", {})
    for doc_path in ctx.get("documents", []):
        read_only_docs.add(doc_path)

    if not read_only_docs:
        return errs

    # Check all patches
    patches_dir = Path(round_dir) / "patches"
    if patches_dir.exists():
        for patch_file in patches_dir.glob("*.yaml"):
            try:
                patch = load_yaml(str(patch_file))
                patch_path = patch.get("target_document", {}).get("path", "")
                if patch_path in read_only_docs:
                    errs.append(f"Inv5 violation in {patch_file.name}: patch writes to read-only document '{patch_path}'")
            except Exception as e:
                errs.append(f"FAIL: Cannot parse {patch_file.name}: {e}")

    if not errs:
        print(f"PASS: No writes to read-only documents {read_only_docs}")
    return errs


def main():
    if len(sys.argv) < 2:
        print("Usage: cr-validate-readonly-documents <contract.yaml>")
        sys.exit(1)

    contract_path = sys.argv[1]
    round_dir = str(Path(contract_path).parent)
    errs = validate_readonly(contract_path, round_dir)

    if errs:
        for e in errs:
            print(e)
        sys.exit(1)
    else:
        sys.exit(0)


if __name__ == "__main__":
    main()
