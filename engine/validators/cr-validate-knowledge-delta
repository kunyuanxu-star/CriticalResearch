#!/usr/bin/env python3
"""
cr-validate-knowledge-delta — Verifies that a knowledge-delta.yaml exists
and is non-empty, or an explicit justification is provided (Inv11).
"""
import sys
import yaml
from pathlib import Path


def load_yaml(path: str) -> dict:
    with open(path) as f:
        return yaml.safe_load(f)


def validate_knowledge_delta(round_dir: str) -> list[str]:
    errs = []

    delta_file = Path(round_dir) / "knowledge-delta.yaml"
    if not delta_file.exists():
        errs.append("Inv11 violation: knowledge-delta.yaml missing — every round must produce a knowledge delta or explicit justification")
        return errs

    try:
        delta = load_yaml(str(delta_file))
        has_content = False

        # Check for actual knowledge entries
        for key in ["claims", "terminology", "related_work", "design_decisions",
                     "evaluation_obligations", "open_questions", "updates", "changes"]:
            if delta.get(key):
                has_content = True
                break

        # Check for explicit justification of no knowledge
        if not has_content:
            justification = delta.get("no_knowledge_justification")
            if not justification:
                errs.append("Inv11 violation: knowledge-delta.yaml has no entries and no no_knowledge_justification — must update knowledge or explain why not")
    except Exception as e:
        errs.append(f"FAIL: Cannot parse knowledge-delta.yaml: {e}")

    if not errs:
        print("PASS: knowledge-delta.yaml is valid")
    return errs


def main():
    if len(sys.argv) < 2:
        print("Usage: cr-validate-knowledge-delta <round_dir>")
        sys.exit(1)

    round_dir = sys.argv[1]
    errs = validate_knowledge_delta(round_dir)

    if errs:
        for e in errs:
            print(e)
        sys.exit(1)
    else:
        sys.exit(0)


if __name__ == "__main__":
    main()
