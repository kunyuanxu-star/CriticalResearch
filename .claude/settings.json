{
  "description": "critical-cs-research deterministic enforcement hooks — validates artifacts at each workflow stage",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR}/scripts/cr-guard-path\" \"${CLAUDE_TOOL_NAME}\" \"${CLAUDE_TOOL_INPUT}\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR}/hooks/check-round.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR}/scripts/cr-validate-stop\" \"${CLAUDE_PROJECT_DIR}\""
          }
        ]
      }
    ]
  }
}
