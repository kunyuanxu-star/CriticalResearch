{
  "description": "critical-cs-research deterministic enforcement hooks. Uses global critical-research-hook wrapper installed by install.sh to ~/.local/bin/.",
  "hooks": {
    "UserPromptExpansion": [
      {
        "matcher": "critical-cs-research",
        "hooks": [
          {
            "type": "command",
            "command": "critical-research-hook user-prompt-expansion",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "critical-research-hook user-prompt-submit",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "critical-research-hook pre-tool-use",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "critical-research-hook post-tool-use",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "critical-research-hook stop \"${CLAUDE_PROJECT_DIR}\"",
            "timeout": 60
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "project_settings|local_settings|skills",
        "hooks": [
          {
            "type": "command",
            "command": "critical-research-hook config-change",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
