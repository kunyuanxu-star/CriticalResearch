{
  "description": "critical-cs-research checkpoint hooks — validates artifacts at each workflow stage",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR}/hooks/check-all.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR}/hooks/check-all.sh\""
          }
        ]
      }
    ]
  }
}
