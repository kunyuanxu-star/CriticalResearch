{
  "description": "CriticalResearch minimal gates. The hook wrapper is installed by install.sh to ~/.local/bin/.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "critical-research-hook pre-tool-use",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "critical-research-hook stop \"${CLAUDE_PROJECT_DIR}\"",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
