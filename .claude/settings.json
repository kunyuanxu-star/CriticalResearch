{
  "description": "critical-cs-research deterministic enforcement hooks — validates artifacts at each workflow stage. Uses CR_SKILL_HOME if set, falls back to CLAUDE_PROJECT_DIR.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR}/scripts/critical-research-hook\" pre-tool-use \"${CLAUDE_TOOL_NAME}\" \"${CLAUDE_TOOL_INPUT}\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR}/scripts/critical-research-hook\" post-tool-use"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR}/scripts/critical-research-hook\" stop \"${CLAUDE_PROJECT_DIR}\""
          }
        ]
      }
    ]
  }
}
